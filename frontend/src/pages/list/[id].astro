---
import Base from "../../layouts/Base.astro";
import MediaCard from "../../components/MediaCard.astro";
import ListCard from "../../components/ListCard.astro";
import VisibilityFilters from "../../components/VisibilityFilters.astro";
import { api, type ListDetail, type UserList, type PublicList, type MediaItem } from "../../lib/api";
export const prerender = false;



const { id } = Astro.params;
const { token, user } = Astro.locals;

let list: ListDetail | null = null;
let otherLists: UserList[] = [];
let publicLists: PublicList[] = [];
let error = "";

try {
  [list, { lists: otherLists }, { lists: publicLists }] = await Promise.all([
    api.lists.get(Number(id), token!),
    api.lists.getAll(token!),
    api.lists.getPublic(token!),
  ]);
  otherLists = otherLists.filter((l) => l.id !== Number(id));
  publicLists = publicLists.filter((l) => l.username !== user?.username);
} catch (e: unknown) {
  error = e instanceof Error ? e.message : String(e);
}

if (!list && !error) {
  return Astro.redirect("/lists");
}

Astro.response.headers.set("Cache-Control", "no-store");
---

<Base title={list?.name || "List"}>
  {error && !list && (
    <div class="max-w-md mx-auto mt-20 text-center">
      <div class="bg-red-500/10 border border-red-500/20 text-red-500 p-6 rounded-2xl mb-6">
        <p class="font-bold text-lg mb-2">Oops!</p>
        <p class="text-sm opacity-80">{error}</p>
      </div>
      <a href="/lists" class="text-blue-500 hover:underline">Back to Lists</a>
    </div>
  )}

  {list && (
    <div class="max-w-6xl mx-auto">
      <!-- Header -->
      <div class="mb-10">
        <nav class="flex items-center gap-2 text-sm text-zinc-400 mb-6">
          <a href="/lists" class="hover:text-zinc-100 transition">Lists</a>
          <span class="text-zinc-700">/</span>
          <span class="text-zinc-100 font-bold truncate">{list.name}</span>
        </nav>

        <div class="flex flex-col sm:flex-row sm:items-start justify-between gap-4">
          <div class="min-w-0">
            <div class="flex items-center gap-3 mb-2 flex-wrap">
              <h1 id="list-title" class="text-4xl font-black text-zinc-100 tracking-tight"><span id="list-title-text">{list.name}</span></h1>
              {list.privacy_level === "public" && (
                <span id="list-privacy-badge" class="text-[10px] font-black text-emerald-400 bg-emerald-500/10 border border-emerald-500/20 px-2.5 py-1 rounded-full uppercase tracking-widest">
                  Public
                </span>
              )}
              {list.privacy_level === "friends_only" && (
                <span id="list-privacy-badge" class="text-[10px] font-black text-amber-400 bg-amber-500/10 border border-amber-500/20 px-2.5 py-1 rounded-full uppercase tracking-widest">
                  Friends
                </span>
              )}
            </div>
            {list.description && (
              <p id="list-desc" class="text-zinc-400 text-base leading-relaxed max-w-2xl">{list.description}</p>
            )}
            <p class="text-xs font-bold text-zinc-400 uppercase tracking-widest mt-3">
              {list.item_count} {list.item_count === 1 ? "item" : "items"}
            </p>
          </div>

          <div class="flex gap-2 shrink-0">
            {list.is_owner && (
              <>
                <button
                  id="edit-list-btn"
                  class="flex items-center gap-2 px-4 py-2.5 bg-zinc-800 hover:bg-zinc-700 text-zinc-300 font-bold rounded-xl transition-all text-sm border border-zinc-700 cursor-pointer"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125" />
                  </svg>
                  Edit
                </button>
                <button
                  id="automation-list-btn"
                  class="flex items-center gap-2 px-4 py-2.5 bg-blue-500/10 hover:bg-blue-500/20 text-blue-400 font-bold rounded-xl transition-all text-sm border border-blue-500/20 cursor-pointer"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15.59 14.37a6 6 0 0 1-5.84 7.38v-4.8m5.84-2.58a14.98 14.98 0 0 0 6.16-12.12A14.98 14.98 0 0 0 9.63 8.41m5.96 5.96a14.96 14.96 0 0 1-12.12 6.16 14.96 14.96 0 0 1 6.16-12.12m5.96 5.96-5.96-5.96" />
                  </svg>
                  Automation
                </button>
                <button
                  id="cleanup-list-btn"
                  class="flex items-center gap-2 px-4 py-2.5 bg-emerald-500/10 hover:bg-emerald-500/20 text-emerald-400 font-bold rounded-xl transition-all text-sm border border-emerald-500/20 cursor-pointer"
                  title="Remove collected items"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                  </svg>
                  Clean
                </button>
                <button
                  id="delete-list-btn"
                  class="flex items-center gap-2 px-4 py-2.5 bg-red-500/10 hover:bg-red-500/20 text-red-400 font-bold rounded-xl transition-all text-sm border border-red-500/20 cursor-pointer"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
                  </svg>
                  Delete
                </button>
              </>
            )}
          </div>
        </div>
      </div>

      <!-- Edit Modal -->
      <div id="edit-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4">
        <div id="edit-backdrop" class="absolute inset-0 bg-black/70 backdrop-blur-sm"></div>
        <div class="relative bg-zinc-900 border border-zinc-800 rounded-3xl p-8 w-full max-w-md shadow-2xl">
          <button type="button" id="edit-close-x" class="absolute top-6 right-6 p-2 text-zinc-500 hover:text-zinc-100 hover:bg-zinc-800 rounded-xl transition-all cursor-pointer z-10" aria-label="Close modal">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-5 h-5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
            </svg>
          </button>

          <div class="flex items-center gap-5 mb-8">
            <div class="p-3 bg-blue-500/10 rounded-2xl shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6 text-blue-500">
                <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125" />
              </svg>
            </div>
            <div>
              <h2 class="text-2xl font-black text-zinc-100 tracking-tight">Edit List</h2>
              <p class="text-xs font-bold text-zinc-500 uppercase tracking-widest mt-1">Update name or description</p>
            </div>
          </div>

          <form id="edit-form" class="space-y-4">
            <div>
              <label for="edit-name" class="block text-xs font-bold text-zinc-400 uppercase tracking-widest mb-2">Name</label>
              <input
                type="text"
                id="edit-name"
                value={list.name}
                maxlength="255"
                required
                class="w-full bg-zinc-950 border border-zinc-800 rounded-xl px-4 py-3 text-zinc-100 focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all"
              />
            </div>
            <div>
              <label for="edit-desc" class="block text-xs font-bold text-zinc-400 uppercase tracking-widest mb-2">Description</label>
              <textarea
                id="edit-desc"
                rows="2"
                class="w-full bg-zinc-950 border border-zinc-800 rounded-xl px-4 py-3 text-zinc-100 focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all resize-none"
              >{list.description || ""}</textarea>
            </div>

            <div id="edit-error" class="hidden text-xs text-red-400 bg-red-500/10 border border-red-500/20 rounded-lg px-3 py-2"></div>
            <div class="flex justify-end gap-3 pt-4 border-t border-zinc-800/50 mt-6">
              <button type="button" id="edit-cancel-btn" class="px-6 py-2.5 text-zinc-500 hover:text-zinc-300 font-bold transition-all text-sm cursor-pointer">Cancel</button>
              <button type="submit" id="edit-submit-btn" class="px-8 py-2.5 bg-blue-600 hover:bg-blue-500 text-white font-bold rounded-xl transition-all text-sm cursor-pointer shadow-lg shadow-blue-600/20 disabled:opacity-50">Save Changes</button>
            </div>
          </form>
        </div>
      </div>

      <!-- Automation Modal -->
      <div id="automation-modal" class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-black/80 backdrop-blur-sm hidden">
        <div id="automation-backdrop" class="absolute inset-0"></div>
        <div class="relative w-full max-w-lg bg-zinc-900 border border-zinc-800 rounded-3xl p-8 shadow-2xl overflow-hidden">
          <button type="button" id="auto-close-x" class="absolute top-6 right-6 p-2 text-zinc-500 hover:text-zinc-100 hover:bg-zinc-800 rounded-xl transition-all cursor-pointer z-10" aria-label="Close modal">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-5 h-5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
            </svg>
          </button>

          <div class="flex items-center gap-5 mb-8">
            <div class="p-3 bg-blue-500/10 rounded-2xl shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6 text-blue-500">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.59 14.37a6 6 0 0 1-5.84 7.38v-4.8m5.84-2.58a14.98 14.98 0 0 0 6.16-12.12A14.98 14.98 0 0 0 9.63 8.41m5.96 5.96a14.96 14.96 0 0 1-12.12 6.16 14.96 14.96 0 0 1 6.16-12.12m5.96 5.96-5.96-5.96" />
              </svg>
            </div>
            <div>
              <h2 class="text-2xl font-black text-zinc-100 tracking-tight">Automation Settings</h2>
              <p class="text-xs font-bold text-zinc-500 uppercase tracking-widest mt-1">Sonarr & Radarr Integration</p>
            </div>
          </div>

          <form id="automation-form" class="space-y-6">
            <div class="space-y-6 max-h-[60vh] overflow-y-auto pr-2 custom-scrollbar">
              <!-- Radarr -->
              <div class="space-y-4 p-5 bg-zinc-950/50 rounded-2xl border border-zinc-800/50">
                <div class="flex items-center justify-between">
                  <label class="flex items-center gap-3 cursor-pointer">
                    <input type="checkbox" id="auto-radarr-checkbox" checked={list.radarr_auto_add} class="w-5 h-5 rounded-lg border-zinc-800 bg-zinc-900 text-blue-600 focus:ring-blue-500 transition-all" />
                    <span class="text-sm font-black text-zinc-100 uppercase tracking-widest">Radarr (Movies)</span>
                  </label>
                  <div class="px-2 py-1 bg-zinc-800 rounded-md text-[9px] font-bold text-zinc-500 uppercase tracking-tighter">Auto-Add</div>
                </div>
                
                <div id="auto-radarr-options" class={list.radarr_auto_add ? "space-y-4 pt-4 border-t border-zinc-800/50" : "hidden space-y-4 pt-4 border-t border-zinc-800/50"}>
                  <div class="grid grid-cols-2 gap-4">
                    <div>
                      <label class="block text-[10px] font-bold text-zinc-500 uppercase tracking-widest mb-1.5 ml-1">Root Folder</label>
                      <select id="auto-radarr-root" class="w-full bg-zinc-900 border border-zinc-800 rounded-xl px-3 py-2.5 text-xs text-zinc-100 focus:outline-none focus:ring-1 focus:ring-blue-500 transition-all">
                        {list.radarr_root_folder ? <option value={list.radarr_root_folder}>{list.radarr_root_folder}</option> : <option value="">Loading...</option>}
                      </select>
                    </div>
                    <div>
                      <label class="block text-[10px] font-bold text-zinc-500 uppercase tracking-widest mb-1.5 ml-1">Quality Profile</label>
                      <select id="auto-radarr-quality" class="w-full bg-zinc-900 border border-zinc-800 rounded-xl px-3 py-2.5 text-xs text-zinc-100 focus:outline-none focus:ring-1 focus:ring-blue-500 transition-all">
                        {list.radarr_quality_profile ? <option value={list.radarr_quality_profile}>{list.radarr_quality_profile}</option> : <option value="">Loading...</option>}
                      </select>
                    </div>
                  </div>
                  <div>
                    <label class="block text-[10px] font-bold text-zinc-500 uppercase tracking-widest mb-1.5 ml-1">Monitor</label>
                    <select id="auto-radarr-monitor" class="w-full bg-zinc-900 border border-zinc-800 rounded-xl px-3 py-2.5 text-xs text-zinc-100 focus:outline-none focus:ring-1 focus:ring-blue-500 transition-all">
                      <option value="movieOnly" selected={list.radarr_monitor === "movieOnly"}>Movie Only</option>
                      <option value="movieAndCollection" selected={list.radarr_monitor === "movieAndCollection"}>Movie and Collection</option>
                      <option value="none" selected={list.radarr_monitor === "none"}>None</option>
                    </select>
                  </div>
                  <div>
                    <label class="block text-[10px] font-bold text-zinc-500 uppercase tracking-widest mb-1.5 ml-1">Tags</label>
                    <div id="auto-radarr-tags-container" class="space-y-3">
                      <div id="auto-radarr-selected-tags" class="flex flex-wrap gap-1.5 min-h-[32px] p-2 bg-zinc-950 border border-zinc-800 rounded-xl">
                        <span class="text-[10px] text-zinc-600 italic px-1">No tags selected</span>
                      </div>
                      <div class="space-y-2">
                        <div class="relative group">
                          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="absolute left-2.5 top-1/2 -translate-y-1/2 w-3.5 h-3.5 text-zinc-500 group-focus-within:text-blue-500 transition-colors">
                            <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
                          </svg>
                          <input type="text" id="auto-radarr-tags-search" placeholder="Search or type tags..." class="w-full bg-zinc-900/50 border border-zinc-800 rounded-lg pl-8 pr-3 py-1.5 text-[10px] text-zinc-300 focus:outline-none focus:ring-1 focus:ring-blue-500 transition-all" />
                        </div>
                        <div class="space-y-1.5">
                          <p class="text-[9px] font-bold text-zinc-600 uppercase tracking-tight ml-1">Available Tags (Click to add)</p>
                          <div id="auto-radarr-available-tags" class="flex flex-wrap gap-1.5 max-h-32 overflow-y-auto p-1 custom-scrollbar">
                            <span class="text-[10px] text-zinc-500 italic">Loading tags...</span>
                          </div>
                        </div>
                      </div>
                    </div>
                    <input type="hidden" id="auto-radarr-tags-hidden" value={list.radarr_tags?.join(",") || ""} />
                  </div>
                </div>
              </div>

              <!-- Sonarr -->
              <div class="space-y-4 p-5 bg-zinc-950/50 rounded-2xl border border-zinc-800/50">
                <div class="flex items-center justify-between">
                  <label class="flex items-center gap-3 cursor-pointer">
                    <input type="checkbox" id="auto-sonarr-checkbox" checked={list.sonarr_auto_add} class="w-5 h-5 rounded-lg border-zinc-800 bg-zinc-900 text-blue-600 focus:ring-blue-500 transition-all" />
                    <span class="text-sm font-black text-zinc-100 uppercase tracking-widest">Sonarr (Shows)</span>
                  </label>
                  <div class="px-2 py-1 bg-zinc-800 rounded-md text-[9px] font-bold text-zinc-500 uppercase tracking-tighter">Auto-Add</div>
                </div>
                
                <div id="auto-sonarr-options" class={list.sonarr_auto_add ? "space-y-4 pt-4 border-t border-zinc-800/50" : "hidden space-y-4 pt-4 border-t border-zinc-800/50"}>
                  <div class="grid grid-cols-2 gap-4">
                    <div>
                      <label class="block text-[10px] font-bold text-zinc-500 uppercase tracking-widest mb-1.5 ml-1">Root Folder</label>
                      <select id="auto-sonarr-root" class="w-full bg-zinc-900 border border-zinc-800 rounded-xl px-3 py-2.5 text-xs text-zinc-100 focus:outline-none focus:ring-1 focus:ring-blue-500 transition-all">
                        {list.sonarr_root_folder ? <option value={list.sonarr_root_folder}>{list.sonarr_root_folder}</option> : <option value="">Loading...</option>}
                      </select>
                    </div>
                    <div>
                      <label class="block text-[10px] font-bold text-zinc-500 uppercase tracking-widest mb-1.5 ml-1">Quality Profile</label>
                      <select id="auto-sonarr-quality" class="w-full bg-zinc-900 border border-zinc-800 rounded-xl px-3 py-2.5 text-xs text-zinc-100 focus:outline-none focus:ring-1 focus:ring-blue-500 transition-all">
                        {list.sonarr_quality_profile ? <option value={list.sonarr_quality_profile}>{list.sonarr_quality_profile}</option> : <option value="">Loading...</option>}
                      </select>
                    </div>
                  </div>
                  <div class="grid grid-cols-2 gap-4">
                    <div>
                      <label class="block text-[10px] font-bold text-zinc-500 uppercase tracking-widest mb-1.5 ml-1">Series Type</label>
                      <select id="auto-sonarr-type" class="w-full bg-zinc-900 border border-zinc-800 rounded-xl px-3 py-2.5 text-xs text-zinc-100 focus:outline-none focus:ring-1 focus:ring-blue-500 transition-all">
                        <option value="standard" selected={list.sonarr_series_type === "standard"}>Standard</option>
                        <option value="daily" selected={list.sonarr_series_type === "daily"}>Daily</option>
                        <option value="anime" selected={list.sonarr_series_type === "anime"}>Anime</option>
                      </select>
                    </div>
                    <div>
                      <label class="block text-[10px] font-bold text-zinc-500 uppercase tracking-widest mb-1.5 ml-1">Monitor</label>
                      <select id="auto-sonarr-monitor" class="w-full bg-zinc-900 border border-zinc-800 rounded-xl px-3 py-2.5 text-xs text-zinc-100 focus:outline-none focus:ring-1 focus:ring-blue-500 transition-all">
                        <option value="all" selected={list.sonarr_monitor === "all"}>All Episodes</option>
                        <option value="future" selected={list.sonarr_monitor === "future"}>Future Episodes</option>
                        <option value="missing" selected={list.sonarr_monitor === "missing"}>Missing Episodes</option>
                        <option value="existing" selected={list.sonarr_monitor === "existing"}>Existing Episodes</option>
                        <option value="pilot" selected={list.sonarr_monitor === "pilot"}>Pilot Episode</option>
                        <option value="firstSeason" selected={list.sonarr_monitor === "firstSeason"}>First Season</option>
                        <option value="lastSeason" selected={list.sonarr_monitor === "lastSeason"}>Last Season</option>
                        <option value="none" selected={list.sonarr_monitor === "none"}>None</option>
                      </select>
                    </div>
                  </div>
                  <div>
                    <label class="block text-[10px] font-bold text-zinc-500 uppercase tracking-widest mb-1.5 ml-1">Tags</label>
                    <div id="auto-sonarr-tags-container" class="space-y-3">
                      <div id="auto-sonarr-selected-tags" class="flex flex-wrap gap-1.5 min-h-[32px] p-2 bg-zinc-950 border border-zinc-800 rounded-xl">
                        <span class="text-[10px] text-zinc-600 italic px-1">No tags selected</span>
                      </div>
                      <div class="space-y-2">
                        <div class="relative group">
                          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="absolute left-2.5 top-1/2 -translate-y-1/2 w-3.5 h-3.5 text-zinc-500 group-focus-within:text-blue-500 transition-colors">
                            <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
                          </svg>
                          <input type="text" id="auto-sonarr-tags-search" placeholder="Search or type tags..." class="w-full bg-zinc-900/50 border border-zinc-800 rounded-lg pl-8 pr-3 py-1.5 text-[10px] text-zinc-300 focus:outline-none focus:ring-1 focus:ring-blue-500 transition-all" />
                        </div>
                        <div class="space-y-1.5">
                          <p class="text-[9px] font-bold text-zinc-600 uppercase tracking-tight ml-1">Available Tags (Click to add)</p>
                          <div id="auto-sonarr-available-tags" class="flex flex-wrap gap-1.5 max-h-32 overflow-y-auto p-1 custom-scrollbar">
                            <span class="text-[10px] text-zinc-500 italic">Loading tags...</span>
                          </div>
                        </div>
                      </div>
                    </div>
                    <input type="hidden" id="auto-sonarr-tags-hidden" value={list.sonarr_tags?.join(",") || ""} />
                  </div>
                  <label class="flex items-center gap-3 cursor-pointer group">
                    <input type="checkbox" id="auto-sonarr-season-folder" checked={list.sonarr_season_folder} class="w-4 h-4 rounded-md border-zinc-800 bg-zinc-900 text-blue-600 focus:ring-blue-500 transition-all" />
                    <span class="text-xs font-bold text-zinc-400 group-hover:text-zinc-300 transition-colors uppercase tracking-wider">Use Season Folders</span>
                  </label>
                </div>
              </div>
            </div>

            <div id="automation-error" class="hidden text-xs text-red-400 bg-red-500/10 border border-red-500/20 rounded-xl px-4 py-3"></div>
            <div class="flex justify-end gap-3 pt-6 border-t border-zinc-800/50 mt-6">
              <button type="button" id="auto-cancel-btn-footer" class="px-6 py-2.5 text-zinc-500 hover:text-zinc-300 font-bold transition-all text-sm cursor-pointer">Cancel</button>
              <button type="submit" id="auto-submit-btn" class="px-8 py-2.5 bg-blue-600 hover:bg-blue-500 text-white font-bold rounded-xl transition-all text-sm cursor-pointer shadow-lg shadow-blue-600/20 disabled:opacity-50">Save Settings</button>
            </div>
          </form>
        </div>
      </div>

      <!-- Add Items Search (owner only) -->
      {list.is_owner && (
      <div class="mb-10 bg-zinc-900/40 border border-zinc-800/60 rounded-3xl p-6">
        <h2 class="text-sm font-black text-zinc-400 uppercase tracking-widest mb-4">Add Items</h2>
        <div class="flex flex-col sm:flex-row gap-3">
          <input
            type="text"
            id="search-input"
            placeholder="Search for a movie, show, or person to add..."
            class="flex-1 bg-zinc-950 border border-zinc-800 rounded-xl px-4 py-3 text-zinc-100 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all placeholder:text-zinc-400"
          />
          <div class="flex gap-1.5 bg-zinc-950 border border-zinc-800 rounded-xl p-1 shrink-0">
            {[
              { value: "all", label: "All" },
              { value: "movie", label: "Movies" },
              { value: "series", label: "Shows" },
              { value: "person", label: "People" },
            ].map(f => (
              <button
                class="search-filter-btn px-3 py-1.5 text-xs font-bold rounded-lg transition-all cursor-pointer"
                class:list={[
                  f.value === "all"
                    ? "bg-zinc-800 text-zinc-100"
                    : "text-zinc-500 hover:text-zinc-300"
                ]}
                data-filter={f.value}
              >
                {f.label}
              </button>
            ))}
          </div>
        </div>
        <div id="search-results" class="mt-4 grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-4 hidden"></div>
        <div id="search-loading" class="hidden mt-4 flex items-center justify-center gap-2 py-6 text-zinc-500 text-sm">
          <svg class="animate-spin w-4 h-4 shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
          </svg>
          Searching…
        </div>
        <p id="search-empty" class="hidden mt-4 text-sm text-zinc-400 text-center py-4">No results found.</p>
      </div>
      )}

      <!-- Items Grid -->
      <div>
        <div class="flex items-center justify-between mb-6">
          <h2 class="text-sm font-black text-zinc-400 uppercase tracking-widest">Items</h2>
          <div class="flex items-center gap-4">
            <VisibilityFilters />
          </div>
        </div>
        {list.items.length === 0 ? (
          <div id="empty-state" class="text-center py-16 bg-zinc-900/20 border border-zinc-800/50 border-dashed rounded-3xl">
            <div class="text-4xl mb-3">📋</div>
            <p class="text-zinc-500">{list.is_owner ? "This list is empty. Search above to add movies and shows." : "This list is empty."}</p>
          </div>
        ) : (
          <div id="items-grid" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-6">
            {list.items.map((entry) => (
              <div class="relative group/item" data-item-id={entry.id}>
                <MediaCard item={entry.media} />
                {list.is_owner && (
                  <button
                    class="remove-item-btn absolute top-2 right-2 bg-red-600/90 hover:bg-red-500 text-white rounded-full w-7 h-7 flex items-center justify-center shadow-lg cursor-pointer z-10 transition-colors"
                    data-item-id={entry.id}
                    aria-label="Remove from list"
                  >
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="w-3.5 h-3.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
                    </svg>
                  </button>
                )}
              </div>
            ))}
          </div>
        )}
        {list.items.length === 0 && <div id="items-grid" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-6 hidden"></div>}
      </div>

      <!-- Other Lists -->
      {otherLists.length > 0 && (
        <div class="mt-16 pt-10 border-t border-zinc-800/50">
          <h2 class="text-sm font-black text-zinc-400 uppercase tracking-widest mb-6">Your Other Lists</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
            {otherLists.map((l) => (
              <ListCard
                id={l.id}
                name={l.name}
                description={l.description}
                privacy_level={l.privacy_level}
                item_count={l.item_count}
                preview_posters={l.preview_posters}
              />
            ))}
          </div>
        </div>
      )}

      <!-- Community Lists -->
      {publicLists.length > 0 && (
        <div class="mt-16 pt-10 border-t border-zinc-800/50">
          <h2 class="text-sm font-black text-zinc-400 uppercase tracking-widest mb-6">From the Community</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
            {publicLists.map((l) => (
              <ListCard
                id={l.id}
                name={l.name}
                description={l.description}
                privacy_level={l.privacy_level}
                item_count={l.item_count}
                preview_posters={l.preview_posters}
                username={l.username}
              />
            ))}
          </div>
        </div>
      )}
    </div>
  )}
</Base>

<script define:vars={{ 
  token, 
  listId: list?.id, 
  apiKey: user?.api_key,
  initialRadarrAutoAdd: list?.radarr_auto_add,
  initialSonarrAutoAdd: list?.sonarr_auto_add,
  initialRadarrTags: list?.radarr_tags || [],
  initialSonarrTags: list?.sonarr_tags || [],
  initialRadarrRoot: list?.radarr_root_folder,
  initialRadarrQuality: list?.radarr_quality_profile,
  initialRadarrMonitor: list?.radarr_monitor,
  initialSonarrRoot: list?.sonarr_root_folder,
  initialSonarrQuality: list?.sonarr_quality_profile,
  initialSonarrMonitor: list?.sonarr_monitor,
  initialSonarrType: list?.sonarr_series_type,
  initialSonarrSeasonFolder: list?.sonarr_season_folder
}}>
  // Reload when restored from bfcache so DOM mutations (newly added items) aren't lost.

  function esc(str) {
    if (str == null) return '';
    return String(str)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }
  // --- Edit list ---
  const editModal = document.getElementById('edit-modal');
  const editForm = document.getElementById('edit-form');
  const editError = document.getElementById('edit-error');
  const editSubmitBtn = document.getElementById('edit-submit-btn');

  document.getElementById('edit-list-btn')?.addEventListener('click', () => {
    editModal.classList.remove('hidden');
    document.getElementById('edit-name').focus();
  });

  function closeEditModal() {
    editModal.classList.add('hidden');
    editError.classList.add('hidden');
  }
  document.getElementById('edit-cancel-btn')?.addEventListener('click', closeEditModal);
  document.getElementById('edit-backdrop')?.addEventListener('click', closeEditModal);
  document.getElementById('edit-close-x')?.addEventListener('click', closeEditModal);

  // --- Automation Settings Modal ---
  const automationModal = document.getElementById('automation-modal');
  const automationForm = document.getElementById('automation-form');
  const automationListBtn = document.getElementById('automation-list-btn');
  const autoCancelBtn = document.getElementById('auto-cancel-btn');
  const autoBackdrop = document.getElementById('automation-backdrop');
  const autoSubmitBtn = document.getElementById('auto-submit-btn');
  const autoError = document.getElementById('automation-error');

  function openAutomationModal() {
    // Reset inputs to current saved state
    if (radarrCheckbox) radarrCheckbox.checked = initialRadarrAutoAdd;
    if (sonarrCheckbox) sonarrCheckbox.checked = initialSonarrAutoAdd;
    
    const radarrMon = document.getElementById('auto-radarr-monitor');
    if (radarrMon) radarrMon.value = currentRadarrMonitor;
    
    const sonarrMon = document.getElementById('auto-sonarr-monitor');
    if (sonarrMon) sonarrMon.value = currentSonarrMonitor;
    
    const sonarrType = document.getElementById('auto-sonarr-type');
    if (sonarrType) sonarrType.value = currentSonarrType;
    
    const sonarrSF = document.getElementById('auto-sonarr-season-folder');
    if (sonarrSF) sonarrSF.checked = currentSonarrSeasonFolder;

    automationModal.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  }

  function closeAutomationModal() {
    automationModal.classList.add('hidden');
    document.body.style.overflow = '';
    autoError.classList.add('hidden');
  }

  automationListBtn?.addEventListener('click', openAutomationModal);
  document.getElementById('auto-cancel-btn-footer')?.addEventListener('click', closeAutomationModal);
  document.getElementById('auto-close-x')?.addEventListener('click', closeAutomationModal);
  autoBackdrop?.addEventListener('click', closeAutomationModal);

  const radarrCheckbox = document.getElementById('auto-radarr-checkbox');
  const radarrOptions = document.getElementById('auto-radarr-options');
  const sonarrCheckbox = document.getElementById('auto-sonarr-checkbox');
  const sonarrOptions = document.getElementById('auto-sonarr-options');

  let selectedTagsRadarr = new Set(initialRadarrTags.map(id => id.toString()));
  let selectedTagsSonarr = new Set(initialSonarrTags.map(id => id.toString()));
  let currentRadarrRoot = initialRadarrRoot;
  let currentRadarrQuality = initialRadarrQuality;
  let currentRadarrMonitor = initialRadarrMonitor;
  let currentSonarrRoot = initialSonarrRoot;
  let currentSonarrQuality = initialSonarrQuality;
  let currentSonarrMonitor = initialSonarrMonitor;
  let currentSonarrType = initialSonarrType;
  let currentSonarrSeasonFolder = initialSonarrSeasonFolder;

  function updateTagUI(type) {
    const selectedSet = type === 'radarr' ? selectedTagsRadarr : selectedTagsSonarr;
    const selectedEl = document.getElementById(`auto-${type}-selected-tags`);
    const hiddenInput = document.getElementById(`auto-${type}-tags-hidden`);
    const searchInput = document.getElementById(`auto-${type}-tags-search`);
    const status = connectionsStatus?.[type];
    
    if (!status || !selectedEl || !hiddenInput) return;

    // Update hidden input
    hiddenInput.value = Array.from(selectedSet).join(',');

    // Render selected tags
    if (selectedSet.size === 0) {
      selectedEl.innerHTML = '<span class="text-[10px] text-zinc-600 italic px-1">No tags selected</span>';
    } else {
      selectedEl.innerHTML = Array.from(selectedSet).map(id => {
        const tag = status.tags?.find(t => t.id.toString() === id.toString());
        const label = tag ? tag.label : id;
        return `
          <div class="flex items-center gap-1.5 px-2 py-1 bg-blue-500/10 border border-blue-500/20 rounded-lg group/tag">
            <span class="text-[10px] font-bold text-blue-400 uppercase tracking-tight">${label}</span>
            <button type="button" class="text-blue-500/50 hover:text-blue-400 cursor-pointer" onclick="toggleTag('${type}', '${id}')">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-2.5 h-2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
              </svg>
            </button>
          </div>
        `;
      }).join('');
    }

    // Update available tags (highlight selected and filter by search)
    const availableEl = document.getElementById(`auto-${type}-available-tags`);
    if (availableEl && status.tags) {
      const query = searchInput?.value?.toLowerCase() || '';
      const filtered = status.tags.filter(t => t.label.toLowerCase().includes(query));
      
      if (filtered.length === 0) {
        availableEl.innerHTML = '<span class="text-[10px] text-zinc-600 italic px-1">No matching tags</span>';
      } else {
        availableEl.innerHTML = filtered.map(t => {
          const isSelected = selectedSet.has(t.id.toString());
          return `
            <button type="button" 
              onclick="toggleTag('${type}', '${t.id}')"
              class="px-2 py-1 rounded-lg text-[10px] font-bold uppercase tracking-tight transition-all cursor-pointer
                ${isSelected 
                  ? 'bg-blue-600 text-white shadow-lg shadow-blue-600/20' 
                  : 'bg-zinc-800 text-zinc-400 hover:bg-zinc-700 hover:text-zinc-200 border border-zinc-700'}">
              ${t.label}
            </button>
          `;
        }).join('');
      }
    }
  }

  window.toggleTag = (type, id) => {
    const selectedSet = type === 'radarr' ? selectedTagsRadarr : selectedTagsSonarr;
    const idStr = id.toString();
    if (selectedSet.has(idStr)) {
      selectedSet.delete(idStr);
    } else {
      selectedSet.add(idStr);
    }
    updateTagUI(type);
  };

  ['radarr', 'sonarr'].forEach(type => {
    document.getElementById(`auto-${type}-tags-search`)?.addEventListener('input', () => updateTagUI(type));
  });

  let connectionsStatus = null;
  async function fetchAutomationProfiles(type) {
    try {
      if (!connectionsStatus) {
        const res = await fetch('/api/proxy/auth/connection-status', {
          headers: { 'Authorization': `Bearer ${token}` }
        });
        connectionsStatus = await res.json();
      }

      const status = connectionsStatus[type];
      if (!status || !status.configured) {
        const optionsEl = document.getElementById(`auto-${type}-options`);
        optionsEl.innerHTML = `<p class="text-[10px] text-red-400 p-2">${type.charAt(0).toUpperCase() + type.slice(1)} is not configured in your settings.</p>`;
        return;
      }

      const rootSelect = document.getElementById(`auto-${type}-root`);
      const profileSelect = document.getElementById(`auto-${type}-quality`);
      
      // Current values from list
      const currentRoot = type === 'radarr' ? currentRadarrRoot : currentSonarrRoot;
      const currentProfile = type === 'radarr' ? currentRadarrQuality : currentSonarrQuality;

      if (rootSelect) {
        rootSelect.innerHTML = status.root_folders.map(f => `<option value="${f.path}" ${f.path === currentRoot ? 'selected' : ''}>${f.path} (${(f.freeSpace / 1024 / 1024 / 1024).toFixed(1)} GB free)</option>`).join('');
      }
      if (profileSelect) {
        profileSelect.innerHTML = status.quality_profiles.map(p => `<option value="${p.id}" ${p.id == currentProfile ? 'selected' : ''}>${p.name}</option>`).join('');
      }
      
      updateTagUI(type);
    } catch (err) {
      console.error(`Failed to fetch ${type} profiles`, err);
    }
  }

  radarrCheckbox?.addEventListener('change', () => {
    const isChecked = radarrCheckbox.checked;
    radarrOptions.classList.toggle('hidden', !isChecked);
    if (isChecked) fetchAutomationProfiles('radarr');
  });

  sonarrCheckbox?.addEventListener('change', () => {
    const isChecked = sonarrCheckbox.checked;
    sonarrOptions.classList.toggle('hidden', !isChecked);
    if (isChecked) fetchAutomationProfiles('sonarr');
  });

  // Fetch initial if enabled
  if (radarrCheckbox?.checked) fetchAutomationProfiles('radarr');
  if (sonarrCheckbox?.checked) fetchAutomationProfiles('sonarr');

  automationForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    const payload = { 
      radarr_auto_add: radarrCheckbox.checked,
      sonarr_auto_add: sonarrCheckbox.checked,
    };

    if (radarrCheckbox.checked) {
      const rootVal = document.getElementById('auto-radarr-root').value;
      const qualVal = document.getElementById('auto-radarr-quality').value;
      if (rootVal) payload.radarr_root_folder = rootVal;
      if (qualVal) {
        const parsed = parseInt(qualVal);
        if (!isNaN(parsed)) payload.radarr_quality_profile = parsed;
      }
      payload.radarr_monitor = document.getElementById('auto-radarr-monitor').value;
      payload.radarr_tags = Array.from(selectedTagsRadarr).map(id => parseInt(id));
      if (payload.radarr_tags.length === 0) payload.radarr_tags = null;
    }

    if (sonarrCheckbox.checked) {
      const rootVal = document.getElementById('auto-sonarr-root').value;
      const qualVal = document.getElementById('auto-sonarr-quality').value;
      if (rootVal) payload.sonarr_root_folder = rootVal;
      if (qualVal) {
        const parsed = parseInt(qualVal);
        if (!isNaN(parsed)) payload.sonarr_quality_profile = parsed;
      }
      payload.sonarr_series_type = document.getElementById('auto-sonarr-type').value;
      payload.sonarr_monitor = document.getElementById('auto-sonarr-monitor').value;
      payload.sonarr_season_folder = document.getElementById('auto-sonarr-season-folder').checked;
      payload.sonarr_tags = Array.from(selectedTagsSonarr).map(id => parseInt(id));
      if (payload.sonarr_tags.length === 0) payload.sonarr_tags = null;
    }

    autoSubmitBtn.disabled = true;
    autoSubmitBtn.textContent = 'Saving...';
    autoError.classList.add('hidden');

    try {
      const res = await fetch(`/api/proxy/lists/${listId}`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
        body: JSON.stringify(payload),
      });
      if (!res.ok) {
        const err = await res.json();
        throw new Error(err.detail || 'Failed to update automation settings');
      }
      
      // Update local state for next modal open
      if (payload.radarr_root_folder !== undefined) currentRadarrRoot = payload.radarr_root_folder;
      if (payload.radarr_quality_profile !== undefined) currentRadarrQuality = payload.radarr_quality_profile;
      if (payload.radarr_monitor !== undefined) currentRadarrMonitor = payload.radarr_monitor;
      if (payload.sonarr_root_folder !== undefined) currentSonarrRoot = payload.sonarr_root_folder;
      if (payload.sonarr_quality_profile !== undefined) currentSonarrQuality = payload.sonarr_quality_profile;
      if (payload.sonarr_monitor !== undefined) currentSonarrMonitor = payload.sonarr_monitor;
      if (payload.sonarr_series_type !== undefined) currentSonarrType = payload.sonarr_series_type;
      if (payload.sonarr_season_folder !== undefined) currentSonarrSeasonFolder = payload.sonarr_season_folder;

      closeAutomationModal();
      window.showToast?.('Automation settings saved', 'success');
    } catch (err) {
      autoError.textContent = err.message;
      autoError.classList.remove('hidden');
    } finally {
      autoSubmitBtn.disabled = false;
      autoSubmitBtn.textContent = 'Save Settings';
    }
  });

  editForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const name = document.getElementById('edit-name').value.trim();
    const description = document.getElementById('edit-desc').value.trim() || null;
    const privacyLevel = document.querySelector('input[name="edit-privacy"]:checked').value;

    editSubmitBtn.disabled = true;
    editSubmitBtn.textContent = 'Saving...';
    editError.classList.add('hidden');

    try {
      const res = await fetch(`/api/proxy/lists/${listId}`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
        body: JSON.stringify({ name, description, privacy_level: privacyLevel }),
      });
      if (!res.ok) {
        const err = await res.json();
        throw new Error(err.detail || 'Failed to update list');
      }
      const updated = await res.json();
      document.getElementById('list-title-text').textContent = updated.name;
      const descEl = document.getElementById('list-desc');
      if (descEl) descEl.textContent = updated.description || '';

      // Update badge
      const headerTitle = document.querySelector('#list-title').parentElement;
      const oldBadge = document.getElementById('list-privacy-badge');
      oldBadge?.remove();

      if (updated.privacy_level !== 'private') {
        const badge = document.createElement('span');
        badge.id = 'list-privacy-badge';
        if (updated.privacy_level === 'public') {
          badge.className = 'text-[10px] font-black text-emerald-400 bg-emerald-500/10 border border-emerald-500/20 px-2.5 py-1 rounded-full uppercase tracking-widest';
          badge.textContent = 'Public';
        } else {
          badge.className = 'text-[10px] font-black text-amber-400 bg-amber-500/10 border border-amber-500/20 px-2.5 py-1 rounded-full uppercase tracking-widest';
          badge.textContent = 'Friends';
        }
        headerTitle?.appendChild(badge);
      }

      closeEditModal();
    } catch (err) {
      editError.textContent = err.message;
      editError.classList.remove('hidden');
    } finally {
      editSubmitBtn.disabled = false;
      editSubmitBtn.textContent = 'Save Changes';
    }
  });

  // --- Delete list ---
  document.getElementById('delete-list-btn')?.addEventListener('click', async () => {
    const title = document.getElementById('list-title-text')?.textContent || 'this list';
    const ok = await window.showConfirm(`Delete "${title}"?`, 'This cannot be undone.');
    if (!ok) return;

    try {
      const res = await fetch(`/api/proxy/lists/${listId}`, {
        method: 'DELETE',
        headers: { 'Authorization': `Bearer ${token}` },
      });
      if (res.ok) window.location.href = '/lists';
    } catch (err) {
      console.error('Failed to delete list', err);
    }
  });

  // --- Cleanup collection items ---
  document.getElementById('cleanup-list-btn')?.addEventListener('click', async () => {
    const ok = await window.showConfirm(
      'Clean Collection?',
      'This will remove all items from this list that are already in your collection.'
    );
    if (!ok) return;

    const btn = document.getElementById('cleanup-list-btn');
    const originalContent = btn.innerHTML;
    btn.disabled = true;
    btn.innerHTML = `<svg class="animate-spin w-4 h-4 shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg> Cleaning...`;

    try {
      const res = await fetch(`/api/proxy/lists/${listId}/items/cleanup-collection`, {
        method: 'POST',
        headers: { 'Authorization': `Bearer ${token}` },
      });
      
      if (!res.ok) {
        const err = await res.json();
        throw new Error(err.detail || 'Failed to cleanup list');
      }
      
      const data = await res.json();
      if (data.removed_count > 0) {
        window.showToast?.(`Removed ${data.removed_count} item(s) already in collection`, 'success');
        // Simple way: reload page. More complex: remove items from DOM.
        // Given the grid logic, reloading is safer to ensure all counts/states are correct.
        setTimeout(() => window.location.reload(), 1000);
      } else {
        window.showToast?.('No items in this list are in your collection', 'info');
      }
    } catch (err) {
      console.error('Cleanup failed', err);
      window.showToast?.(err.message, 'error');
    } finally {
      btn.disabled = false;
      btn.innerHTML = originalContent;
    }
  });


  // --- Remove items ---
  function bindRemoveButtons() {
    document.querySelectorAll('.remove-item-btn').forEach(btn => {
      if (btn.dataset.bound) return;
      btn.dataset.bound = 'true';
      btn.addEventListener('click', async (e) => {
        e.preventDefault();
        const itemId = btn.getAttribute('data-item-id');
        btn.disabled = true;
        btn.innerHTML = `<svg class="animate-spin w-3.5 h-3.5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/></svg>`;

        try {
          const res = await fetch(`/api/proxy/lists/${listId}/items/${itemId}`, {
            method: 'DELETE',
            headers: { 'Authorization': `Bearer ${token}` },
          });
          if (res.ok) {
            const card = document.querySelector(`[data-item-id="${itemId}"]`);
            card?.remove();
            // Show empty state if no items left
            const grid = document.getElementById('items-grid');
            if (grid && grid.children.length === 0) {
              document.getElementById('empty-state')?.classList.remove('hidden');
            }
          }
        } catch (err) {
          console.error('Failed to remove item', err);
          btn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="w-3.5 h-3.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" /></svg>`;
          btn.disabled = false;
        }
      });
    });
  }
  bindRemoveButtons();

  // --- Search & Add ---
  const searchInput = document.getElementById('search-input');
  const searchResults = document.getElementById('search-results');
  const searchEmpty = document.getElementById('search-empty');
  const searchLoading = document.getElementById('search-loading');
  let searchTimeout = null;
  let activeFilter = 'all';
  let searchAbortController = null;

  searchInput?.addEventListener('focus', () => {
    setTimeout(() => {
      const y = searchInput.getBoundingClientRect().top + window.scrollY - 10;
      window.scrollTo({ top: y, behavior: 'smooth' });
    }, 100);
  });

  document.querySelectorAll('.search-filter-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      activeFilter = btn.getAttribute('data-filter');
      document.querySelectorAll('.search-filter-btn').forEach(b => {
        const isActive = b.getAttribute('data-filter') === activeFilter;
        b.classList.toggle('bg-zinc-800', isActive);
        b.classList.toggle('text-zinc-100', isActive);
        b.classList.toggle('text-zinc-500', !isActive);
      });
      const q = searchInput.value.trim();
      if (q.length >= 2) performSearch(q);
    });
  });

  searchInput?.addEventListener('input', () => {
    clearTimeout(searchTimeout);
    const q = searchInput.value.trim();
    if (q.length < 2) {
      searchResults.classList.add('hidden');
      searchEmpty.classList.add('hidden');
      searchLoading.classList.add('hidden');
      return;
    }
    searchTimeout = setTimeout(() => performSearch(q), 350);
  });

  async function performSearch(q) {
    if (searchAbortController) searchAbortController.abort();
    searchAbortController = new AbortController();
    const signal = searchAbortController.signal;

    searchLoading.classList.remove('hidden');
    searchResults.classList.add('hidden');
    searchEmpty.classList.add('hidden');
    try {
      const typeParam = activeFilter !== 'all' ? `&type=${activeFilter}` : '';
      const res = await fetch(`/api/proxy/media/search?q=${encodeURIComponent(q)}&page=1${typeParam}`, {
        headers: { 'Authorization': `Bearer ${token}` },
        signal,
      });
      if (!res.ok) return;
      const data = await res.json();
      const items = activeFilter === 'all'
        ? data.results.filter(i => i.type === 'movie' || i.type === 'series' || i.type === 'person')
        : data.results.filter(i => i.type === activeFilter);

      searchResults.innerHTML = '';
      searchLoading.classList.add('hidden');
      if (items.length === 0) {
        searchEmpty.classList.remove('hidden');
        searchResults.classList.add('hidden');
        return;
      }

      searchEmpty.classList.add('hidden');
      searchResults.classList.remove('hidden');

      items.slice(0, 12).forEach(item => {
        const poster = item.poster_path
          ? (item.poster_path.startsWith('http') ? item.poster_path : `https://image.tmdb.org/t/p/w300${item.poster_path}`)
          : null;
        const year = item.release_date?.slice(0, 4) || '';
        const isPerson = item.type === 'person';
        const rating = item.tmdb_rating ? Number(item.tmdb_rating).toFixed(1) : '';
        const meta = [rating ? '★ ' + rating : '', year].filter(Boolean).join(' · ');

        const el = document.createElement('button');
        el.className = 'group text-left w-full active:scale-95 active:opacity-70 transition-all duration-150 cursor-pointer';
        el.innerHTML = `
          <div class="relative aspect-[2/3] rounded-2xl overflow-hidden bg-zinc-800 mb-2 ring-1 ring-white/5 group-hover:ring-white/20 transition-all duration-300"${item.adult ? ' data-adult="true"' : ''}>
            ${poster
              ? `<img src="${esc(poster)}" alt="${esc(item.title)}" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" />`
              : `<div class="w-full h-full flex items-center justify-center text-zinc-400 text-xs p-2 text-center">${isPerson ? '👤' : esc(item.title)}</div>`
            }
            <div class="add-overlay absolute inset-0 bg-gradient-to-t from-black/70 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end justify-center pb-3">
              <span class="text-white text-[10px] font-black uppercase tracking-widest bg-blue-600 px-2.5 py-1 rounded-full shadow">Add</span>
            </div>
          </div>
          <p class="text-sm font-bold text-zinc-300 truncate group-hover:text-zinc-100 transition-colors leading-snug">${esc(item.title)}</p>
          <p class="text-xs text-zinc-500 mt-0.5">${esc(meta) || (isPerson ? 'Person' : '')}</p>
        `;
        el.addEventListener('click', () => addItem(item.tmdb_id, item.type, el, item));
        searchResults.appendChild(el);
      });
    } catch (err) {
      if (err.name === 'AbortError') return;
      searchLoading.classList.add('hidden');
      console.error('Search failed', err);
    }
  }

  function buildCard(media) {
    const isPerson = media.type === 'person';
    const isSeries = media.type === 'series';
    const showActionBar = !isPerson && media.type !== 'collection';

    const href = isSeries
      ? `/show/${media.tmdb_id}`
      : isPerson
      ? `/person/${media.tmdb_id}`
      : `/media/${media.type}/${media.tmdb_id}`;

    const poster = media.poster_path
      ? (media.poster_path.startsWith('http') ? media.poster_path : `https://image.tmdb.org/t/p/w500${media.poster_path}`)
      : null;

    const rating = media.tmdb_rating ? Number(media.tmdb_rating).toFixed(1) : null;
    const year = media.release_date?.slice(0, 4) ?? '';
    const watched = media.watched ?? false;
    const inLists = media.in_lists ?? [];
    const inLibrary = media.in_library ?? false;
    const collectionPct = media.collection_pct ?? (inLibrary ? 100 : 0);
    const collectStyle = isSeries
      ? `background: linear-gradient(to right, rgba(168,85,247,0.2) ${collectionPct}%, transparent ${collectionPct}%)`
      : '';

    const actionBar = showActionBar ? `
      <div class="grid grid-cols-3 flex-shrink-0">
        <button
          data-action="watched"
          data-watched="${watched}"
          data-state="${watched ? 'active' : 'inactive'}"
          title="${watched ? 'Mark as unwatched' : 'Mark as watched'}"
          class="flex flex-col items-center justify-center gap-1 py-2.5 transition-all cursor-pointer border-r border-zinc-800/60 hover:brightness-125 ${watched ? 'bg-green-500/20 text-green-400' : 'bg-zinc-900 text-zinc-400 hover:bg-green-500/10 hover:text-green-500'}"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/>
            <circle cx="12" cy="12" r="3" fill="${watched ? 'currentColor' : 'none'}"/>
          </svg>
          <span class="text-[8px] font-bold uppercase tracking-wider leading-none">Watched</span>
        </button>
        <button
          data-action="list"
          data-in-lists="${esc(JSON.stringify(inLists))}"
          data-state="${inLists.length > 0 ? 'active' : 'inactive'}"
          title="Add to list"
          class="flex flex-col items-center justify-center gap-1 py-2.5 transition-all cursor-pointer border-r border-zinc-800/60 hover:brightness-125 ${inLists.length > 0 ? 'bg-sky-500/20 text-sky-400' : 'bg-zinc-900 text-zinc-400 hover:bg-sky-500/10 hover:text-sky-400'}"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/>
            <line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/>
            <line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/>
          </svg>
          <span class="text-[8px] font-bold uppercase tracking-wider leading-none">Lists</span>
        </button>
        <button
          data-action="collected"
          data-in-library="${inLibrary}"
          data-collection-pct="${collectionPct}"
          data-state="${(inLibrary || collectionPct > 0) ? 'active' : 'inactive'}"
          title="${isSeries ? `${collectionPct}% in library` : (inLibrary ? 'In collection' : 'Add to collection')}"
          style="${esc(collectStyle)}"
          class="relative flex flex-col items-center justify-center gap-1 py-2.5 transition-all cursor-pointer overflow-hidden hover:brightness-125 ${(inLibrary || collectionPct > 0) ? 'bg-purple-500/20 text-purple-400' : 'bg-zinc-900 text-zinc-400 hover:bg-purple-500/10 hover:text-purple-400'}"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="m2 7 4.41-4.41A2 2 0 0 1 7.83 2h8.34a2 2 0 0 1 1.42.59L22 7"/>
            <path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/><path d="M15 22v-4a3 3 0 0 0-6 0v4"/>
            <path d="M2 7h20"/>
          </svg>
          <span class="text-[8px] font-bold uppercase tracking-wider leading-none">${isSeries ? `${collectionPct}%` : 'Collected'}</span>
        </button>
      </div>` : '';

    const progressPct = isSeries && media.total_episodes_count 
      ? ((media.watched_episodes_count ?? 0) / media.total_episodes_count * 100)
      : (media.progress_percent ?? 0);
    const showProgress = !isPerson && progressPct > 0;

    return `
      <div
        class="group relative flex flex-col rounded-2xl overflow-hidden bg-zinc-900 border border-zinc-800 hover:border-blue-500/50 hover:shadow-2xl hover:shadow-blue-900/20 transition-all duration-300 transform hover:-translate-y-1"
        data-card
        data-tmdb-id="${media.tmdb_id}"
        data-media-type="${esc(media.type)}"
        data-show-tmdb-id="${media.show_tmdb_id ?? ''}"
        data-season="${media.season_number ?? ''}"
        data-watched="${media.watched ?? false}"
        data-collected="${media.in_library ?? false}"
        data-listed="${(media.in_lists ?? []).length > 0}"
      >
        <a href="${esc(href)}" class="block">
          <div class="aspect-[2/3] bg-zinc-950 relative overflow-hidden ring-1 ring-white/5 group-hover:ring-blue-500/30 transition-all duration-300"${media.adult ? ' data-adult="true"' : ''}>
            ${poster
              ? `<img src="${esc(poster)}" alt="${esc(media.title)}" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" loading="lazy" decoding="async" />`
              : `<div class="w-full h-full flex flex-col items-center justify-center text-zinc-700 bg-zinc-900 p-4 text-center"><span class="text-3xl mb-2 opacity-30">🎬</span><span class="text-xs font-bold uppercase tracking-widest">${esc(media.title)}</span></div>`
            }
            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
            ${rating ? `<div class="absolute top-2 right-2 bg-black/80 backdrop-blur-md text-yellow-400 text-[10px] font-black px-2 py-0.5 rounded-full shadow-lg border border-zinc-800 flex items-center gap-1"><span class="text-xs leading-none">★</span> ${esc(rating)}</div>` : ''}
            ${showProgress ? `
              <div class="absolute bottom-0 left-0 right-0 h-1.5 bg-zinc-800/80">
                <div class="h-full bg-blue-500 rounded-r-full" style="width: ${progressPct}%"></div>
              </div>
            ` : ''}
          </div>
        </a>
        ${actionBar}
        <a href="${esc(href)}" class="block p-3 bg-gradient-to-b from-zinc-900 to-zinc-950 flex-1">
          <h3 class="text-sm font-bold text-zinc-100 truncate group-hover:text-blue-400 transition-colors leading-tight mb-1">${esc(media.title)}</h3>
          <div class="flex items-center justify-between">
            ${year ? `<span class="text-[11px] font-medium text-zinc-500 tracking-wide">${esc(year)}</span>` : '<span></span>'}
            <div class="flex items-center gap-2">
              ${showProgress ? `<span class="text-[10px] font-bold text-zinc-500 tabular-nums">${Math.round(progressPct)}%</span>` : ''}
              <span class="text-[9px] font-black text-zinc-400 uppercase tracking-widest px-1.5 py-0.5 bg-zinc-800/50 rounded border border-zinc-800">${isSeries ? 'Show' : esc(media.type)}</span>
            </div>
          </div>
        </a>
      </div>`;
  }

  async function addItem(tmdbId, mediaType, btn, searchItem) {
    btn.disabled = true;
    // Show spinner immediately
    const overlay = btn.querySelector('.add-overlay');
    if (overlay) {
      overlay.classList.remove('opacity-0', 'group-hover:opacity-100');
      overlay.classList.add('opacity-100');
      overlay.innerHTML = `<svg class="animate-spin w-7 h-7 text-white drop-shadow" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/></svg>`;
    }
    try {
      const res = await fetch(`/api/proxy/lists/${listId}/items`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
        body: JSON.stringify({ tmdb_id: tmdbId, media_type: mediaType }),
      });

      if (res.status === 409) {
        btn.style.opacity = '0.4';
        btn.title = 'Already in list';
        // Show "already added" check overlay
        if (overlay) {
          overlay.innerHTML = `<span class="text-white text-xl font-black">✓</span>`;
        }
        return;
      }
      if (!res.ok) {
        const err = await res.json();
        throw new Error(err.detail || 'Failed to add item');
      }

      const entry = await res.json();

      // Swap spinner → green checkmark
      if (overlay) {
        overlay.classList.add('!bg-green-500/30');
        overlay.innerHTML = `<span class="text-white text-2xl font-black drop-shadow">✓</span>`;
      }
      btn.classList.add('pointer-events-none');
      btn.title = 'Added!';

      // Ensure items grid exists (it may not if list was empty)
      let grid = document.getElementById('items-grid');
      const emptyState = document.getElementById('empty-state');
      if (!grid) {
        grid = document.createElement('div');
        grid.id = 'items-grid';
        grid.className = 'grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-6';
        emptyState?.parentNode?.insertBefore(grid, emptyState);
      }
      emptyState?.classList.add('hidden');
      grid.classList.remove('hidden');

      // Build the card from search result data (has reliable poster/year),
      // then use entry.id from API for the remove button.
      const cardMedia = {
        ...entry.media,
        poster_path: searchItem?.poster_path ?? entry.media.poster_path,
        release_date: searchItem?.release_date ?? entry.media.release_date,
        tmdb_rating: searchItem?.tmdb_rating ?? entry.media.tmdb_rating,
      };

      const wrapper = document.createElement('div');
      wrapper.className = 'relative group/item';
      wrapper.setAttribute('data-item-id', String(entry.id));
      wrapper.innerHTML = `
        ${buildCard(cardMedia)}
        <button class="remove-item-btn absolute top-2 right-2 bg-red-600/90 hover:bg-red-500 text-white rounded-full w-7 h-7 flex items-center justify-center shadow-lg cursor-pointer z-10 transition-colors"
          data-item-id="${esc(String(entry.id))}" aria-label="Remove from list">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="w-3.5 h-3.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
          </svg>
        </button>
      `;
      grid.appendChild(wrapper);
      bindRemoveButtons();
    } catch (err) {
      console.error('Failed to add item', err);
      // Restore overlay to "Add" state so the user can retry
      if (overlay) {
        overlay.classList.add('opacity-0', 'group-hover:opacity-100');
        overlay.classList.remove('opacity-100');
        overlay.innerHTML = `<span class="text-white text-[10px] font-black uppercase tracking-widest bg-blue-600 px-2.5 py-1 rounded-full shadow">Add</span>`;
      }
      btn.disabled = false;
    }
  }
</script>
