---
import Base from "../layouts/Base.astro";
import ThemeToggle from "../components/ThemeToggle.astro";
import PasswordToggle from "../components/PasswordToggle.astro";
import { api } from "../lib/api";
import type { OidcConfig } from "../lib/api";

let error = "";
let success = "";
let showTotpStep = false;
let tempToken = "";

const oidcConfig: OidcConfig = await api.auth.oidcConfig().catch(() => ({
  enabled: false,
  provider_name: "SSO",
  disable_password_login: false,
}));

const { enabled: registrationEnabled, smtp_configured: smtpConfigured } = await api.auth.registrationStatus().catch(() => ({ enabled: false, smtp_configured: false }));
const { has_users: hasUsers } = await api.auth.hasUsers().catch(() => ({ has_users: true }));

if (Astro.url.searchParams.get("restored") === "true") {
  success = "Database restored successfully. You can now log in.";
}

const oidcError = Astro.url.searchParams.get("oidc_error");
if (oidcError) {
  error = decodeURIComponent(oidcError.replace(/\+/g, " "));
}

const urlError = Astro.url.searchParams.get("error");
if (urlError === "invalid_activation_token") {
  error = "This activation link is invalid.";
} else if (urlError === "activation_token_expired") {
  error = "This activation link has expired. Please register again or contact an administrator.";
}

if (Astro.url.searchParams.get("email_activated") === "true") {
  success = "Your email has been confirmed! You can now sign in.";
}

if (Astro.url.searchParams.get("password_reset") === "true") {
  success = "Your password has been reset. You can now sign in with your new password.";
}


if (Astro.request.method === "POST") {
  const data = await Astro.request.formData();
  const step = (data.get("_step") as string) || "login";

  if (step === "login") {
    try {
      const result = await api.auth.login(data);
      if (result.requires_2fa && result.temp_token) {
        showTotpStep = true;
        tempToken = result.temp_token;
      } else if (result.access_token) {
        Astro.cookies.set("token", result.access_token, {
          path: "/",
          httpOnly: true,
          sameSite: "lax",
          maxAge: 60 * 60 * 24 * 7,
        });
        return Astro.redirect("/");
      }
    } catch (e: unknown) {
      error = e instanceof Error ? e.message : "Login failed";
    }
  } else if (step === "verify_2fa") {
    const submittedTempToken = (data.get("temp_token") as string) || "";
    const code = (data.get("totp_code") as string) || "";
    try {
      const result = await api.auth.totp2faVerifyLogin({ temp_token: submittedTempToken, code });
      if (result.access_token) {
        Astro.cookies.set("token", result.access_token, {
          path: "/",
          httpOnly: true,
          sameSite: "lax",
          maxAge: 60 * 60 * 24 * 7,
        });
        return Astro.redirect("/");
      }
    } catch (e: unknown) {
      error = e instanceof Error ? e.message : "Verification failed";
      showTotpStep = true;
      tempToken = submittedTempToken;
    }
  }
}

const token = Astro.cookies.get("token")?.value;
if (token) {
  return Astro.redirect("/");
}
---

<Base title="Login" hideNav>
  <div class="max-w-md mx-auto mt-16 p-8 bg-zinc-900/40 border border-zinc-800 rounded-3xl shadow-2xl backdrop-blur-md relative">
    <ThemeToggle />
    <div class="flex flex-col items-center mb-6">
      <img src="/scrob.png" alt="Scrob Logo" class="w-36 object-contain mb-2" />
      <span class="text-zinc-100 font-bold text-xl tracking-tight">Scrob</span>
    </div>
    <h1 class="text-3xl font-bold mb-6 text-zinc-100 text-center">Login</h1>
    
    {error && (
      <div class="bg-red-500/10 border border-red-500 text-red-500 p-3 rounded-lg mb-6">
        {error}
      </div>
    )}

    {success && (
      <div class="bg-green-500/10 border border-green-500 text-green-400 p-3 rounded-lg mb-6">
        {success}
      </div>
    )}

    {!showTotpStep ? (
      <>
        {/* OIDC button */}
        {oidcConfig.enabled && (
          <a
            href="/oidc-start"
            tabindex="2"
            class="flex items-center justify-center gap-2 w-full bg-zinc-800 hover:bg-zinc-700 border border-zinc-700 text-zinc-100 font-bold py-2 rounded-lg transition-colors cursor-pointer mb-4"
          >
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 5.25a3 3 0 013 3m3 0a6 6 0 01-7.029 5.912c-.563-.097-1.159.026-1.563.43L10.5 17.25H8.25v2.25H6v2.25H2.25v-2.818c0-.597.237-1.17.659-1.591l6.499-6.499c.404-.404.527-1 .43-1.563A6 6 0 1121.75 8.25z" />
            </svg>
            Login with {oidcConfig.provider_name}
          </a>
        )}

        {/* Divider when both options are visible */}
        {oidcConfig.enabled && !oidcConfig.disable_password_login && (
          <div class="relative my-4">
            <div class="absolute inset-0 flex items-center">
              <div class="w-full border-t border-zinc-800"></div>
            </div>
            <div class="relative flex justify-center">
              <span class="bg-zinc-900 px-3 text-xs text-zinc-400">or</span>
            </div>
          </div>
        )}

        {/* Password form */}
        {!oidcConfig.disable_password_login && (
          <form method="POST" class="space-y-4">
            <input type="hidden" name="_step" value="login" />
            <div>
              <label for="username" class="block text-sm font-medium text-zinc-400 mb-1">Username</label>
              <input
                type="text"
                name="username"
                id="username"
                required
                tabindex="3"
                class="w-full bg-zinc-800 border border-zinc-700 rounded-lg px-4 py-3 text-zinc-100 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all"
              />
            </div>
            <div>
            <div class="flex items-center justify-between">
                <label for="password" class="block text-sm font-medium text-zinc-400">Password</label>
                {smtpConfigured && (
                  <a href="/forgot-password" tabindex="7" class="text-xs text-zinc-500 hover:text-zinc-300 transition-colors">Forgot password?</a>
                )}
              </div>
              <div class="relative group/field">
                <input
                  type="password"
                  name="password"
                  id="password"
                  required
                  tabindex="4"
                  class="w-full bg-zinc-800 border border-zinc-700 rounded-lg pl-4 pr-10 py-3 text-zinc-100 focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all"
                />
                <PasswordToggle tabindex="5" />
              </div>
            </div>
            <button
              type="submit"
              tabindex="6"
              class="w-full bg-blue-600 hover:bg-blue-500 text-white font-bold py-3 rounded-xl transition-all shadow-lg shadow-blue-600/20 active:scale-95 duration-200 cursor-pointer mt-4"
            >
              Sign In
            </button>
          </form>
        )}

        {!oidcConfig.disable_password_login && registrationEnabled && (
          <div class="mt-6 text-center text-sm text-zinc-500">
            Don't have an account? <a href="/register" tabindex="8" class="text-zinc-100 hover:underline">Register</a>
          </div>
        )}
      </>
    ) : (
      <form method="POST" class="space-y-4">
        <input type="hidden" name="_step" value="verify_2fa" />
        <input type="hidden" name="temp_token" value={tempToken} />
        <div class="text-center mb-2">
          <div class="w-12 h-12 bg-zinc-800 rounded-full flex items-center justify-center mx-auto mb-3">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6 text-zinc-300">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" />
            </svg>
          </div>
          <p class="text-sm text-zinc-400">Enter the 6-digit code from your authenticator app, or a backup code.</p>
        </div>
        <div>
          <label for="totp_code" class="block text-sm font-medium text-zinc-400 mb-1">Verification Code</label>
          <input
            type="text"
            name="totp_code"
            id="totp_code"
            required
            autocomplete="one-time-code"
            inputmode="numeric"
            placeholder="000000 or XXXX-XXXX"
            class="w-full bg-zinc-800 border border-zinc-700 rounded-lg px-4 py-3 text-zinc-100 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all text-center tracking-widest text-lg font-mono"
          />
        </div>
        <button
          type="submit"
          class="w-full bg-blue-600 hover:bg-blue-500 text-white font-bold py-3 rounded-xl transition-all shadow-lg shadow-blue-600/20 active:scale-95 duration-200 cursor-pointer mt-4"
        >
          Verify
        </button>
        <div class="text-center">
          <a href="/login" class="text-sm text-zinc-500 hover:text-zinc-300 transition-colors">Back to login</a>
        </div>
      </form>
    )}
  </div>

  {!hasUsers && (
    <div class="max-w-md mx-auto mt-4 mb-12">
      <div class="flex items-center gap-3 mb-4">
        <div class="flex-1 border-t border-zinc-800"></div>
        <span class="text-xs text-zinc-600">or restore from backup</span>
        <div class="flex-1 border-t border-zinc-800"></div>
      </div>
      <div class="p-6 bg-zinc-900/40 border border-zinc-800 rounded-2xl shadow-2xl backdrop-blur-md">
        <h2 class="font-semibold text-zinc-100 mb-1">Restore Database</h2>
        <p class="text-sm text-zinc-400 mb-4">Upload a <code class="text-zinc-300">.bak</code> file to restore a previous installation.</p>
        <div class="flex flex-col gap-3">
          <input id="bootstrap-restore-file" type="file" accept=".bak"
            class="block w-full text-sm text-zinc-400 file:mr-3 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-semibold file:bg-zinc-800 file:text-zinc-300 hover:file:bg-zinc-700 file:cursor-pointer cursor-pointer" />
          <button id="bootstrap-restore-btn" disabled
            class="w-full px-5 py-2.5 bg-red-600 hover:bg-red-500 text-white text-sm font-semibold rounded-xl transition-colors cursor-pointer disabled:opacity-50 disabled:cursor-not-allowed">
            Restore Database
          </button>
        </div>
        <div id="bootstrap-restore-error" class="hidden mt-3 text-sm text-red-400 bg-red-500/10 border border-red-500/20 rounded-lg px-3 py-2"></div>
      </div>
    </div>
  )}
</Base>

<!-- Bootstrap Restore Confirmation Modal -->
<div id="bootstrap-restore-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4">
  <div id="bootstrap-restore-modal-backdrop" class="absolute inset-0 bg-black/70 backdrop-blur-sm"></div>
  <div class="relative bg-zinc-900/85 border border-zinc-800/85 rounded-3xl p-8 w-full max-w-md shadow-2xl backdrop-blur-xl overflow-hidden">
    <h2 class="text-xl font-black text-zinc-100 mb-2">Restore Database?</h2>
    <p class="text-sm text-zinc-400 mb-1">Restoring from:</p>
    <p id="bootstrap-restore-modal-filename" class="text-sm text-zinc-100 font-medium mb-4 break-all"></p>
    <div class="bg-red-500/10 border border-red-500/20 rounded-xl px-4 py-3 mb-6">
      <p class="text-sm text-red-400 font-medium">All existing data will be permanently overwritten. This cannot be undone.</p>
    </div>
    <div class="flex gap-3">
      <button type="button" id="bootstrap-restore-cancel-btn"
        class="flex-1 px-4 py-3 bg-zinc-800/50 hover:bg-zinc-800 text-zinc-300 font-bold rounded-xl transition-all text-sm cursor-pointer border border-zinc-700/40 active:scale-95">
        Cancel
      </button>
      <button type="button" id="bootstrap-restore-confirm-btn"
        class="flex-1 px-4 py-3 bg-red-600 hover:bg-red-500 text-white font-bold rounded-xl transition-all text-sm cursor-pointer active:scale-95">
        Restore
      </button>
    </div>
  </div>
</div>

<script>
  // ── Bootstrap restore ──
  const bootstrapFile = document.getElementById('bootstrap-restore-file') as HTMLInputElement | null;
  const bootstrapBtn = document.getElementById('bootstrap-restore-btn') as HTMLButtonElement | null;
  const bootstrapModal = document.getElementById('bootstrap-restore-modal');

  if (bootstrapFile && bootstrapBtn && bootstrapModal) {
    function openModal() {
      const file = bootstrapFile!.files?.[0];
      if (!file) return;
      document.getElementById('bootstrap-restore-modal-filename')!.textContent = file.name;
      bootstrapModal!.classList.remove('hidden');
    }
    function closeModal() {
      bootstrapModal!.classList.add('hidden');
    }

    bootstrapFile.addEventListener('change', () => {
      bootstrapBtn!.disabled = !bootstrapFile.files?.length;
    });
    bootstrapBtn.addEventListener('click', openModal);
    document.getElementById('bootstrap-restore-cancel-btn')?.addEventListener('click', closeModal);
    document.getElementById('bootstrap-restore-modal-backdrop')?.addEventListener('click', closeModal);

    document.getElementById('bootstrap-restore-confirm-btn')?.addEventListener('click', async () => {
      const file = bootstrapFile.files?.[0];
      if (!file) return;
      closeModal();
      bootstrapBtn!.disabled = true;
      bootstrapBtn!.textContent = 'Restoring…';
      document.getElementById('bootstrap-restore-error')!.classList.add('hidden');
      try {
        const fd = new FormData();
        fd.append('file', file);
        const res = await fetch('/api/proxy/auth/bootstrap-restore', { method: 'POST', body: fd });
        if (!res.ok) {
          const data = await res.json().catch(() => ({}));
          throw new Error(data.detail || 'Restore failed');
        }
        window.location.href = '/login?restored=true';
      } catch (err: unknown) {
        const errEl = document.getElementById('bootstrap-restore-error')!;
        errEl.textContent = err instanceof Error ? err.message : 'Restore failed';
        errEl.classList.remove('hidden');
        bootstrapBtn!.disabled = false;
        bootstrapBtn!.textContent = 'Restore Database';
      }
    });
  }
</script>