<!-- Clear Database Confirmation Modal -->
<div id="clear-database-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4">
  <div id="clear-database-modal-backdrop" class="absolute inset-0 bg-black/70 backdrop-blur-sm"></div>
  <div class="relative bg-zinc-900 border border-zinc-800 rounded-3xl p-8 w-full max-w-md shadow-2xl">
    <h2 class="text-xl font-black text-zinc-100 mb-2">Clear Entire Database?</h2>
    <p class="text-sm text-zinc-400 mb-6">This will delete all media, history, collections, and lists globally across all users. This is a highly destructive operation. Only user settings and admin settings will remain.</p>
    <div class="flex gap-3">
      <button type="button" id="clear-database-cancel-btn"
        class="flex-1 px-4 py-3 bg-zinc-800 hover:bg-zinc-700 text-zinc-300 font-bold rounded-xl transition-colors text-sm cursor-pointer">
        Cancel
      </button>
      <button type="button" id="clear-database-confirm-btn"
        class="flex-1 px-4 py-3 bg-red-600 hover:bg-red-500 text-white font-bold rounded-xl transition-colors text-sm cursor-pointer">
        Clear Database
      </button>
    </div>
  </div>
</div>

<script>
  const appData = document.getElementById('app-data') as HTMLElement;
  const token = appData.dataset.token!;
  const currentUserId = parseInt(appData.dataset.currentUserId!);

  function esc(s: string | null | undefined): string {
    if (s == null) return '';
    return String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  }

  function showMessage(text: string, type: 'success' | 'error' = 'success') {
    const msg = document.getElementById('js-message')!;
    msg.textContent = text;
    msg.className = `p-4 rounded-lg mb-8 ${
      type === 'success'
        ? 'bg-green-500/10 border border-green-500 text-green-500'
        : 'bg-red-500/10 border border-red-500 text-red-500'
    }`;
    msg.classList.remove('hidden');
    window.scrollTo({ top: 0, behavior: 'smooth' });
    if ((window as any)._msgTimeout) clearTimeout((window as any)._msgTimeout);
    (window as any)._msgTimeout = setTimeout(() => msg.classList.add('hidden'), 4000);
  }

  function setConnStatus(id: string, state: 'checking' | 'connected' | 'disconnected') {
    const el = document.getElementById(id);
    if (!el) return;
    el.classList.remove('hidden');
    if (state === 'checking') {
      el.textContent = 'Checking…';
      el.className = 'text-xs font-normal px-1.5 py-0.5 rounded bg-zinc-700 text-zinc-400';
    } else if (state === 'connected') {
      el.textContent = '● Connected';
      el.className = 'text-xs font-normal px-1.5 py-0.5 rounded bg-green-500/15 text-green-400';
    } else {
      el.textContent = '● Disconnected';
      el.className = 'text-xs font-normal px-1.5 py-0.5 rounded bg-red-500/15 text-red-400';
    }
  }

  function renderTags(containerId: string, tags: { id: number; label: string }[], selectedIds: number[], prefix: string) {
    const container = document.getElementById(containerId);
    if (!container) return;
    if (!tags || tags.length === 0) {
      container.innerHTML = '<span class="text-xs text-zinc-500 italic px-2 py-1">No tags available</span>';
      return;
    }
    container.innerHTML = tags.map(tag => {
      const checked = selectedIds.includes(tag.id);
      return `<label class="flex items-center gap-1.5 px-2 py-1 rounded-md cursor-pointer text-xs transition-colors ${checked ? 'bg-blue-600/20 text-blue-300' : 'bg-zinc-800 text-zinc-400 hover:bg-zinc-700'}">
        <input type="checkbox" name="${esc(prefix)}_tags" value="${esc(String(tag.id))}" ${checked ? 'checked' : ''} class="sr-only" />
        ${esc(tag.label)}
      </label>`;
    }).join('');
    container.querySelectorAll('label').forEach(label => {
      label.addEventListener('click', () => {
        const cb = label.querySelector('input[type="checkbox"]') as HTMLInputElement;
        const isChecked = cb.checked;
        label.className = `flex items-center gap-1.5 px-2 py-1 rounded-md cursor-pointer text-xs transition-colors ${isChecked ? 'bg-blue-600/20 text-blue-300' : 'bg-zinc-800 text-zinc-400 hover:bg-zinc-700'}`;
      });
    });
  }

  // ── Collapsibles ──
  document.querySelectorAll('.collapsible-header').forEach(header => {
    header.addEventListener('click', () => {
      const targetId = header.getAttribute('data-target');
      const body = targetId ? document.getElementById(targetId) : null;
      if (!body) return;
      const isOpen = !body.classList.contains('hidden');
      body.classList.toggle('hidden', isOpen);
      header.querySelector('.collapsible-chevron')?.classList.toggle('rotate-180', !isOpen);
    });
  });

  // ── Password toggles ──
  document.querySelectorAll('.password-toggle').forEach(btn => {
    btn.addEventListener('click', () => {
      const input = btn.closest('.relative')?.querySelector('input') as HTMLInputElement | null;
      if (!input) return;
      input.type = input.type === 'password' ? 'text' : 'password';
      btn.querySelector('.eye-icon')?.classList.toggle('hidden');
      btn.querySelector('.eye-slash-icon')?.classList.toggle('hidden');
    });
  });

  // ── Test & Fetch ──
  document.getElementById('test-radarr-btn')?.addEventListener('click', async () => {
    const u = (document.getElementById('radarr_url') as HTMLInputElement).value.trim();
    const t = (document.getElementById('radarr_token') as HTMLInputElement).value.trim();
    if (!u || !t) { showMessage('Enter Radarr URL and API key first.', 'error'); return; }
    setConnStatus('radarr-conn-status', 'checking');
    try {
      const testRes = await fetch(`/api/proxy/auth/test-radarr?url=${encodeURIComponent(u)}&token=${encodeURIComponent(t)}`, {
        method: 'POST', headers: { 'Authorization': `Bearer ${token}` },
      });
      if (!testRes.ok) { setConnStatus('radarr-conn-status', 'disconnected'); throw new Error((await testRes.json()).detail || 'Failed to connect'); }

      const profRes = await fetch(`/api/proxy/auth/radarr/profiles?url=${encodeURIComponent(u)}&token=${encodeURIComponent(t)}`, {
        headers: { 'Authorization': `Bearer ${token}` },
      });
      const profData = await profRes.json();

      const rootSelect = document.getElementById('radarr_root_folder') as HTMLSelectElement;
      const qualSelect = document.getElementById('radarr_quality_profile') as HTMLSelectElement;
      const currentFolder = rootSelect.value;
      const currentProfile = qualSelect.value;
      rootSelect.innerHTML = '<option value="">-- Select Folder --</option>' +
        profData.root_folders.map((f: { path: string; freeSpace: number }) =>
          `<option value="${esc(f.path)}" ${f.path === currentFolder ? 'selected' : ''}>${esc(f.path)} (${(f.freeSpace / 1024**3).toFixed(1)}GB free)</option>`).join('');
      qualSelect.innerHTML = '<option value="">-- Select Profile --</option>' +
        profData.quality_profiles.map((p: { id: number; name: string }) =>
          `<option value="${esc(String(p.id))}" ${String(p.id) === currentProfile ? 'selected' : ''}>${esc(p.name)}</option>`).join('');

      const tagContainer = document.getElementById('radarr_tags_list')!;
      const selectedTags = Array.from(tagContainer.querySelectorAll<HTMLInputElement>('input[name="radarr_tags"]')).map(i => parseInt(i.value));
      renderTags('radarr_tags_list', profData.tags, selectedTags, 'radarr');

      setConnStatus('radarr-conn-status', 'connected');
      showMessage('Radarr connected and profiles fetched.');
    } catch (err: unknown) {
      showMessage(err instanceof Error ? err.message : 'Radarr error', 'error');
    }
  });

  document.getElementById('test-sonarr-btn')?.addEventListener('click', async () => {
    const u = (document.getElementById('sonarr_url') as HTMLInputElement).value.trim();
    const t = (document.getElementById('sonarr_token') as HTMLInputElement).value.trim();
    if (!u || !t) { showMessage('Enter Sonarr URL and API key first.', 'error'); return; }
    setConnStatus('sonarr-conn-status', 'checking');
    try {
      const testRes = await fetch(`/api/proxy/auth/test-sonarr?url=${encodeURIComponent(u)}&token=${encodeURIComponent(t)}`, {
        method: 'POST', headers: { 'Authorization': `Bearer ${token}` },
      });
      if (!testRes.ok) { setConnStatus('sonarr-conn-status', 'disconnected'); throw new Error((await testRes.json()).detail || 'Failed to connect'); }

      const profRes = await fetch(`/api/proxy/auth/sonarr/profiles?url=${encodeURIComponent(u)}&token=${encodeURIComponent(t)}`, {
        headers: { 'Authorization': `Bearer ${token}` },
      });
      const profData = await profRes.json();

      const rootSelect = document.getElementById('sonarr_root_folder') as HTMLSelectElement;
      const qualSelect = document.getElementById('sonarr_quality_profile') as HTMLSelectElement;
      const currentFolder = rootSelect.value;
      const currentProfile = qualSelect.value;
      rootSelect.innerHTML = '<option value="">-- Select Folder --</option>' +
        profData.root_folders.map((f: { path: string; freeSpace: number }) =>
          `<option value="${esc(f.path)}" ${f.path === currentFolder ? 'selected' : ''}>${esc(f.path)} (${(f.freeSpace / 1024**3).toFixed(1)}GB free)</option>`).join('');
      qualSelect.innerHTML = '<option value="">-- Select Profile --</option>' +
        profData.quality_profiles.map((p: { id: number; name: string }) =>
          `<option value="${esc(String(p.id))}" ${String(p.id) === currentProfile ? 'selected' : ''}>${esc(p.name)}</option>`).join('');

      const tagContainer = document.getElementById('sonarr_tags_list')!;
      const selectedTags = Array.from(tagContainer.querySelectorAll<HTMLInputElement>('input[name="sonarr_tags"]')).map(i => parseInt(i.value));
      renderTags('sonarr_tags_list', profData.tags, selectedTags, 'sonarr');

      setConnStatus('sonarr-conn-status', 'connected');
      showMessage('Sonarr connected and profiles fetched.');
    } catch (err: unknown) {
      showMessage(err instanceof Error ? err.message : 'Sonarr error', 'error');
    }
  });

  // ── Global settings form ──
  document.getElementById('global-settings-form')!.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = document.getElementById('save-settings-btn') as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = 'Saving…';

    const form = e.target as HTMLFormElement;
    const fd = new FormData(form);
    const body: Record<string, string | number | boolean | number[] | null> = {};

    for (const f of ['tmdb_api_key', 'radarr_url', 'radarr_token', 'radarr_root_folder', 'sonarr_url', 'sonarr_token', 'sonarr_root_folder']) {
      const v = ((fd.get(f) as string) ?? '').trim();
      body[f] = v || null;
    }
    for (const f of ['radarr_quality_profile', 'sonarr_quality_profile']) {
      const v = ((fd.get(f) as string) ?? '').trim();
      body[f] = v ? parseInt(v) : null;
    }
    body['sonarr_season_folder'] = fd.get('sonarr_season_folder') === 'true';

    const radarrTags = fd.getAll('radarr_tags').map(v => parseInt(v as string)).filter(n => !isNaN(n));
    body['radarr_tags'] = radarrTags.length ? radarrTags : null;
    const sonarrTags = fd.getAll('sonarr_tags').map(v => parseInt(v as string)).filter(n => !isNaN(n));
    body['sonarr_tags'] = sonarrTags.length ? sonarrTags : null;

    try {
      const res = await fetch('/api/proxy/admin/settings', {
        method: 'PATCH',
        headers: { 'Authorization': `Bearer ${token}`, 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });
      if (!res.ok) throw new Error((await res.json()).detail || 'Failed to save');
      showMessage('Settings saved successfully.');
    } catch (err: unknown) {
      showMessage(err instanceof Error ? err.message : 'Failed to save', 'error');
    } finally {
      btn.disabled = false;
      btn.textContent = 'Save Changes';
    }
  });

  // ── Database backup ──
  document.getElementById('backup-btn')?.addEventListener('click', async () => {
    const btn = document.getElementById('backup-btn') as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = 'Preparing…';
    try {
      const res = await fetch('/api/proxy/admin/backup', {
        headers: { 'Authorization': `Bearer ${token}` },
      });
      if (!res.ok) {
        const data = await res.json().catch(() => ({}));
        throw new Error(data.detail || 'Backup failed');
      }
      const cd = res.headers.get('Content-Disposition');
      const filename = cd?.match(/filename="([^"]+)"/)?.[1] ?? 'scrob_backup.bak';
      const blob = await res.blob();
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = filename;
      a.click();
      URL.revokeObjectURL(url);
      showMessage('Backup downloaded successfully.');
    } catch (err: unknown) {
      showMessage(err instanceof Error ? err.message : 'Backup failed', 'error');
    } finally {
      btn.disabled = false;
      btn.textContent = 'Download Backup';
    }
  });

  // ── Database restore ──
  const restoreFile = document.getElementById('restore-file') as HTMLInputElement;
  const restoreBtn = document.getElementById('restore-btn') as HTMLButtonElement;
  const restoreModal = document.getElementById('restore-modal')!;

  function openRestoreModal() {
    const file = restoreFile.files?.[0];
    if (!file) return;
    document.getElementById('restore-modal-filename')!.textContent = file.name;
    restoreModal.classList.remove('hidden');
  }

  function closeRestoreModal() {
    restoreModal.classList.add('hidden');
  }

  restoreFile?.addEventListener('change', () => {
    restoreBtn.disabled = !restoreFile.files?.length;
  });

  restoreBtn?.addEventListener('click', openRestoreModal);

  document.getElementById('restore-cancel-btn')?.addEventListener('click', closeRestoreModal);
  document.getElementById('restore-modal-backdrop')?.addEventListener('click', closeRestoreModal);

  document.getElementById('restore-confirm-btn')?.addEventListener('click', async () => {
    const file = restoreFile.files?.[0];
    if (!file) return;
    closeRestoreModal();
    restoreBtn.disabled = true;
    restoreBtn.textContent = 'Restoring…';
    try {
      const fd = new FormData();
      fd.append('file', file);
      const res = await fetch('/api/proxy/admin/restore', {
        method: 'POST',
        headers: { 'Authorization': `Bearer ${token}` },
        body: fd,
      });
      if (!res.ok) {
        const data = await res.json().catch(() => ({}));
        throw new Error(data.detail || 'Restore failed');
      }
      restoreBtn.textContent = 'Redirecting…';
      showMessage('Database restored. Logging out…');
      setTimeout(() => {
        const form = document.createElement('form');
        form.method = 'POST';
        form.action = '/logout';
        document.body.appendChild(form);
        form.submit();
      }, 1500);
    } catch (err: unknown) {
      showMessage(err instanceof Error ? err.message : 'Restore failed', 'error');
      restoreBtn.disabled = false;
      restoreBtn.textContent = 'Restore Database';
    }
  });

  // ── Users table ──
  function countAdmins(): number {
    return document.querySelectorAll('#users-table-body tr.user-main-row[data-is-admin="true"]').length;
  }

  function refreshToggleButtons() {
    const sole = countAdmins() === 1;
    document.querySelectorAll<HTMLTableRowElement>('#users-table-body tr.user-main-row[data-user-id]').forEach(row => {
      const userId = parseInt(row.dataset.userId!);
      const isAdmin = row.dataset.isAdmin === 'true';
      const detailRow = document.querySelector<HTMLTableRowElement>(`tr.user-detail-row[data-detail-for="${userId}"]`);
      [row, detailRow].forEach(r => {
        const btn = r?.querySelector<HTMLButtonElement>('.toggle-admin-btn');
        if (!btn) return;
        if (isAdmin && userId === currentUserId && sole) {
          btn.disabled = true;
          btn.title = 'You are the sole admin. Promote another user first.';
        } else {
          btn.disabled = false;
          btn.title = '';
        }
      });
    });
  }

  function updateRow(row: HTMLTableRowElement, isAdmin: boolean) {
    row.dataset.isAdmin = String(isAdmin);
    const badge = row.querySelector('td:nth-child(3) span')!;
    if (isAdmin) {
      badge.className = 'inline-flex items-center px-2 py-0.5 rounded-md text-xs font-semibold bg-amber-500/10 text-amber-400 border border-amber-500/20';
      badge.textContent = 'Admin';
    } else {
      badge.className = 'inline-flex items-center px-2 py-0.5 rounded-md text-xs font-semibold bg-zinc-700/50 text-zinc-400 border border-zinc-700';
      badge.textContent = 'User';
    }
    const adminClass = 'toggle-admin-btn px-3 py-1.5 text-xs font-semibold rounded-lg transition-all active:scale-95 cursor-pointer border bg-zinc-800 hover:bg-zinc-700 text-zinc-300 border-zinc-700';
    const userClass = 'toggle-admin-btn px-3 py-1.5 text-xs font-semibold rounded-lg transition-all active:scale-95 cursor-pointer border bg-amber-500/10 hover:bg-amber-500/20 text-amber-400 border-amber-500/20';
    const userId = row.dataset.userId!;
    const detailRow = document.querySelector<HTMLTableRowElement>(`tr.user-detail-row[data-detail-for="${userId}"]`);
    [row, detailRow].forEach(r => {
      const btn = r?.querySelector<HTMLButtonElement>('.toggle-admin-btn');
      if (!btn) return;
      btn.className = isAdmin ? adminClass : userClass;
      btn.textContent = isAdmin ? 'Remove Admin' : 'Make Admin';
    });
    refreshToggleButtons();
  }

  // ── Row expand/collapse ──
  document.querySelectorAll<HTMLTableRowElement>('#users-table-body tr.user-main-row').forEach(mainRow => {
    mainRow.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      if (target.closest('button')) return;
      const userId = mainRow.dataset.userId!;
      const detailRow = document.querySelector<HTMLTableRowElement>(`tr.user-detail-row[data-detail-for="${userId}"]`);
      if (!detailRow) return;
      const isOpen = !detailRow.classList.contains('hidden');
      detailRow.classList.toggle('hidden', isOpen);
      mainRow.querySelector('.row-chevron')?.classList.toggle('rotate-180', !isOpen);
    });
  });

  // ── Copy API key ──
  document.getElementById('users-table-body')!.addEventListener('click', async (e) => {
    const btn = (e.target as HTMLElement).closest('.copy-api-key-btn');
    if (!btn) return;
    e.stopPropagation();
    const detailRow = btn.closest('tr.user-detail-row') as HTMLTableRowElement | null;
    if (!detailRow) return;
    const key = detailRow.querySelector('.user-api-key')?.textContent?.trim() ?? '';
    await navigator.clipboard.writeText(key);
    const svg = btn.querySelector('svg')!;
    svg.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />';
    setTimeout(() => {
      svg.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" d="M15.75 17.25v3.375c0 .621-.504 1.125-1.125 1.125h-9.75a1.125 1.125 0 01-1.125-1.125V7.875c0-.621.504-1.125 1.125-1.125H6.75a9.06 9.06 0 011.5.124m7.5 10.376h3.375c.621 0 1.125-.504 1.125-1.125V11.25c0-4.46-3.243-8.161-7.5-8.976a9.06 9.06 0 00-1.5-.124H9.375c-.621 0-1.125.504-1.125 1.125v3.5m7.5 10.375H9.375a1.125 1.125 0 01-1.125-1.125v-9.25m12 6.625v-1.875a3.375 3.375 0 00-3.375-3.375h-1.5a1.125 1.125 0 01-1.125-1.125v-1.5a3.375 3.375 0 00-3.375-3.375H9.75" />';
    }, 1500);
  });

  refreshToggleButtons();

  // ── Delete user modal ──
  const deleteUserModal = document.getElementById('delete-user-modal')!;
  let pendingDelete: { userId: number; row: HTMLTableRowElement; btn: HTMLButtonElement; isSelf: boolean } | null = null;

  function openDeleteModal(userId: number, username: string, row: HTMLTableRowElement, btn: HTMLButtonElement, isSelf: boolean) {
    pendingDelete = { userId, row, btn, isSelf };
    const body = document.getElementById('delete-user-modal-body')!;
    if (isSelf) {
      body.innerHTML = `Deleting your own account (<strong class="text-zinc-100">${esc(username)}</strong>) will log you out immediately. This cannot be undone.`;
    } else {
      body.innerHTML = `Are you sure you want to delete <strong class="text-zinc-100">${esc(username)}</strong>? This cannot be undone.`;
    }
    deleteUserModal.classList.remove('hidden');
  }

  function closeDeleteModal() {
    deleteUserModal.classList.add('hidden');
    pendingDelete = null;
  }

  document.getElementById('delete-user-cancel-btn')?.addEventListener('click', closeDeleteModal);
  document.getElementById('delete-user-modal-backdrop')?.addEventListener('click', closeDeleteModal);

  document.getElementById('delete-user-confirm-btn')?.addEventListener('click', async () => {
    if (!pendingDelete) return;
    const { userId, row, btn, isSelf } = pendingDelete;
    closeDeleteModal();
    btn.disabled = true;
    try {
      const res = await fetch(`/api/proxy/admin/users/${userId}`, {
        method: 'DELETE', headers: { 'Authorization': `Bearer ${token}` },
      });
      if (!res.ok) throw new Error((await res.json()).detail || 'Failed');
      if (isSelf) {
        const form = document.createElement('form');
        form.method = 'POST';
        form.action = '/logout';
        document.body.appendChild(form);
        form.submit();
      } else {
        const detailRow = document.querySelector(`tr.user-detail-row[data-detail-for="${userId}"]`);
        detailRow?.remove();
        row.remove();
        refreshToggleButtons();
        showMessage('User deleted.');
      }
    } catch (err: unknown) {
      showMessage(err instanceof Error ? err.message : 'Failed', 'error');
      btn.disabled = false;
    }
  });

  // ── Admin heal ──
  const adminHealBtn = document.getElementById('admin-heal-btn') as HTMLButtonElement;
  const adminHealModal = document.getElementById('admin-heal-modal')!;

  adminHealBtn?.addEventListener('click', () => {
    adminHealModal.classList.remove('hidden');
  });

  document.getElementById('admin-heal-cancel-btn')?.addEventListener('click', () => {
    adminHealModal.classList.add('hidden');
  });

  document.getElementById('admin-heal-modal-backdrop')?.addEventListener('click', () => {
    adminHealModal.classList.add('hidden');
  });

  document.getElementById('admin-heal-confirm-btn')?.addEventListener('click', async () => {
    adminHealModal.classList.add('hidden');
    adminHealBtn.disabled = true;
    adminHealBtn.textContent = 'Starting…';
    try {
      const res = await fetch('/api/proxy/admin/maintenance/heal', {
        method: 'POST',
        headers: { 'Authorization': `Bearer ${token}` },
      });
      if (!res.ok) throw new Error((await res.json()).detail || 'Failed to start heal');
      showMessage('Server-wide metadata heal started — it will run in the background.');
    } catch (err: unknown) {
      showMessage(err instanceof Error ? err.message : 'Failed to start heal', 'error');
    } finally {
      adminHealBtn.disabled = false;
      adminHealBtn.textContent = 'Run Heal';
    }
  });

  // ── Clear database ──
  const clearDatabaseBtn = document.getElementById('admin-clear-database-btn') as HTMLButtonElement;
  const clearDatabaseModal = document.getElementById('clear-database-modal')!;

  clearDatabaseBtn?.addEventListener('click', () => {
    clearDatabaseModal.classList.remove('hidden');
  });

  document.getElementById('clear-database-cancel-btn')?.addEventListener('click', () => {
    clearDatabaseModal.classList.add('hidden');
  });

  document.getElementById('clear-database-modal-backdrop')?.addEventListener('click', () => {
    clearDatabaseModal.classList.add('hidden');
  });

  document.getElementById('clear-database-confirm-btn')?.addEventListener('click', async () => {
    clearDatabaseModal.classList.add('hidden');
    clearDatabaseBtn.disabled = true;
    clearDatabaseBtn.textContent = 'Clearing…';
    try {
      const res = await fetch('/api/proxy/admin/database', {
        method: 'DELETE',
        headers: { 'Authorization': `Bearer ${token}` },
      });
      if (!res.ok) throw new Error((await res.json()).detail || 'Failed to clear database');
      showMessage('Database successfully cleared. All user state reset.');
    } catch (err: unknown) {
      showMessage(err instanceof Error ? err.message : 'Failed to clear database', 'error');
    } finally {
      clearDatabaseBtn.disabled = false;
      clearDatabaseBtn.textContent = 'Clear Database';
    }
  });

  document.getElementById('users-table-body')!.addEventListener('click', async (e) => {
    const target = e.target as HTMLElement;
    if (target.closest('.copy-api-key-btn')) return;

    // Resolve the main row and userId from either the main row or detail row
    let mainRow = target.closest('tr.user-main-row') as HTMLTableRowElement | null;
    if (!mainRow) {
      const detailRow = target.closest('tr.user-detail-row') as HTMLTableRowElement | null;
      if (!detailRow) return;
      const detailFor = detailRow.dataset.detailFor!;
      mainRow = document.querySelector<HTMLTableRowElement>(`tr.user-main-row[data-user-id="${detailFor}"]`);
    }
    if (!mainRow) return;
    const userId = parseInt(mainRow.dataset.userId!);

    if (target.closest('.toggle-admin-btn')) {
      const btn = target.closest('.toggle-admin-btn') as HTMLButtonElement;
      if (btn.disabled) return;
      btn.disabled = true;
      try {
        const res = await fetch(`/api/proxy/admin/users/${userId}/toggle-admin`, {
          method: 'PATCH', headers: { 'Authorization': `Bearer ${token}` },
        });
        if (!res.ok) throw new Error((await res.json()).detail || 'Failed');
        const updated = await res.json();
        updateRow(mainRow, updated.is_admin);
        showMessage('User updated.');
      } catch (err: unknown) {
        showMessage(err instanceof Error ? err.message : 'Failed', 'error');
        btn.disabled = false;
      }
    }

    if (target.closest('.delete-user-btn')) {
      const username = mainRow.querySelector('td')!.textContent!.trim();
      const isSelf = userId === currentUserId;
      openDeleteModal(userId, username, mainRow, target.closest('.delete-user-btn') as HTMLButtonElement, isSelf);
    }
  });
</script>
