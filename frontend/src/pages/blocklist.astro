---
import Base from "../layouts/Base.astro";
import MediaCard from "../components/MediaCard.astro";
import { api, type MediaItem, type ContentFilters } from "../lib/api";

const { token } = Astro.locals;
if (!token) {
  return Astro.redirect("/login");
}

const tab = Astro.url.searchParams.get("tab") ?? "items";

let blockedItems: MediaItem[] = [];
let droppedItems: MediaItem[] = [];
let blockedItemsCount = 0;
let droppedItemsCount = 0;
let filters: ContentFilters = { blocked_genres: [], blocked_keywords: [], blocked_regexes: [], available_genres: [] };
let error = "";

try {
  const [blocklist, cf] = await Promise.all([
    api.media.getBlocklist(token),
    api.contentFilters.get(token),
  ]);
  
  const actualBlocklist = blocklist?.filter(i => !i.is_dropped) || [];
  const actualDroplist = blocklist?.filter(i => i.is_dropped) || [];
  
  blockedItemsCount = actualBlocklist.length;
  droppedItemsCount = actualDroplist.length;
  filters = cf;

  if (tab === "items" && actualBlocklist.length > 0) {
    const detailPromises = actualBlocklist.map(item => {
      if (item.media_type === 'series') {
        return api.shows.get(item.tmdb_id, token)
          .then(show => ({ ...show, type: 'series' as const, release_date: show.first_air_date }))
          .catch(() => null);
      }
      return api.media.get(item.media_type, item.tmdb_id, token).catch(() => null);
    });
    const results = await Promise.all(detailPromises);
    blockedItems = results.filter((item): item is MediaItem => item !== null);
  } else if (tab === "dropped" && actualDroplist.length > 0) {
    const detailPromises = actualDroplist.map(item => {
      if (item.media_type === 'series') {
        return api.shows.get(item.tmdb_id, token)
          .then(show => ({ ...show, type: 'series' as const, release_date: show.first_air_date }))
          .catch(() => null);
      }
      return api.media.get(item.media_type, item.tmdb_id, token).catch(() => null);
    });
    const results = await Promise.all(detailPromises);
    droppedItems = results.filter((item): item is MediaItem => item !== null);
  }
} catch (e: any) {
  error = e.message;
}

const GENRE_CATEGORIES: Record<string, string[]> = {
  "Movies": ["Action","Adventure","Animation","Comedy","Crime","Documentary","Drama","Family","Fantasy","History","Horror","Music","Mystery","Romance","Science Fiction","Thriller","War","Western"],
  "TV": ["Action & Adventure","Animation","Comedy","Crime","Documentary","Drama","Family","Kids","Mystery","News","Reality","Sci-Fi & Fantasy","Soap","Talk","War & Politics","Western"],
};
---

<Base title="Blocklist & Content Filters">
  <div id="app-data" data-token={token} class="hidden" aria-hidden="true"></div>

  <!-- Header -->
  <div class="mb-8">
    <div class="flex items-center gap-4 mb-3">
      <a href="/settings" class="p-2 hover:bg-zinc-800 rounded-full text-zinc-400 hover:text-zinc-100 transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
      </a>
      <h1 class="text-3xl font-bold text-zinc-100 tracking-tight">Content Filters</h1>
    </div>
    <p class="text-zinc-400 ml-12">Block individual titles, entire genres, or keywords from your explore pages.</p>
  </div>

  {error && (
    <div class="p-4 bg-red-500/10 border border-red-500/20 rounded-xl text-red-400 mb-8">{error}</div>
  )}

  <!-- Tab Bar -->
  <div class="flex items-center gap-1 p-1 bg-zinc-900/60 border border-zinc-800 rounded-2xl w-fit max-w-full mb-8 overflow-x-auto no-scrollbar">
    {[
      { id: "items",    label: "Blocked Items",       icon: "M18.364 18.364A9 9 0 0 0 5.636 5.636m12.728 12.728A9 9 0 0 1 5.636 5.636m12.728 12.728L5.636 5.636" },
      { id: "dropped",  label: "Dropped Shows",       icon: "M19 14l-7 7-7-7" },
      { id: "genres",   label: "Genre Filters",       icon: "M3.5 5.5h17M3.5 9.5h17M3.5 13.5h17M3.5 17.5h17" },
      { id: "keywords", label: "Keywords & Regex",    icon: "m21 21-6-6m2-5a7 7 0 1 1-14 0 7 7 0 0 1 14 0z" },
    ].map(t => (
      <a
        href={`/blocklist?tab=${t.id}`}
        class={`flex items-center gap-2 px-4 py-2 rounded-xl text-sm font-semibold transition-all shrink-0 ${tab === t.id ? "bg-zinc-700 text-zinc-100 shadow-sm" : "text-zinc-400 hover:text-zinc-200"}`}
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d={t.icon}/></svg>
        {t.label}
        {t.id === "items" && blockedItemsCount > 0 && (
          <span class="ml-1 bg-zinc-600 text-zinc-300 text-[10px] font-bold px-1.5 py-0.5 rounded-full">{blockedItemsCount}</span>
        )}
        {t.id === "dropped" && droppedItemsCount > 0 && (
          <span class="ml-1 bg-amber-900/60 text-amber-300 text-[10px] font-bold px-1.5 py-0.5 rounded-full">{droppedItemsCount}</span>
        )}
        {t.id === "genres" && filters.blocked_genres.length > 0 && (
          <span class="ml-1 bg-rose-900/60 text-rose-300 text-[10px] font-bold px-1.5 py-0.5 rounded-full">{filters.blocked_genres.length}</span>
        )}
        {t.id === "keywords" && (filters.blocked_keywords.length + filters.blocked_regexes.length) > 0 && (
          <span class="ml-1 bg-rose-900/60 text-rose-300 text-[10px] font-bold px-1.5 py-0.5 rounded-full">{filters.blocked_keywords.length + filters.blocked_regexes.length}</span>
        )}
      </a>
    ))}
  </div>

  <!-- ── Tab: Blocked Items ─────────────────────────────── -->
  {tab === "items" && (
    blockedItems.length === 0 ? (
      <div class="flex flex-col items-center justify-center py-20 bg-zinc-900/30 border border-dashed border-zinc-800 rounded-3xl">
        <span class="text-4xl mb-4">🛡️</span>
        <h2 class="text-xl font-bold text-zinc-100 mb-2">No blocked titles</h2>
        <p class="text-zinc-500 text-sm">Block individual items from their detail pages to hide them here.</p>
      </div>
    ) : (
      <div id="blocklist-grid" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-6">
        {blockedItems.map(item => (
          <div class="relative group/blocked" data-tmdb-id={item.tmdb_id} data-media-type={item.type}>
            <MediaCard item={item} hideBlock={true} hideRating={true} />
            <div class="absolute inset-x-0 top-0 p-2 flex justify-end opacity-0 group-hover/blocked:opacity-100 transition-opacity z-20 pointer-events-none">
              <button
                data-action="unblock-direct"
                class="pointer-events-auto bg-zinc-900/90 backdrop-blur-md border border-zinc-700 hover:border-red-500/50 hover:bg-red-500/20 text-zinc-100 hover:text-red-400 px-3 py-1.5 rounded-lg text-xs font-bold transition-all shadow-xl cursor-pointer flex items-center gap-1.5"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
                Unblock
              </button>
            </div>
          </div>
        ))}
      </div>
    )
  )}
  
  <!-- ── Tab: Dropped Shows ─────────────────────────────── -->
  {tab === "dropped" && (
    droppedItems.length === 0 ? (
      <div class="flex flex-col items-center justify-center py-20 bg-zinc-900/30 border border-dashed border-zinc-800 rounded-3xl">
        <span class="text-4xl mb-4">⏬</span>
        <h2 class="text-xl font-bold text-zinc-100 mb-2">No dropped shows</h2>
        <p class="text-zinc-500 text-sm">Drop shows from their detail pages to hide them from your "Next Up" list.</p>
      </div>
    ) : (
      <div id="dropped-grid" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-6">
        {droppedItems.map(item => (
          <div class="relative group/dropped" data-tmdb-id={item.tmdb_id} data-media-type={item.type}>
            <MediaCard item={item} hideBlock={true} hideRating={true} />
            <div class="absolute inset-x-0 top-0 p-2 flex justify-end opacity-0 group-hover/dropped:opacity-100 transition-opacity z-20 pointer-events-none">
              <button
                data-action="unblock-direct"
                class="pointer-events-auto bg-zinc-900/90 backdrop-blur-md border border-zinc-700 hover:border-emerald-500/50 hover:bg-emerald-500/20 text-zinc-100 hover:text-emerald-400 px-3 py-1.5 rounded-lg text-xs font-bold transition-all shadow-xl cursor-pointer flex items-center gap-1.5"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/></svg>
                Resume Tracking
              </button>
            </div>
          </div>
        ))}
      </div>
    )
  )}

  <!-- ── Tab: Genre Filters ─────────────────────────────── -->
  {tab === "genres" && (
    <div id="genre-panel">
      <p class="text-sm text-zinc-400 mb-6">
        Click a genre chip to block it. Any discovery result (trending, popular, search) matching a blocked genre will be hidden. Changes are saved automatically.
      </p>

      {Object.entries(GENRE_CATEGORIES).map(([cat, genres]) => (
        <div class="mb-8">
          <h2 class="text-xs font-black uppercase tracking-widest text-zinc-500 mb-3">{cat}</h2>
          <div class="flex flex-wrap gap-2">
            {genres.map(genre => {
              const isBlocked = filters.blocked_genres.includes(genre);
              return (
                <button
                  data-action="toggle-genre"
                  data-genre={genre}
                  class={`genre-chip px-4 py-2 rounded-xl text-sm font-semibold border transition-all duration-150 cursor-pointer select-none ${
                    isBlocked
                      ? "bg-rose-600/20 border-rose-500/50 text-rose-300 hover:bg-rose-600/30"
                      : "bg-zinc-900/60 border-zinc-700 text-zinc-300 hover:border-zinc-500 hover:text-zinc-100"
                  }`}
                >
                  {isBlocked && (
                    <svg class="inline -mt-0.5 mr-1 w-3 h-3" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M18 6 6 18M6 6l12 12"/></svg>
                  )}
                  {genre}
                </button>
              );
            })}
          </div>
        </div>
      ))}

      <div id="genre-save-status" class="text-xs text-zinc-500 mt-2 h-4"></div>
    </div>
  )}

  <!-- ── Tab: Keyword & Regex Filters ──────────────────── -->
  {tab === "keywords" && (
    <div class="grid md:grid-cols-2 gap-8" id="kw-re-panel">

      <!-- Keywords -->
      <div>
        <h2 class="text-base font-bold text-zinc-100 mb-1">Keyword Filters</h2>
        <p class="text-sm text-zinc-400 mb-5">Any title containing this text (case-insensitive) will be hidden.</p>

        <ul id="kw-list" class="space-y-2 mb-4">
          {filters.blocked_keywords.map(kw => (
            <li class="flex items-center justify-between bg-zinc-900/60 border border-zinc-800 rounded-xl px-4 py-2.5" data-kw={kw}>
              <span class="font-mono text-sm text-zinc-200">{kw}</span>
              <button data-action="remove-keyword" data-value={kw} class="text-zinc-500 hover:text-red-400 transition-colors p-1 cursor-pointer ml-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18M6 6l12 12"/></svg>
              </button>
            </li>
          ))}
          {filters.blocked_keywords.length === 0 && (
            <li id="kw-empty" class="text-sm text-zinc-500 italic py-2">No keyword filters yet.</li>
          )}
        </ul>

        <div class="flex gap-2">
          <input
            id="kw-input"
            type="text"
            placeholder="e.g. reality"
            class="flex-1 bg-zinc-900 border border-zinc-800 focus:border-zinc-600 rounded-xl px-4 py-2.5 text-sm text-zinc-100 focus:outline-none transition-colors"
          />
          <button id="kw-add-btn" class="px-4 py-2.5 bg-zinc-700 hover:bg-zinc-600 text-zinc-100 text-sm font-bold rounded-xl transition-colors cursor-pointer">Add</button>
        </div>
        <div id="kw-save-status" class="text-xs text-zinc-500 mt-2 h-4"></div>
      </div>

      <!-- Regexes -->
      <div>
        <h2 class="text-base font-bold text-zinc-100 mb-1">Regex Filters</h2>
        <p class="text-sm text-zinc-400 mb-5">Applied via <code class="text-zinc-300 bg-zinc-800 px-1 rounded">re.search(pattern, title, IGNORECASE)</code>. Invalid patterns are rejected.</p>

        <ul id="re-list" class="space-y-2 mb-4">
          {filters.blocked_regexes.map(re => (
            <li class="flex items-center justify-between bg-zinc-900/60 border border-zinc-800 rounded-xl px-4 py-2.5" data-re={re}>
              <span class="font-mono text-sm text-violet-300">{re}</span>
              <button data-action="remove-regex" data-value={re} class="text-zinc-500 hover:text-red-400 transition-colors p-1 cursor-pointer ml-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18M6 6l12 12"/></svg>
              </button>
            </li>
          ))}
          {filters.blocked_regexes.length === 0 && (
            <li id="re-empty" class="text-sm text-zinc-500 italic py-2">No regex filters yet.</li>
          )}
        </ul>

        <div class="flex gap-2">
          <div class="relative flex-1">
            <input
              id="re-input"
              type="text"
              placeholder="e.g. ^The\s"
              class="w-full bg-zinc-900 border border-zinc-800 focus:border-zinc-600 rounded-xl px-4 py-2.5 pr-10 text-sm text-violet-300 font-mono focus:outline-none transition-colors"
            />
            <span id="re-validity" class="absolute right-3 top-1/2 -translate-y-1/2 text-xs font-bold hidden"></span>
          </div>
          <button id="re-add-btn" class="px-4 py-2.5 bg-zinc-700 hover:bg-zinc-600 text-zinc-100 text-sm font-bold rounded-xl transition-colors cursor-pointer">Add</button>
        </div>
        <div id="re-save-status" class="text-xs text-zinc-500 mt-2 h-4"></div>
      </div>

    </div>
  )}
</Base>

<script>
  // ── Unblock items ─────────────────────────────────────────────────────────
  document.addEventListener('click', async (e) => {
    const btn = (e.target as HTMLElement).closest('[data-action="unblock-direct"]') as HTMLButtonElement;
    if (!btn) return;
    const container = btn.closest('[data-tmdb-id]') as HTMLElement;
    const tmdbId = container?.dataset.tmdbId;
    const mediaType = container?.dataset.mediaType;
    if (!tmdbId || !mediaType) return;
    btn.disabled = true;
    btn.innerHTML = '<span class="animate-spin inline-block w-3 h-3 border-2 border-white/30 border-t-white rounded-full"></span>';
    const token = (document.getElementById('app-data') as HTMLElement)?.dataset.token;
    try {
      const res = await fetch(`/api/proxy/media/blocklist?tmdb_id=${tmdbId}&media_type=${mediaType}`, {
        method: 'DELETE', headers: { 'Authorization': `Bearer ${token}` }
      });
      if (res.ok) {
        container.remove();
        const grid = document.getElementById('blocklist-grid');
        if (grid && grid.children.length === 0) window.location.reload();
      } else throw new Error();
    } catch {
      btn.disabled = false;
      btn.innerHTML = 'Unblock';
    }
  });
</script>

<script>
  // ── Genre toggle ──────────────────────────────────────────────────────────
  const genrePanel = document.getElementById('genre-panel');
  if (genrePanel) {
    const token = (document.getElementById('app-data') as HTMLElement)?.dataset.token;
    const status = document.getElementById('genre-save-status');
    const blocked: Set<string> = new Set(
      Array.from(document.querySelectorAll('.genre-chip[data-genre]'))
        .filter(el => el.classList.contains('bg-rose-600/20'))
        .map(el => (el as HTMLElement).dataset.genre!)
    );

    function setStatus(msg: string, ok = true) {
      if (!status) return;
      status.textContent = msg;
      status.className = `text-xs mt-2 h-4 transition-opacity ${ok ? 'text-emerald-400' : 'text-red-400'}`;
      setTimeout(() => { status.textContent = ''; }, 2000);
    }

    async function saveGenres() {
      try {
        const res = await fetch('/api/proxy/media/content-filters/genres', {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
          body: JSON.stringify({ genres: Array.from(blocked) }),
        });
        if (!res.ok) throw new Error();
        setStatus(`✓ Saved — ${blocked.size} genre${blocked.size !== 1 ? 's' : ''} blocked`);
      } catch {
        setStatus('✗ Failed to save', false);
      }
    }

    genrePanel.addEventListener('click', async (e) => {
      const btn = (e.target as HTMLElement).closest('[data-action="toggle-genre"]') as HTMLElement;
      if (!btn) return;
      const genre = btn.dataset.genre!;
      if (blocked.has(genre)) {
        blocked.delete(genre);
        btn.className = 'genre-chip px-4 py-2 rounded-xl text-sm font-semibold border transition-all duration-150 cursor-pointer select-none bg-zinc-900/60 border-zinc-700 text-zinc-300 hover:border-zinc-500 hover:text-zinc-100';
        btn.innerHTML = genre;
      } else {
        blocked.add(genre);
        btn.className = 'genre-chip px-4 py-2 rounded-xl text-sm font-semibold border transition-all duration-150 cursor-pointer select-none bg-rose-600/20 border-rose-500/50 text-rose-300 hover:bg-rose-600/30';
        btn.innerHTML = `<svg class="inline -mt-0.5 mr-1 w-3 h-3" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M18 6 6 18M6 6l12 12"/></svg>${genre}`;
      }
      await saveGenres();
    });
  }
</script>

<script>
  // ── Keyword & Regex filters ────────────────────────────────────────────────
  const kwRePanel = document.getElementById('kw-re-panel');
  if (kwRePanel) {
    const token = (document.getElementById('app-data') as HTMLElement)?.dataset.token;

    // --- helpers ---
    function keywords(): string[] {
      return Array.from(document.querySelectorAll('#kw-list li[data-kw]')).map(el => (el as HTMLElement).dataset.kw!);
    }
    function regexes(): string[] {
      return Array.from(document.querySelectorAll('#re-list li[data-re]')).map(el => (el as HTMLElement).dataset.re!);
    }
    function showStatus(id: string, msg: string, ok = true) {
      const el = document.getElementById(id);
      if (!el) return;
      el.textContent = msg;
      el.className = `text-xs mt-2 h-4 ${ok ? 'text-emerald-400' : 'text-red-400'}`;
      setTimeout(() => { el.textContent = ''; }, 2500);
    }

    async function saveKeywords() {
      const res = await fetch('/api/proxy/media/content-filters/keywords', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
        body: JSON.stringify({ keywords: keywords() }),
      });
      if (!res.ok) throw new Error();
    }
    async function saveRegexes() {
      const res = await fetch('/api/proxy/media/content-filters/regexes', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
        body: JSON.stringify({ regexes: regexes() }),
      });
      if (!res.ok) {
        const data = await res.json().catch(() => ({}));
        throw new Error(data.detail || 'Invalid regex');
      }
    }

    function makeKwItem(kw: string): HTMLLIElement {
      const li = document.createElement('li');
      li.className = 'flex items-center justify-between bg-zinc-900/60 border border-zinc-800 rounded-xl px-4 py-2.5';
      li.dataset.kw = kw;
      li.innerHTML = `<span class="font-mono text-sm text-zinc-200">${kw}</span>
        <button data-action="remove-keyword" data-value="${kw}" class="text-zinc-500 hover:text-red-400 transition-colors p-1 cursor-pointer ml-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18M6 6l12 12"/></svg>
        </button>`;
      return li;
    }

    function makeReItem(re: string): HTMLLIElement {
      const li = document.createElement('li');
      li.className = 'flex items-center justify-between bg-zinc-900/60 border border-zinc-800 rounded-xl px-4 py-2.5';
      li.dataset.re = re;
      li.innerHTML = `<span class="font-mono text-sm text-violet-300">${re}</span>
        <button data-action="remove-regex" data-value="${re}" class="text-zinc-500 hover:text-red-400 transition-colors p-1 cursor-pointer ml-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18M6 6l12 12"/></svg>
        </button>`;
      return li;
    }

    // --- Add keyword ---
    document.getElementById('kw-add-btn')?.addEventListener('click', async () => {
      const input = document.getElementById('kw-input') as HTMLInputElement;
      const val = input.value.trim();
      if (!val) return;
      const list = document.getElementById('kw-list')!;
      const empty = document.getElementById('kw-empty');
      empty?.remove();
      list.appendChild(makeKwItem(val));
      input.value = '';
      try { await saveKeywords(); showStatus('kw-save-status', `✓ "${val}" added`); }
      catch { showStatus('kw-save-status', '✗ Failed to save', false); }
    });

    // --- Add regex ---
    const reInput = document.getElementById('re-input') as HTMLInputElement;
    const reValidity = document.getElementById('re-validity')!;
    reInput?.addEventListener('input', () => {
      const val = reInput.value.trim();
      if (!val) { reValidity.classList.add('hidden'); return; }
      try { new RegExp(val); reValidity.textContent = '✓'; reValidity.className = 'absolute right-3 top-1/2 -translate-y-1/2 text-xs font-bold text-emerald-400'; }
      catch { reValidity.textContent = '✗'; reValidity.className = 'absolute right-3 top-1/2 -translate-y-1/2 text-xs font-bold text-red-400'; }
    });

    document.getElementById('re-add-btn')?.addEventListener('click', async () => {
      const val = reInput.value.trim();
      if (!val) return;
      try { new RegExp(val); } catch { showStatus('re-save-status', '✗ Invalid regex pattern', false); return; }
      const list = document.getElementById('re-list')!;
      document.getElementById('re-empty')?.remove();
      list.appendChild(makeReItem(val));
      reInput.value = '';
      reValidity.classList.add('hidden');
      try { await saveRegexes(); showStatus('re-save-status', `✓ Pattern added`); }
      catch (err: any) { showStatus('re-save-status', `✗ ${err.message}`, false); }
    });

    // --- Remove keyword / regex (event delegation) ---
    document.addEventListener('click', async (e) => {
      const btn = (e.target as HTMLElement).closest('[data-action="remove-keyword"]') as HTMLElement;
      if (btn) {
        const li = btn.closest('li[data-kw]')!;
        li.remove();
        if (!keywords().length) {
          const list = document.getElementById('kw-list')!;
          const empty = document.createElement('li');
          empty.id = 'kw-empty';
          empty.className = 'text-sm text-zinc-500 italic py-2';
          empty.textContent = 'No keyword filters yet.';
          list.appendChild(empty);
        }
        try { await saveKeywords(); showStatus('kw-save-status', '✓ Removed'); }
        catch { showStatus('kw-save-status', '✗ Failed to save', false); }
      }

      const btn2 = (e.target as HTMLElement).closest('[data-action="remove-regex"]') as HTMLElement;
      if (btn2) {
        const li = btn2.closest('li[data-re]')!;
        li.remove();
        if (!regexes().length) {
          const list = document.getElementById('re-list')!;
          const empty = document.createElement('li');
          empty.id = 're-empty';
          empty.className = 'text-sm text-zinc-500 italic py-2';
          empty.textContent = 'No regex filters yet.';
          list.appendChild(empty);
        }
        try { await saveRegexes(); showStatus('re-save-status', '✓ Removed'); }
        catch { showStatus('re-save-status', '✗ Failed to save', false); }
      }
    });

    // Enter key to add
    document.getElementById('kw-input')?.addEventListener('keydown', e => { if (e.key === 'Enter') document.getElementById('kw-add-btn')?.click(); });
    reInput?.addEventListener('keydown', e => { if (e.key === 'Enter') document.getElementById('re-add-btn')?.click(); });
  }
</script>
