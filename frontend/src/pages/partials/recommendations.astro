---
import MediaCard from "../../components/MediaCard.astro";
import { api } from "../../lib/api";

export const partial = true;

const token = Astro.cookies.get("token")?.value;
const type = Astro.url.searchParams.get("type");
const id = Astro.url.searchParams.get("id");

if (!token || !type || !id) {
  return new Response(null, { status: 400 });
}

let recommendations: any[] = [];
try {
  if (type === "movie" || type === "episode") {
    const res = await api.media.getRecommendations(type, parseInt(id), token);
    recommendations = res.results;
  } else if (type === "series") {
    const res = await api.shows.getRecommendations(parseInt(id), token);
    recommendations = res.results;
  }
} catch (e) {
  console.error("Failed to fetch recommendations partial", e);
}

if (recommendations.length === 0) {
  return new Response(null, { status: 204 });
}
---

<section class="mb-16">
  <div class="flex items-center justify-between mb-8 group">
    <h2 class="text-2xl font-black text-zinc-100 tracking-tight flex items-center gap-3">
      <span class="w-1 h-6 bg-blue-600 rounded-full"></span>
      More like this
    </h2>
  </div>

  <div class="grid grid-cols-2 xs:grid-cols-3 sm:grid-cols-4 lg:grid-cols-4 xl:grid-cols-4 gap-3 md:gap-4">
    {recommendations.map(item => (
      <MediaCard item={item} />
    ))}
  </div>
</section>
