---
import MediaCard from "../../components/MediaCard.astro";
import { api } from "../../lib/api";

export const prerender = false;

const { token } = Astro.locals;
const showUriId = Astro.url.searchParams.get("show_uri_id");

if (!showUriId) {
  return new Response("Missing show_uri_id", { status: 400 });
}

let item = null;

try {
  const data = await api.history.nextUp(token);
  item = data.next_up.find(i => i.show_uri_id === showUriId || i.uri_id === showUriId);
} catch (e) {
  console.error("Failed to fetch next up item:", e);
}
---

{item ? <MediaCard item={item} /> : <div class="hidden" data-remove-card></div>}
