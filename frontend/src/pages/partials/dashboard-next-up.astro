---
import MediaCard from "../../components/MediaCard.astro";
import ActionBar from "../../components/ActionBar.astro";
import { api } from "../../lib/api";
import { mediaUrl } from "../../lib/urls";

export const prerender = false;

const { token } = Astro.locals;
let nextUp = [];

try {
  const data = await api.history.nextUp(token, 10);
  nextUp = data?.next_up ?? [];
} catch (e) {
  console.error("Failed to fetch next up for partial:", e);
}

if (nextUp.length === 0) {
  return new Response("", { status: 200 }); // Empty if no next up
}

const hero = nextUp[0];
const primaryMetadataSource = Astro.cookies.get("primary_metadata_source")?.value || "tmdb";
const heroHref = mediaUrl(hero, primaryMetadataSource === "tvdb");
const episodeLabel = hero.season_number != null && hero.episode_number != null
  ? `S${hero.season_number} E${hero.episode_number}`
  : null;
const rawBackdrop = hero.backdrop_path || hero.show_backdrop_path;
const heroBackdrop = rawBackdrop
  ? (rawBackdrop.startsWith('http') ? rawBackdrop : `https://image.tmdb.org/t/p/w1280${rawBackdrop}`)
  : null;
---

<section class="relative md:-mt-8 mb-16" id="dashboard-next-up">
  <div class="absolute -top-20 md:-top-32 left-1/2 -translate-x-1/2 w-screen h-[600px] overflow-hidden pointer-events-none" style="mask-image: linear-gradient(to bottom, transparent 0%, black 15%, black 60%, transparent 100%); -webkit-mask-image: linear-gradient(to bottom, transparent 0%, black 15%, black 60%, transparent 100%);" data-adult-backdrop={hero.adult ? "true" : undefined}>
    <div class="absolute inset-0 bg-gradient-to-t from-[var(--color-hero-fade)] via-[var(--color-hero-fade)]/40 to-transparent z-10"></div>
    {heroBackdrop ? (
      <img
        src={heroBackdrop}
        alt=""
        class="w-full h-full object-cover opacity-50 blur-[1px]"
        loading="eager"
        decoding="async"
      />
    ) : (
      <div class="w-full h-full bg-zinc-900 opacity-50"></div>
    )}
  </div>

  <div class="relative aspect-[16/9] sm:aspect-[21/8] md:aspect-[21/5] min-h-[280px] sm:min-h-[auto] flex flex-col">
    <div class="flex items-center justify-between pt-8 pb-0 shrink-0">
      <h2 class="text-2xl font-black text-zinc-100 tracking-tight flex items-center gap-3">
        <span class="w-1 h-6 bg-blue-600 rounded-full"></span>
        Next Up
      </h2>
      <a href="/next-up" class="text-sm font-bold uppercase tracking-widest text-zinc-400 hover:text-blue-400 transition-all flex items-center gap-2 group/all">
        See All
        <span class="group-hover/all:translate-x-1 transition-transform">→</span>
      </a>
    </div>

    <div class="flex-1 flex flex-col justify-end pb-6 sm:pb-8 pt-8">
      <div class="flex flex-row items-end justify-between gap-4 sm:gap-6 w-full">
        <a href={heroHref} class="block flex-1 min-w-0 group">
          {episodeLabel && (
            <span class="inline-block text-xs font-bold uppercase tracking-widest text-blue-400 bg-blue-500/10 border border-blue-500/20 px-3 py-1 rounded-full mb-3">
              {episodeLabel}
            </span>
          )}
          <h3 class="text-2xl sm:text-4xl font-black text-zinc-100 leading-tight mb-1 drop-shadow-lg group-hover:text-blue-200 transition-colors">
            {hero.show_title ?? hero.title}
          </h3>
          {hero.show_title && (
            <p class="text-sm sm:text-base text-zinc-300 font-medium truncate">{hero.title}</p>
          )}
        </a>

        <div class="shrink-0 scale-90 sm:scale-100 origin-right self-end md:self-auto md:origin-center" data-next-up-hero>
          <ActionBar
            tmdbId={hero.tmdb_id}
            mediaType={hero.type}
            watched={hero.watched ?? false}
            inLists={hero.in_lists ?? []}
            inLibrary={hero.in_library ?? false}
            collectionPct={hero.collection_pct ?? (hero.in_library ? 100 : 0)}
            showUriId={hero.show_uri_id ?? (hero.show_tmdb_id ? `tmdb:s:${hero.show_tmdb_id}` : undefined)}
            showTmdbId={hero.show_tmdb_id ?? undefined}
            seasonNumber={hero.season_number ?? undefined}
            episodeNumber={hero.episode_number ?? undefined}
            isMonitored={hero.is_monitored}
            requestEnabled={hero.request_enabled}
            userRating={hero.user_rating}
            mediaId={hero.id}
          />
        </div>
      </div>
    </div>
  </div>

  <div data-next-up-list class="relative flex gap-3 overflow-x-auto pb-3 scrollbar-none pt-6 -mx-6 px-6 md:mx-0 md:px-0">
    {nextUp.map((item) => <div class="flex-shrink-0 w-40"><MediaCard item={item} /></div>)}
  </div>
</section>
