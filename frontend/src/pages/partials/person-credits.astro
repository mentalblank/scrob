---
import MediaCard from "../../components/MediaCard.astro";
import { api, type MediaItem } from "../../lib/api";

export const partial = true;

const token = Astro.cookies.get("token")?.value;
const personId = parseInt(Astro.url.searchParams.get("person_id") || "0");
const page = parseInt(Astro.url.searchParams.get("page") || "1");

if (!token || !personId) {
  return new Response(null, { status: 400 });
}

let person: Awaited<ReturnType<typeof api.media.getPerson>>;
try {
  person = await api.media.getPerson(personId, page, token);
} catch {
  return new Response(null, { status: 500 });
}

const credits = person.credits || [];
---

<div data-total-credits={person.total_credits} data-page-size={person.page_size}>
  {credits.map((item) => (
    <div class="flex flex-col gap-1">
      <MediaCard item={item as unknown as MediaItem} />
      {item.character && (
        <p class="text-xs text-zinc-500 truncate px-1">as {item.character}</p>
      )}
    </div>
  ))}
</div>
