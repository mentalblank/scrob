---
import { api } from "../lib/api";

// Initiate the OIDC flow: get the provider's auth URL + a fresh state token from
// the backend, set the state as an httpOnly cookie on the browser, then redirect
// the browser to the provider. The backend is never contacted by the browser directly.

let errorMsg = "";

try {
  const { auth_url, state } = await api.auth.oidcAuthorize();

  Astro.cookies.set("oidc_state", state, {
    path: "/",
    httpOnly: true,
    secure: import.meta.env.PROD,
    sameSite: "lax",
    maxAge: 600, // 10 minutes
  });

  return Astro.redirect(auth_url);
} catch (e: unknown) {
  errorMsg = e instanceof Error ? e.message : "Failed to initiate SSO login";
}
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>SSO Error</title>
  </head>
  <body>
    <p>{errorMsg}</p>
    <a href="/login">Back to login</a>
  </body>
</html>
