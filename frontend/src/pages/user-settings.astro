---
import Base from "../layouts/Base.astro";
import { api } from "../lib/api";
import type { UserPreferences, PrivacyLevel } from "../lib/api";

const { token } = Astro.locals;
const [profileData, me, countriesRes, languagesRes, movieGenresRes, showGenresRes] = await Promise.all([
  api.profile.get(token!).catch(() => null),
  api.auth.me(token!),
  api.media.getCountries(token!).catch(() => []),
  api.media.getLanguages(token!).catch(() => []),
  api.media.getGenres("movie", token!).catch(() => ({ genres: [] })),
  api.media.getGenres("tv", token!).catch(() => ({ genres: [] })),
]);

const prefs: UserPreferences = {
  display_name: null,
  bio: null,
  country: null,
  movie_genres: [],
  show_genres: [],
  streaming_services: [],
  content_language: null,
  privacy_level: "private",
  ...(profileData ?? {}),
};

const PRIVACY_LEVELS: [PrivacyLevel, string, string][] = [
  ["private", "Private", "Only you can see your profile and activity."],
  ["friends_only", "Friends Only", "Only people you follow (and who follow you back) can see your activity."],
  ["public", "Public", "Anyone on this instance can see your profile and activity."],
];

const CONTENT_LANGUAGES = (languagesRes || [])
  .filter(l => l.iso_639_1 && l.english_name)
  .map(l => [l.iso_639_1, l.english_name])
  .sort((a, b) => a[1].localeCompare(b[1]));

const MOVIE_GENRES = (movieGenresRes?.genres || []).map(g => g.name).sort();
const SHOW_GENRES = (showGenresRes?.genres || []).map(g => g.name).sort();

const watchRegion = prefs.country || "US";
const providersRes = await api.media.getWatchProviders("movie", watchRegion, token).catch(() => ({ results: [] }));
const allProviders = providersRes.results || [];

const COUNTRIES = (countriesRes || [])
  .map(c => [c.iso_3166_1, c.english_name])
  .sort((a, b) => a[1].localeCompare(b[1]));
---

<Base title="Profile">
  <div id="app-data" data-token={token} class="hidden" aria-hidden="true"></div>
  <div class="max-w-4xl mx-auto">
    <h1 class="text-3xl font-bold text-zinc-100 mb-8">Profile</h1>

    <div id="js-message" class="hidden p-4 rounded-lg mb-8"></div>

    <div class="space-y-12">

      <!-- Identity -->
      <section>
        <div class="flex items-center justify-between mb-4 border-b border-zinc-800 pb-2">
          <h2 class="text-xl font-semibold text-zinc-100">Identity</h2>
        </div>

        <!-- Avatar -->
        <div class="flex items-center gap-6 mb-8">
          <div id="avatar-preview" class="w-20 h-20 rounded-2xl overflow-hidden bg-zinc-800 border border-zinc-700 flex items-center justify-center shrink-0">
            {prefs.avatar_url ? (
              <img id="avatar-img" src={`/api/proxy${prefs.avatar_url}`} alt="Avatar" class="w-full h-full object-cover" />
            ) : (
              <span id="avatar-initials" class="text-2xl font-black text-zinc-400 select-none">
                {(prefs.display_name ?? me.username)[0].toUpperCase()}
              </span>
            )}
          </div>
          <div class="space-y-2">
            <p class="text-sm font-medium text-zinc-300">Profile Picture</p>
            <p class="text-xs text-zinc-500">JPEG, PNG or WebP · Max 5 MB</p>
            <div class="flex items-center gap-2 flex-wrap">
              <label class="cursor-pointer px-4 py-2 bg-zinc-800 hover:bg-zinc-700 border border-zinc-700 hover:border-zinc-500 text-zinc-200 text-sm font-medium rounded-lg transition-all">
                <span id="upload-label">Choose file</span>
                <input id="avatar-input" type="file" accept="image/jpeg,image/png,image/webp" class="sr-only" />
              </label>
              {prefs.avatar_url && (
                <button id="remove-avatar-btn" type="button" class="px-4 py-2 bg-red-500/10 hover:bg-red-500/20 border border-red-500/30 text-red-400 text-sm font-medium rounded-lg transition-all">
                  Remove
                </button>
              )}
            </div>
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="space-y-2">
            <label for="display_name" class="block text-sm font-medium text-zinc-400">Display Name</label>
            <input
              type="text"
              id="display_name"
              name="display_name"
              value={prefs.display_name ?? ""}
              placeholder={me.username}
              maxlength={64}
              class="w-full bg-zinc-900 border border-zinc-800 rounded-lg px-4 py-3 text-zinc-100 placeholder:text-zinc-400 focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all"
            />
            <p class="text-xs text-zinc-500">Shown instead of your username where your name appears.</p>
          </div>
          <div class="space-y-2">
            <label for="bio" class="block text-sm font-medium text-zinc-400">Bio</label>
            <textarea
              id="bio"
              name="bio"
              maxlength={280}
              placeholder="A few words about yourself…"
              class="w-full bg-zinc-900 border border-zinc-800 rounded-lg px-4 py-3 text-zinc-100 placeholder:text-zinc-400 focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all resize-none h-[94px]"
            >{prefs.bio ?? ""}</textarea>
          </div>
        </div>
      </section>

      <!-- Privacy -->
      <section>
        <div class="mb-4 border-b border-zinc-800 pb-2">
          <h2 class="text-xl font-semibold text-zinc-100">Privacy</h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          {PRIVACY_LEVELS.map(([value, label, desc]) => (
            <label class={`relative flex flex-col p-4 rounded-xl border cursor-pointer transition-all hover:bg-zinc-900/50 group ${prefs.privacy_level === value ? 'bg-blue-500/5 border-blue-500/50' : 'bg-zinc-900 border-zinc-800'}`}>
              <div class="flex items-center justify-between mb-1">
                <span class={`font-semibold ${prefs.privacy_level === value ? 'text-blue-400' : 'text-zinc-100 group-hover:text-zinc-200'}`}>{label}</span>
                <input
                  type="radio"
                  name="privacy_level"
                  value={value}
                  checked={prefs.privacy_level === value}
                  class="w-4 h-4 text-blue-500 bg-zinc-800 border-zinc-700 focus:ring-blue-500 focus:ring-offset-zinc-900"
                />
              </div>
              <span class="text-xs text-zinc-500 leading-relaxed">{desc}</span>
            </label>
          ))}
        </div>
      </section>

      <!-- Discovery Preferences -->
      <section>
        <div class="mb-6 border-b border-zinc-800 pb-3">
          <h2 class="text-xl font-bold text-zinc-100">Discovery Preferences</h2>
          <p class="text-xs text-zinc-500 mt-1">Configure how media is discovered and recommendations are generated.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-10">
          <div class="space-y-2">
            <label for="country" class="block text-sm font-semibold text-zinc-400 uppercase tracking-wider">Region</label>
            <select
              id="country"
              name="country"
              class="w-full bg-zinc-900 border border-zinc-800 rounded-xl px-4 py-3 text-zinc-100 focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all"
            >
              <option value="">— Not set —</option>
              {COUNTRIES.map(([code, name]) => (
                <option value={code} selected={prefs.country === code}>{name}</option>
              ))}
            </select>
            <p class="text-[10px] text-zinc-500 font-medium leading-relaxed">
              Used to fetch relevant streaming availability and filter content for your region. Changing this will refresh the service list below.
            </p>
          </div>

          <div class="space-y-2">
            <label for="content_language" class="block text-sm font-semibold text-zinc-400 uppercase tracking-wider">Content Language</label>
            <select
              id="content_language"
              name="content_language"
              class="w-full bg-zinc-900 border border-zinc-800 rounded-xl px-4 py-3 text-zinc-100 focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all"
            >
              <option value="">— Any language —</option>
              {CONTENT_LANGUAGES.map(([code, name]) => (
                <option value={code} selected={prefs.content_language === code}>{name}</option>
              ))}
            </select>
            <p class="text-[10px] text-zinc-500 font-medium leading-relaxed">
              Prioritize recommendations in your preferred original language.
            </p>
          </div>
        </div>

        <div class="space-y-4">
          <label class="block text-sm font-semibold text-zinc-400 uppercase tracking-wider">Streaming Services</label>
          <p class="text-xs text-zinc-500 leading-relaxed">
            Select the services you subscribe to. The Discover page will highlight content available on your services.
          </p>
          <div id="streaming-services-list" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-3" data-selected={JSON.stringify(prefs.streaming_services)}>
            {allProviders.map((p: any) => {
              const active = prefs.streaming_services.includes(String(p.provider_id));
              return (
                <button
                  type="button"
                  data-provider-id={String(p.provider_id)}
                  class={`provider-toggle group relative flex flex-col items-center gap-3 p-4 rounded-2xl border transition-all hover:bg-zinc-800/50 ${active ? 'bg-blue-600/10 border-blue-500/40 text-blue-400 ring-2 ring-blue-500/20' : 'bg-zinc-900 border-zinc-800 text-zinc-500'}`}
                >
                  <div class="relative w-12 h-12 rounded-xl overflow-hidden shadow-lg group-hover:scale-110 transition-transform">
                    <img src={p.logo_path} alt={p.provider_name} class="w-full h-full object-cover" />
                    {active && (
                      <div class="absolute inset-0 bg-blue-500/20 flex items-center justify-center">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="w-6 h-6 text-white drop-shadow-md">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                        </svg>
                      </div>
                    )}
                  </div>
                  <span class="text-[10px] font-black uppercase tracking-widest text-center leading-tight truncate w-full">{p.provider_name}</span>
                </button>
              );
            })}
          </div>
          {allProviders.length === 0 && (
            <div class="p-8 rounded-2xl border border-dashed border-zinc-800 text-center">
              <p class="text-sm text-zinc-500">No providers found for this region. Please select a country first.</p>
            </div>
          )}
        </div>
      </section>

      <!-- Favourite Movie Genres -->
      <section>
        <div class="mb-4 border-b border-zinc-800 pb-2">
          <h2 class="text-xl font-bold text-zinc-100">Favourite Movie Genres</h2>
          <p class="text-xs text-zinc-500 mt-1">Pick the genres you enjoy most. The Discover page will show dedicated rows for your favourites.</p>
        </div>
        <div id="movie-genre-list" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-3" data-selected={JSON.stringify(prefs.movie_genres)}>
          {MOVIE_GENRES.map((genre) => {
            const active = prefs.movie_genres.includes(genre);
            return (
              <button
                type="button"
                data-genre-type="movie"
                data-value={genre}
                class={`genre-toggle flex items-center justify-center p-3 rounded-xl border text-[10px] font-black uppercase tracking-widest transition-all hover:bg-zinc-800/50 ${active ? "bg-blue-600/10 border-blue-500/40 text-blue-400 ring-2 ring-blue-500/20" : "bg-zinc-900 border-zinc-800 text-zinc-500"}`}
              >
                {genre}
              </button>
            );
          })}
        </div>
      </section>

      <!-- Favourite Show Genres -->
      <section>
        <div class="mb-4 border-b border-zinc-800 pb-2">
          <h2 class="text-xl font-bold text-zinc-100">Favourite Show Genres</h2>
          <p class="text-xs text-zinc-500 mt-1">Pick the genres you enjoy most. The Discover page will show dedicated rows for your favourites.</p>
        </div>
        <div id="show-genre-list" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-3" data-selected={JSON.stringify(prefs.show_genres)}>
          {SHOW_GENRES.map((genre) => {
            const active = prefs.show_genres.includes(genre);
            return (
              <button
                type="button"
                data-genre-type="show"
                data-value={genre}
                class={`genre-toggle flex items-center justify-center p-3 rounded-xl border text-[10px] font-black uppercase tracking-widest transition-all hover:bg-zinc-800/50 ${active ? "bg-blue-600/10 border-blue-500/40 text-blue-400 ring-2 ring-blue-500/20" : "bg-zinc-900 border-zinc-800 text-zinc-500"}`}
              >
                {genre}
              </button>
            );
          })}
        </div>
      </section>

      <!-- Save -->
      <div class="pt-6 pb-8">
        <button
          id="save-btn"
          type="button"
          class="w-full md:w-auto bg-zinc-100 text-zinc-950 font-bold px-8 py-3 rounded-xl hover:bg-zinc-200 transition-colors cursor-pointer disabled:opacity-50"
        >
          Save Changes
        </button>
      </div>

    </div>
  </div>
</Base>

<script>
  function setup() {
    const appData = document.getElementById('app-data');
    const token = appData?.dataset.token ?? '';

    function esc(s: unknown): string {
      if (s == null) return '';
      return String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
    }

    function showMessage(text: string, type: 'success' | 'error' = 'success') {
      const msg = document.getElementById('js-message');
      if (!msg) return;
      msg.textContent = text;
      msg.className = `p-4 rounded-lg mb-8 ${
        type === 'success'
          ? 'bg-green-500/10 border border-green-500 text-green-500'
          : 'bg-red-500/10 border border-red-500 text-red-500'
      }`;
      msg.classList.remove('hidden');
      window.scrollTo({ top: 0, behavior: 'smooth' });
      if ((window as Window & { _msgTimeout?: ReturnType<typeof setTimeout> })._msgTimeout)
        clearTimeout((window as Window & { _msgTimeout?: ReturnType<typeof setTimeout> })._msgTimeout);
      (window as Window & { _msgTimeout?: ReturnType<typeof setTimeout> })._msgTimeout =
        setTimeout(() => msg.classList.add('hidden'), 4000);
    }

    // Avatar upload
    const avatarInput = document.getElementById('avatar-input') as HTMLInputElement | null;
    const uploadLabel = document.getElementById('upload-label');
    const removeBtn = document.getElementById('remove-avatar-btn') as HTMLButtonElement | null;

    function setAvatarPreview(src: string | null) {
      const preview = document.getElementById('avatar-preview');
      if (!preview) return;
      if (src) {
        preview.innerHTML = `<img id="avatar-img" src="${esc(src)}" alt="Avatar" class="w-full h-full object-cover" />`;
      } else {
        const initial = (document.getElementById('display_name') as HTMLInputElement | null)?.value.trim()[0]
          ?? (uploadLabel?.closest('section')?.querySelector('span')?.textContent?.trim()[0] ?? '?');
        preview.innerHTML = `<span class="text-2xl font-black text-zinc-400 select-none">${esc(initial.toUpperCase())}</span>`;
      }
    }

    avatarInput?.addEventListener('change', async () => {
      const file = avatarInput.files?.[0];
      if (!file) return;
      if (uploadLabel) uploadLabel.textContent = 'Uploading…';
      const form = new FormData();
      form.append('file', file);
      try {
        const res = await fetch('/api/proxy/profile/me/avatar', {
          method: 'POST',
          headers: { 'Authorization': `Bearer ${token}` },
          body: form,
        });
        if (!res.ok) {
          const data = await res.json() as { detail?: string };
          throw new Error(data.detail ?? 'Upload failed');
        }
        const data = await res.json() as { avatar_url: string };
        setAvatarPreview(`/api/proxy${data.avatar_url}?t=${Date.now()}`);
        if (removeBtn) removeBtn.classList.remove('hidden');
        showMessage('Avatar updated.');
      } catch (e: unknown) {
        showMessage(e instanceof Error ? e.message : 'Upload failed.', 'error');
      } finally {
        if (uploadLabel) uploadLabel.textContent = 'Choose file';
        avatarInput.value = '';
      }
    });

    removeBtn?.addEventListener('click', async () => {
      removeBtn.disabled = true;
      try {
        const res = await fetch('/api/proxy/profile/me/avatar', {
          method: 'DELETE',
          headers: { 'Authorization': `Bearer ${token}` },
        });
        if (!res.ok) throw new Error('Failed to remove avatar');
        setAvatarPreview(null);
        removeBtn.classList.add('hidden');
        showMessage('Avatar removed.');
      } catch (e: unknown) {
        showMessage(e instanceof Error ? e.message : 'Failed to remove avatar.', 'error');
      } finally {
        removeBtn.disabled = false;
      }
    });

    // Discovery Preference Toggles
    const streamingList = document.getElementById('streaming-services-list');
    const movieGenreList = document.getElementById('movie-genre-list');
    const showGenreList = document.getElementById('show-genre-list');
    
    const selectedStreaming = new Set(JSON.parse(streamingList?.dataset.selected || '[]'));
    const selectedMovieGenres = new Set(JSON.parse(movieGenreList?.dataset.selected || '[]'));
    const selectedShowGenres = new Set(JSON.parse(showGenreList?.dataset.selected || '[]'));

    function refreshButton(btn: HTMLElement, active: boolean) {
      if (active) {
        btn.classList.add('bg-blue-600/10', 'border-blue-500/40', 'text-blue-400', 'ring-2', 'ring-blue-500/20');
        btn.classList.remove('bg-zinc-900', 'border-zinc-800', 'text-zinc-500');
        const check = btn.querySelector('.absolute');
        if (check) check.classList.remove('hidden');
      } else {
        btn.classList.remove('bg-blue-600/10', 'border-blue-500/40', 'text-blue-400', 'ring-2', 'ring-blue-500/20');
        btn.classList.add('bg-zinc-900', 'border-zinc-800', 'text-zinc-500');
        const check = btn.querySelector('.absolute');
        if (check) check.classList.add('hidden');
      }
    }

    streamingList?.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('.provider-toggle') as HTMLElement;
      if (!btn) return;
      const id = btn.dataset.providerId!;
      if (selectedStreaming.has(id)) selectedStreaming.delete(id); else selectedStreaming.add(id);
      refreshButton(btn, selectedStreaming.has(id));
    });

    movieGenreList?.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('.genre-toggle') as HTMLElement;
      if (!btn) return;
      const val = btn.dataset.value!;
      if (selectedMovieGenres.has(val)) selectedMovieGenres.delete(val); else selectedMovieGenres.add(val);
      refreshButton(btn, selectedMovieGenres.has(val));
    });

    showGenreList?.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('.genre-toggle') as HTMLElement;
      if (!btn) return;
      const val = btn.dataset.value!;
      if (selectedShowGenres.has(val)) selectedShowGenres.delete(val); else selectedShowGenres.add(val);
      refreshButton(btn, selectedShowGenres.has(val));
    });

    // Region Change - Refresh providers (Reload page for simplicity, like in nosocial)
    const countrySelect = document.getElementById('country') as HTMLSelectElement | null;
    countrySelect?.addEventListener('change', async () => {
      // We could fetch dynamically, but reloading ensures the server-side allProviders is updated
      // However, we should save the country first or pass it as a query param.
      // Let's just save automatically on change for country.
      saveBtn?.click();
      setTimeout(() => window.location.reload(), 500);
    });

    // Privacy radio buttons
    document.querySelectorAll<HTMLInputElement>('input[name="privacy_level"]').forEach(radio => {
      radio.addEventListener('change', () => {
        document.querySelectorAll<HTMLInputElement>('input[name="privacy_level"]').forEach(r => {
          const label = r.closest('label');
          const span = label?.querySelector('.font-semibold');
          if (r.checked) {
            label?.classList.add('bg-blue-500/5', 'border-blue-500/50');
            label?.classList.remove('bg-zinc-900', 'border-zinc-800');
            span?.classList.add('text-blue-400');
            span?.classList.remove('text-zinc-100');
          } else {
            label?.classList.remove('bg-blue-500/5', 'border-blue-500/50');
            label?.classList.add('bg-zinc-900', 'border-zinc-800');
            span?.classList.remove('text-blue-400');
            span?.classList.add('text-zinc-100');
          }
        });
      });
    });

    // Save
    const saveBtn = document.getElementById('save-btn') as HTMLButtonElement | null;
    saveBtn?.addEventListener('click', async () => {
      saveBtn.disabled = true;
      const orig = saveBtn.textContent;
      saveBtn.textContent = 'Saving…';
      const displayName = (document.getElementById('display_name') as HTMLInputElement | null)?.value.trim() ?? '';
      const bio = (document.getElementById('bio') as HTMLTextAreaElement | null)?.value.trim() ?? '';
      const country = (document.getElementById('country') as HTMLSelectElement | null)?.value ?? '';
      const contentLanguage = (document.getElementById('content_language') as HTMLSelectElement | null)?.value ?? '';

      const activeChips = (group: string) =>
        Array.from(document.querySelectorAll<HTMLButtonElement>(`button[data-chip="${group}"].bg-blue-500\\/20`))
          .map(b => b.dataset.value ?? '');

      try {
        const res = await fetch('/api/proxy/profile/me', {
          method: 'PATCH',
          headers: {
            'Authorization': `Bearer ${token}`,
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({
            display_name: displayName || null,
            bio: bio || null,
            country: country || null,
            content_language: contentLanguage || null,
            privacy_level: (document.querySelector('input[name="privacy_level"]:checked') as HTMLInputElement | null)?.value,
            streaming_services: Array.from(selectedStreaming),
            movie_genres: Array.from(selectedMovieGenres),
            show_genres: Array.from(selectedShowGenres),
          }),
        });
        if (!res.ok) {
          const data = await res.json() as { detail?: string };
          throw new Error(data.detail ?? 'Failed to save');
        }
        showMessage('Profile saved successfully.');
      } catch (e: unknown) {
        showMessage(e instanceof Error ? e.message : 'Failed to save profile.', 'error');
      } finally {
        saveBtn.disabled = false;
        saveBtn.textContent = orig;
      }
    });
  }

  setup();
  document.addEventListener('astro:after-swap', setup);
</script>
