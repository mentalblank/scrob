        fetchLocalShows().then(() => {
          localShowsList.forEach(show => {
            const opt = document.createElement("option");
            opt.value = show.tmdb_id.toString();
            opt.textContent = `${show.title} (${show.first_air_date ? new Date(show.first_air_date).getFullYear() : 'N/A'})`;
            epShowSelect.appendChild(opt);
          });
        });
        return;
      }
      
      localShowsList.forEach(show => {
