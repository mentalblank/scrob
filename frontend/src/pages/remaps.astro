            </div>
            <div>
              <label class="block text-xs font-semibold text-zinc-400 mb-1.5">Source Season Number</label>
              <input type="number" id="source-season-input" placeholder="e.g. 2" class="w-full bg-zinc-950 border border-zinc-800 rounded-xl px-3 py-2.5 text-zinc-200 text-sm focus:border-blue-500 focus:outline-none transition" />
            </div>
          </div>
          
          <div id="source-season-select-group" class="hidden space-y-3">
             <label class="block text-xs font-semibold text-zinc-400 mb-1.5">Select Source Season</label>
