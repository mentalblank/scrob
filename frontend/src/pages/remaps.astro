        const cards = document.querySelectorAll(".season-remap-card");
        let visibleCount = 0;
        
        cards.forEach(card => {
          const text = card.textContent?.toLowerCase() || "";
          if (text.includes(query)) {
            card.classList.remove("hidden");
            visibleCount++;
          } else {
            card.classList.add("hidden");
          }
        });

        const noResults = document.getElementById("no-season-results");
        if (noResults) {
          if (visibleCount === 0) {
            noResults.classList.remove("hidden");
          } else {
            noResults.classList.add("hidden");
          }
        }
      });
    }

    // 2. Episode Remaps Search
    const episodeSearchInput = document.getElementById("episode-search");
    if (episodeSearchInput) {
      episodeSearchInput.addEventListener("input", (e) => {
        const query = (e.target as HTMLInputElement).value.toLowerCase().trim();
        const panels = document.querySelectorAll(".show-episodes-panel");
        let totalVisibleEpisodes = 0;

        // Parse query for patterns
        const sxeRegex = /s(\d+)\s*e(\d+)/i;
        const crossRegex = /(\d+)\s*x\s*(\d+)/i;
        const sRegex = /^s(\d+)$/i;
        const eRegex = /^e(\d+)$/i;

        const sxeMatch = query.match(sxeRegex);
        const crossMatch = query.match(crossRegex);
        const sMatch = query.match(sRegex);
        const eMatch = query.match(eRegex);
        const isNum = /^\d+$/.test(query);
        const queryNum = isNum ? parseInt(query, 10) : null;

        panels.forEach(panel => {
          const showTitleAttr = (panel.getAttribute("data-show-title") || "").toLowerCase();
          const showTmdbId = panel.getAttribute("data-show-tmdb") || "";
          
          const showHeader = panel.querySelector("[data-show-toggle]");
          const showTitle = showTitleAttr || showHeader?.querySelector("h3")?.textContent?.toLowerCase() || "";

          let showHasVisibleEpisodes = false;

          // Process season containers within this show panel
          const seasons = panel.querySelectorAll(".season-group-container");
          seasons.forEach(seasonContainer => {
            let seasonHasVisibleEpisodes = false;
            
            // Process individual episode rows within this season
            const rows = seasonContainer.querySelectorAll(".override-row-container");
            rows.forEach(row => {
              const srcSeason = parseInt(row.getAttribute("data-source-season") || "0", 10);
              const srcEpisode = parseInt(row.getAttribute("data-source-episode") || "0", 10);
              const tgtSeason = parseInt(row.getAttribute("data-target-season") || "0", 10);
              const tgtEpisode = parseInt(row.getAttribute("data-target-episode") || "0", 10);
              
              const srcTitle = (row.getAttribute("data-source-title") || "").toLowerCase();
              const tgtTitle = (row.getAttribute("data-target-title") || "").toLowerCase();

              const rowText = row.textContent?.toLowerCase() || "";

              let match = false;

              if (query === "") {
                match = true;
              } else if (sxeMatch) {
                // SxxExx format
                const qSeason = parseInt(sxeMatch[1], 10);
                const qEpisode = parseInt(sxeMatch[2], 10);
                match = (srcSeason === qSeason && srcEpisode === qEpisode) ||
                        (tgtSeason === qSeason && tgtEpisode === qEpisode);
              } else if (crossMatch) {
                // 1x02 format
                const qSeason = parseInt(crossMatch[1], 10);
                const qEpisode = parseInt(crossMatch[2], 10);
                match = (srcSeason === qSeason && srcEpisode === qEpisode) ||
                        (tgtSeason === qSeason && tgtEpisode === qEpisode);
              } else if (sMatch) {
                // Season only (S01)
                const qSeason = parseInt(sMatch[1], 10);
                match = (srcSeason === qSeason || tgtSeason === qSeason);
              } else if (eMatch) {
                // Episode only (E02)
                const qEpisode = parseInt(eMatch[1], 10);
                match = (srcEpisode === qEpisode || tgtEpisode === qEpisode);
              } else if (isNum && queryNum !== null) {
                // Lone number: check exact episode numbers, season numbers or TMDB show ID
                match = (srcEpisode === queryNum || tgtEpisode === queryNum || 
                         srcSeason === queryNum || tgtSeason === queryNum ||
                         showTmdbId === query);
              } else {
                // General text search on titles, overview, show title, etc.
                match = showTitle.includes(query) || 
                        showTmdbId.includes(query) || 
                        srcTitle.includes(query) || 
                        tgtTitle.includes(query) ||
                        rowText.includes(query);
              }
              
              if (match) {
                row.classList.remove("hidden");
                seasonHasVisibleEpisodes = true;
                showHasVisibleEpisodes = true;
                totalVisibleEpisodes++;
              } else {
                row.classList.add("hidden");
              }
            });

            // Hide/Show season container based on whether it has visible matching rows
            if (seasonHasVisibleEpisodes) {
              seasonContainer.classList.remove("hidden");
            } else {
              seasonContainer.classList.add("hidden");
            }
          });

          // Hide/Show entire show panel
          if (showHasVisibleEpisodes) {
            panel.classList.remove("hidden");
          } else {
            panel.classList.add("hidden");
          }

          const collapsePanel = panel.querySelector("[id^='panel-']");
          const chevron = panel.querySelector("[id^='chevron-']");
          
          if (query !== "") {
            if (showHasVisibleEpisodes) {
              collapsePanel?.classList.remove("hidden");
              chevron?.classList.add("rotate-90");
            }
          } else {
            collapsePanel?.classList.add("hidden");
            chevron?.classList.remove("rotate-90");
          }
        });

        const noResults = document.getElementById("no-episode-results");
        if (noResults) {
          if (totalVisibleEpisodes === 0) {
            noResults.classList.remove("hidden");
          } else {
            noResults.classList.add("hidden");
          }
        }
      });
    }

    // 3. Custom Renames Search
    const renameSearchInput = document.getElementById("rename-search");
    if (renameSearchInput) {
      renameSearchInput.addEventListener("input", (e) => {
        const query = (e.target as HTMLInputElement).value.toLowerCase().trim();
        const panels = document.querySelectorAll(".show-renames-panel");
        let totalVisibleRenames = 0;

        panels.forEach(panel => {
          const showHeader = panel.querySelector("[data-rename-toggle]");
          const showTitle = showHeader?.querySelector("h3")?.textContent?.toLowerCase() || "";
          const showTmdbId = panel.getAttribute("data-rename-tmdb") || "";
          
          let showHasVisibleRenames = false;

          const rows = panel.querySelectorAll(".custom-rename-row");
          rows.forEach(row => {
            const rowText = row.textContent?.toLowerCase() || "";
            const match = rowText.includes(query) || showTitle.includes(query) || showTmdbId.includes(query);
            
            if (match) {
              row.classList.remove("hidden");
              showHasVisibleRenames = true;
              totalVisibleRenames++;
            } else {
              row.classList.add("hidden");
            }
          });

          // Hide/Show entire show panel
          if (showHasVisibleRenames) {
            panel.classList.remove("hidden");
          } else {
            panel.classList.add("hidden");
          }

          const collapsePanel = panel.querySelector("[id^='rename-panel-']");
          const chevron = panel.querySelector("[id^='rename-chevron-']");
          
          if (query !== "") {
            if (showHasVisibleRenames) {
              collapsePanel?.classList.remove("hidden");
              chevron?.classList.add("rotate-90");
            }
          } else {
            collapsePanel?.classList.add("hidden");
            chevron?.classList.remove("rotate-90");
          }
        });

        const noResults = document.getElementById("no-rename-results");
        if (noResults) {
          if (totalVisibleRenames === 0) {
            noResults.classList.remove("hidden");
          } else {
            noResults.classList.add("hidden");
          }
        }
      });
    }

    // Bulk Delete Action
    document.querySelectorAll(".bulk-delete-btn").forEach(button => {
      button.addEventListener("click", async () => {
        const showId = button.getAttribute("data-show-id")!;
        const panel = document.getElementById(`panel-${showId}`);
        if (!panel) return;

        const checkedBoxes = panel.querySelectorAll(".override-row-checkbox:checked");
        const ids = Array.from(checkedBoxes).map(box => parseInt(box.getAttribute("data-override-id")!));
        
        if (ids.length === 0) return;

        if (!confirm(`Are you sure you want to bulk delete ${ids.length} episode overrides for this show?`)) {
          return;
        }

        button.setAttribute("disabled", "true");
        const originalText = button.innerHTML;
        button.innerHTML = "Deleting...";

        try {
          const res = await fetch("/api/proxy/sync/episode-overrides/bulk-delete", {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
              "Authorization": `Bearer ${token}`
            },
            body: JSON.stringify({ ids })
          });
          if (res.ok) {
            window.showToast?.(`Successfully deleted ${ids.length} overrides!`, "success");
            setTimeout(() => window.location.reload(), 600);
          } else {
            window.showToast?.("Failed to bulk delete overrides", "error");
            button.removeAttribute("disabled");
            button.innerHTML = originalText;
          }
        } catch (err) {
          window.showToast?.("Error bulk deleting overrides", "error");
          button.removeAttribute("disabled");
          button.innerHTML = originalText;
        }
      });
    });

    // Custom Renames Actions
    document.querySelectorAll(".custom-rename-edit-btn").forEach(button => {
      button.addEventListener("click", async () => {
        const payloadStr = button.getAttribute("data-payload");
        if (!payloadStr) return;
        const item = JSON.parse(payloadStr);

        const newName = prompt(`Enter new title for ${item.context} (Currently: ${item.custom_title})`, item.custom_title);
        if (newName === null || newName.trim() === item.custom_title) return; // cancelled or unchanged

        const body: any = { custom_title: newName.trim() === '' ? null : newName.trim() };
        
        if (item.type === 'show') {
          body.show_uri_id = item.show_uri_id;
        } else if (item.type === 'season') {
          body.show_uri_id = item.show_uri_id;
          body.season_number = item.season_number;
          body.season_custom_name = body.custom_title;
          delete body.custom_title;
        } else if (item.type === 'episode') {
          body.media_id = item.media_id;
        }

        try {
          const res = await fetch('/api/proxy/sync/custom-title', {
            method: 'PATCH',
            headers: {
              'Content-Type': 'application/json',
              'Authorization': `Bearer ${token}`
            },
            body: JSON.stringify(body)
          });

          if (res.ok) {
            window.showToast?.("Custom title updated successfully", "success");
            setTimeout(() => window.location.reload(), 600);
          } else {
            window.showToast?.("Failed to update custom title", "error");
          }
        } catch (e) {
          window.showToast?.("Error updating custom title", "error");
        }
      });
    });

    document.querySelectorAll(".custom-rename-delete-btn").forEach(button => {
      button.addEventListener("click", async () => {
        const payloadStr = button.getAttribute("data-payload");
        if (!payloadStr) return;
        const item = JSON.parse(payloadStr);

        if (!confirm(`Are you sure you want to remove the custom title for ${item.context}? It will revert to '${item.original_title}'.`)) return;

        const body: any = {};
        if (item.type === 'show') {
          body.show_uri_id = item.show_uri_id;
          body.custom_title = null;
        } else if (item.type === 'season') {
          body.show_uri_id = item.show_uri_id;
          body.season_number = item.season_number;
          body.season_custom_name = null;
        } else if (item.type === 'episode') {
          body.media_id = item.media_id;
          body.custom_title = null;
        } else if (item.type === 'movie') {
          body.media_id = item.media_id;
          body.custom_title = null;
        }

        try {
          const res = await fetch('/api/proxy/sync/custom-title', {
            method: 'PATCH',
            headers: {
              'Content-Type': 'application/json',
              'Authorization': `Bearer ${token}`
            },
            body: JSON.stringify(body)
          });
          
          if (res.ok) {
            window.showToast?.("Custom title removed successfully", "success");
            setTimeout(() => window.location.reload(), 600);
          } else {
            window.showToast?.("Failed to remove custom title", "error");
          }
        } catch (e) {
          window.showToast?.("Error removing custom title", "error");
        }
      });
    });

    // Episode Remap Modal Logic
    const epModal = document.getElementById("ep-remap-modal")!;
    const addEpRemapBtn = document.getElementById("add-ep-remap-btn")!;
    const closeEpModalBtn = document.getElementById("close-ep-modal-btn")!;
    const cancelEpModalBtn = document.getElementById("cancel-ep-modal-btn")!;
    const saveEpRemapBtn = document.getElementById("save-ep-remap-btn") as HTMLButtonElement;

    const epSrcTmdbInput = document.getElementById("ep-src-tmdb") as HTMLInputElement;
    const epTgtTmdbInput = document.getElementById("ep-tgt-tmdb") as HTMLInputElement;
    
    const epSrcSeasonInput = document.getElementById("ep-src-season") as HTMLInputElement;
    const epSrcEpisodeStartInput = document.getElementById("ep-src-episode-start") as HTMLInputElement;
    const epSrcEpisodeEndInput = document.getElementById("ep-src-episode-end") as HTMLInputElement;
    const epTgtSeasonInput = document.getElementById("ep-tgt-season") as HTMLInputElement;
    const epTgtEpisodeStartInput = document.getElementById("ep-tgt-episode-start") as HTMLInputElement;

    function openEpModal() {
      epModal.classList.remove("opacity-0", "pointer-events-none");
      epModal.classList.add("opacity-100");
    }

    function closeEpModal() {
      epModal.classList.add("opacity-0", "pointer-events-none");
      epModal.classList.remove("opacity-100");
      
      const epSrcTypeSelect = document.getElementById("ep-src-type") as HTMLSelectElement;
      const epTgtTypeSelect = document.getElementById("ep-tgt-type") as HTMLSelectElement;
      if (epSrcTypeSelect) epSrcTypeSelect.value = "tmdb";
      if (epTgtTypeSelect) epTgtTypeSelect.value = "tmdb";

      // Reset inputs
      epSrcTmdbInput.value = "";
      epTgtTmdbInput.value = "";
      epSrcSeasonInput.value = "";
      epSrcEpisodeStartInput.value = "";
      epSrcEpisodeEndInput.value = "";
      epTgtSeasonInput.value = "";
      epTgtEpisodeStartInput.value = "";
    }

    addEpRemapBtn.addEventListener("click", openEpModal);
    closeEpModalBtn.addEventListener("click", closeEpModal);
    cancelEpModalBtn.addEventListener("click", closeEpModal);
    epModal.addEventListener("click", (e) => {
      if (e.target === epModal) closeEpModal();
    });

    // Auto-fill target TMDB ID when source TMDB ID is typed
    let lastSrcTmdb = "";
    epSrcTmdbInput.addEventListener("input", () => {
      if (epTgtTmdbInput.value === lastSrcTmdb || !epTgtTmdbInput.value) {
        epTgtTmdbInput.value = epSrcTmdbInput.value;
      }
      lastSrcTmdb = epSrcTmdbInput.value;
    });

    // Save Action supporting ranges
    saveEpRemapBtn.addEventListener("click", async () => {
      const srcType = (document.getElementById("ep-src-type") as HTMLSelectElement).value;
      const tgtType = (document.getElementById("ep-tgt-type") as HTMLSelectElement).value;

      const srcRaw = epSrcTmdbInput.value.trim();
      const tgtRaw = epTgtTmdbInput.value.trim();
      const srcUri = srcRaw.includes(":") ? srcRaw : `${srcType}:s:${srcRaw}`;
      const tgtUri = tgtRaw.includes(":") ? tgtRaw : `${tgtType}:s:${tgtRaw}`;

      const srcSeason = parseInt(epSrcSeasonInput.value);
      const srcEpStart = parseInt(epSrcEpisodeStartInput.value);
      const srcEpEndVal = epSrcEpisodeEndInput.value ? parseInt(epSrcEpisodeEndInput.value) : NaN;
      const tgtSeason = parseInt(epTgtSeasonInput.value);
      const tgtEpStart = parseInt(epTgtEpisodeStartInput.value);

      if (!srcRaw || !tgtRaw || isNaN(srcSeason) || isNaN(srcEpStart) || isNaN(tgtSeason) || isNaN(tgtEpStart)) {
        window.showToast?.("Please enter valid IDs, Season, and Episode Start values.", "error");
        return;
      }

      if (!isNaN(srcEpEndVal) && srcEpEndVal < srcEpStart) {
        window.showToast?.("Source Episode End must be greater than or equal to Episode Start.", "error");
        return;
      }

      const count = !isNaN(srcEpEndVal) ? (srcEpEndVal - srcEpStart + 1) : 1;
      saveEpRemapBtn.disabled = true;
      saveEpRemapBtn.textContent = count > 1 ? `Saving (${count} overrides)...` : "Saving...";

      try {
        const savedIds = [];
        // Save sequentially to avoid DB lock issues on large ranges
        for (let i = 0; i < count; i++) {
          const bodyData = {
            source_show_uri_id: srcUri,
            source_season_number: srcSeason,
            source_episode_number: srcEpStart + i,
            target_show_uri_id: tgtUri,
            target_season_number: tgtSeason,
            target_episode_number: tgtEpStart + i
          };
          
          const res = await fetch('/api/proxy/sync/episode-overrides', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              'Authorization': `Bearer ${token}`
            },
            body: JSON.stringify(bodyData)
          });
          if (!res.ok) throw new Error(`Failed to save override ${i+1}`);
          const data = await res.json();
          savedIds.push(data.id);
          
          if (count > 1) {
            saveEpRemapBtn.textContent = `Saved ${i + 1}/${count}...`;
          }
        }

        // Apply all overrides
        saveEpRemapBtn.textContent = "Applying Changes...";
        for (let i = 0; i < savedIds.length; i++) {
          const id = savedIds[i];
          if (count > 1) {
            saveEpRemapBtn.textContent = `Applying ${i + 1}/${count}...`;
          }
          const applyRes = await fetch(`/api/proxy/sync/episode-overrides/${id}/apply`, {
            method: 'POST',
            headers: { 'Authorization': `Bearer ${token}` }
          });
          if (!applyRes.ok) console.warn(`Failed to apply episode override ${id}`);
        }

        window.showToast?.(count > 1 ? `Successfully saved and applied ${count} episode overrides!` : "Successfully applied episode remap!", "success");
        closeEpModal();
        setTimeout(() => window.location.reload(), 800);
      } catch (e: any) {
        window.showToast?.(e.message || "Error communicating with server", "error");
        saveEpRemapBtn.disabled = false;
        saveEpRemapBtn.textContent = "Save Episode Remap";
      }
    });

    // Edit Existing Mappings Logic
    document.querySelectorAll(".edit-ep-btn").forEach(btn => {
      btn.addEventListener("click", () => {
        const srcUri = btn.getAttribute("data-src-uri") || "";
        const srcSeason = btn.getAttribute("data-src-season");
        const srcEp = btn.getAttribute("data-src-ep");
        const tgtUri = btn.getAttribute("data-tgt-uri") || "";
        const tgtSeason = btn.getAttribute("data-tgt-season");
        const tgtEp = btn.getAttribute("data-tgt-ep");

        openEpModal();

        const srcTypeSelect = document.getElementById("ep-src-type") as HTMLSelectElement;
        const tgtTypeSelect = document.getElementById("ep-tgt-type") as HTMLSelectElement;

        const srcProvider = srcUri.split(":")[0] || "tmdb";
        if (srcTypeSelect) srcTypeSelect.value = srcProvider;
        epSrcTmdbInput.value = srcUri;

        const tgtProvider = tgtUri.split(":")[0] || "tmdb";
        if (tgtTypeSelect) tgtTypeSelect.value = tgtProvider;
        epTgtTmdbInput.value = tgtUri;

        epSrcSeasonInput.value = srcSeason || "";
        epSrcEpisodeStartInput.value = srcEp || "";
        epSrcEpisodeEndInput.value = "";
        epTgtSeasonInput.value = tgtSeason || "";
        epTgtEpisodeStartInput.value = tgtEp || "";
      });
    });

    // Auto-fill and Open Modals based on URL Query Parameters
    const params = new URLSearchParams(window.location.search);
    const mode = params.get('mode');
    
    if (mode === 'season') {
      const uri = params.get('src_uri');
      const season = params.get('src_season');

      if (uri) {
        resetModalState();
        remapModal.classList.remove("opacity-0", "pointer-events-none");

        sourceShowTmdbInput.value = uri;
        targetShowTmdbInput.value = uri;

        // 2. Pre-fill season coordinates
        if (season) {
          sourceSeasonInput.value = season;
          targetSeasonInput.value = season;
        }

        // 3. Trigger lookups
        sourceShowLookupBtn.click();
        targetShowLookupBtn.click();

        // 4. Validate form
        validateForm();
      }
      // Remove params from URL so refresh doesn't pop it open again
      window.history.replaceState({}, document.title, window.location.pathname);
    } else if (mode === 'ep') {
      const uri = params.get('src_uri');
      const season = params.get('src_season');
      const ep = params.get('src_ep');

      if (uri) {
        openEpModal();
        epSrcTmdbInput.value = uri;
        epTgtTmdbInput.value = uri;

        // 2. Fill coordinates
        if (season) epSrcSeasonInput.value = season;
        if (ep) epSrcEpisodeStartInput.value = ep;
        
        // Trigger target TMDB id listener
        epSrcTmdbInput.dispatchEvent(new Event("input"));
      }
      // Remove params from URL so refresh doesn't pop it open again
      window.history.replaceState({}, document.title, window.location.pathname);
    }

  });
</script>
