    async function resolveManualEpisodeMediaId(showUri: string, seasonNumber: number, episodeNumber: number) {
      try {
        const res = await fetch(`/api/proxy/shows/${encodeURIComponent(showUri)}/season/${seasonNumber}`, {
          headers: { "Authorization": `Bearer ${token}` }
        });
        if (res.ok) {
          const data = await res.json();
          const episodes = data.episodes || [];
          const ep = episodes.find((e: any) => e.episode_number === episodeNumber);
          return ep ? ep.id : null;
        }
      } catch (err) {
        console.error("Error resolving manual episode media ID", err);
      }
      return null;
    }

    // Save Custom Rename Action
    saveRenameBtn.addEventListener("click", async () => {
      const customTitle = renameCustomTitleInput.value.trim();
      const body: any = {};

      if (isManualRename) {
        const idType = renameManualIdType.value;
        const idVal = renameManualIdInput.value.trim();
        const showUri = `${idType}:s:${idVal}`;

        if (renameType === "show") {
          body.show_uri_id = showUri;
          body.custom_title = customTitle;
        } else if (renameType === "movie") {
          const matchedMovie = localMoviesList.find(m => m.tmdb_id?.toString() === idVal);
          if (!matchedMovie) {
            window.showToast?.("Movie not found in collection. Ensure it is synced first.", "error");
            return;
          }
          body.media_id = matchedMovie.id;
          body.custom_title = customTitle;
        } else if (renameType === "season") {
          body.show_uri_id = showUri;
          body.season_number = parseInt(renameManualSeasonInput.value);
          body.season_custom_name = customTitle;
        } else if (renameType === "episode") {
          const seasonNum = parseInt(renameManualSeasonInput.value);
          const episodeNum = parseInt(renameManualEpisodeInput.value);
          
          saveRenameBtn.disabled = true;
          saveRenameBtn.textContent = "Resolving Episode...";
          
          const resolvedMediaId = await resolveManualEpisodeMediaId(showUri, seasonNum, episodeNum);
          if (!resolvedMediaId) {
            window.showToast?.("Episode not found in collection. Ensure it is synced first.", "error");
            saveRenameBtn.disabled = false;
            saveRenameBtn.textContent = "Save Custom Rename";
            return;
          }
          body.media_id = resolvedMediaId;
          body.custom_title = customTitle;
        }
      } else {
        if (renameType === "show") {
          body.show_uri_id = renameSelectedShow.uri_id ?? (renameSelectedShow.tvdb_id ? `tvdb:s:${renameSelectedShow.tvdb_id}` : `tmdb:s:${renameSelectedShow.tmdb_id}`);
          body.custom_title = customTitle;
        } else if (renameType === "movie") {
          body.media_id = renameSelectedShow.id;
          body.custom_title = customTitle;
        } else if (renameType === "season") {
          body.show_uri_id = renameSelectedShow.uri_id ?? (renameSelectedShow.tvdb_id ? `tvdb:s:${renameSelectedShow.tvdb_id}` : `tmdb:s:${renameSelectedShow.tmdb_id}`);
          body.season_number = renameSelectedSeason;
          body.season_custom_name = customTitle;
        } else if (renameType === "episode") {
          body.media_id = renameSelectedEpisode.id;
          body.custom_title = customTitle;
        }
      }

      saveRenameBtn.disabled = true;
      saveRenameBtn.textContent = "Saving...";

      try {
        const res = await fetch("/api/proxy/sync/custom-title", {
          method: "PATCH",
          headers: {
            "Content-Type": "application/json",
            "Authorization": `Bearer ${token}`
          },
          body: JSON.stringify(body)
        });

        if (res.ok) {
          window.showToast?.("Custom rename applied successfully", "success");
          closeRenameModal();
          setTimeout(() => window.location.reload(), 800);
        } else {
          const detail = await res.json();
          window.showToast?.(detail.detail || "Failed to apply custom rename", "error");
          saveRenameBtn.disabled = false;
          saveRenameBtn.textContent = "Save Custom Rename";
        }
      } catch (err) {
        window.showToast?.("Error saving custom rename", "error");
        saveRenameBtn.disabled = false;
        saveRenameBtn.textContent = "Save Custom Rename";
