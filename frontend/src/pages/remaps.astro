        epSrcTmdbInput.value = "";
        epTgtTmdbInput.value = "";
        resetEpSeasonEpisodeDropdowns();
        return;
      }
      
      selectedEpShowObj = localShowsList.find(s => s.tmdb_id.toString() === tmdbId);
      epSrcTmdbInput.value = tmdbId;
      epTgtTmdbInput.value = tmdbId;
      
      populateEpSeasonDropdowns();
    });

    function resetEpSeasonEpisodeDropdowns() {
      epSrcSeasonSelect.innerHTML = '<option value="">-- Choose Show First --</option>';
      epSrcEpisodeSelect.innerHTML = '<option value="">-- Choose Season First --</option>';
      epTgtSeasonSelect.innerHTML = '<option value="">-- Choose Show First --</option>';
      epTgtEpisodeSelect.innerHTML = '<option value="">-- Choose Season First --</option>';
      
      epSrcSeasonSelect.disabled = true;
      epSrcEpisodeSelect.disabled = true;
      epTgtSeasonSelect.disabled = true;
      epTgtEpisodeSelect.disabled = true;
    }

    function populateEpSeasonDropdowns() {
      if (!selectedEpShowObj || !selectedEpShowObj.seasons_meta) {
        resetEpSeasonEpisodeDropdowns();
        return;
      }
      
      epSrcSeasonSelect.innerHTML = '<option value="">-- Choose Season --</option>';
      selectedEpShowObj.seasons_meta.forEach((season: any) => {
        const opt = document.createElement("option");
        opt.value = season.season_number.toString();
        opt.textContent = season.season_number === 0 ? "Specials" : `Season ${season.season_number}`;
        epSrcSeasonSelect.appendChild(opt);
      });
      epSrcSeasonSelect.disabled = false;
      
      epTgtSeasonSelect.innerHTML = '<option value="">-- Choose Season --</option>';
      selectedEpShowObj.seasons_meta.forEach((season: any) => {
        const opt = document.createElement("option");
        opt.value = season.season_number.toString();
        opt.textContent = season.season_number === 0 ? "Specials" : `Season ${season.season_number}`;
        epTgtSeasonSelect.appendChild(opt);
      });
      epTgtSeasonSelect.disabled = false;
      
      epSrcEpisodeSelect.innerHTML = '<option value="">-- Choose Season First --</option>';
      epSrcEpisodeSelect.disabled = true;
      epTgtEpisodeSelect.innerHTML = '<option value="">-- Choose Season First --</option>';
      epTgtEpisodeSelect.disabled = true;
    }

    epSrcSeasonSelect.addEventListener("change", () => {
