        epTgtSeasonInput.value = epTgtSeasonSelect.value;
        epTgtEpisodeInput.value = epTgtEpisodeSelect.value;
      } else {
        epCoordsMode = "dropdown";
        epCoordsManualGroup.classList.add("hidden");
        epCoordsSelectGroup.classList.remove("hidden");
        epToggleCoordsMode.textContent = "Toggle Manual Coordinate Input";
        
        if (epSrcSeasonInput.value) epSrcSeasonSelect.value = epSrcSeasonInput.value;
        if (epSrcEpisodeInput.value) epSrcEpisodeSelect.value = epSrcEpisodeInput.value;
        if (epTgtSeasonInput.value) epTgtSeasonSelect.value = epTgtSeasonInput.value;
        if (epTgtEpisodeInput.value) epTgtEpisodeSelect.value = epTgtEpisodeInput.value;
      }
    });

    // Handle show dropdown change to load seasons
    epShowSelect.addEventListener("change", () => {
