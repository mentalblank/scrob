    epSrcTmdbInput.addEventListener("input", () => {
      if (epTgtTmdbInput.value === lastSrcTmdb || !epTgtTmdbInput.value) {
        epTgtTmdbInput.value = epSrcTmdbInput.value;
      }
      lastSrcTmdb = epSrcTmdbInput.value;
    });

    // Save Action supporting ranges
    saveEpRemapBtn.addEventListener("click", async () => {
      const srcTmdb = parseInt(epSrcTmdbInput.value);
      const tgtTmdb = parseInt(epTgtTmdbInput.value);
      const srcSeason = parseInt(epSrcSeasonInput.value);
      const srcEpStart = parseInt(epSrcEpisodeStartInput.value);
      const srcEpEndVal = epSrcEpisodeEndInput.value ? parseInt(epSrcEpisodeEndInput.value) : NaN;
      const tgtSeason = parseInt(epTgtSeasonInput.value);
      const tgtEpStart = parseInt(epTgtEpisodeStartInput.value);

      if (isNaN(srcTmdb) || isNaN(tgtTmdb) || isNaN(srcSeason) || isNaN(srcEpStart) || isNaN(tgtSeason) || isNaN(tgtEpStart)) {
        window.showToast?.("Please enter valid TMDB IDs, Season, and Episode Start values.", "error");
        return;
      }

      const hasRange = !isNaN(srcEpEndVal) && srcEpEndVal > srcEpStart;
      if (!isNaN(srcEpEndVal) && srcEpEndVal < srcEpStart) {
        window.showToast?.("Source Episode End must be greater than or equal to Episode Start.", "error");
        return;
      }

      const count = hasRange ? (srcEpEndVal - srcEpStart + 1) : 1;
      const overridesToSave = [];
      for (let i = 0; i < count; i++) {
        overridesToSave.push({
          source_show_tmdb_id: srcTmdb,
          source_season_number: srcSeason,
          source_episode_number: srcEpStart + i,
          target_show_tmdb_id: tgtTmdb,
          target_season_number: tgtSeason,
          target_episode_number: tgtEpStart + i
        });
      }

      saveEpRemapBtn.disabled = true;
      saveEpRemapBtn.textContent = count > 1 ? `Saving (${count} overrides)...` : "Saving...";

      try {
        // Save all overrides in parallel
        const savePromises = overridesToSave.map(async (bodyData) => {
          const res = await fetch('/api/proxy/sync/episode-overrides', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              'Authorization': `Bearer ${token}`
            },
            body: JSON.stringify(bodyData)
          });
          if (!res.ok) throw new Error("Failed to save episode override");
          return res.json();
        });

        const savedOverrides = await Promise.all(savePromises);

        // Apply all overrides
        saveEpRemapBtn.textContent = "Applying...";
        const applyPromises = savedOverrides.map(async (data) => {
          const applyRes = await fetch(`/api/proxy/sync/episode-overrides/${data.id}/apply`, {
            method: 'POST',
            headers: { 'Authorization': `Bearer ${token}` }
          });
          if (!applyRes.ok) throw new Error("Failed to apply episode override");
          return applyRes.json();
        });

        await Promise.all(applyPromises);

        window.showToast?.(count > 1 ? `Successfully saved and applied ${count} episode overrides!` : "Successfully applied episode remap!", "success");
        closeEpModal();
        setTimeout(() => window.location.reload(), 800);
      } catch (e) {
        window.showToast?.("Error communicating with server or applying override", "error");
        saveEpRemapBtn.disabled = false;
        saveEpRemapBtn.textContent = "Save Episode Remap";
      }
    });

