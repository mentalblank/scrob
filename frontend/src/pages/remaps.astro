    // Save Action
    saveEpRemapBtn.addEventListener("click", async () => {
      const srcTmdb = parseInt(epSrcTmdbInput.value);
      const tgtTmdb = parseInt(epTgtTmdbInput.value);
      
      let srcSeason: number;
      let srcEp: number;
      let tgtSeason: number;
      let tgtEp: number;
      
      if (epCoordsMode === "dropdown") {
        srcSeason = parseInt(epSrcSeasonSelect.value);
        srcEp = parseInt(epSrcEpisodeSelect.value);
        tgtSeason = parseInt(epTgtSeasonSelect.value);
        tgtEp = parseInt(epTgtEpisodeSelect.value);
      } else {
        srcSeason = parseInt(epSrcSeasonInput.value);
        srcEp = parseInt(epSrcEpisodeInput.value);
        tgtSeason = parseInt(epTgtSeasonInput.value);
        tgtEp = parseInt(epTgtEpisodeInput.value);
      }

      if (isNaN(srcTmdb) || isNaN(tgtTmdb) || isNaN(srcSeason) || isNaN(srcEp) || isNaN(tgtSeason) || isNaN(tgtEp)) {
        window.showToast?.("Please choose a show and select valid coordinate mappings", "error");
        return;
      }

      saveEpRemapBtn.disabled = true;
      saveEpRemapBtn.textContent = "Saving...";

      try {
        const res = await fetch('/api/proxy/sync/episode-overrides', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Authorization': `Bearer ${token}`
          },
          body: JSON.stringify({
            source_show_tmdb_id: srcTmdb,
            source_season_number: srcSeason,
            source_episode_number: srcEp,
            target_show_tmdb_id: tgtTmdb,
            target_season_number: tgtSeason,
            target_episode_number: tgtEp
          })
        });

        if (res.ok) {
          const data = await res.json();
          window.showToast?.("Episode override saved. Applying...", "success");
          
          const applyRes = await fetch(`/api/proxy/sync/episode-overrides/${data.id}/apply`, {
            method: 'POST',
            headers: { 'Authorization': `Bearer ${token}` }
          });
          
          if (applyRes.ok) {
            window.showToast?.("Successfully applied episode remap!", "success");
            closeEpModal();
            setTimeout(() => window.location.reload(), 800);
          } else {
            window.showToast?.("Saved, but failed to apply. Check logs.", "error");
            closeEpModal();
            setTimeout(() => window.location.reload(), 1000);
          }
        } else {
          window.showToast?.("Failed to save episode override", "error");
          saveEpRemapBtn.disabled = false;
          saveEpRemapBtn.textContent = "Save Episode Remap";
        }
      } catch (e) {
        window.showToast?.("Error communicating with server", "error");
        saveEpRemapBtn.disabled = false;
        saveEpRemapBtn.textContent = "Save Episode Remap";
