---
import Base from "../layouts/Base.astro";
import { api } from "../lib/api";

const { token } = Astro.locals;
if (!token) {
  return Astro.redirect("/login");
}

let seasonOverrides = [];
let episodeOverrides = [];
let groupedShowsList = [];
let customTitles = [];
let groupedCustomTitlesList = [];
let error = "";

try {
  const [dataSeason, dataEp, dataTitles, settings] = await Promise.all([
    api.sync.getSeasonOverrides(token),
    api.sync.getEpisodeOverrides(token),
    api.sync.getCustomTitles(token),
    api.auth.getSettings(token)
  ]);
  
  seasonOverrides = dataSeason;
  episodeOverrides = dataEp.overrides || [];
  
  // Group episode overrides by show URI
  const groupedEpisodeOverrides: Record<string, any> = {};
  episodeOverrides.forEach((override: any) => {
    const showKey = override.source_show_uri_id ?? String(override.source_show_id);
    if (!groupedEpisodeOverrides[showKey]) {
      groupedEpisodeOverrides[showKey] = {
        show_key: showKey.replace(/[^a-zA-Z0-9_-]/g, '_'),
        show_title: override.source_show_title,
        show_uri_id: override.source_show_uri_id,
        show_tmdb_id: override.source_show_id,
        show_poster_path: override.source_show_poster_path,
        overrides: [],
        seasons: {}
      };
    }
    groupedEpisodeOverrides[showKey].overrides.push(override);

    const seasonNum = override.source_season_number;
    if (!groupedEpisodeOverrides[showKey].seasons[seasonNum]) {
      groupedEpisodeOverrides[showKey].seasons[seasonNum] = [];
    }
    groupedEpisodeOverrides[showKey].seasons[seasonNum].push(override);
  });
  groupedShowsList = Object.values(groupedEpisodeOverrides);
  
  customTitles = dataTitles.results || [];
  
  // Group custom titles by show ID
  const groupedCustomTitles: Record<string, any> = {};
  customTitles.forEach((item: any) => {
    let groupId = item.show_uri_id ?? String(item.show_tmdb_id ?? 0);
    let groupTitle = item.show_title || "Global / Unlinked";
    let groupPoster = item.show_poster_path || null;

    if (item.type === 'movie') {
      groupId = "movies";
      groupTitle = "Movies";
      groupPoster = null;
    }

    if (!groupedCustomTitles[groupId]) {
      groupedCustomTitles[groupId] = {
        show_title: groupTitle,
        show_uri_id: item.show_uri_id ?? null,
        show_tmdb_id: item.show_tmdb_id || 0,
        show_poster_path: groupPoster,
        items: [],
        isMovies: item.type === 'movie'
      };
    }
    groupedCustomTitles[groupId].items.push(item);
  });
  // Sort groups: movies first, then shows alphabetically, unlinked last
  groupedCustomTitlesList = Object.values(groupedCustomTitles).sort((a: any, b: any) => {
    if (a.isMovies) return -1;
    if (b.isMovies) return 1;
    if (!a.show_uri_id && !a.show_tmdb_id) return 1;
    if (!b.show_uri_id && !b.show_tmdb_id) return -1;
    return a.show_title.localeCompare(b.show_title);
  });
  
} catch (e: any) {
  error = e.message;
}
---

<Base title="Metadata Overrides">
  <div id="app-data" data-token={token} class="hidden" aria-hidden="true"></div>

  <div class="max-w-6xl mx-auto px-4 py-8">
    <!-- Header with Back Button -->
    <div class="mb-8">
      <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-3">
        <div class="flex items-center gap-4">
          <a href="/settings" class="p-2 hover:bg-zinc-800 rounded-full text-zinc-400 hover:text-zinc-100 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
          </a>
          <h1 class="text-3xl font-bold text-zinc-100 tracking-tight">Metadata Overrides</h1>
        </div>
        {(seasonOverrides.length > 0 || (episodeOverrides && episodeOverrides.length > 0)) && (
          <button id="apply-all-overrides-btn" class="flex items-center gap-2 px-4 py-2.5 bg-emerald-600/20 hover:bg-emerald-600/35 border border-emerald-500/40 text-emerald-300 text-sm font-bold rounded-xl transition-all shadow-lg active:scale-95 cursor-pointer shrink-0 ml-12 sm:ml-0" title="Apply all overrides and remap episodes">
            <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21.5 2v6h-6M21.34 15.57a10 10 0 1 1-.57-8.38l5.67-5.67"/></svg>
            Apply All Remaps
          </button>
        )}
      </div>
      <p class="text-zinc-400 ml-12 text-sm sm:text-base">Point specific seasons, episodes, or titles of a TV show in your collection to different TMDB shows, seasons, or custom entries to resolve metadata mismatches and share progress states.</p>
    </div>

    {error && (
      <div class="p-4 bg-red-500/10 border border-red-500/20 rounded-xl text-red-400 mb-8">{error}</div>
    )}

    <!-- Toolbar -->
    <div class="flex flex-col lg:flex-row lg:items-center justify-between gap-4 mb-6">
      <h2 class="section-headline mb-1 flex items-center gap-2">
        Active Season Remaps
        <span class="text-xs bg-zinc-800 text-zinc-400 font-bold px-2 py-0.5 rounded-full">{seasonOverrides.length}</span>
      </h2>
      <div class="flex flex-col sm:flex-row items-stretch sm:items-center gap-3">
        {seasonOverrides.length > 0 && (
          <input 
            type="text" 
            id="season-search" 
            placeholder="Search season remaps..." 
            class="px-4 py-2 bg-zinc-950/40 border border-zinc-800 focus:border-indigo-500 rounded-xl text-xs text-zinc-200 focus:outline-none focus:ring-1 focus:ring-indigo-500 w-full sm:w-64 placeholder-zinc-600 transition-all"
          />
        )}
        <button id="add-remap-btn" class="flex items-center justify-center gap-2 px-5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white font-bold rounded-xl text-sm transition-all shadow-lg active:scale-95 cursor-pointer shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5v14"/></svg>
          Add Season Remap
        </button>
      </div>
    </div>

    <!-- Active Overrides List -->
    {seasonOverrides.length === 0 ? (
      <div class="flex flex-col items-center justify-center py-20 border border-zinc-800 bg-zinc-950/20 rounded-3xl backdrop-blur-md">
        <div class="w-16 h-16 rounded-full bg-zinc-900 border border-zinc-800 flex items-center justify-center text-zinc-500 mb-4 shadow-inner">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m21 16-4 4-4-4"/><path d="M17 20V4"/><path d="m3 8 4-4 4 4"/><path d="M7 4v16"/></svg>
        </div>
        <h3 class="text-zinc-200 font-semibold mb-1">No Season Remaps</h3>
        <p class="text-zinc-500 text-xs max-w-sm text-center">All your TV show seasons are currently using their standard synced TMDB mappings.</p>
      </div>
    ) : (
      <div>
        <div class="grid grid-cols-1 gap-4">
          {seasonOverrides.map((override) => (
            <div class="season-remap-card flex flex-col md:flex-row items-center justify-between p-5 bg-zinc-900/40 border border-zinc-800 rounded-2xl gap-6 hover:border-zinc-700/80 transition-all duration-300 hover:shadow-lg">
              
              <!-- Source Show -->
              <div class="flex items-center gap-3 w-full md:w-2/5 min-w-0">
                <div class="min-w-0 flex-1">
                  <span class="text-[9px] font-extrabold uppercase text-zinc-500 tracking-wider">Source Show</span>
                  {override.source_show_uri_id
                    ? <a href={`/show/${override.source_show_uri_id}`} class="block text-zinc-100 font-bold truncate text-sm mt-0.5 hover:text-blue-400 transition-colors" title={override.source_show_title}>{override.source_show_title}</a>
                    : <span class="block text-zinc-100 font-bold truncate text-sm mt-0.5">{override.source_show_title}</span>
                  }
                  <div class="flex flex-wrap items-center gap-1.5 mt-1">
                    <span class="px-2 py-0.5 bg-zinc-800 border border-zinc-750 rounded-md text-[10px] font-bold text-zinc-300">Season {override.source_season_number}</span>
                    <span class="text-[9px] text-zinc-500 font-medium bg-zinc-950/60 px-1.5 py-0.5 rounded border border-zinc-850">{override.source_show_uri_id}</span>
                  </div>
                </div>
              </div>

              <!-- Arrow Indicator -->
              <div class="flex flex-col items-center justify-center shrink-0">
                <div class="w-9 h-9 rounded-full bg-zinc-950 border border-zinc-800 flex items-center justify-center text-blue-500 shadow-md">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </div>
              </div>

              <!-- Target Show -->
              <div class="flex items-center gap-3 w-full md:w-2/5 min-w-0">
                <div class="min-w-0 flex-1">
                  <span class="text-[9px] font-extrabold uppercase text-blue-400 tracking-wider">Target TMDB Show</span>
                  {override.target_show_uri_id
                    ? <a href={`/show/${override.target_show_uri_id}`} class="block text-zinc-100 font-bold truncate text-sm mt-0.5 hover:text-blue-400 transition-colors" title={override.target_show_title}>{override.target_show_title}</a>
                    : <span class="block text-zinc-100 font-bold truncate text-sm mt-0.5">{override.target_show_title}</span>
                  }
                  <div class="flex flex-wrap items-center gap-1.5 mt-1">
                    <span class="px-2 py-0.5 bg-blue-950/40 border border-blue-900/30 rounded-md text-[10px] font-bold text-blue-400">Season {override.target_season_number}</span>
                    <span class="text-[9px] text-zinc-500 font-medium bg-zinc-950/60 px-1.5 py-0.5 rounded border border-zinc-850">{override.target_show_uri_id}</span>
                  </div>
                </div>
              </div>

              <!-- Actions -->
              <div class="flex items-center gap-2 w-full md:w-auto justify-end shrink-0 border-t border-zinc-800 md:border-t-0 pt-4 md:pt-0">
                <button class="edit-season-btn flex items-center gap-1.5 px-3 py-2 bg-zinc-800 hover:bg-zinc-750 active:scale-95 text-zinc-200 text-xs font-bold rounded-xl transition-all cursor-pointer shadow-sm" data-source-uri={override.source_show_uri_id} data-source-season={override.source_season_number} data-target-uri={override.target_show_uri_id} data-target-season={override.target_season_number} title="Edit override">
                  <svg class="w-3.5 h-3.5" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/><path d="m15 5 4 4"/></svg>
                  Edit
                </button>
                <button data-apply-id={override.id} class="flex items-center gap-1.5 px-3 py-2 bg-zinc-800 hover:bg-zinc-750 active:scale-95 text-zinc-200 text-xs font-bold rounded-xl transition-all cursor-pointer shadow-sm" title="Re-apply override & fetch TMDB metadata">
                  <svg class="w-3.5 h-3.5" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21.5 2v6h-6M21.34 15.57a10 10 0 1 1-.57-8.38l5.67-5.67"/></svg>
                  Apply
                </button>
                <button data-delete-id={override.id} class="flex items-center gap-1.5 px-3 py-2 bg-rose-950/20 hover:bg-rose-900/30 border border-rose-900/40 text-rose-300 text-xs font-bold rounded-xl transition-all cursor-pointer shadow-sm active:scale-95" title="Delete override">
                  <svg class="w-3.5 h-3.5" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2M10 11v6M14 11v6"/></svg>
                  Delete
                </button>
              </div>

            </div>
          ))}
        </div>
        <!-- Season search empty state -->
        <div id="no-season-results" class="hidden flex flex-col items-center justify-center py-16 border border-zinc-800 bg-zinc-950/20 rounded-3xl backdrop-blur-md">
          <div class="w-12 h-12 rounded-full bg-zinc-900 border border-zinc-800 flex items-center justify-center text-zinc-500 mb-3 shadow-inner">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
          </div>
          <h3 class="text-zinc-300 font-semibold mb-1 text-sm">No Matching Season Remaps</h3>
          <p class="text-zinc-500 text-xs text-center">Try adjusting your keywords or search query.</p>
        </div>
      </div>
    )}
    
    <!-- Episode Remaps Section -->
    <div class="mt-16 mb-8">
      <div class="flex flex-col lg:flex-row lg:items-center justify-between gap-4 mb-6">
        <h2 class="section-headline mb-1 flex items-center gap-2">
          Active Episode Remaps
          <span class="text-xs bg-zinc-800 text-zinc-400 font-bold px-2 py-0.5 rounded-full">{episodeOverrides.length}</span>
        </h2>
        <div class="flex flex-col sm:flex-row items-stretch sm:items-center gap-3">
          {episodeOverrides.length > 0 && (
            <input 
              type="text" 
              id="episode-search" 
              placeholder="Search episode remaps..." 
              class="px-4 py-2 bg-zinc-950/40 border border-zinc-800 focus:border-indigo-500 rounded-xl text-xs text-zinc-200 focus:outline-none focus:ring-1 focus:ring-indigo-500 w-full sm:w-64 placeholder-zinc-600 transition-all"
            />
          )}
          <button id="add-ep-remap-btn" class="flex items-center justify-center gap-2 px-5 py-2.5 bg-indigo-600 hover:bg-indigo-500 text-white font-bold rounded-xl text-sm transition-all shadow-lg active:scale-95 cursor-pointer shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5v14"/></svg>
            Add Episode Remap
          </button>
        </div>
      </div>

      <!-- Episode Overrides List Grouped by Show -->
      {episodeOverrides.length === 0 ? (
        <div class="flex flex-col items-center justify-center py-16 border border-zinc-800 bg-zinc-950/20 rounded-3xl backdrop-blur-md">
          <div class="w-16 h-16 rounded-full bg-zinc-900 border border-zinc-800 flex items-center justify-center text-zinc-500 mb-4 shadow-inner">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><line x1="3" x2="21" y1="9" y2="9"/><line x1="9" x2="9" y1="21" y2="9"/></svg>
          </div>
          <h3 class="text-zinc-200 font-semibold mb-1">No Episode Remaps</h3>
          <p class="text-zinc-500 text-xs max-w-sm text-center">No individual episodes have been remapped.</p>
        </div>
      ) : (
        <div class="space-y-4">
          {groupedShowsList.map((showGroup: any) => (
            <div class="show-episodes-panel border border-zinc-800 rounded-3xl bg-zinc-900/20 overflow-hidden backdrop-blur-md transition-all duration-300" data-show-uri={showGroup.show_uri_id ?? showGroup.show_key}>
              
              <!-- Show Panel Header (Collapsible Toggle) -->
              <div 
                class="flex items-center justify-between p-5 bg-zinc-900/60 border-b border-zinc-850 cursor-pointer select-none hover:bg-zinc-800/40 transition-colors"
                data-show-toggle={showGroup.show_key}
              >
                <div class="flex items-center gap-4 min-w-0">
                  <!-- Collapsible chevron icon -->
                  <svg 
                    class="w-5 h-5 text-zinc-400 transition-transform duration-300 transform" 
                    id={`chevron-${showGroup.show_key}`} 
                    xmlns="http://www.w3.org/2000/svg" 
                    width="24" 
                    height="24" 
                    viewBox="0 0 24 24" 
                    fill="none" 
                    stroke="currentColor" 
                    stroke-width="2.5" 
                    stroke-linecap="round" 
                    stroke-linejoin="round"
                  >
                    <path d="m9 18 6-6-6-6"/>
                  </svg>
                  
                  <div class="min-w-0">
                    <h3 class="text-base font-bold text-zinc-100 truncate hover:text-indigo-400 transition-colors">
                      {showGroup.show_title}
                    </h3>
                    <span class="text-[10px] text-zinc-500 font-bold bg-zinc-950 px-2 py-0.5 rounded border border-zinc-850 mt-1 inline-block">{showGroup.show_uri_id ?? ("TMDB ID: " + showGroup.show_tmdb_id)}</span>
                  </div>
                </div>

                <div class="flex items-center gap-3 shrink-0">
                  <span class="text-xs bg-zinc-805 text-zinc-400 border border-zinc-750 px-2.5 py-0.5 rounded-full font-extrabold">
                    {showGroup.overrides.length} remaps
                  </span>
                </div>
              </div>

              <!-- Collapsible Content Panel (Hidden by default) -->
              <div 
                id={`panel-${showGroup.show_key}`} 
                class="hidden divide-y divide-zinc-850 bg-zinc-950/20"
              >
                
                <!-- Bulk Actions Toolbar -->
                <div class="px-5 py-3 bg-zinc-900/20 flex flex-col sm:flex-row sm:items-center justify-between gap-3 border-b border-zinc-850">
                  <div class="flex items-center gap-2">
                    <input 
                      type="checkbox" 
                      class="bulk-show-select-all rounded border-zinc-700 bg-zinc-950 text-indigo-600 focus:ring-indigo-500 cursor-pointer w-4 h-4" 
                      data-show-id={showGroup.show_key} 
                    />
                    <span class="text-xs font-bold text-zinc-400">Select All in Show</span>
                  </div>
                  
                  <button 
                    class="bulk-delete-btn flex items-center justify-center gap-1.5 px-3 py-1.5 bg-rose-950/20 hover:bg-rose-900/30 border border-rose-900/40 text-rose-400 text-xs font-bold rounded-xl transition-all cursor-pointer shadow-sm active:scale-95 disabled:opacity-40 disabled:cursor-not-allowed"
                    data-show-id={showGroup.show_key}
                    disabled
                  >
                    <svg class="w-3.5 h-3.5" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2M10 11v6M14 11v6"/></svg>
                    Delete Selected (<span class="bulk-selected-count">0</span>)
                  </button>
                </div>

                <!-- Season Groups -->
                <div class="divide-y divide-zinc-850/60">
                  {Object.entries(showGroup.seasons)
                    .sort(([a], [b]) => Number(a) - Number(b))
                    .map(([seasonNum, overrides]: [string, any]) => {
                      // Sort episodes in season group by episode number ascending
                      const sortedOverrides = [...overrides].sort((a: any, b: any) => a.source_episode_number - b.source_episode_number);
                      
                      return (
                        <div class="season-group-container bg-zinc-950/10" data-season-num={seasonNum} data-show-id={showGroup.show_key}>
                          <!-- Season Sub-Header -->
                          <div class="px-5 py-2.5 bg-zinc-900/15 flex items-center justify-between border-b border-zinc-850/40">
                            <div class="flex items-center gap-2.5">
                              <input
                                type="checkbox"
                                class="bulk-season-select-all rounded border-zinc-700 bg-zinc-950 text-indigo-600 focus:ring-indigo-500 cursor-pointer w-3.5 h-3.5 shrink-0"
                                data-show-id={showGroup.show_key}
                                data-season-num={seasonNum}
                                title={`Select all in Season ${seasonNum}`}
                              />
                              <span class="text-xs font-black uppercase text-indigo-400 tracking-wider">
                                Season {seasonNum}
                              </span>
                            </div>
                            <span class="text-[10px] bg-zinc-850 text-zinc-400 px-2 py-0.5 rounded-full font-bold">
                              {overrides.length} remaps
                            </span>
                          </div>

                          <!-- Individual Overrides in Season — compact chip grid -->
                          <div class="p-3 grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-1.5">
                            {sortedOverrides.map((override: any) => (
                              <div 
                                class="override-row-container group flex items-center gap-2 px-3 py-2 rounded-xl bg-zinc-900/30 border border-zinc-800/60 hover:border-zinc-700/80 hover:bg-zinc-800/30 transition-all duration-150"
                                data-source-season={override.source_season_number}
                                data-source-episode={override.source_episode_number}
                                data-target-season={override.target_season_number}
                                data-target-episode={override.target_episode_number}
                                data-source-title={(override.source_episode_title || "").toLowerCase()}
                                data-target-title={(override.target_episode_title || "").toLowerCase()}
                                data-show-title={showGroup.show_title.toLowerCase()}
                                data-show-uri={showGroup.show_uri_id ?? showGroup.show_key}
                              >
                                <!-- Checkbox -->
                                <input 
                                  type="checkbox" 
                                  class="override-row-checkbox rounded border-zinc-700 bg-zinc-950 text-indigo-600 focus:ring-indigo-500 cursor-pointer w-3.5 h-3.5 shrink-0" 
                                  data-override-id={override.id}
                                  data-show-id={showGroup.show_key}
                                />

                                <!-- Mapping chips -->
                                <div class="flex items-center gap-1.5 flex-1 min-w-0">
                                  <span class="font-mono text-[11px] font-bold text-zinc-300 bg-zinc-800 border border-zinc-700/70 px-1.5 py-0.5 rounded shrink-0">
                                    S{override.source_season_number.toString().padStart(2, '0')}E{override.source_episode_number.toString().padStart(2, '0')}
                                  </span>
                                  <svg class="w-3 h-3 text-zinc-600 shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                                  <span class="font-mono text-[11px] font-bold text-indigo-400 bg-indigo-500/10 border border-indigo-500/20 px-1.5 py-0.5 rounded shrink-0">
                                    S{override.target_season_number.toString().padStart(2, '0')}E{override.target_episode_number.toString().padStart(2, '0')}
                                  </span>
                                  {override.source_show_uri_id !== override.target_show_uri_id && (
                                    <span class="text-[9px] bg-amber-500/10 text-amber-400 border border-amber-500/20 px-1.5 py-0.5 rounded font-black truncate" title={override.target_show_title}>
                                      {override.target_show_title}
                                    </span>
                                  )}
                                </div>

                                <!-- Actions (visible on hover) -->
                                <div class="flex items-center gap-1 shrink-0 opacity-0 group-hover:opacity-100 transition-opacity duration-150">
                                  <button class="edit-ep-btn p-1 rounded-lg text-zinc-500 hover:text-blue-400 hover:bg-zinc-800 transition-all cursor-pointer" data-src-uri={override.source_show_uri_id} data-src-season={override.source_season_number} data-src-ep={override.source_episode_number} data-tgt-uri={override.target_show_uri_id} data-tgt-season={override.target_season_number} data-tgt-ep={override.target_episode_number} title="Edit">
                                    <svg class="w-3 h-3" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/><path d="m15 5 4 4"/></svg>
                                  </button>
                                  <button data-ep-apply-id={override.id} class="p-1 rounded-lg text-zinc-500 hover:text-emerald-400 hover:bg-zinc-800 transition-all cursor-pointer" title="Re-apply">
                                    <svg class="w-3 h-3" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21.5 2v6h-6M21.34 15.57a10 10 0 1 1-.57-8.38l5.67-5.67"/></svg>
                                  </button>
                                  <button data-ep-delete-id={override.id} class="p-1 rounded-lg text-zinc-500 hover:text-rose-400 hover:bg-zinc-800 transition-all cursor-pointer" title="Delete">
                                    <svg class="w-3 h-3" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2M10 11v6M14 11v6"/></svg>
                                  </button>
                                </div>
                              </div>
                            ))}
                          </div>
                        </div>
                      );
                    })}
                </div>

              </div>

            </div>
          ))}
          <!-- Episode search empty state -->
          <div id="no-episode-results" class="hidden flex flex-col items-center justify-center py-16 border border-zinc-800 bg-zinc-950/20 rounded-3xl backdrop-blur-md">
            <div class="w-12 h-12 rounded-full bg-zinc-900 border border-zinc-800 flex items-center justify-center text-zinc-500 mb-3 shadow-inner">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
            </div>
            <h3 class="text-zinc-300 font-semibold mb-1 text-sm">No Matching Episode Remaps</h3>
            <p class="text-zinc-500 text-xs text-center">Try adjusting your keywords or search query.</p>
          </div>
        </div>
    )}
    </div>

    <!-- Custom Renames Section -->
    <div class="mt-16">
      <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-6">
        <h2 class="section-headline mb-1 flex items-center gap-2">
          Global Custom Renames
          <span class="text-xs bg-zinc-800 text-zinc-400 font-bold px-2 py-0.5 rounded-full">{customTitles.length}</span>
        </h2>
        <div class="flex items-center gap-3 w-full sm:w-auto">
          {customTitles.length > 0 && (
            <input 
              type="text" 
              id="rename-search" 
              placeholder="Search custom renames..." 
              class="px-4 py-2 bg-zinc-950/40 border border-zinc-800 focus:border-indigo-500 rounded-xl text-xs text-zinc-200 focus:outline-none focus:ring-1 focus:ring-indigo-500 w-full sm:w-64 placeholder-zinc-600 transition-all"
            />
          )}
          <button 
            id="add-rename-btn" 
            class="px-4 py-2 bg-indigo-600 hover:bg-indigo-500 active:scale-95 text-white font-bold rounded-xl text-xs flex items-center gap-1.5 shadow-lg shadow-indigo-600/10 cursor-pointer transition-all"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5v14"/></svg>
            Add Rename
          </button>
        </div>
      </div>

      {customTitles.length === 0 ? (
        <div class="flex flex-col items-center justify-center py-16 border border-zinc-800 bg-zinc-950/20 rounded-3xl backdrop-blur-md">
          <div class="w-16 h-16 rounded-full bg-zinc-900 border border-zinc-800 flex items-center justify-center text-zinc-500 mb-4 shadow-inner">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
          </div>
          <h3 class="text-zinc-200 font-semibold mb-1">No Custom Renames</h3>
          <p class="text-zinc-500 text-xs max-w-sm text-center">You haven't renamed any shows, seasons, or episodes.</p>
        </div>
      ) : (
        <div class="space-y-4">
          {groupedCustomTitlesList.map((showGroup: any) => (
            <div class="show-renames-panel border border-zinc-800 rounded-3xl bg-zinc-900/20 overflow-hidden backdrop-blur-md transition-all duration-300" data-rename-uri={showGroup.show_uri_id ?? showGroup.show_key}>
              
              <!-- Show Panel Header (Collapsible Toggle) -->
              <div 
                class="flex items-center justify-between p-5 bg-zinc-900/60 border-b border-zinc-850 cursor-pointer select-none hover:bg-zinc-800/40 transition-colors"
                data-rename-toggle={showGroup.show_key}
              >
                <div class="flex items-center gap-4 min-w-0">
                  <!-- Collapsible chevron icon -->
                  <svg 
                    class="w-5 h-5 text-zinc-400 transition-transform duration-300 transform" 
                    id={`rename-chevron-${showGroup.show_key}`} 
                    xmlns="http://www.w3.org/2000/svg" 
                    width="24" 
                    height="24" 
                    viewBox="0 0 24 24" 
                    fill="none" 
                    stroke="currentColor" 
                    stroke-width="2.5" 
                    stroke-linecap="round" 
                    stroke-linejoin="round"
                  >
                    <path d="m9 18 6-6-6-6"/>
                  </svg>
                  
                  <!-- Show Poster Image -->
                  {(showGroup.show_uri_id || showGroup.show_tmdb_id) && (
                    <div class="w-10 h-14 rounded-lg overflow-hidden bg-zinc-950 border border-zinc-800 shrink-0 shadow-sm">
                      {showGroup.show_poster_path ? (
                        <img src={showGroup.show_poster_path} alt="" class="w-full h-full object-cover" loading="lazy" />
                      ) : (
                        <div class="w-full h-full flex items-center justify-center text-[8px] text-zinc-600 font-bold bg-zinc-900">NO ART</div>
                      )}
                    </div>
                  )}

                  <div class="min-w-0">
                    <h3 class="text-base font-bold text-zinc-100 truncate hover:text-indigo-400 transition-colors">
                      {showGroup.show_title}
                    </h3>
                    {(showGroup.show_uri_id || showGroup.show_tmdb_id) && (
                      <span class="text-[10px] text-zinc-500 font-bold bg-zinc-950 px-2 py-0.5 rounded border border-zinc-850 mt-1 inline-block">{showGroup.show_uri_id ?? ("TMDB ID: " + showGroup.show_tmdb_id)}</span>
