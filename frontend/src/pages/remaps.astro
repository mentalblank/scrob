<script>
  document.addEventListener("DOMContentLoaded", () => {
    const appData = document.getElementById("app-data");
    const token = appData?.dataset.token;
    if (!token) return;
    // Modal Control Elements
    const remapModal = document.getElementById("remap-modal")!;
    const addRemapBtn = document.getElementById("add-remap-btn")!;
    const closeModalBtn = document.getElementById("close-modal-btn")!;
    const cancelModalBtn = document.getElementById("cancel-modal-btn")!;
    const saveRemapBtn = document.getElementById("save-remap-btn") as HTMLButtonElement;

    // Wizard Step 1 Elements (Source)
    const sourceShowSearch = document.getElementById("source-show-search") as HTMLInputElement;
    const sourceShowSearchBtn = document.getElementById("source-show-search-btn")!;
    const sourceShowResults = document.getElementById("source-show-results")!;
    const sourceSelectedShowCard = document.getElementById("source-selected-show-card")!;
    const sourceSelectedShowPoster = document.getElementById("source-selected-show-poster") as HTMLImageElement;
    const sourceSelectedShowTitle = document.getElementById("source-selected-show-title")!;
    const sourceSelectedShowMeta = document.getElementById("source-selected-show-meta")!;
    const sourceChangeShowBtn = document.getElementById("source-change-show-btn")!;
    const sourceManualToggle = document.getElementById("source-manual-toggle")!;
    const sourceShowManualBtn = document.getElementById("source-show-manual-btn")!;
    const sourceManualGroup = document.getElementById("source-manual-group")!;
    const sourceShowTmdbInput = document.getElementById("source-show-tmdb-input") as HTMLInputElement;
    const sourceSeasonInput = document.getElementById("source-season-input") as HTMLInputElement;
    const sourceShowLookupBtn = document.getElementById("source-show-lookup-btn")!;
    const sourceSeasonSelectGroup = document.getElementById("source-season-select-group")!;
    const sourceSeasonButtons = document.getElementById("source-season-buttons")!;

    const sourceManualPreview = document.getElementById("source-manual-preview")!;
    const sourceManualPoster = document.getElementById("source-manual-poster") as HTMLImageElement;
    const sourceManualNoPoster = document.getElementById("source-manual-no-poster")!;
    const sourceManualTitle = document.getElementById("source-manual-title")!;
    const sourceManualMeta = document.getElementById("source-manual-meta")!;

    // Wizard Step 2 Elements (Target)
    const targetManualGroup = document.getElementById("target-manual-group")!;
    const targetShowTmdbInput = document.getElementById("target-show-tmdb-input") as HTMLInputElement;
    const targetSeasonInput = document.getElementById("target-season-input") as HTMLInputElement;
    const targetShowLookupBtn = document.getElementById("target-show-lookup-btn")!;
    const targetManualPreview = document.getElementById("target-manual-preview")!;
    const targetManualPoster = document.getElementById("target-manual-poster") as HTMLImageElement;
    const targetManualNoPoster = document.getElementById("target-manual-no-poster")!;
    const targetManualTitle = document.getElementById("target-manual-title")!;
    const targetManualMeta = document.getElementById("target-manual-meta")!;

    // State Variables
    let localShowsList: any[] = [];
    let localMoviesList: any[] = [];
    let remapSelectedSourceShow: any = null;
    let remapSelectedSourceSeason: number | null = null;

    // Open Modal Action
    addRemapBtn.addEventListener("click", () => {
      resetModalState();
      remapModal.classList.remove("opacity-0", "pointer-events-none");
      fetchLocalShows();
    });

    // Close Modal Action
    const closeModal = () => {
      remapModal.classList.add("opacity-0", "pointer-events-none");
    };
    closeModalBtn.addEventListener("click", closeModal);
    cancelModalBtn.addEventListener("click", closeModal);

    // Fetch shows in user's collection
    async function fetchLocalShows() {
      if (localShowsList && localShowsList.length > 0) {
        return;
      }
      try {
        const res = await fetch("/api/proxy/sync/source-shows", {
          headers: { "Authorization": `Bearer ${token}` }
        });
        if (res.ok) {
          const data = await res.json();
          localShowsList = Array.isArray(data) ? data : data.results || [];
        }
      } catch (err) {
        console.error("Error loading local shows", err);
      }
    }

    // Fetch movies in user's collection
    async function fetchLocalMovies() {
      if (localMoviesList && localMoviesList.length > 0) {
        return;
      }
      try {
        const res = await fetch("/api/proxy/sync/source-movies", {
          headers: { "Authorization": `Bearer ${token}` }
        });
        if (res.ok) {
          const data = await res.json();
          localMoviesList = Array.isArray(data) ? data : data.results || [];
        }
      } catch (err) {
        console.error("Error loading local movies", err);
      }
    }

    // Season Remap Search
    const performSourceShowSearch = () => {
      const q = sourceShowSearch.value.trim().toLowerCase();
      if (!q) {
        renderSourceShowResults(localShowsList);
        return;
      }
      const filtered = localShowsList.filter(show => 
        show.title.toLowerCase().includes(q) || 
        show.tmdb_id?.toString().includes(q)
      );
      renderSourceShowResults(filtered);
    };

    sourceShowSearchBtn.addEventListener("click", performSourceShowSearch);
    sourceShowSearch.addEventListener("input", performSourceShowSearch);

    function renderSourceShowResults(results: any[]) {
      sourceShowResults.innerHTML = "";
      if (results.length === 0) {
        sourceShowResults.innerHTML = '<div class="col-span-full text-center text-xs text-zinc-500 py-4">No matching local shows found.</div>';
        sourceShowResults.classList.remove("hidden");
        return;
      }

      results.forEach(show => {
        const card = document.createElement("div");
        card.className = "flex items-center gap-3 p-2 bg-zinc-950/40 border border-zinc-800 rounded-xl hover:border-zinc-700 cursor-pointer transition text-left group";
        
        let posterHtml = `<div class="w-8 h-12 rounded bg-zinc-900 flex items-center justify-center text-[7px] text-zinc-750 font-bold shrink-0">NO ART</div>`;
        if (show.poster_path) {
          posterHtml = `<img src="${show.poster_path}" class="w-8 h-12 rounded object-cover shrink-0" />`;
        }

        const year = show.first_air_date ? new Date(show.first_air_date).getFullYear() : "N/A";
        const idLabel = (show.uri_id?.startsWith('tvdb:') || (show.tvdb_id && !show.tmdb_id)) ? `TVDB: ${show.tvdb_id ?? show.uri_id?.split(':')[2]}` : `TMDB: ${show.tmdb_id}`;
        
        card.innerHTML = `
          ${posterHtml}
          <div class="min-w-0">
            <h4 class="text-zinc-200 font-bold truncate text-xs" title="${show.title}">${show.title}</h4>
            <span class="text-[9px] text-zinc-500">${year} • ${idLabel}</span>
          </div>
        `;

        card.addEventListener("click", () => selectSourceShow(show));
        sourceShowResults.appendChild(card);
      });
      sourceShowResults.classList.remove("hidden");
    }

    function selectSourceShow(show: any) {
      remapSelectedSourceShow = show;
      remapSelectedSourceSeason = null;

      sourceSelectedShowTitle.textContent = show.title;
      const year = show.first_air_date ? new Date(show.first_air_date).getFullYear() : "N/A";
      const idLabel = (show.uri_id?.startsWith('tvdb:') || (show.tvdb_id && !show.tmdb_id)) ? `TVDB ID: ${show.tvdb_id ?? show.uri_id?.split(':')[2]}` : `TMDB ID: ${show.tmdb_id}`;
      sourceSelectedShowMeta.textContent = `${year} • ${idLabel}`;
      if (show.poster_path) {
        sourceSelectedShowPoster.src = show.poster_path;
        sourceSelectedShowPoster.classList.remove("hidden");
      } else {
        sourceSelectedShowPoster.classList.add("hidden");
      }

      sourceShowSearch.parentElement!.classList.add("hidden");
      sourceShowResults.classList.add("hidden");
      sourceSelectedShowCard.classList.remove("hidden");
      sourceManualToggle.classList.add("hidden");
      sourceManualGroup.classList.add("hidden");
      
      sourceSeasonSelectGroup.classList.remove("hidden");
      renderSourceSeasonButtons(show.seasons_meta || []);
      
      sourceShowTmdbInput.value = show.uri_id ?? (show.tvdb_id ? `tvdb:s:${show.tvdb_id}` : `tmdb:s:${show.tmdb_id}`);

      validateForm();
    }

    sourceChangeShowBtn.addEventListener("click", () => {
      remapSelectedSourceShow = null;
      remapSelectedSourceSeason = null;

      sourceSelectedShowCard.classList.add("hidden");
      sourceShowSearch.parentElement!.classList.remove("hidden");
      sourceShowResults.classList.remove("hidden");
      sourceManualToggle.classList.remove("hidden");
      sourceSeasonSelectGroup.classList.add("hidden");
      
      sourceShowTmdbInput.value = "";
      sourceSeasonInput.value = "";
      
      validateForm();
    });

    sourceShowManualBtn.addEventListener("click", () => {
      sourceShowSearch.parentElement!.classList.add("hidden");
      sourceShowResults.classList.add("hidden");
      sourceManualToggle.classList.add("hidden");
      sourceManualGroup.classList.remove("hidden");
    });

    function renderSourceSeasonButtons(seasons: any[]) {
      sourceSeasonButtons.innerHTML = "";
      if (seasons.length === 0) {
        sourceSeasonButtons.innerHTML = '<span class="text-xs text-zinc-500">No seasons found.</span>';
        return;
      }

      seasons.forEach(season => {
        const btn = document.createElement("button");
        btn.type = "button";
        btn.className = "px-3 py-1.5 border border-zinc-800 bg-zinc-900/40 text-zinc-300 font-bold text-xs rounded-xl cursor-pointer transition active:scale-95";
        btn.textContent = season.season_number === 0 ? "Specials" : `Season ${season.season_number}`;
        
        btn.addEventListener("click", () => {
          sourceSeasonButtons.querySelectorAll("button").forEach(b => {
            b.className = "px-3 py-1.5 border border-zinc-800 bg-zinc-900/40 text-zinc-300 font-bold text-xs rounded-xl cursor-pointer transition active:scale-95";
          });
          btn.className = "px-3 py-1.5 border border-indigo-500/40 bg-indigo-600/10 text-indigo-300 font-bold text-xs rounded-xl cursor-pointer transition shadow-md";
          remapSelectedSourceSeason = season.season_number;
          sourceSeasonInput.value = season.season_number.toString();
          validateForm();
        });

        sourceSeasonButtons.appendChild(btn);
      });
    }

    sourceShowTmdbInput.addEventListener("input", validateForm);
    sourceSeasonInput.addEventListener("input", validateForm);
    targetShowTmdbInput.addEventListener("input", validateForm);
    targetSeasonInput.addEventListener("input", validateForm);

    // Manual Source Show Lookup
    sourceShowLookupBtn.addEventListener("click", async () => {
      const type = (document.getElementById("source-show-id-type") as HTMLSelectElement).value;
      const rawVal = sourceShowTmdbInput.value.trim();
      if (!rawVal) return;

      const uriForLookup = rawVal.includes(":") ? rawVal : `${type}:s:${rawVal}`;

      sourceShowLookupBtn.textContent = "...";
      try {
        const res = await fetch(`/api/proxy/sync/tmdb-show-preview/${uriForLookup}`, {
          headers: { "Authorization": `Bearer ${token}` }
        });
        if (res.ok) {
          const data = await res.json();
          sourceManualTitle.textContent = data.title;
          const year = data.first_air_date ? new Date(data.first_air_date).getFullYear() : 'N/A';
          sourceManualMeta.textContent = `${year} • ${(data.uri_id?.startsWith('tvdb:') || data.tvdb_id && !data.tmdb_id) ? 'TVDB ID: ' + data.tvdb_id : 'TMDB ID: ' + data.tmdb_id}`;
          
          if (data.poster_path) {
            sourceManualPoster.src = data.poster_path;
            sourceManualPoster.classList.remove("hidden");
            sourceManualNoPoster.classList.add("hidden");
          } else {
            sourceManualPoster.classList.add("hidden");
            sourceManualNoPoster.classList.remove("hidden");
          }
          sourceManualPreview.classList.remove("hidden");
        } else {
          window.showToast?.("Show not found on TMDB/TVDB", "error");
          sourceManualPreview.classList.add("hidden");
        }
      } catch (err) {
        window.showToast?.("Error fetching show", "error");
        sourceManualPreview.classList.add("hidden");
      } finally {
        sourceShowLookupBtn.textContent = "Lookup";
      }
    });

    // Manual Target Show Lookup
    targetShowLookupBtn.addEventListener("click", async () => {
      const type = (document.getElementById("target-show-id-type") as HTMLSelectElement).value;
      const rawVal = targetShowTmdbInput.value.trim();
      if (!rawVal) return;

      const uriForLookupTgt = rawVal.includes(":") ? rawVal : `${type}:s:${rawVal}`;

      targetShowLookupBtn.textContent = "...";
      try {
        const res = await fetch(`/api/proxy/sync/tmdb-show-preview/${uriForLookupTgt}`, {
          headers: { "Authorization": `Bearer ${token}` }
        });
        if (res.ok) {
          const data = await res.json();
          targetManualTitle.textContent = data.title;
          const year = data.first_air_date ? new Date(data.first_air_date).getFullYear() : 'N/A';
          targetManualMeta.textContent = `${year} • ${(data.uri_id?.startsWith('tvdb:') || data.tvdb_id && !data.tmdb_id) ? 'TVDB ID: ' + data.tvdb_id : 'TMDB ID: ' + data.tmdb_id}`;
          
          if (data.poster_path) {
            targetManualPoster.src = data.poster_path;
            targetManualPoster.classList.remove("hidden");
            targetManualNoPoster.classList.add("hidden");
          } else {
            targetManualPoster.classList.add("hidden");
            targetManualNoPoster.classList.remove("hidden");
          }
          targetManualPreview.classList.remove("hidden");
        } else {
          window.showToast?.("Show not found on TMDB/TVDB", "error");
          targetManualPreview.classList.add("hidden");
        }
      } catch (err) {
        window.showToast?.("Error fetching show", "error");
        targetManualPreview.classList.add("hidden");
      } finally {
        targetShowLookupBtn.textContent = "Lookup";
      }
    });

    function validateForm() {
      const isSourceValid = !!sourceShowTmdbInput.value && !!sourceSeasonInput.value;
      const isTargetValid = !!targetShowTmdbInput.value && !!targetSeasonInput.value;
      saveRemapBtn.disabled = !(isSourceValid && isTargetValid);
    }

    function resetModalState() {
      const srcTypeSelect = document.getElementById("source-show-id-type") as HTMLSelectElement;
      const tgtTypeSelect = document.getElementById("target-show-id-type") as HTMLSelectElement;
      if (srcTypeSelect) srcTypeSelect.value = "tmdb";
      if (tgtTypeSelect) tgtTypeSelect.value = "tmdb";
      
      remapSelectedSourceShow = null;
      remapSelectedSourceSeason = null;
      sourceShowSearch.value = "";
      sourceShowSearch.parentElement!.classList.remove("hidden");
      sourceShowResults.innerHTML = "";
      sourceShowResults.classList.add("hidden");
      sourceSelectedShowCard.classList.add("hidden");
      sourceManualToggle.classList.remove("hidden");
      sourceManualGroup.classList.add("hidden");
      sourceSeasonSelectGroup.classList.add("hidden");
      sourceSeasonButtons.innerHTML = "";

      sourceShowTmdbInput.value = "";
      sourceSeasonInput.value = "";
      sourceManualPreview.classList.add("hidden");

      targetShowTmdbInput.value = "";
      targetSeasonInput.value = "";
      targetManualPreview.classList.add("hidden");

      saveRemapBtn.disabled = true;
    }

    // Save and Apply Remap
    saveRemapBtn.addEventListener("click", async () => {
      const srcType = (document.getElementById("source-show-id-type") as HTMLSelectElement).value;
      const tgtType = (document.getElementById("target-show-id-type") as HTMLSelectElement).value;

      const srcRaw = sourceShowTmdbInput.value.trim();
      const tgtRaw = targetShowTmdbInput.value.trim();
      const sourceUri = srcRaw.includes(":") ? srcRaw : `${srcType}:s:${srcRaw}`;
      const targetUri = tgtRaw.includes(":") ? tgtRaw : `${tgtType}:s:${tgtRaw}`;

      const sourceSeasonNum = parseInt(sourceSeasonInput.value);
      const targetSeasonNum = parseInt(targetSeasonInput.value);

      saveRemapBtn.disabled = true;
      saveRemapBtn.textContent = "Saving...";

      try {
        const createRes = await fetch("/api/proxy/sync/season-overrides", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            "Authorization": `Bearer ${token}`
          },
          body: JSON.stringify({
            source_show_uri_id: sourceUri,
            source_season_number: sourceSeasonNum,
            target_show_uri_id: targetUri,
            target_season_number: targetSeasonNum
          })
        });

        if (!createRes.ok) {
          const detail = await createRes.json();
          window.showToast?.(detail.detail || "Failed to create Season Override", "error");
          saveRemapBtn.disabled = false;
          saveRemapBtn.textContent = "Save & Apply Remap";
          return;
        }

        const override = await createRes.json();
        saveRemapBtn.textContent = "Applying Override...";

        const applyRes = await fetch(`/api/proxy/sync/season-overrides/${override.id}/apply`, {
          method: "POST",
          headers: { "Authorization": `Bearer ${token}` }
        });

        if (applyRes.ok) {
          const result = await applyRes.json();
          window.showToast?.(`Remapped successfully! Remapped ${result.remapped} episode(s).`, "success");
          closeModal();
          setTimeout(() => window.location.reload(), 1000);
        } else {
          window.showToast?.("Remap saved, but failed to apply metadata shift.", "error");
          closeModal();
          setTimeout(() => window.location.reload(), 1000);
        }
      } catch (err) {
        window.showToast?.("Error saving custom season override", "error");
        saveRemapBtn.disabled = false;
        saveRemapBtn.textContent = "Save & Apply Remap";
      }
    });


    // Custom Rename Modal Elements
    const renameModal = document.getElementById("rename-modal")!;
    const addRenameBtn = document.getElementById("add-rename-btn")!;
    const closeRenameModalBtn = document.getElementById("close-rename-modal-btn")!;
    const cancelRenameModalBtn = document.getElementById("cancel-rename-modal-btn")!;
    const saveRenameBtn = document.getElementById("save-rename-btn") as HTMLButtonElement;

    const renameTypeMovie = document.getElementById("rename-type-movie")!;
    const renameTypeShow = document.getElementById("rename-type-show")!;
    const renameTypeSeason = document.getElementById("rename-type-season")!;
    const renameTypeEpisode = document.getElementById("rename-type-episode")!;
    const renameTypeSection = document.getElementById("rename-type-section")!;

    const renameShowSearch = document.getElementById("rename-show-search") as HTMLInputElement;
    const renameShowSearchBtn = document.getElementById("rename-show-search-btn")!;
    const renameShowResults = document.getElementById("rename-show-results")!;
    
    const renameSelectedShowCard = document.getElementById("rename-selected-show-card")!;
    const renameSelectedShowPoster = document.getElementById("rename-selected-show-poster") as HTMLImageElement;
    const renameSelectedShowTitle = document.getElementById("rename-selected-show-title")!;
    const renameSelectedShowYear = document.getElementById("rename-selected-show-year")!;
    const renameChangeShowBtn = document.getElementById("rename-change-show-btn")!;

    const renameSeasonSection = document.getElementById("rename-season-section")!;
    const renameSeasonButtons = document.getElementById("rename-season-buttons")!;

    const renameEpisodeSection = document.getElementById("rename-episode-section")!;
    const renameEpisodeContainer = document.getElementById("rename-episode-container")!;
    
    const renameCustomTitleInput = document.getElementById("rename-custom-title-input") as HTMLInputElement;

    // Manual Rename Elements
    const renameShowManualBtn = document.getElementById("rename-show-manual-btn")!;
    const renameManualFields = document.getElementById("rename-manual-fields")!;
    const renameManualMediaType = document.getElementById("rename-manual-media-type") as HTMLSelectElement;
    const renameManualIdType = document.getElementById("rename-manual-id-type") as HTMLSelectElement;
    const renameManualIdInput = document.getElementById("rename-manual-id-input") as HTMLInputElement;
    const renameManualSeasonGroup = document.getElementById("rename-manual-season-group")!;
    const renameManualSeasonInput = document.getElementById("rename-manual-season-input") as HTMLInputElement;
    const renameManualEpisodeGroup = document.getElementById("rename-manual-episode-group")!;
    const renameManualEpisodeInput = document.getElementById("rename-manual-episode-input") as HTMLInputElement;

    // Custom Rename State
    let renameType: "show" | "season" | "episode" | "movie" = "show";
    let renameSelectedShow: any = null;
    let renameSelectedSeason: number | null = null;
    let renameSelectedEpisode: any = null;
    let isManualRename = false;

    // Open Custom Rename Modal
    addRenameBtn.addEventListener("click", () => {
      resetRenameModal();
      renameModal.classList.remove("opacity-0", "pointer-events-none");
      fetchRenameLocalMedia();
    });

    // Close Custom Rename Modal
    const closeRenameModal = () => {
      renameModal.classList.add("opacity-0", "pointer-events-none");
    };
    closeRenameModalBtn.addEventListener("click", closeRenameModal);
    cancelRenameModalBtn.addEventListener("click", closeRenameModal);
    renameModal.addEventListener("click", (e) => {
      if (e.target === renameModal) closeRenameModal();
    });

    // Toggle Rename Type Tab Selection
    function selectRenameType(type: "show" | "season" | "episode" | "movie") {
      renameType = type;
      
      // Update Tab Styles
      [renameTypeMovie, renameTypeShow, renameTypeSeason, renameTypeEpisode].forEach(btn => {
        btn.className = "flex-1 px-4 py-2.5 rounded-xl border border-zinc-800 bg-zinc-900/40 text-zinc-400 font-bold text-xs transition cursor-pointer text-center";
      });

      const activeBtn = type === "movie" ? renameTypeMovie : type === "show" ? renameTypeShow : type === "season" ? renameTypeSeason : renameTypeEpisode;
      activeBtn.className = "flex-1 px-4 py-2.5 rounded-xl border border-indigo-500/30 bg-indigo-600/10 text-zinc-100 font-bold text-xs transition cursor-pointer text-center";

      if (isManualRename) {
        if (type === "show" || type === "movie") {
          renameManualSeasonGroup.classList.add("hidden");
        } else if (type === "season") {
          renameManualSeasonGroup.classList.remove("hidden");
          renameManualEpisodeGroup.classList.add("hidden");
        } else if (type === "episode") {
          renameManualSeasonGroup.classList.remove("hidden");
          renameManualEpisodeGroup.classList.remove("hidden");
        }
      } else {
        renameManualSeasonGroup.classList.add("hidden");
        renameManualEpisodeGroup.classList.add("hidden");

        // Show/Hide Sections
        if (type === "show" || type === "movie") {
          renameSeasonSection.classList.add("hidden");
          renameEpisodeSection.classList.add("hidden");
        } else if (type === "season") {
          renameSeasonSection.classList.remove("hidden");
          renameEpisodeSection.classList.add("hidden");
          if (renameSelectedShow) {
            renderRenameSeasonButtons(renameSelectedShow.seasons_meta || []);
          }
        } else if (type === "episode") {
          renameSeasonSection.classList.remove("hidden");
          renameEpisodeSection.classList.remove("hidden");
          if (renameSelectedShow) {
            renderRenameSeasonButtons(renameSelectedShow.seasons_meta || []);
          }
        }
      }

      validateRenameForm();
    }

    renameTypeMovie.addEventListener("click", () => selectRenameType("movie"));
    renameTypeShow.addEventListener("click", () => selectRenameType("show"));
    renameTypeSeason.addEventListener("click", () => selectRenameType("season"));
    renameTypeEpisode.addEventListener("click", () => selectRenameType("episode"));

    function fetchRenameLocalMedia() {
      fetchLocalShows();
      fetchLocalMovies();
    }

    const performRenameShowSearch = () => {
      const q = renameShowSearch.value.trim().toLowerCase();
      if (!q) {
        renderRenameShowResults([...localShowsList, ...localMoviesList]);
        return;
      }
      const filteredShows = localShowsList.filter(show => 
        show.title.toLowerCase().includes(q) || 
        (show.original_title && show.original_title.toLowerCase().includes(q)) || 
        show.tmdb_id?.toString().includes(q)
      );
      const filteredMovies = localMoviesList.filter(movie => 
        movie.title.toLowerCase().includes(q) || 
        (movie.tmdb_title && movie.tmdb_title.toLowerCase().includes(q)) || 
        movie.tmdb_id?.toString().includes(q)
      );
      renderRenameShowResults([...filteredShows, ...filteredMovies]);
    };

    renameShowSearchBtn.addEventListener("click", performRenameShowSearch);
    renameShowSearch.addEventListener("keydown", (e) => {
      if (e.key === "Enter") {
        e.preventDefault();
        performRenameShowSearch();
      }
    });

    function renderRenameShowResults(results: any[]) {
      renameShowResults.innerHTML = "";
      if (results.length === 0) {
        renameShowResults.innerHTML = '<div class="col-span-full text-center text-xs text-zinc-500 py-4">No matching local media found.</div>';
        renameShowResults.classList.remove("hidden");
        return;
      }

      results.forEach(media => {
        const isMovie = !media.first_air_date && (media.release_date || media.tmdb_title);
        const card = document.createElement("div");
        card.className = "flex items-center gap-3 p-2 bg-zinc-900 border border-zinc-800 rounded-xl hover:border-zinc-700 cursor-pointer transition text-left group";
        
        let posterHtml = `<div class="w-8 h-12 rounded bg-zinc-950 flex items-center justify-center text-[7px] text-zinc-750 font-bold shrink-0">NO ART</div>`;
        if (media.poster_path) {
          posterHtml = `<img src="${media.poster_path}" class="w-8 h-12 rounded object-cover shrink-0" />`;
        }

        const year = (media.first_air_date || media.release_date) ? new Date(media.first_air_date || media.release_date).getFullYear() : "N/A";
        const typeLabel = isMovie ? "MOVIE" : "SHOW";

        const idLabel = (media.uri_id?.startsWith('tvdb:') || (media.tvdb_id && !media.tmdb_id)) ? `TVDB: ${media.tvdb_id ?? media.uri_id?.split(':')[2]}` : `TMDB: ${media.tmdb_id}`;
        card.innerHTML = `
          ${posterHtml}
          <div class="min-w-0">
            <span class="text-[7px] font-black px-1.5 py-0.5 rounded ${isMovie ? 'bg-blue-900/30 text-blue-400' : 'bg-indigo-900/30 text-indigo-400'}">${typeLabel}</span>
            <h4 class="text-zinc-200 font-bold truncate text-xs mt-0.5" title="${media.title}">${media.title}</h4>
            <span class="text-[9px] text-zinc-500">${year} • ${idLabel}</span>
          </div>
        `;

        card.addEventListener("click", () => selectRenameShow(media));
        renameShowResults.appendChild(card);
      });
      renameShowResults.classList.remove("hidden");
    }

    function selectRenameShow(media: any) {
      renameSelectedShow = media;
      renameSelectedSeason = null;
      renameSelectedEpisode = null;
      
      const isMovie = !media.first_air_date && (media.release_date || media.tmdb_title);

      renameSelectedShowTitle.textContent = media.title;
      const year = (media.first_air_date || media.release_date) ? new Date(media.first_air_date || media.release_date).getFullYear() : "N/A";
      const idLabel = (media.uri_id?.startsWith('tvdb:') || (media.tvdb_id && !media.tmdb_id)) ? `TVDB ID: ${media.tvdb_id ?? media.uri_id?.split(':')[2]}` : `TMDB ID: ${media.tmdb_id}`;
      renameSelectedShowYear.textContent = `${year} • ${idLabel}`;
      if (media.poster_path) {
        renameSelectedShowPoster.src = media.poster_path;
        renameSelectedShowPoster.classList.remove("hidden");
      } else {
        renameSelectedShowPoster.classList.add("hidden");
      }

      renameShowSearch.classList.add("hidden");
      renameShowSearchBtn.classList.add("hidden");
      renameShowResults.classList.add("hidden");
      renameSelectedShowCard.classList.remove("hidden");
      renameTypeSection.classList.remove("hidden");

      if (isMovie) {
        renameTypeMovie.classList.remove("hidden");
        renameTypeShow.classList.add("hidden");
        renameTypeSeason.classList.add("hidden");
        renameTypeEpisode.classList.add("hidden");
        selectRenameType("movie");
      } else {
        renameTypeMovie.classList.add("hidden");
        renameTypeShow.classList.remove("hidden");
        renameTypeSeason.classList.remove("hidden");
        renameTypeEpisode.classList.remove("hidden");
        selectRenameType("show");
      }

      validateRenameForm();
    }

    renameChangeShowBtn.addEventListener("click", () => {
      renameSelectedShow = null;
      renameSelectedSeason = null;
      renameSelectedEpisode = null;

      renameSelectedShowCard.classList.add("hidden");
      renameShowSearch.classList.remove("hidden");
      renameShowSearchBtn.classList.remove("hidden");
      renameShowResults.classList.remove("hidden");
      renameTypeSection.classList.add("hidden");
      
      renameSeasonSection.classList.add("hidden");
      renameEpisodeSection.classList.add("hidden");

      renderRenameShowResults([...localShowsList, ...localMoviesList]);
      validateRenameForm();
    });

    function renderRenameSeasonButtons(seasons: any[]) {
      renameSeasonButtons.innerHTML = "";
      if (seasons.length === 0) {
        renameSeasonButtons.innerHTML = '<span class="text-xs text-zinc-500">No seasons found for this show.</span>';
        return;
      }

      seasons.forEach(season => {
        const label = season.season_number === 0 ? "Specials" : `Season ${season.season_number}`;
        const btn = document.createElement("button");
        btn.type = "button";
        btn.className = "px-3 py-1.5 border border-zinc-800 hover:border-zinc-700 bg-zinc-900/60 hover:bg-zinc-800 text-zinc-300 font-bold text-xs rounded-xl cursor-pointer transition active:scale-95";
        btn.textContent = `${label}`;
        
        btn.addEventListener("click", () => {
          renameSeasonButtons.querySelectorAll("button").forEach(b => {
            b.className = "px-3 py-1.5 border border-zinc-800 hover:border-zinc-700 bg-zinc-900/60 hover:bg-zinc-800 text-zinc-300 font-bold text-xs rounded-xl cursor-pointer transition active:scale-95";
          });
          btn.className = "px-3 py-1.5 border border-blue-800 bg-blue-950/40 text-blue-300 font-bold text-xs rounded-xl cursor-pointer transition shadow-md";
          renameSelectedSeason = season.season_number;
          
          if (renameType === "episode") {
            fetchRenameEpisodes(renameSelectedShow.uri_id ?? `tmdb:s:${renameSelectedShow.tmdb_id}`, season.season_number);
          }
          validateRenameForm();
        });

        renameSeasonButtons.appendChild(btn);
      });
    }

    async function fetchRenameEpisodes(showUri: string, seasonNumber: number) {
      renameEpisodeContainer.innerHTML = '<div class="text-xs text-zinc-500 py-4 text-center">Loading episodes...</div>';
      try {
        const res = await fetch(`/api/proxy/shows/${encodeURIComponent(showUri)}/season/${seasonNumber}`, {
          headers: { "Authorization": `Bearer ${token}` }
        });
        if (res.ok) {
          const data = await res.json();
          renderRenameEpisodes(data.episodes || []);
        } else {
          renameEpisodeContainer.innerHTML = '<div class="text-xs text-red-400 py-4 text-center">Failed to load episodes.</div>';
        }
      } catch (err) {
        renameEpisodeContainer.innerHTML = '<div class="text-xs text-red-400 py-4 text-center">Error loading episodes.</div>';
      }
    }

    function renderRenameEpisodes(episodes: any[]) {
      renameEpisodeContainer.innerHTML = "";
      const localEps = episodes.filter(ep => ep.id !== null);
      if (localEps.length === 0) {
        renameEpisodeContainer.innerHTML = '<div class="text-xs text-zinc-500 py-4 text-center">No collected episodes in library for this season.</div>';
        validateRenameForm();
        return;
      }

      localEps.forEach(ep => {
        const div = document.createElement("div");
        div.className = "flex items-center justify-between p-3 bg-zinc-900 border border-zinc-800 hover:border-zinc-700 rounded-xl cursor-pointer transition active:scale-[0.99]";
        
        let posterHtml = `<div class="w-12 h-8 rounded bg-zinc-950 flex items-center justify-center text-[8px] text-zinc-750 font-bold shrink-0">NO ART</div>`;
        if (ep.poster_path) {
          posterHtml = `<img src="${ep.poster_path}" class="w-12 h-8 rounded object-cover shrink-0 border border-zinc-800" />`;
        }

        div.innerHTML = `
          <div class="flex items-center gap-3 min-w-0">
            ${posterHtml}
            <div class="min-w-0">
              <span class="text-[9px] font-black uppercase text-indigo-400">Episode ${ep.episode_number}</span>
              <h4 class="text-zinc-200 font-bold text-xs truncate" title="${ep.title}">${ep.title}</h4>
            </div>
          </div>
        `;

        div.addEventListener("click", () => {
          renameEpisodeContainer.querySelectorAll("div").forEach(d => {
            d.className = "flex items-center justify-between p-3 bg-zinc-900 border border-zinc-800 hover:border-zinc-700 rounded-xl cursor-pointer transition active:scale-[0.99]";
          });
