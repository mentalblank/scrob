      if (isNaN(seasonNum)) {
        epSrcEpisodeSelect.innerHTML = '<option value="">-- Choose Season First --</option>';
        epSrcEpisodeSelect.disabled = true;
        return;
      }
      
      const seasonMeta = selectedEpShowObj.seasons_meta.find((s: any) => s.season_number === seasonNum);
      const epCount = seasonMeta ? seasonMeta.episode_count : 100;
      
      epSrcEpisodeSelect.innerHTML = '<option value="">-- Choose Episode --</option>';
      for (let i = 1; i <= epCount; i++) {
        const opt = document.createElement("option");
        opt.value = i.toString();
        opt.textContent = `Episode ${i}`;
        epSrcEpisodeSelect.appendChild(opt);
      }
      epSrcEpisodeSelect.disabled = false;
