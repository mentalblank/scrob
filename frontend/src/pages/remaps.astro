    // 2. Episode Remaps Search
    const episodeSearchInput = document.getElementById("episode-search");
    if (episodeSearchInput) {
      episodeSearchInput.addEventListener("input", (e) => {
        const query = (e.target as HTMLInputElement).value.toLowerCase().trim();
        const panels = document.querySelectorAll(".show-episodes-panel");
        let totalVisibleEpisodes = 0;

        // Parse query for patterns
        const sxeRegex = /s(\d+)\s*e(\d+)/i;
        const crossRegex = /(\d+)\s*x\s*(\d+)/i;
        const sRegex = /^s(\d+)$/i;
        const eRegex = /^e(\d+)$/i;

        const sxeMatch = query.match(sxeRegex);
        const crossMatch = query.match(crossRegex);
        const sMatch = query.match(sRegex);
        const eMatch = query.match(eRegex);
        const isNum = /^\d+$/.test(query);
        const queryNum = isNum ? parseInt(query, 10) : null;

        panels.forEach(panel => {
          const showTitleAttr = (panel.getAttribute("data-show-title") || "").toLowerCase();
          const showTmdbId = panel.getAttribute("data-show-tmdb") || "";
          
          const showHeader = panel.querySelector("[data-show-toggle]");
          const showTitle = showTitleAttr || showHeader?.querySelector("h3")?.textContent?.toLowerCase() || "";

          let showHasVisibleEpisodes = false;

          // Process season containers within this show panel
          const seasons = panel.querySelectorAll(".season-group-container");
          seasons.forEach(seasonContainer => {
            let seasonHasVisibleEpisodes = false;
            
            // Process individual episode rows within this season
            const rows = seasonContainer.querySelectorAll(".override-row-container");
            rows.forEach(row => {
              const srcSeason = parseInt(row.getAttribute("data-source-season") || "0", 10);
              const srcEpisode = parseInt(row.getAttribute("data-source-episode") || "0", 10);
              const tgtSeason = parseInt(row.getAttribute("data-target-season") || "0", 10);
              const tgtEpisode = parseInt(row.getAttribute("data-target-episode") || "0", 10);
              
              const srcTitle = (row.getAttribute("data-source-title") || "").toLowerCase();
              const tgtTitle = (row.getAttribute("data-target-title") || "").toLowerCase();

              const rowText = row.textContent?.toLowerCase() || "";

              let match = false;

              if (query === "") {
                match = true;
              } else if (sxeMatch) {
                // SxxExx format
                const qSeason = parseInt(sxeMatch[1], 10);
                const qEpisode = parseInt(sxeMatch[2], 10);
                match = (srcSeason === qSeason && srcEpisode === qEpisode) ||
                        (tgtSeason === qSeason && tgtEpisode === qEpisode);
              } else if (crossMatch) {
                // 1x02 format
                const qSeason = parseInt(crossMatch[1], 10);
                const qEpisode = parseInt(crossMatch[2], 10);
                match = (srcSeason === qSeason && srcEpisode === qEpisode) ||
                        (tgtSeason === qSeason && tgtEpisode === qEpisode);
              } else if (sMatch) {
                // Season only (S01)
                const qSeason = parseInt(sMatch[1], 10);
                match = (srcSeason === qSeason || tgtSeason === qSeason);
              } else if (eMatch) {
                // Episode only (E02)
                const qEpisode = parseInt(eMatch[1], 10);
                match = (srcEpisode === qEpisode || tgtEpisode === qEpisode);
              } else if (isNum && queryNum !== null) {
                // Lone number: check exact episode numbers, season numbers or TMDB show ID
                match = (srcEpisode === queryNum || tgtEpisode === queryNum || 
                         srcSeason === queryNum || tgtSeason === queryNum ||
                         showTmdbId === query);
              } else {
                // General text search on titles, overview, show title, etc.
                match = showTitle.includes(query) || 
                        showTmdbId.includes(query) || 
                        srcTitle.includes(query) || 
                        tgtTitle.includes(query) ||
                        rowText.includes(query);
              }
              
              if (match) {
                row.classList.remove("hidden");
                seasonHasVisibleEpisodes = true;
                showHasVisibleEpisodes = true;
                totalVisibleEpisodes++;
              } else {
                row.classList.add("hidden");
              }
            });

            // Hide/Show season container based on whether it has visible matching rows
            if (seasonHasVisibleEpisodes) {
              seasonContainer.classList.remove("hidden");
            } else {
              seasonContainer.classList.add("hidden");
            }
          });

          // Hide/Show entire show panel
          if (showHasVisibleEpisodes) {
            panel.classList.remove("hidden");
          } else {
            panel.classList.add("hidden");
          }

          const collapsePanel = panel.querySelector("[id^='panel-']");
          const chevron = panel.querySelector("[id^='chevron-']");
          
          if (query !== "") {
            if (showHasVisibleEpisodes) {
              collapsePanel?.classList.remove("hidden");
              chevron?.classList.add("rotate-90");
            }
          } else {
            collapsePanel?.classList.add("hidden");
            chevron?.classList.remove("rotate-90");
          }
        });

        const noResults = document.getElementById("no-episode-results");
        if (noResults) {
          if (totalVisibleEpisodes === 0) {
            noResults.classList.remove("hidden");
          } else {
            noResults.classList.add("hidden");
          }
        }
      });
    }

