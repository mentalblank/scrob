              />
              <button id="source-show-search-btn" class="px-4 bg-zinc-800 hover:bg-zinc-700 text-zinc-300 rounded-xl text-xs font-bold transition cursor-pointer">Search</button>
            </div>
            <div id="source-show-results" class="grid grid-cols-1 sm:grid-cols-2 gap-2 max-h-48 overflow-y-auto hidden no-scrollbar">
              <!-- Search results will appear here -->
