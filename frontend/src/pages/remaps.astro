---
import Base from "../layouts/Base.astro";

const { token } = Astro.locals;
if (!token) {
  return Astro.redirect("/login");
}

let seasonOverrides = [];
let episodeOverrides = [];
let groupedShowsList = [];
let customTitles = [];
let groupedCustomTitlesList = [];
let error = "";

try {
  const BACKEND_PORT = (import.meta.env.BACKEND_PORT as string | undefined) ?? "7331";
  
  const [resSeason, resEp, resTitles] = await Promise.all([
    fetch(`http://localhost:${BACKEND_PORT}/sync/season-overrides`, { headers: { 'Authorization': `Bearer ${token}` } }),
    fetch(`http://localhost:${BACKEND_PORT}/sync/episode-overrides`, { headers: { 'Authorization': `Bearer ${token}` } }),
    fetch(`http://localhost:${BACKEND_PORT}/sync/custom-titles`, { headers: { 'Authorization': `Bearer ${token}` } })
  ]);
  
  if (resSeason.ok) seasonOverrides = await resSeason.json();
  else error += "Failed to load season overrides. ";
  
  if (resEp.ok) episodeOverrides = (await resEp.json()).overrides || [];
  else error += "Failed to load episode overrides. ";
  
  // Group episode overrides by show ID
  const groupedEpisodeOverrides: Record<number, any> = {};
  episodeOverrides.forEach((override: any) => {
    const showId = override.source_show_tmdb_id;
    if (!groupedEpisodeOverrides[showId]) {
      groupedEpisodeOverrides[showId] = {
        show_title: override.source_show_title,
        show_tmdb_id: showId,
        show_poster_path: override.source_show_poster_path,
        overrides: [],
        seasons: {}
      };
    }
    groupedEpisodeOverrides[showId].overrides.push(override);
    
    const seasonNum = override.source_season_number;
    if (!groupedEpisodeOverrides[showId].seasons[seasonNum]) {
      groupedEpisodeOverrides[showId].seasons[seasonNum] = [];
    }
    groupedEpisodeOverrides[showId].seasons[seasonNum].push(override);
  });
  groupedShowsList = Object.values(groupedEpisodeOverrides);
  
  if (resTitles.ok) {
    customTitles = (await resTitles.json()).results || [];
    
    // Group custom titles by show ID
    const groupedCustomTitles: Record<number, any> = {};
    customTitles.forEach((item: any) => {
      const showId = item.show_tmdb_id || 0;
      if (!groupedCustomTitles[showId]) {
        groupedCustomTitles[showId] = {
          show_title: item.show_title || "Global / Unlinked",
          show_tmdb_id: showId,
          show_poster_path: item.show_poster_path || null,
          items: []
        };
      }
      groupedCustomTitles[showId].items.push(item);
    });
    // Sort show groups: shows with posters / names first, unlinked last
    groupedCustomTitlesList = Object.values(groupedCustomTitles).sort((a: any, b: any) => {
      if (a.show_tmdb_id === 0) return 1;
      if (b.show_tmdb_id === 0) return -1;
      return a.show_title.localeCompare(b.show_title);
    });
  } else {
    error += "Failed to load custom titles. ";
  }
  
} catch (e: any) {
  error = e.message;
}
---

<Base title="Metadata Overrides">
  <div id="app-data" data-token={token} class="hidden" aria-hidden="true"></div>

  <div class="max-w-6xl mx-auto px-4 py-8">
    <!-- Header with Back Button -->
    <div class="mb-8">
      <div class="flex items-center gap-4 mb-3">
        <a href="/settings" class="p-2 hover:bg-zinc-800 rounded-full text-zinc-400 hover:text-zinc-100 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        </a>
        <h1 class="text-3xl font-bold text-zinc-100 tracking-tight">Metadata Overrides</h1>
      </div>
      <p class="text-zinc-400 ml-12 text-sm sm:text-base">Point specific seasons, episodes, or titles of a TV show in your collection to different TMDB shows, seasons, or custom entries to resolve metadata mismatches and share progress states.</p>
    </div>

    {error && (
      <div class="p-4 bg-red-500/10 border border-red-500/20 rounded-xl text-red-400 mb-8">{error}</div>
    )}

    <!-- Toolbar -->
    <div class="flex flex-col lg:flex-row lg:items-center justify-between gap-4 mb-6">
      <h2 class="text-xl font-semibold text-zinc-200 flex items-center gap-2">
        Active Season Remaps
        <span class="text-xs bg-zinc-800 text-zinc-400 font-bold px-2 py-0.5 rounded-full">{seasonOverrides.length}</span>
      </h2>
      <div class="flex flex-col sm:flex-row items-stretch sm:items-center gap-3">
        {seasonOverrides.length > 0 && (
          <input 
            type="text" 
            id="season-search" 
            placeholder="Search season remaps..." 
            class="px-4 py-2 bg-zinc-950/40 border border-zinc-800 focus:border-indigo-500 rounded-xl text-xs text-zinc-200 focus:outline-none focus:ring-1 focus:ring-indigo-500 w-full sm:w-64 placeholder-zinc-600 transition-all"
          />
        )}
        <button id="add-remap-btn" class="flex items-center justify-center gap-2 px-5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white font-bold rounded-xl text-sm transition-all shadow-lg active:scale-95 cursor-pointer shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5v14"/></svg>
          Add Season Remap
        </button>
      </div>
    </div>

    <!-- Active Overrides List -->
    {seasonOverrides.length === 0 ? (
      <div class="flex flex-col items-center justify-center py-20 border border-zinc-800 bg-zinc-950/20 rounded-3xl backdrop-blur-md">
        <div class="w-16 h-16 rounded-full bg-zinc-900 border border-zinc-800 flex items-center justify-center text-zinc-500 mb-4 shadow-inner">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m21 16-4 4-4-4"/><path d="M17 20V4"/><path d="m3 8 4-4 4 4"/><path d="M7 4v16"/></svg>
        </div>
        <h3 class="text-zinc-200 font-semibold mb-1">No Season Remaps</h3>
        <p class="text-zinc-500 text-xs max-w-sm text-center">All your TV show seasons are currently using their standard synced TMDB mappings.</p>
      </div>
    ) : (
      <div>
        <div class="grid grid-cols-1 gap-4">
          {seasonOverrides.map((override) => (
            <div class="season-remap-card flex flex-col md:flex-row items-center justify-between p-5 bg-zinc-900/40 border border-zinc-800 rounded-2xl gap-6 hover:border-zinc-700/80 transition-all duration-300 hover:shadow-lg">
              
              <!-- Source Show -->
              <div class="flex items-center gap-4 w-full md:w-2/5 min-w-0">
                <div class="w-12 h-18 rounded-lg overflow-hidden bg-zinc-950 border border-zinc-800 shrink-0 shadow-md">
                  {override.source_show_poster_path ? (
                    <img src={override.source_show_poster_path} alt="" class="w-full h-full object-cover" loading="lazy" />
                  ) : (
                    <div class="w-full h-full flex items-center justify-center text-[10px] text-zinc-600 font-bold bg-zinc-900">NO ART</div>
                  )}
                </div>
                <div class="min-w-0 flex-1">
                  <span class="text-[9px] font-extrabold uppercase text-zinc-500 tracking-wider">Source Show</span>
                  <a href={`/show/${override.source_show_tmdb_id}`} class="block text-zinc-100 font-bold truncate text-sm mt-0.5 hover:text-blue-400 transition-colors" title={override.source_show_title}>{override.source_show_title}</a>
                  <div class="flex flex-wrap items-center gap-1.5 mt-1">
                    <span class="px-2 py-0.5 bg-zinc-800 border border-zinc-750 rounded-md text-[10px] font-bold text-zinc-300">Season {override.source_season_number}</span>
                    <span class="text-[9px] text-zinc-500 font-medium bg-zinc-950/60 px-1.5 py-0.5 rounded border border-zinc-850">TMDB: {override.source_show_tmdb_id}</span>
                  </div>
                </div>
              </div>

              <!-- Arrow Indicator -->
              <div class="flex flex-col items-center justify-center shrink-0">
                <div class="w-9 h-9 rounded-full bg-zinc-950 border border-zinc-800 flex items-center justify-center text-blue-500 shadow-md">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </div>
              </div>

              <!-- Target Show -->
              <div class="flex items-center gap-4 w-full md:w-2/5 min-w-0">
                <div class="w-12 h-18 rounded-lg overflow-hidden bg-zinc-950 border border-zinc-800 shrink-0 shadow-md">
                  {override.target_show_poster_path ? (
                    <img src={override.target_show_poster_path} alt="" class="w-full h-full object-cover" loading="lazy" />
                  ) : (
                    <div class="w-full h-full flex items-center justify-center text-[10px] text-zinc-600 font-bold bg-zinc-900">NO ART</div>
                  )}
                </div>
                <div class="min-w-0 flex-1">
                  <span class="text-[9px] font-extrabold uppercase text-blue-400 tracking-wider">Target TMDB Show</span>
                  <a href={`/show/${override.target_show_tmdb_id}`} class="block text-zinc-100 font-bold truncate text-sm mt-0.5 hover:text-blue-400 transition-colors" title={override.target_show_title}>{override.target_show_title}</a>
                  <div class="flex flex-wrap items-center gap-1.5 mt-1">
                    <span class="px-2 py-0.5 bg-blue-950/40 border border-blue-900/30 rounded-md text-[10px] font-bold text-blue-400">Season {override.target_season_number}</span>
                    <span class="text-[9px] text-zinc-500 font-medium bg-zinc-950/60 px-1.5 py-0.5 rounded border border-zinc-850">TMDB: {override.target_show_tmdb_id}</span>
                  </div>
                </div>
              </div>

              <!-- Actions -->
              <div class="flex items-center gap-2 w-full md:w-auto justify-end shrink-0 border-t border-zinc-800 md:border-t-0 pt-4 md:pt-0">
                <button class="edit-season-btn flex items-center gap-1.5 px-3 py-2 bg-zinc-800 hover:bg-zinc-750 active:scale-95 text-zinc-200 text-xs font-bold rounded-xl transition-all cursor-pointer shadow-sm" data-source-tmdb={override.source_show_tmdb_id} data-source-season={override.source_season_number} data-target-tmdb={override.target_show_tmdb_id} data-target-season={override.target_season_number} title="Edit override">
                  <svg class="w-3.5 h-3.5" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/><path d="m15 5 4 4"/></svg>
                  Edit
                </button>
                <button data-apply-id={override.id} class="flex items-center gap-1.5 px-3 py-2 bg-zinc-800 hover:bg-zinc-750 active:scale-95 text-zinc-200 text-xs font-bold rounded-xl transition-all cursor-pointer shadow-sm" title="Re-apply override & fetch TMDB metadata">
                  <svg class="w-3.5 h-3.5" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21.5 2v6h-6M21.34 15.57a10 10 0 1 1-.57-8.38l5.67-5.67"/></svg>
                  Apply
                </button>
                <button data-delete-id={override.id} class="flex items-center gap-1.5 px-3 py-2 bg-rose-950/20 hover:bg-rose-900/30 border border-rose-900/40 text-rose-300 text-xs font-bold rounded-xl transition-all cursor-pointer shadow-sm active:scale-95" title="Delete override">
                  <svg class="w-3.5 h-3.5" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2M10 11v6M14 11v6"/></svg>
                  Delete
                </button>
              </div>

            </div>
          ))}
        </div>
        <!-- Season search empty state -->
        <div id="no-season-results" class="hidden flex flex-col items-center justify-center py-16 border border-zinc-800 bg-zinc-950/20 rounded-3xl backdrop-blur-md">
          <div class="w-12 h-12 rounded-full bg-zinc-900 border border-zinc-800 flex items-center justify-center text-zinc-500 mb-3 shadow-inner">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
          </div>
          <h3 class="text-zinc-300 font-semibold mb-1 text-sm">No Matching Season Remaps</h3>
          <p class="text-zinc-500 text-xs text-center">Try adjusting your keywords or search query.</p>
        </div>
      </div>
    )}
    
    <!-- Episode Remaps Section -->
    <div class="mt-16 mb-8">
      <div class="flex flex-col lg:flex-row lg:items-center justify-between gap-4 mb-6">
        <h2 class="text-xl font-semibold text-zinc-200 flex items-center gap-2">
          Active Episode Remaps
          <span class="text-xs bg-zinc-800 text-zinc-400 font-bold px-2 py-0.5 rounded-full">{episodeOverrides.length}</span>
        </h2>
        <div class="flex flex-col sm:flex-row items-stretch sm:items-center gap-3">
          {episodeOverrides.length > 0 && (
            <input 
              type="text" 
              id="episode-search" 
              placeholder="Search episode remaps..." 
              class="px-4 py-2 bg-zinc-950/40 border border-zinc-800 focus:border-indigo-500 rounded-xl text-xs text-zinc-200 focus:outline-none focus:ring-1 focus:ring-indigo-500 w-full sm:w-64 placeholder-zinc-600 transition-all"
            />
          )}
          <button id="auto-remap-btn" class="flex items-center justify-center gap-2 px-5 py-2.5 bg-zinc-800 hover:bg-zinc-700 border border-zinc-700/80 text-zinc-200 hover:text-white font-bold rounded-xl text-sm transition-all shadow-md active:scale-95 cursor-pointer shrink-0">
            <svg class="w-4 h-4 text-indigo-400 animate-pulse" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m21 16-4 4-4-4"/><path d="M17 20V4"/><path d="m3 8 4-4 4 4"/><path d="M7 4v16"/></svg>
            TVDB ⇆ TMDB Auto-Remapper
          </button>
          <button id="add-ep-remap-btn" class="flex items-center justify-center gap-2 px-5 py-2.5 bg-indigo-600 hover:bg-indigo-500 text-white font-bold rounded-xl text-sm transition-all shadow-lg active:scale-95 cursor-pointer shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5v14"/></svg>
            Add Episode Remap
          </button>
        </div>
      </div>

      <!-- Episode Overrides List Grouped by Show -->
      {episodeOverrides.length === 0 ? (
        <div class="flex flex-col items-center justify-center py-16 border border-zinc-800 bg-zinc-950/20 rounded-3xl backdrop-blur-md">
          <div class="w-16 h-16 rounded-full bg-zinc-900 border border-zinc-800 flex items-center justify-center text-zinc-500 mb-4 shadow-inner">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><line x1="3" x2="21" y1="9" y2="9"/><line x1="9" x2="9" y1="21" y2="9"/></svg>
          </div>
          <h3 class="text-zinc-200 font-semibold mb-1">No Episode Remaps</h3>
          <p class="text-zinc-500 text-xs max-w-sm text-center">No individual episodes have been remapped.</p>
        </div>
      ) : (
        <div class="space-y-4">
          {groupedShowsList.map((showGroup: any) => (
            <div class="show-episodes-panel border border-zinc-800 rounded-3xl bg-zinc-900/20 overflow-hidden backdrop-blur-md transition-all duration-300" data-show-tmdb={showGroup.show_tmdb_id}>
              
              <!-- Show Panel Header (Collapsible Toggle) -->
              <div 
                class="flex items-center justify-between p-5 bg-zinc-900/60 border-b border-zinc-850 cursor-pointer select-none hover:bg-zinc-800/40 transition-colors"
                data-show-toggle={showGroup.show_tmdb_id}
              >
                <div class="flex items-center gap-4 min-w-0">
                  <!-- Collapsible chevron icon -->
                  <svg 
                    class="w-5 h-5 text-zinc-400 transition-transform duration-300 transform" 
                    id={`chevron-${showGroup.show_tmdb_id}`} 
                    xmlns="http://www.w3.org/2000/svg" 
                    width="24" 
                    height="24" 
                    viewBox="0 0 24 24" 
                    fill="none" 
                    stroke="currentColor" 
                    stroke-width="2.5" 
                    stroke-linecap="round" 
                    stroke-linejoin="round"
                  >
                    <path d="m9 18 6-6-6-6"/>
                  </svg>
                  
                  <!-- Show Poster Image -->
                  <div class="w-10 h-14 rounded-lg overflow-hidden bg-zinc-950 border border-zinc-800 shrink-0 shadow-sm">
                    {showGroup.show_poster_path ? (
                      <img src={showGroup.show_poster_path} alt="" class="w-full h-full object-cover" loading="lazy" />
                    ) : (
                      <div class="w-full h-full flex items-center justify-center text-[8px] text-zinc-600 font-bold bg-zinc-900">NO ART</div>
                    )}
                  </div>

                  <div class="min-w-0">
                    <h3 class="text-base font-bold text-zinc-100 truncate hover:text-indigo-400 transition-colors">
                      {showGroup.show_title}
                    </h3>
                    <span class="text-[10px] text-zinc-500 font-bold bg-zinc-950 px-2 py-0.5 rounded border border-zinc-850 mt-1 inline-block">TMDB ID: {showGroup.show_tmdb_id}</span>
                  </div>
                </div>

                <div class="flex items-center gap-3 shrink-0">
                  <span class="text-xs bg-zinc-805 text-zinc-400 border border-zinc-750 px-2.5 py-0.5 rounded-full font-extrabold">
                    {showGroup.overrides.length} remaps
                  </span>
                </div>
              </div>

              <!-- Collapsible Content Panel (Hidden by default) -->
              <div 
                id={`panel-${showGroup.show_tmdb_id}`} 
                class="hidden divide-y divide-zinc-850 bg-zinc-950/20"
              >
                
                <!-- Bulk Actions Toolbar -->
                <div class="px-5 py-3 bg-zinc-900/20 flex flex-col sm:flex-row sm:items-center justify-between gap-3 border-b border-zinc-850">
                  <div class="flex items-center gap-2">
                    <input 
                      type="checkbox" 
                      class="bulk-show-select-all rounded border-zinc-700 bg-zinc-950 text-indigo-600 focus:ring-indigo-500 cursor-pointer w-4 h-4" 
                      data-show-id={showGroup.show_tmdb_id} 
                    />
                    <span class="text-xs font-bold text-zinc-400">Select All in Show</span>
                  </div>
                  
                  <button 
                    class="bulk-delete-btn flex items-center justify-center gap-1.5 px-3 py-1.5 bg-rose-950/20 hover:bg-rose-900/30 border border-rose-900/40 text-rose-400 text-xs font-bold rounded-xl transition-all cursor-pointer shadow-sm active:scale-95 disabled:opacity-40 disabled:cursor-not-allowed"
                    data-show-id={showGroup.show_tmdb_id}
                    disabled
                  >
                    <svg class="w-3.5 h-3.5" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2M10 11v6M14 11v6"/></svg>
                    Delete Selected (<span class="bulk-selected-count">0</span>)
                  </button>
                </div>

                <!-- Season Groups -->
                <div class="divide-y divide-zinc-850/60">
                  {Object.entries(showGroup.seasons)
                    .sort(([a], [b]) => Number(a) - Number(b))
                    .map(([seasonNum, overrides]: [string, any]) => {
                      // Sort episodes in season group by episode number ascending
                      const sortedOverrides = [...overrides].sort((a: any, b: any) => a.source_episode_number - b.source_episode_number);
                      
                      return (
                        <div class="season-group-container bg-zinc-950/10">
                          <!-- Season Sub-Header -->
                          <div class="px-5 py-2.5 bg-zinc-900/15 flex items-center justify-between border-b border-zinc-850/40">
                            <span class="text-xs font-black uppercase text-indigo-400 tracking-wider">
                              Season {seasonNum}
                            </span>
                            <span class="text-[10px] bg-zinc-850 text-zinc-400 px-2 py-0.5 rounded-full font-bold">
                              {overrides.length} remaps
                            </span>
                          </div>

                          <!-- Individual Overrides in Season -->
                          <div class="grid grid-cols-1 divide-y divide-zinc-850/40">
                            {sortedOverrides.map((override: any) => (
                              <div 
                                class="override-row-container flex flex-col lg:flex-row items-center justify-between p-5 gap-6 hover:bg-zinc-800/10 transition-colors duration-200"
                                data-source-season={override.source_season_number}
                                data-source-episode={override.source_episode_number}
                                data-target-season={override.target_season_number}
                                data-target-episode={override.target_episode_number}
                                data-source-title={(override.source_episode_title || "").toLowerCase()}
                                data-target-title={(override.target_episode_title || "").toLowerCase()}
                                data-show-title={showGroup.show_title.toLowerCase()}
                                data-show-tmdb={showGroup.show_tmdb_id}
                              >
                                
                                <!-- Bulk Select Checkbox + Source coordinates -->
                                <div class="flex items-center gap-4 w-full lg:w-2/5 min-w-0">
                                  <input 
                                    type="checkbox" 
                                    class="override-row-checkbox rounded border-zinc-700 bg-zinc-950 text-indigo-600 focus:ring-indigo-500 cursor-pointer w-4 h-4 shrink-0" 
                                    data-override-id={override.id}
                                    data-show-id={showGroup.show_tmdb_id}
                                  />
                                  
                                  <div class="min-w-0 flex-1">
                                    <span class="text-[9px] font-extrabold uppercase text-zinc-500 tracking-wider block">Source Episode</span>
                                    <div class="flex items-center gap-2 mt-0.5 min-w-0">
                                      <span class="px-2 py-0.5 bg-zinc-800 border border-zinc-750 rounded-md text-[10px] font-bold text-zinc-300 shrink-0">
                                        S{override.source_season_number.toString().padStart(2, '0')}E{override.source_episode_number.toString().padStart(2, '0')}
                                      </span>
                                      <span class="text-xs text-zinc-400 font-medium truncate" title={override.source_episode_title}>
                                        {override.source_episode_title || "Unknown Episode"}
                                      </span>
                                    </div>
                                  </div>
                                </div>

                                <!-- Arrow Indicator -->
                                <div class="flex items-center justify-center shrink-0">
                                  <div class="w-8 h-8 rounded-full bg-zinc-950 border border-zinc-850 flex items-center justify-center text-indigo-500 shadow-md">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                                  </div>
                                </div>

                                <!-- Target coordinates -->
                                <div class="flex items-center gap-4 w-full lg:w-2/5 min-w-0">
                                  <div class="w-10 h-15 rounded-lg overflow-hidden bg-zinc-950 border border-zinc-800 shrink-0 shadow-sm hidden sm:block">
                                    {override.target_show_poster_path ? (
                                      <img src={override.target_show_poster_path} alt="" class="w-full h-full object-cover" loading="lazy" />
                                    ) : (
                                      <div class="w-full h-full flex items-center justify-center text-[9px] text-zinc-600 font-bold bg-zinc-900">NO ART</div>
                                    )}
                                  </div>
                                  <div class="min-w-0 flex-1">
                                    <span class="text-[9px] font-extrabold uppercase text-zinc-500 tracking-wider block">Target Episode</span>
                                    <div class="flex items-center gap-2 mt-0.5 min-w-0">
                                      <span class="px-2 py-0.5 bg-indigo-950/40 border border-indigo-900/30 rounded-md text-[10px] font-bold text-indigo-400 shrink-0">
                                        S{override.target_season_number.toString().padStart(2, '0')}E{override.target_episode_number.toString().padStart(2, '0')}
                                      </span>
                                      <span class="text-xs text-zinc-450 font-medium truncate" title={override.target_episode_title}>
                                        {override.target_episode_title || "Unknown Episode"}
                                      </span>
                                    </div>
                                  </div>
                                </div>

                                <!-- Actions -->
                                <div class="flex items-center gap-2 w-full lg:w-auto justify-end shrink-0 border-t border-zinc-850 lg:border-t-0 pt-4 lg:pt-0">
                                  <button class="edit-ep-btn flex items-center gap-1.5 px-3 py-1.5 bg-zinc-800 hover:bg-zinc-750 active:scale-95 text-zinc-200 text-xs font-bold rounded-xl transition-all cursor-pointer shadow-sm" data-src-tmdb={override.source_show_tmdb_id} data-src-season={override.source_season_number} data-src-ep={override.source_episode_number} data-tgt-tmdb={override.target_show_tmdb_id} data-tgt-season={override.target_season_number} data-tgt-ep={override.target_episode_number} title="Edit override">
                                    <svg class="w-3.5 h-3.5" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/><path d="m15 5 4 4"/></svg>
                                    Edit
                                  </button>
                                  <button data-ep-apply-id={override.id} class="flex items-center gap-1.5 px-3 py-1.5 bg-zinc-800 hover:bg-zinc-750 active:scale-95 text-zinc-200 text-xs font-bold rounded-xl transition-all cursor-pointer shadow-sm" title="Re-apply override & fetch TMDB metadata">
                                    <svg class="w-3.5 h-3.5" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21.5 2v6h-6M21.34 15.57a10 10 0 1 1-.57-8.38l5.67-5.67"/></svg>
                                    Apply
                                  </button>
                                  <button data-ep-delete-id={override.id} class="flex items-center gap-1.5 px-3 py-1.5 bg-rose-950/20 hover:bg-rose-900/30 border border-rose-900/40 text-rose-300 text-xs font-bold rounded-xl transition-all cursor-pointer shadow-sm active:scale-95" title="Delete override">
                                    <svg class="w-3.5 h-3.5" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2M10 11v6M14 11v6"/></svg>
                                    Delete
                                  </button>
                                </div>

                              </div>
                            ))}
                          </div>
                        </div>
                      );
                    })}
                </div>

              </div>

            </div>
          ))}
          <!-- Episode search empty state -->
          <div id="no-episode-results" class="hidden flex flex-col items-center justify-center py-16 border border-zinc-800 bg-zinc-950/20 rounded-3xl backdrop-blur-md">
            <div class="w-12 h-12 rounded-full bg-zinc-900 border border-zinc-800 flex items-center justify-center text-zinc-500 mb-3 shadow-inner">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
            </div>
            <h3 class="text-zinc-300 font-semibold mb-1 text-sm">No Matching Episode Remaps</h3>
            <p class="text-zinc-500 text-xs text-center">Try adjusting your keywords or search query.</p>
          </div>
        </div>
    )}
    </div>

    <!-- Custom Renames Section -->
    <div class="mt-16">
      <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-6">
        <h2 class="text-xl font-semibold text-zinc-200 flex items-center gap-2">
          Global Custom Renames
          <span class="text-xs bg-zinc-800 text-zinc-400 font-bold px-2 py-0.5 rounded-full">{customTitles.length}</span>
        </h2>
        {customTitles.length > 0 && (
          <input 
            type="text" 
            id="rename-search" 
            placeholder="Search custom renames..." 
            class="px-4 py-2 bg-zinc-950/40 border border-zinc-800 focus:border-indigo-500 rounded-xl text-xs text-zinc-200 focus:outline-none focus:ring-1 focus:ring-indigo-500 w-full sm:w-64 placeholder-zinc-600 transition-all"
          />
        )}
      </div>

      {customTitles.length === 0 ? (
        <div class="flex flex-col items-center justify-center py-16 border border-zinc-800 bg-zinc-950/20 rounded-3xl backdrop-blur-md">
          <div class="w-16 h-16 rounded-full bg-zinc-900 border border-zinc-800 flex items-center justify-center text-zinc-500 mb-4 shadow-inner">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
          </div>
          <h3 class="text-zinc-200 font-semibold mb-1">No Custom Renames</h3>
          <p class="text-zinc-500 text-xs max-w-sm text-center">You haven't renamed any shows, seasons, or episodes.</p>
        </div>
      ) : (
        <div class="space-y-4">
          {groupedCustomTitlesList.map((showGroup: any) => (
            <div class="show-renames-panel border border-zinc-800 rounded-3xl bg-zinc-900/20 overflow-hidden backdrop-blur-md transition-all duration-300" data-rename-tmdb={showGroup.show_tmdb_id}>
              
              <!-- Show Panel Header (Collapsible Toggle) -->
              <div 
                class="flex items-center justify-between p-5 bg-zinc-900/60 border-b border-zinc-850 cursor-pointer select-none hover:bg-zinc-800/40 transition-colors"
                data-rename-toggle={showGroup.show_tmdb_id}
              >
                <div class="flex items-center gap-4 min-w-0">
                  <!-- Collapsible chevron icon -->
                  <svg 
                    class="w-5 h-5 text-zinc-400 transition-transform duration-300 transform" 
                    id={`rename-chevron-${showGroup.show_tmdb_id}`} 
                    xmlns="http://www.w3.org/2000/svg" 
                    width="24" 
                    height="24" 
                    viewBox="0 0 24 24" 
                    fill="none" 
                    stroke="currentColor" 
                    stroke-width="2.5" 
                    stroke-linecap="round" 
                    stroke-linejoin="round"
                  >
                    <path d="m9 18 6-6-6-6"/>
                  </svg>
                  
                  <!-- Show Poster Image -->
                  {showGroup.show_tmdb_id > 0 && (
                    <div class="w-10 h-14 rounded-lg overflow-hidden bg-zinc-950 border border-zinc-800 shrink-0 shadow-sm">
                      {showGroup.show_poster_path ? (
                        <img src={showGroup.show_poster_path} alt="" class="w-full h-full object-cover" loading="lazy" />
                      ) : (
                        <div class="w-full h-full flex items-center justify-center text-[8px] text-zinc-600 font-bold bg-zinc-900">NO ART</div>
                      )}
                    </div>
                  )}

                  <div class="min-w-0">
                    <h3 class="text-base font-bold text-zinc-100 truncate hover:text-indigo-400 transition-colors">
                      {showGroup.show_title}
                    </h3>
                    {showGroup.show_tmdb_id > 0 && (
                      <span class="text-[10px] text-zinc-500 font-bold bg-zinc-950 px-2 py-0.5 rounded border border-zinc-850 mt-1 inline-block">TMDB ID: {showGroup.show_tmdb_id}</span>
                    )}
                  </div>
                </div>

                <div class="flex items-center gap-3 shrink-0">
                  <span class="text-xs bg-zinc-850 text-zinc-400 border border-zinc-750 px-2.5 py-0.5 rounded-full font-extrabold">
                    {showGroup.items.length} renames
                  </span>
                </div>
              </div>

              <!-- Collapsible Content Panel (Hidden by default) -->
              <div 
                id={`rename-panel-${showGroup.show_tmdb_id}`} 
                class="hidden divide-y divide-zinc-850 bg-zinc-950/20"
              >
                <div class="overflow-x-auto">
                  <table class="w-full text-left border-collapse">
                    <thead>
                      <tr class="bg-zinc-900 border-b border-zinc-800 text-xs text-zinc-500 uppercase tracking-wider">
                        <th class="px-5 py-3 font-semibold w-24">Type</th>
                        <th class="px-5 py-3 font-semibold">Context</th>
                        <th class="px-5 py-3 font-semibold">Original Title</th>
                        <th class="px-5 py-3 font-semibold">Custom Title</th>
                        <th class="px-5 py-3 font-semibold text-right w-28">Actions</th>
                      </tr>
                    </thead>
                    <tbody class="divide-y divide-zinc-850/50 text-sm">
                      {showGroup.items.map((item: any) => (
                        <tr class="custom-rename-row hover:bg-zinc-800/10 transition-colors">
                          <td class="px-5 py-4 whitespace-nowrap">
                            {item.type === 'show' && <span class="px-2 py-1 bg-purple-900/30 text-purple-400 rounded font-bold text-xs">Show</span>}
                            {item.type === 'season' && <span class="px-2 py-1 bg-teal-900/30 text-teal-400 rounded font-bold text-xs">Season</span>}
                            {item.type === 'episode' && <span class="px-2 py-1 bg-orange-900/30 text-orange-400 rounded font-bold text-xs">Episode</span>}
                          </td>
                          <td class="px-5 py-4 text-zinc-400">{item.context}</td>
                          <td class="px-5 py-4 text-zinc-500 line-through decoration-zinc-600">{item.original_title}</td>
                          <td class="px-5 py-4 text-zinc-200 font-bold">{item.custom_title}</td>
                          <td class="px-5 py-4 text-right">
                            <button class="custom-rename-edit-btn p-1.5 text-zinc-500 hover:text-blue-400 transition-colors" data-payload={JSON.stringify(item)} title="Edit">
                              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/><path d="m15 5 4 4"/></svg>
                            </button>
                            <button class="custom-rename-delete-btn p-1.5 text-zinc-500 hover:text-red-400 transition-colors ml-2" data-payload={JSON.stringify(item)} title="Remove Override">
                              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2M10 11v6M14 11v6"/></svg>
                            </button>
                          </td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              </div>

            </div>
          ))}
          <!-- Rename search empty state -->
          <div id="no-rename-results" class="hidden flex flex-col items-center justify-center py-16 border border-zinc-800 bg-zinc-950/20 rounded-3xl backdrop-blur-md">
            <div class="w-12 h-12 rounded-full bg-zinc-900 border border-zinc-800 flex items-center justify-center text-zinc-500 mb-3 shadow-inner">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
            </div>
            <h3 class="text-zinc-300 font-semibold mb-1 text-sm">No Matching Custom Renames</h3>
            <p class="text-zinc-500 text-xs text-center">Try adjusting your keywords or search query.</p>
          </div>
        </div>
      )}
    </div>
  </div>

  <!-- Wizard Modal -->
  <div id="remap-modal" class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-zinc-950/85 backdrop-blur-sm opacity-0 pointer-events-none transition-all duration-300">
    <div class="bg-zinc-900 border border-zinc-800 rounded-3xl w-full max-w-2xl overflow-hidden shadow-2xl flex flex-col max-h-[90vh]">
      
      <!-- Modal Header -->
      <div class="px-6 py-5 border-b border-zinc-850 flex items-center justify-between">
        <div>
          <h2 class="text-xl font-bold text-zinc-100">Add Custom Season Remap</h2>
          <p class="text-xs text-zinc-400 mt-0.5">Define a new source-to-target season override mapping.</p>
        </div>
        <button id="close-modal-btn" class="w-8 h-8 rounded-full bg-zinc-800 hover:bg-zinc-700 text-zinc-300 flex items-center justify-center cursor-pointer transition">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18M6 6l12 12"/></svg>
        </button>
      </div>

      <!-- Modal Body (Scrollable) -->
      <div class="p-6 overflow-y-auto space-y-6 flex-1">
        
        <!-- STEP 1: SOURCE SHOW & SEASON -->
        <div class="space-y-4">
          <div class="flex items-center justify-between">
            <h3 class="text-sm font-bold text-zinc-200 uppercase tracking-wider flex items-center gap-2">
              <span class="w-5 h-5 rounded-full bg-zinc-800 text-zinc-400 text-xs flex items-center justify-center font-bold">1</span>
              Source Season (From Library)
            </h3>
            <button id="toggle-source-mode-btn" class="text-xs text-blue-400 hover:underline font-semibold cursor-pointer">
              Toggle Manual TMDB Input
            </button>
          </div>

          <!-- Mode A: Dropdown Selection -->
          <div id="source-select-group" class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label class="block text-xs font-semibold text-zinc-400 mb-1.5">Select Local Show</label>
              <select id="source-show-select" class="w-full bg-zinc-950 border border-zinc-800 rounded-xl px-3 py-2.5 text-zinc-200 text-sm focus:border-blue-500 focus:outline-none transition">
                <option value="">-- Loading Local Shows --</option>
              </select>
            </div>
            <div>
              <label class="block text-xs font-semibold text-zinc-400 mb-1.5">Select Source Season</label>
              <select id="source-season-select" class="w-full bg-zinc-950 border border-zinc-800 rounded-xl px-3 py-2.5 text-zinc-200 text-sm focus:border-blue-500 focus:outline-none transition" disabled>
                <option value="">-- Select Show First --</option>
              </select>
            </div>
          </div>

          <!-- Mode B: Manual Input (Hidden) -->
          <div id="source-manual-group" class="grid grid-cols-1 sm:grid-cols-2 gap-4 hidden">
            <div>
              <label class="block text-xs font-semibold text-zinc-400 mb-1.5">Source Show TMDB ID</label>
              <div class="flex gap-2">
                <input type="number" id="source-show-tmdb-input" placeholder="e.g. 85937" class="w-full bg-zinc-950 border border-zinc-800 rounded-xl px-3 py-2.5 text-zinc-200 text-sm focus:border-blue-500 focus:outline-none transition" />
                <button id="source-show-lookup-btn" class="px-3 py-2 bg-zinc-800 hover:bg-zinc-700 text-zinc-300 font-bold rounded-xl text-xs transition cursor-pointer">Lookup</button>
              </div>
            </div>
            <div>
              <label class="block text-xs font-semibold text-zinc-400 mb-1.5">Source Season Number</label>
              <input type="number" id="source-season-input" placeholder="e.g. 2" class="w-full bg-zinc-950 border border-zinc-800 rounded-xl px-3 py-2.5 text-zinc-200 text-sm focus:border-blue-500 focus:outline-none transition" />
            </div>
          </div>
          <!-- Manual Preview Card -->
          <div id="source-manual-preview" class="flex items-center gap-4 p-3 bg-zinc-900/50 border border-zinc-800 rounded-xl hidden mt-3">
            <img id="source-manual-poster" src="" class="w-8 h-12 rounded object-cover hidden" />
            <div id="source-manual-no-poster" class="w-8 h-12 bg-zinc-950 rounded flex items-center justify-center text-[8px] text-zinc-600 font-bold hidden">NO ART</div>
            <div>
              <h4 id="source-manual-title" class="text-sm font-bold text-zinc-200"></h4>
              <p id="source-manual-meta" class="text-xs text-zinc-500"></p>
            </div>
          </div>
        </div>

        <hr class="border-zinc-850" />

        <!-- STEP 2: TARGET SHOW & SEASON (TMDB SEARCH) -->
        <div class="space-y-4">
          <h3 class="text-sm font-bold text-zinc-200 uppercase tracking-wider flex items-center gap-2">
            <span class="w-5 h-5 rounded-full bg-zinc-800 text-zinc-400 text-xs flex items-center justify-center font-bold">2</span>
            Target Season (On TMDB)
          </h3>

          <!-- Search Box -->
          <div class="flex gap-2">
            <input type="text" id="target-search-input" placeholder="Search TMDB for target show (e.g. Demon Slayer)..." class="w-full bg-zinc-950 border border-zinc-800 rounded-xl px-4 py-2.5 text-zinc-200 text-sm focus:border-blue-500 focus:outline-none transition" />
            <button id="target-search-btn" class="px-5 py-2.5 bg-zinc-800 hover:bg-zinc-700 active:scale-95 text-zinc-200 font-bold rounded-xl text-sm transition-all cursor-pointer">
              Search
            </button>
          </div>

          <!-- Search Results Container -->
          <div id="search-results-container" class="grid grid-cols-2 sm:grid-cols-3 gap-3 max-h-56 overflow-y-auto pr-1 hidden border border-zinc-850 p-2.5 rounded-2xl bg-zinc-950/40">
            <!-- Results populated here dynamically -->
          </div>

          <!-- Selected Card -->
          <div id="target-selected-card" class="flex items-center gap-4 p-4 bg-blue-950/20 border border-blue-900/30 rounded-2xl hidden">
            <div class="w-10 h-15 rounded-lg overflow-hidden bg-zinc-950 shrink-0 shadow-md border border-zinc-850">
              <img id="target-selected-poster" src="" alt="" class="w-full h-full object-cover hidden" />
              <div id="target-selected-no-poster" class="w-full h-full bg-zinc-900 flex items-center justify-center text-[8px] text-zinc-600 font-bold">NO ART</div>
            </div>
            <div class="min-w-0 flex-1">
              <span class="text-[9px] font-extrabold uppercase text-blue-400 tracking-wider">Selected Target</span>
              <h4 id="target-selected-title" class="text-zinc-100 font-bold truncate text-sm"></h4>
              <p id="target-selected-meta" class="text-[10px] text-zinc-400 mt-0.5"></p>
            </div>
            <button id="target-change-btn" class="px-3 py-1.5 bg-zinc-850 hover:bg-zinc-800 text-zinc-300 font-bold text-xs rounded-lg cursor-pointer transition">
              Change
            </button>
          </div>

          <!-- Season Selection -->
          <div id="target-season-group" class="space-y-2 hidden">
            <label class="block text-xs font-semibold text-zinc-400">Select Target Season</label>
            <div id="target-season-buttons" class="flex flex-wrap gap-2">
              <!-- Season buttons generated dynamically -->
            </div>
          </div>
        </div>

      </div>

      <!-- Modal Footer -->
      <div class="px-6 py-4 bg-zinc-950/60 border-t border-zinc-850 flex justify-end gap-3 shrink-0">
        <button id="cancel-modal-btn" class="px-5 py-2.5 bg-zinc-800 hover:bg-zinc-750 text-zinc-300 font-bold rounded-xl text-sm transition-all cursor-pointer">
          Cancel
        </button>
        <button id="save-remap-btn" class="px-5 py-2.5 bg-blue-600 hover:bg-blue-500 disabled:bg-blue-600/30 disabled:text-white/40 text-white font-bold rounded-xl text-sm transition-all disabled:cursor-not-allowed cursor-pointer shadow-lg" disabled>
          Save & Apply Remap
        </button>
      </div>

    </div>
  </div>
</Base>

  <!-- Auto-Remap Modal -->
  <div id="auto-remap-modal" class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-zinc-950/85 backdrop-blur-sm opacity-0 pointer-events-none transition-all duration-300">
    <div class="bg-zinc-900 border border-zinc-800 rounded-3xl w-full max-w-4xl overflow-hidden shadow-2xl flex flex-col max-h-[90vh]">
      
      <!-- Modal Header -->
      <div class="px-6 py-5 border-b border-zinc-850 flex items-center justify-between shrink-0">
        <div>
          <h3 class="text-xl font-bold text-zinc-100 tracking-tight flex items-center gap-2">
            <svg class="w-6 h-6 text-indigo-400 animate-pulse" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m21 16-4 4-4-4"/><path d="M17 20V4"/><path d="m3 8 4-4 4 4"/><path d="M7 4v16"/></svg>
            TVDB ⇆ TMDB Episode Auto-Remapper
          </h3>
          <p class="text-zinc-400 text-xs mt-1">Intelligently match and remap seasons & episodes of a show between TVDB and TMDB databases automatically.</p>
        </div>
        <button id="close-auto-modal-btn" class="p-2 -mr-2 text-zinc-500 hover:text-zinc-200 hover:bg-zinc-800 rounded-full transition-colors cursor-pointer">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18M6 6l12 12"/></svg>
        </button>
      </div>

      <!-- Modal Body (Scrollable) -->
