    function validateRenameForm() {
      let isValid = false;
      const hasTitle = renameCustomTitleInput.value.trim().length > 0;
      
      if (isManualRename) {
        const hasId = renameManualIdInput.value.trim().length > 0;
        if (renameType === "show" || renameType === "movie") {
          isValid = hasId && hasTitle;
        } else if (renameType === "season") {
          const hasSeason = renameManualSeasonInput.value.trim().length > 0;
          isValid = hasId && hasSeason && hasTitle;
        } else if (renameType === "episode") {
          const hasSeason = renameManualSeasonInput.value.trim().length > 0;
          const hasEpisode = renameManualEpisodeInput.value.trim().length > 0;
          isValid = hasId && hasSeason && hasEpisode && hasTitle;
        }
      } else {
        if (renameType === "show" || renameType === "movie") {
          isValid = !!renameSelectedShow && hasTitle;
        } else if (renameType === "season") {
          isValid = !!renameSelectedShow && renameSelectedSeason !== null && hasTitle;
        } else if (renameType === "episode") {
          isValid = !!renameSelectedShow && renameSelectedSeason !== null && !!renameSelectedEpisode && hasTitle;
        }
      }

      saveRenameBtn.disabled = !isValid;
    }

