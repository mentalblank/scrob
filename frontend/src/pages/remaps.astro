            <img id="source-manual-poster" src="" class="w-8 h-12 rounded object-cover hidden" />
            <div id="source-manual-no-poster" class="w-8 h-12 bg-zinc-950 rounded flex items-center justify-center text-[8px] text-zinc-650 font-bold hidden">NO ART</div>
            <div>
              <h4 id="source-manual-title" class="text-sm font-bold text-zinc-200"></h4>
              <p id="source-manual-meta" class="text-xs text-zinc-500"></p>
            </div>
          </div>
        </div>

        <hr class="border-zinc-850" />

        <!-- STEP 2: TARGET SHOW & SEASON -->
        <div class="space-y-4">
          <h3 class="text-sm font-bold text-zinc-200 uppercase tracking-wider flex items-center gap-2">
            <span class="w-5 h-5 rounded-full bg-zinc-800 text-zinc-400 text-xs flex items-center justify-center font-bold">2</span>
            Target Season (On TMDB/TVDB)
          </h3>

          <div id="target-manual-group" class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label class="block text-xs font-semibold text-zinc-400 mb-1.5">Target Show ID</label>
              <div class="flex gap-2">
                <select id="target-show-id-type" class="bg-zinc-950 border border-zinc-800 rounded-xl px-2 py-2 text-zinc-300 text-xs focus:border-blue-500 focus:outline-none transition cursor-pointer">
                  <option value="tmdb">TMDB</option>
                  <option value="tvdb">TVDB</option>
                </select>
                <input type="number" id="target-show-tmdb-input" placeholder="e.g. 85937" class="w-full bg-zinc-950 border border-zinc-800 rounded-xl px-3 py-2.5 text-zinc-200 text-sm focus:border-blue-500 focus:outline-none transition" />
                <button id="target-show-lookup-btn" class="px-3 py-2 bg-zinc-800 hover:bg-zinc-700 text-zinc-300 font-bold rounded-xl text-xs transition cursor-pointer">Lookup</button>
              </div>
            </div>
            <div>
              <label class="block text-xs font-semibold text-zinc-400 mb-1.5">Target Season Number</label>
              <input type="number" id="target-season-input" placeholder="e.g. 2" class="w-full bg-zinc-950 border border-zinc-800 rounded-xl px-3 py-2.5 text-zinc-200 text-sm focus:border-blue-500 focus:outline-none transition" />
            </div>
          </div>
          <!-- Target Manual Preview Card -->
          <div id="target-manual-preview" class="flex items-center gap-4 p-3 bg-zinc-900/50 border border-zinc-800 rounded-xl hidden mt-3">
            <img id="target-manual-poster" src="" class="w-8 h-12 rounded object-cover hidden" />
            <div id="target-manual-no-poster" class="w-8 h-12 bg-zinc-950 rounded flex items-center justify-center text-[8px] text-zinc-650 font-bold hidden">NO ART</div>
            <div>
              <h4 id="target-manual-title" class="text-sm font-bold text-zinc-200"></h4>
              <p id="target-manual-meta" class="text-xs text-zinc-500"></p>
            </div>
          </div>
        </div>

      </div>

      <!-- Modal Footer -->
      <div class="px-6 py-4 bg-zinc-950/60 border-t border-zinc-850 flex justify-end gap-3 shrink-0">
        <button id="cancel-modal-btn" class="px-5 py-2.5 bg-zinc-800 hover:bg-zinc-750 text-zinc-300 font-bold rounded-xl text-sm transition-all cursor-pointer">
          Cancel
        </button>
        <button id="save-remap-btn" class="px-5 py-2.5 bg-blue-600 hover:bg-blue-500 disabled:bg-blue-600/30 disabled:text-white/40 text-white font-bold rounded-xl text-sm transition-all disabled:cursor-not-allowed cursor-pointer shadow-lg" disabled>
          Save & Apply Remap
        </button>
      </div>

    </div>
  </div>
</Base>  </div>

  <!-- Episode Remap Modal -->
  <div id="ep-remap-modal" class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-zinc-950/85 backdrop-blur-sm opacity-0 pointer-events-none transition-all duration-300">
    <div class="bg-zinc-900/85 border border-zinc-800/85 rounded-3xl w-full max-w-xl overflow-hidden shadow-2xl flex flex-col max-h-[90vh] backdrop-blur-xl">
      
      <!-- Modal Header -->
      <div class="px-6 py-5 border-b border-zinc-850 flex items-center justify-between shrink-0">
        <div>
          <h3 class="text-xl font-bold text-zinc-100 tracking-tight flex items-center gap-2">
            <svg class="w-5 h-5 text-indigo-400" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5v14"/></svg>
            Add Custom Episode Remap
          </h3>
          <p class="text-zinc-400 text-xs mt-1">Specify source to target episode mappings for exact synchronization.</p>
