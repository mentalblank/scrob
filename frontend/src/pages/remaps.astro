    // Recalculate selected checkboxes for a show group
    function updateBulkDeleteState(showId: string) {
      const panel = document.getElementById(`panel-${showId}`);
      if (!panel) return;

      const checkedBoxes = panel.querySelectorAll(".override-row-checkbox:checked");
      const totalBoxes = panel.querySelectorAll(".override-row-checkbox");
      const selectAllCheckbox = panel.querySelector(".bulk-show-select-all") as HTMLInputElement;
      const bulkDeleteBtn = panel.querySelector(".bulk-delete-btn") as HTMLButtonElement;
      const countSpan = panel.querySelector(".bulk-selected-count")!;

      countSpan.textContent = checkedBoxes.length.toString();

      if (checkedBoxes.length > 0) {
        bulkDeleteBtn.removeAttribute("disabled");
      } else {
        bulkDeleteBtn.setAttribute("disabled", "true");
      }

      if (selectAllCheckbox && totalBoxes.length > 0) {
        selectAllCheckbox.checked = checkedBoxes.length === totalBoxes.length;
      }
    }

