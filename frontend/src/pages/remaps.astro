                      <option value="tmdb">TMDB</option>
                      <option value="tvdb">TVDB</option>
                    </select>
                  </div>
                </div>
                <div>
                  <label class="block text-[10px] font-black uppercase tracking-wider text-zinc-500 mb-1.5">Show or Movie ID</label>
                  <input type="text" id="rename-manual-id-input" placeholder="e.g. 85937" class="w-full bg-zinc-900 border border-zinc-800 rounded-xl px-3.5 py-2.5 text-zinc-200 text-xs focus:border-indigo-500 focus:outline-none transition" />
