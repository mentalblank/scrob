    const previewMatchPct = document.getElementById("preview-match-pct")!;
    const previewUnmatchedBadge = document.getElementById("preview-unmatched-badge")!;
    const previewMatchesList = document.getElementById("preview-matches-list")!;
    
    const filterAllBtn = document.getElementById("filter-all-btn")!;
    const filterMatchedBtn = document.getElementById("filter-matched-btn")!;
    const filterUnmatchedBtn = document.getElementById("filter-unmatched-btn")!;
    const unmatchedCountBadge = document.getElementById("unmatched-count-badge")!;
    
    let activeMappings: any[] = [];
    let tmdbEpisodesList: any[] = [];
    let selectOptionsHtml = "";
    let currentFilter = "all";



    // --- TMDB Show Search Logic ---
    async function performTmdbSearch() {
      const q = autoTmdbSearchInput.value.trim();
      if (!q) return;

      autoTmdbSearchBtn.textContent = "...";
      try {
        const res = await fetch(`/api/proxy/sync/tmdb-show-search?q=${encodeURIComponent(q)}`, {
          headers: { "Authorization": `Bearer ${token}` }
        });
        if (res.ok) {
          const data = await res.json();
          renderAutoSearchResults(data.results || [], "tmdb");
        } else {
          window.showToast?.("TMDB search failed", "error");
        }
      } catch (err) {
        window.showToast?.("Error searching TMDB", "error");
      } finally {
        autoTmdbSearchBtn.textContent = "Search";
      }
    }

    autoTmdbSearchBtn.addEventListener("click", performTmdbSearch);
    autoTmdbSearchInput.addEventListener("keydown", (e) => {
      if (e.key === "Enter") { e.preventDefault(); performTmdbSearch(); }
    });

    autoTmdbChangeBtn.addEventListener("click", () => {
      autoTmdbIdInput.value = "";
      autoTmdbSelected.classList.add("hidden");
      autoTmdbSearchInput.value = "";
      autoTmdbSearchInput.classList.remove("hidden");
      autoTmdbSearchBtn.classList.remove("hidden");
      autoTmdbResults.classList.add("hidden");
    });

    // --- TVDB Show Search Logic ---
    async function performTvdbSearch() {
      const q = autoTvdbSearchInput.value.trim();
      if (!q) return;
      if (!hasSavedTvdbKey) {
        window.showToast?.("TVDB API Key must be configured in settings to use the auto-remapper!", "error");
        return;
      }

      autoTvdbSearchBtn.textContent = "...";
      try {
        const res = await fetch("/api/proxy/sync/tvdb-search", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            "Authorization": `Bearer ${token}`
          },
          body: JSON.stringify({
            query: q
          })
        });
        if (res.ok) {
          const data = await res.json();
          renderAutoSearchResults(data.results || [], "tvdb");
        } else {
          const err = await res.json().catch(() => ({}));
          window.showToast?.(err.detail || "TVDB search failed", "error");
        }
      } catch (err) {
        window.showToast?.("Error searching TVDB", "error");
      } finally {
        autoTvdbSearchBtn.textContent = "Search";
      }
    }

    autoTvdbSearchBtn.addEventListener("click", performTvdbSearch);
    autoTvdbSearchInput.addEventListener("keydown", (e) => {
      if (e.key === "Enter") { e.preventDefault(); performTvdbSearch(); }
    });

    autoTvdbChangeBtn.addEventListener("click", () => {
      autoTvdbIdInput.value = "";
      autoTvdbSelected.classList.add("hidden");
      autoTvdbSearchInput.value = "";
      autoTvdbSearchInput.classList.remove("hidden");
      autoTvdbSearchBtn.classList.remove("hidden");
      autoTvdbResults.classList.add("hidden");
    });

    // --- Shared render for search results ---
    function renderAutoSearchResults(results: any[], source: "tmdb" | "tvdb") {
      const container = source === "tmdb" ? autoTmdbResults : autoTvdbResults;
      container.innerHTML = "";

      if (results.length === 0) {
        container.innerHTML = '<div class="p-4 text-center text-xs text-zinc-500">No shows found. Try a different search.</div>';
        container.classList.remove("hidden");
        return;
      }

      results.forEach(item => {
        const row = document.createElement("div");
        row.className = "flex items-center gap-3 p-2.5 hover:bg-zinc-800/40 cursor-pointer transition-colors";

        const id = source === "tmdb" ? item.tmdb_id : item.tvdb_id;
        const poster = source === "tmdb" ? item.poster_path : item.image;
        const name = item.name || "Unknown";
        const year = item.year || "N/A";

        let imgHtml = `<div class="w-7 h-10 rounded bg-zinc-900 border border-zinc-800 flex items-center justify-center text-[6px] text-zinc-600 font-bold shrink-0">N/A</div>`;
        if (poster) {
          imgHtml = `<img src="${poster}" alt="" class="w-7 h-10 rounded object-cover border border-zinc-800 shrink-0" loading="lazy" />`;
        }

        const idLabel = source === "tmdb" ? "TMDB" : "TVDB";

        row.innerHTML = `
          ${imgHtml}
          <div class="min-w-0 flex-1">
            <div class="text-xs font-bold text-zinc-200 truncate">${name}</div>
            <div class="text-[9px] text-zinc-500 font-medium">${year} • ${idLabel}: ${id || 'N/A'}</div>
          </div>
        `;

        row.addEventListener("click", () => {
          selectAutoShow(source, {
            id,
            name,
            year,
            poster
          });
        });

        container.appendChild(row);
      });

      container.classList.remove("hidden");
    }

    function selectAutoShow(source: "tmdb" | "tvdb", show: { id: number | null; name: string; year: string; poster: string | null }) {
      if (source === "tmdb") {
        autoTmdbIdInput.value = show.id?.toString() || "";
        autoTmdbSelectedTitle.textContent = show.name;
        autoTmdbSelectedMeta.textContent = `${show.year} • TMDB ID: ${show.id}`;

        if (show.poster) {
          autoTmdbSelectedPoster.src = show.poster;
          autoTmdbSelectedPoster.classList.remove("hidden");
          autoTmdbSelectedNoPoster.classList.add("hidden");
        } else {
          autoTmdbSelectedPoster.classList.add("hidden");
          autoTmdbSelectedNoPoster.classList.remove("hidden");
        }

        autoTmdbSelected.classList.remove("hidden");
        autoTmdbResults.classList.add("hidden");
        autoTmdbSearchInput.classList.add("hidden");
        autoTmdbSearchBtn.classList.add("hidden");

        // Save to localStorage
        localStorage.setItem("scrob_auto_tmdb_id", show.id?.toString() || "");
      } else {
        autoTvdbIdInput.value = show.id?.toString() || "";
        autoTvdbSelectedTitle.textContent = show.name;
        autoTvdbSelectedMeta.textContent = `${show.year} • TVDB ID: ${show.id}`;

        if (show.poster) {
          autoTvdbSelectedPoster.src = show.poster;
          autoTvdbSelectedPoster.classList.remove("hidden");
          autoTvdbSelectedNoPoster.classList.add("hidden");
        } else {
          autoTvdbSelectedPoster.classList.add("hidden");
          autoTvdbSelectedNoPoster.classList.remove("hidden");
        }

        autoTvdbSelected.classList.remove("hidden");
        autoTvdbResults.classList.add("hidden");
        autoTvdbSearchInput.classList.add("hidden");
        autoTvdbSearchBtn.classList.add("hidden");

        // Save to localStorage
        localStorage.setItem("scrob_auto_tvdb_id", show.id?.toString() || "");
      }
    }

    function openAutoModal() {
      autoModal.classList.remove("opacity-0", "pointer-events-none");
    }

    function closeAutoModal() {
      autoModal.classList.add("opacity-0", "pointer-events-none");
      // Reset state
      previewArea.classList.add("hidden");
      loader.classList.add("hidden");
      generatePreviewBtn.disabled = false;
      applyAutoRemapsBtn.disabled = true;
      setFilter("all");
    }

    function setFilter(mode: string) {
      currentFilter = mode;
      
      [filterAllBtn, filterMatchedBtn, filterUnmatchedBtn].forEach(btn => {
        btn.classList.remove("bg-zinc-800", "text-zinc-100", "shadow");
        btn.classList.add("text-zinc-400", "hover:text-zinc-200");
      });

      if (mode === "all") {
        filterAllBtn.classList.add("bg-zinc-800", "text-zinc-100", "shadow");
        filterAllBtn.classList.remove("text-zinc-400", "hover:text-zinc-200");
      } else if (mode === "matched") {
        filterMatchedBtn.classList.add("bg-zinc-800", "text-zinc-100", "shadow");
        filterMatchedBtn.classList.remove("text-zinc-400", "hover:text-zinc-200");
      } else if (mode === "unmatched") {
        filterUnmatchedBtn.classList.add("bg-zinc-800", "text-zinc-100", "shadow");
        filterUnmatchedBtn.classList.remove("text-zinc-400", "hover:text-zinc-200");
      }

      renderList();
    }

    filterAllBtn.addEventListener("click", () => setFilter("all"));
    filterMatchedBtn.addEventListener("click", () => setFilter("matched"));
    filterUnmatchedBtn.addEventListener("click", () => setFilter("unmatched"));

    const autoRemapSearchInput = document.getElementById("auto-remap-search") as HTMLInputElement;
    if (autoRemapSearchInput) {
      autoRemapSearchInput.addEventListener("input", () => {
        renderList();
      });
    }

    function renderList() {
      previewMatchesList.innerHTML = "";
      
      const searchQuery = autoRemapSearchInput ? autoRemapSearchInput.value.toLowerCase().trim() : "";
      
      let filtered = activeMappings;
      if (currentFilter === "matched") {
        filtered = activeMappings.filter(m => m.matched);
      } else if (currentFilter === "unmatched") {
        filtered = activeMappings.filter(m => !m.matched);
      }

      if (searchQuery !== "") {
        filtered = filtered.filter(m => {
          const srcTitle = (m.source_title || "").toLowerCase();
          const srcSeasonEp = `s${m.source_season.toString().padStart(2, '0')}e${m.source_episode.toString().padStart(2, '0')}`;
          const tgtSeasonEp = (m.target_season !== null && m.target_episode !== null) ? `s${m.target_season.toString().padStart(2, '0')}e${m.target_episode.toString().padStart(2, '0')}` : "";
          const tgtTitle = (m.target_title || "").toLowerCase();
          
          return srcTitle.includes(searchQuery) || srcSeasonEp.includes(searchQuery) || tgtSeasonEp.includes(searchQuery) || tgtTitle.includes(searchQuery);
        });
      }

      if (filtered.length === 0) {
        previewMatchesList.innerHTML = `<div class="p-6 text-center text-zinc-500">No episodes found matching active query/filters.</div>`;
        return;
      }

      filtered.forEach((m: any) => {
        // Find index in original activeMappings to ensure correct referencing
        const origIndex = activeMappings.indexOf(m);
        const row = document.createElement("div");
        row.className = "p-4 grid grid-cols-1 lg:grid-cols-12 items-center gap-4 border-b border-zinc-850 hover:bg-zinc-800/10 transition-all duration-200";
        
        row.innerHTML = `
          <!-- Column 1: Source Title and Details (TVDB) -->
          <div class="col-span-12 lg:col-span-5 flex items-start gap-3 min-w-0">
            <input type="checkbox" class="auto-include-checkbox mt-1.5 rounded border-zinc-700 bg-zinc-900 text-indigo-600 focus:ring-indigo-500 cursor-pointer w-4.5 h-4.5 shrink-0" data-index="${origIndex}" ${m.matched ? 'checked' : ''} />
            
            <div class="min-w-0 flex-1">
              <div class="flex items-center gap-2 flex-wrap">
                <span class="text-[9px] bg-indigo-950/80 text-indigo-400 border border-indigo-900/40 px-1.5 py-0.5 rounded font-black tracking-wider uppercase">TVDB</span>
                <span class="text-xs font-black text-zinc-350">S${m.source_season.toString().padStart(2, '0')}E${m.source_episode.toString().padStart(2, '0')}</span>
                <span class="text-[10px] text-zinc-550 font-bold">• ${m.source_air_date || 'No Date'}</span>
              </div>
              <div class="text-zinc-200 font-bold text-sm mt-1 leading-relaxed truncate" title="${m.source_title || 'Untitled Episode'}">${m.source_title || 'Untitled Episode'}</div>
            </div>
          </div>

          <!-- Column 2: Connector & Match Confidence Status -->
          <div class="col-span-12 lg:col-span-3 flex flex-row lg:flex-col items-center justify-between lg:justify-center gap-2 lg:gap-1 text-center bg-zinc-950/20 lg:bg-transparent p-2.5 lg:p-0 rounded-xl border border-zinc-850/50 lg:border-0 shrink-0 min-w-0">
            <div class="flex items-center gap-1.5 justify-center">
              ${m.matched ? (() => {
                const conf = m.confidence || 0;
                let badgeClass = "bg-rose-950/40 text-rose-400 border border-rose-900/30";
                if (conf >= 85) {
                  badgeClass = "bg-emerald-950/40 text-emerald-400 border border-emerald-900/30";
                } else if (conf >= 50) {
                  badgeClass = "bg-amber-950/40 text-amber-400 border border-amber-900/30";
                }
                return `
                  <span class="text-[9px] ${badgeClass} px-2 py-0.5 rounded-full font-black tracking-wider shadow-sm shrink-0" title="${m.match_reason}">
                    ${m.confidence}% MATCH
                  </span>
                `;
              })() : `
                <span class="text-[9px] bg-zinc-850/80 text-zinc-400 border border-zinc-700/60 px-2 py-0.5 rounded-full font-black tracking-wider shrink-0">
                  UNMATCHED
                </span>
              `}
            </div>
            
            <div class="hidden lg:flex items-center justify-center text-zinc-650 mt-0.5">
              <svg class="w-4 h-4 text-zinc-600" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </div>
            
            <div class="text-[10px] text-zinc-500 font-extrabold truncate w-full tracking-wide max-w-[150px] lg:max-w-none text-right lg:text-center" title="${m.match_reason || ''}">
              ${m.matched ? m.match_reason : 'Manual override required'}
            </div>
          </div>

          <!-- Column 3: Target Selector Dropdown (TMDB) -->
          <div class="col-span-12 lg:col-span-4 flex items-center gap-2 min-w-0">
            <span class="text-[9px] bg-emerald-950/80 text-emerald-400 border border-emerald-900/40 px-1.5 py-0.5 rounded font-black tracking-wider uppercase shrink-0 lg:hidden">TMDB</span>
            
            <div class="w-full">
              <div class="relative w-full custom-search-select-container" data-index="${origIndex}">
                <!-- Search/Display Input -->
                <div class="flex items-center w-full bg-zinc-900/90 border border-zinc-800 hover:border-zinc-700 focus-within:border-indigo-500 rounded-xl transition-all duration-200 shadow-inner">
                  <input 
                    type="text" 
                    class="custom-search-select-input w-full bg-transparent px-3 py-2 text-xs text-zinc-200 font-semibold focus:outline-none cursor-pointer" 
                    placeholder="Search & select target episode..."
                    readonly
                  />
                  <!-- Dropdown Arrow -->
                  <div class="pr-2.5 text-zinc-500 pointer-events-none">
                    <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
                  </div>
                </div>
                <!-- Options Dropdown Box -->
                <div class="custom-search-select-dropdown hidden absolute top-full left-0 right-0 z-50 mt-1 max-h-60 overflow-y-auto bg-zinc-950 border border-zinc-800 rounded-xl shadow-2xl p-2 flex flex-col gap-2 backdrop-blur-md">
                  <!-- Inline search input inside dropdown -->
                  <div class="relative w-full shrink-0">
                    <input 
                      type="text" 
                      class="custom-search-select-filter w-full bg-zinc-900 border border-zinc-800 focus:border-indigo-500/80 rounded-lg px-2.5 py-1.5 text-[11px] text-zinc-300 focus:outline-none transition-all placeholder-zinc-650" 
                      placeholder="Type to search episodes..."
                    />
                  </div>
                  <!-- Options container -->
                  <div class="custom-search-select-options overflow-y-auto space-y-0.5 max-h-44 text-[11px] font-semibold text-zinc-400 scrollbar-thin">
                    <!-- Loaded on click -->
                  </div>
                </div>
              </div>
            </div>
          </div>
        `;

        previewMatchesList.appendChild(row);
      });

      // Populate select values
      previewMatchesList.querySelectorAll(".custom-search-select-container").forEach(el => {
        const idx = parseInt(el.getAttribute("data-index")!);
        const m = activeMappings[idx];
        const inputEl = el.querySelector(".custom-search-select-input") as HTMLInputElement;
        
        if (m.target_season !== null && m.target_episode !== null) {
          const foundEp = tmdbEpisodesList.find(ep => ep.season === m.target_season && ep.episode === m.target_episode);
          const titleText = foundEp ? foundEp.title : 'Untitled Episode';
          inputEl.value = `S${m.target_season.toString().padStart(2, '0')}E${m.target_episode.toString().padStart(2, '0')} - ${titleText}`;
          el.setAttribute("data-selected-value", `${m.target_season}:${m.target_episode}`);
        } else {
          inputEl.value = "-- Unmapped / Ignore --";
          el.setAttribute("data-selected-value", "");
        }
      });

      // Hook up custom search-select event listeners
      previewMatchesList.querySelectorAll(".custom-search-select-container").forEach(container => {
        const idx = parseInt(container.getAttribute("data-index")!);
        const inputEl = container.querySelector(".custom-search-select-input") as HTMLInputElement;
        const dropdownEl = container.querySelector(".custom-search-select-dropdown") as HTMLDivElement;
        const filterInput = container.querySelector(".custom-search-select-filter") as HTMLInputElement;
        const optionsContainer = container.querySelector(".custom-search-select-options") as HTMLDivElement;

        // Toggle open dropdown
        inputEl.addEventListener("click", (e) => {
          e.stopPropagation();
          
          // Close all other open dropdowns first!
          document.querySelectorAll(".custom-search-select-dropdown").forEach(d => {
            if (d !== dropdownEl) d.classList.add("hidden");
          });

          const isHidden = dropdownEl.classList.contains("hidden");
          if (isHidden) {
            dropdownEl.classList.remove("hidden");
            filterInput.value = "";
            filterInput.focus();
            
            // Build options dynamically!
            optionsContainer.innerHTML = "";
            
            // 1. Unmapped / Ignore option
            const unmappedDiv = document.createElement("div");
            unmappedDiv.className = "custom-option px-2.5 py-1.5 hover:bg-zinc-900 rounded-lg cursor-pointer transition-colors text-zinc-400 font-bold border border-transparent";
            unmappedDiv.setAttribute("data-value", "");
            unmappedDiv.textContent = "-- Unmapped / Ignore --";
            unmappedDiv.addEventListener("click", () => {
              selectOption("", "-- Unmapped / Ignore --");
            });
            optionsContainer.appendChild(unmappedDiv);

            // 2. All episodes from tmdbEpisodesList
            tmdbEpisodesList.forEach((ep: any) => {
              const optDiv = document.createElement("div");
              optDiv.className = "custom-option px-2.5 py-1.5 hover:bg-zinc-900 hover:text-zinc-100 rounded-lg cursor-pointer transition-colors border border-transparent";
              const val = `${ep.season}:${ep.episode}`;
              const label = `S${ep.season.toString().padStart(2, '0')}E${ep.episode.toString().padStart(2, '0')} - ${ep.title || 'Untitled Episode'}`;
              
              optDiv.setAttribute("data-value", val);
              optDiv.textContent = label;
              optDiv.addEventListener("click", () => {
                selectOption(val, label);
              });
              optionsContainer.appendChild(optDiv);
            });
          } else {
            dropdownEl.classList.add("hidden");
          }
        });

        // Live filter/search input inside the dropdown
        filterInput.addEventListener("input", (e) => {
          const query = (e.target as HTMLInputElement).value.toLowerCase().trim();
          optionsContainer.querySelectorAll(".custom-option").forEach(opt => {
            const label = opt.textContent?.toLowerCase() || "";
            const val = opt.getAttribute("data-value") || "";
            
            if (label.includes(query) || val.includes(query)) {
              (opt as HTMLElement).classList.remove("hidden");
            } else {
              (opt as HTMLElement).classList.add("hidden");
            }
          });
        });

        // Function to select an option
        function selectOption(val: string, label: string) {
          inputEl.value = label;
          container.setAttribute("data-selected-value", val);
          dropdownEl.classList.add("hidden");

          if (val === "") {
            activeMappings[idx].target_season = null;
            activeMappings[idx].target_episode = null;
            activeMappings[idx].target_title = null;
            activeMappings[idx].matched = false;
            
            // Uncheck checkbox
            const checkbox = previewMatchesList.querySelector(`.auto-include-checkbox[data-index="${idx}"]`) as HTMLInputElement;
            if (checkbox) checkbox.checked = false;
          } else {
            const [s, eNum] = val.split(":");
            activeMappings[idx].target_season = parseInt(s);
            activeMappings[idx].target_episode = parseInt(eNum);
            
            const foundEp = tmdbEpisodesList.find(ep => ep.season === activeMappings[idx].target_season && ep.episode === activeMappings[idx].target_episode);
            if (foundEp) {
              activeMappings[idx].target_title = foundEp.title;
            }
            activeMappings[idx].matched = true;
            
            // Check checkbox
            const checkbox = previewMatchesList.querySelector(`.auto-include-checkbox[data-index="${idx}"]`) as HTMLInputElement;
            if (checkbox) checkbox.checked = true;
          }
        }
      });

      // Hook up include checkbox listeners
      previewMatchesList.querySelectorAll(".auto-include-checkbox").forEach(el => {
        el.addEventListener("change", (e) => {
          const idx = parseInt((e.target as HTMLElement).getAttribute("data-index")!);
          activeMappings[idx].matched = (e.target as HTMLInputElement).checked;
        });
      });
    }

    // Global click listener to close open select dropdowns
    document.addEventListener("click", (e) => {
      if (!(e.target as HTMLElement).closest(".custom-search-select-container")) {
        document.querySelectorAll(".custom-search-select-dropdown").forEach(d => {
          d.classList.add("hidden");
        });
      }
    });

    if (autoRemapBtn) autoRemapBtn.addEventListener("click", openAutoModal);
    closeAutoModalBtn.addEventListener("click", closeAutoModal);
    cancelAutoModalBtn.addEventListener("click", closeAutoModal);
    autoModal.addEventListener("click", (e) => {
      if (e.target === autoModal) closeAutoModal();
    });

    generatePreviewBtn.addEventListener("click", async () => {
      const tmdbId = parseInt(autoTmdbIdInput.value);
      const tvdbId = parseInt(autoTvdbIdInput.value);
      
      if (!tmdbId || !tvdbId) {
        window.showToast?.("Please search and select both a TMDB show and a TVDB show!", "error");
        return;
      }
      if (!hasSavedTvdbKey) {
        window.showToast?.("TVDB API Key must be configured in settings to use the auto-remapper!", "error");
        return;
      }

      loader.classList.remove("hidden");
      previewArea.classList.add("hidden");
      generatePreviewBtn.disabled = true;
      applyAutoRemapsBtn.disabled = true;

      try {
        const res = await fetch("/api/proxy/sync/auto-map-tvdb-tmdb/preview", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            "Authorization": `Bearer ${token}`
          },
          body: JSON.stringify({
            tmdb_show_id: tmdbId,
            tvdb_show_id: tvdbId
          })
        });

        if (!res.ok) {
          const err = await res.json();
          window.showToast?.(err.detail || "Failed to generate preview", "error");
          loader.classList.add("hidden");
          generatePreviewBtn.disabled = false;
          return;
        }

        const data = await res.json();
        activeMappings = data.matches || [];
        tmdbEpisodesList = data.tmdb_episodes || [];
        
        // Compile dropdown options once in memory
        selectOptionsHtml = `<option value="">-- Unmapped / Ignore --</option>`;
        let currentSeason = -1;
        tmdbEpisodesList.forEach((ep: any) => {
          if (ep.season !== currentSeason) {
            if (currentSeason !== -1) selectOptionsHtml += `</optgroup>`;
            currentSeason = ep.season;
            selectOptionsHtml += `<optgroup label="Season ${currentSeason}">`;
          }
          selectOptionsHtml += `<option value="${ep.season}:${ep.episode}">S${ep.season.toString().padStart(2, '0')}E${ep.episode.toString().padStart(2, '0')} - ${ep.title || 'Untitled Episode'}</option>`;
        });
        if (currentSeason !== -1) selectOptionsHtml += `</optgroup>`;

        // Populate stats
        const totalTvdb = data.total_tvdb_episodes || 0;
        const matchedCount = data.matched_count || 0;
        const unmatchedCount = activeMappings.filter(m => !m.matched).length;
        
        const pct = totalTvdb > 0 ? Math.round((matchedCount / totalTvdb) * 100) : 0;
        previewMatchStats.textContent = `${matchedCount} / ${totalTvdb} matched successfully`;
        previewMatchPct.textContent = `${pct}% Match Rate`;
        
        if (pct >= 85) {
          previewMatchPct.className = "text-xs bg-emerald-950/80 border border-emerald-900/60 text-emerald-400 px-2 py-0.5 rounded-full font-extrabold";
        } else if (pct >= 50) {
          previewMatchPct.className = "text-xs bg-amber-950/80 border border-amber-900/60 text-amber-400 px-2 py-0.5 rounded-full font-extrabold";
        } else {
          previewMatchPct.className = "text-xs bg-rose-950/80 border border-rose-900/60 text-rose-400 px-2 py-0.5 rounded-full font-extrabold";
        }

        previewUnmatchedBadge.textContent = `${unmatchedCount} unmatched`;
        unmatchedCountBadge.textContent = unmatchedCount.toString();

        // Render matched pairs
        renderList();

        loader.classList.add("hidden");
        previewArea.classList.remove("hidden");
        generatePreviewBtn.disabled = false;
        
        if (activeMappings.length > 0) {
          applyAutoRemapsBtn.disabled = false;
        }
      } catch (err: any) {
        window.showToast?.("Error communicating with server", "error");
        loader.classList.add("hidden");
        generatePreviewBtn.disabled = false;
      }
    });

    applyAutoRemapsBtn.addEventListener("click", async () => {
      const tmdbId = parseInt(autoTmdbIdInput.value);
      const tvdbId = parseInt(autoTvdbIdInput.value);
      
      const mappingsToApply = activeMappings.filter(m => m.matched && m.target_season !== null && m.target_episode !== null);
      if (mappingsToApply.length === 0) {
        window.showToast?.("No active mappings with filled target coordinates are checked!", "error");
        return;
      }

      applyAutoRemapsBtn.disabled = true;
      applyAutoRemapsBtn.textContent = "Applying Overrides...";

      try {
        const payload = {
          tmdb_show_id: tmdbId,
          target_show_tmdb_id: tmdbId,
          tvdb_show_id: tvdbId,
          mappings: mappingsToApply.map(m => ({
            source_season: m.source_season,
            source_episode: m.source_episode,
            target_season: m.target_season,
            target_episode: m.target_episode
          }))
        };

        const res = await fetch("/api/proxy/sync/auto-map-tvdb-tmdb/apply", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            "Authorization": `Bearer ${token}`
          },
          body: JSON.stringify(payload)
        });

        if (res.ok) {
          const data = await res.json();
          window.showToast?.(`Successfully applied ${data.overrides_created} overrides and remapped ${data.media_remapped} library items!`, "success");
          closeAutoModal();
          setTimeout(() => window.location.reload(), 1000);
        } else {
          const err = await res.json();
          window.showToast?.(err.detail || "Failed to apply auto-remaps", "error");
          applyAutoRemapsBtn.disabled = false;
          applyAutoRemapsBtn.textContent = "Apply Auto-Remaps";
        }
      } catch (e) {
        window.showToast?.("Error communicating with server", "error");
        applyAutoRemapsBtn.disabled = false;
        applyAutoRemapsBtn.textContent = "Apply Auto-Remaps";
      }
    });

    // Auto-fill and Open Modals based on URL Query Parameters
    const params = new URLSearchParams(window.location.search);
    const mode = params.get('mode');
    
    if (mode === 'season') {
      const tmdb = params.get('src_tmdb');
      const season = params.get('src_season');
      
      if (tmdb) {
        // 1. Open the Season Remap Modal
        resetModalState();
        remapModal.classList.remove("opacity-0", "pointer-events-none");
        
        // 2. Fetch local shows and select matching card
        fetchLocalShows().then(() => {
          const matchedShow = localShowsList.find(s => s.tmdb_id.toString() === tmdb);
          if (matchedShow) {
            selectSourceShow(matchedShow);
            
            if (season) {
              // Wait for buttons to render, then select the season
              setTimeout(() => {
                const seasonButtonsList = sourceSeasonButtons.querySelectorAll("button");
                seasonButtonsList.forEach(sBtn => {
                  const txt = sBtn.textContent || "";
                  if (txt.includes(`Season ${season}`) || (season === "0" && txt.includes("Specials"))) {
                    (sBtn as HTMLButtonElement).click();
                  }
                });
              }, 100);
            }
          } else {
            // Toggle to manual mode and load show metadata
            if (sourceMode === "select") {
              toggleSourceModeBtn.click();
            }
            sourceShowTmdbInput.value = tmdb;
            if (season) sourceSeasonInput.value = season;
            sourceShowLookupBtn.click();
          }
        });

        // 3. Pre-fill target show search with the same TMDB ID to make remapping easy
        targetSearchInput.value = tmdb;
        targetSearchBtn.click();
      }
      // Remove params from URL so refresh doesn't pop it open again
      window.history.replaceState({}, document.title, window.location.pathname);
    } else if (mode === 'ep') {
      const tmdb = params.get('src_tmdb');
      const season = params.get('src_season');
      const ep = params.get('src_ep');
      
      if (tmdb) {
        // 1. Open the Episode Remap Modal
        openEpModal();
        
        // 2. Fill the manual coordinate inputs directly
        epSrcTmdbInput.value = tmdb;
        epTgtTmdbInput.value = tmdb;
        if (season) epSrcSeasonInput.value = season;
        if (ep) epSrcEpisodeStartInput.value = ep;
        
        // Trigger target TMDB id listener
        epSrcTmdbInput.dispatchEvent(new Event("input"));
      }
      // Remove params from URL so refresh doesn't pop it open again
      window.history.replaceState({}, document.title, window.location.pathname);
    }

  });
</script>
