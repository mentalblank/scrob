        <div id="rename-season-section" class="hidden space-y-3 bg-zinc-950/40 border border-zinc-850 p-4 rounded-2xl">
          <label class="block text-xs font-black uppercase tracking-widest text-zinc-400">3. Select Season</label>
          <div id="rename-season-buttons" class="flex flex-wrap gap-2"></div>
        </div>

        <!-- Select Episode (Conditional) -->
        <div id="rename-episode-section" class="hidden space-y-3 bg-zinc-950/40 border border-zinc-850 p-4 rounded-2xl">
          <label class="block text-xs font-black uppercase tracking-widest text-zinc-400">4. Select Episode</label>
          <div id="rename-episode-container" class="max-h-48 overflow-y-auto space-y-2 pr-1 no-scrollbar">
            <p class="text-[10px] text-zinc-500 italic">Select a season first</p>
          </div>
        </div>

        <!-- Custom Name Input -->
        <div class="space-y-3">
          <label class="block text-xs font-black uppercase tracking-widest text-zinc-400">Configure Title Override</label>
          <input type="text" id="rename-custom-title-input" placeholder="Enter custom override name (e.g. Demon Slayer - Entertainment District Arc)..." class="w-full bg-zinc-900 border border-zinc-800 rounded-xl px-4 py-2.5 text-zinc-200 text-xs focus:border-indigo-500 focus:outline-none transition" />
        </div>

      </div>

      <!-- Modal Footer -->
      <div class="px-6 py-4 border-t border-zinc-850 bg-zinc-950/60 flex items-center justify-end shrink-0 gap-3">
        <button id="cancel-rename-modal-btn" class="px-5 py-2.5 bg-zinc-800 hover:bg-zinc-750 text-zinc-300 font-bold rounded-xl text-xs transition-all cursor-pointer">
          Cancel
        </button>
        <button id="save-rename-btn" class="px-6 py-2.5 bg-indigo-600 hover:bg-indigo-500 text-white font-bold rounded-xl text-xs transition-all shadow-lg active:scale-95 cursor-pointer">
          Save Custom Rename
        </button>
      </div>

    </div>
  </div>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const appData = document.getElementById("app-data");
    const token = appData?.dataset.token;
    const hasSavedTvdbKey = appData?.dataset.hasTvdbKey === "true";
    if (!token) return;
    // Modal Control Elements
    const remapModal = document.getElementById("remap-modal")!;
    const addRemapBtn = document.getElementById("add-remap-btn")!;
    const closeModalBtn = document.getElementById("close-modal-btn")!;
    const cancelModalBtn = document.getElementById("cancel-modal-btn")!;
    const saveRemapBtn = document.getElementById("save-remap-btn") as HTMLButtonElement;

    // Wizard Step 1 Elements (Source)
    const toggleSourceModeBtn = document.getElementById("toggle-source-mode-btn")!;
    const sourceSelectGroup = document.getElementById("source-select-group")!;
    const sourceManualGroup = document.getElementById("source-manual-group")!;
    const sourceSearchInput = document.getElementById("source-search-input") as HTMLInputElement;
    const sourceSearchBtn = document.getElementById("source-search-btn")!;
    const sourceSearchResultsContainer = document.getElementById("source-search-results-container")!;
    const sourceSelectedCard = document.getElementById("source-selected-card")!;
    const sourceSelectedPoster = document.getElementById("source-selected-poster") as HTMLImageElement;
    const sourceSelectedNoPoster = document.getElementById("source-selected-no-poster")!;
    const sourceSelectedTitle = document.getElementById("source-selected-title")!;
    const sourceSelectedMeta = document.getElementById("source-selected-meta")!;
    const sourceChangeBtn = document.getElementById("source-change-btn")!;
    const sourceSeasonGroup = document.getElementById("source-season-group")!;
    const sourceSeasonButtons = document.getElementById("source-season-buttons")!;

    const sourceShowTmdbInput = document.getElementById("source-show-tmdb-input") as HTMLInputElement;
    const sourceSeasonInput = document.getElementById("source-season-input") as HTMLInputElement;
    const sourceShowLookupBtn = document.getElementById("source-show-lookup-btn")!;
    const sourceManualPreview = document.getElementById("source-manual-preview")!;
    const sourceManualPoster = document.getElementById("source-manual-poster") as HTMLImageElement;
    const sourceManualNoPoster = document.getElementById("source-manual-no-poster")!;
    const sourceManualTitle = document.getElementById("source-manual-title")!;
    const sourceManualMeta = document.getElementById("source-manual-meta")!;

    // Wizard Step 2 Elements (Target)
    const targetSelectGroup = document.getElementById("target-select-group")!;
    const targetSearchInput = document.getElementById("target-search-input") as HTMLInputElement;
    const targetSearchBtn = document.getElementById("target-search-btn")!;
    const searchResultsContainer = document.getElementById("search-results-container")!;
    const targetSelectedCard = document.getElementById("target-selected-card")!;
    const targetSelectedPoster = document.getElementById("target-selected-poster") as HTMLImageElement;
    const targetSelectedNoPoster = document.getElementById("target-selected-no-poster")!;
    const targetSelectedTitle = document.getElementById("target-selected-title")!;
    const targetSelectedMeta = document.getElementById("target-selected-meta")!;
    const targetChangeBtn = document.getElementById("target-change-btn")!;
    const targetSeasonGroup = document.getElementById("target-season-group")!;
    const targetSeasonButtons = document.getElementById("target-season-buttons")!;

    const targetManualGroup = document.getElementById("target-manual-group")!;
    const targetShowTmdbInput = document.getElementById("target-show-tmdb-input") as HTMLInputElement;
    const targetSeasonInput = document.getElementById("target-season-input") as HTMLInputElement;
    const targetShowLookupBtn = document.getElementById("target-show-lookup-btn")!;
    const targetManualPreview = document.getElementById("target-manual-preview")!;
    const targetManualPoster = document.getElementById("target-manual-poster") as HTMLImageElement;
    const targetManualNoPoster = document.getElementById("target-manual-no-poster")!;
    const targetManualTitle = document.getElementById("target-manual-title")!;
    const targetManualMeta = document.getElementById("target-manual-meta")!;

    // State Variables
    let sourceMode: "select" | "manual" = "select";
    let localShowsList: any[] = [];
    let localMoviesList: any[] = [];
    let selectedLocalShowObj: any = null;
    let selectedLocalSeasonNum: number | null = null;

    let targetSelectedShowObj: any = null;
    let targetSelectedSeasonNum: number | null = null;

    // Open Modal Action
    addRemapBtn.addEventListener("click", () => {
      resetModalState();
      remapModal.classList.remove("opacity-0", "pointer-events-none");
      fetchLocalShows();
    });

    // Close Modal Action
    const closeModal = () => {
      remapModal.classList.add("opacity-0", "pointer-events-none");
    };
    closeModalBtn.addEventListener("click", closeModal);
    cancelModalBtn.addEventListener("click", closeModal);

    // Toggle manual/selection inputs for source and target show simultaneously
    toggleSourceModeBtn.addEventListener("click", () => {
      if (sourceMode === "select") {
        sourceMode = "manual";
        sourceSelectGroup.classList.add("hidden");
        sourceManualGroup.classList.remove("hidden");
        targetSelectGroup.classList.add("hidden");
        targetManualGroup.classList.remove("hidden");
        toggleSourceModeBtn.textContent = "Select From Collection";
      } else {
        sourceMode = "select";
        sourceManualGroup.classList.add("hidden");
        sourceSelectGroup.classList.remove("hidden");
        targetManualGroup.classList.add("hidden");
        targetSelectGroup.classList.remove("hidden");
        toggleSourceModeBtn.textContent = "Toggle Manual TMDB Input";
      }
      validateForm();
    });

    // Fetch shows in user's collection
    async function fetchLocalShows() {
      if (localShowsList && localShowsList.length > 0) {
        return;
      }
      try {
        const res = await fetch("/api/proxy/sync/source-shows", {
          headers: { "Authorization": `Bearer ${token}` }
        });
        if (res.ok) {
          const data = await res.json();
          localShowsList = Array.isArray(data) ? data : data.results || [];
        }
      } catch (err) {
        console.error("Error loading local shows", err);
      }
    }

    // Fetch movies in user's collection
    async function fetchLocalMovies() {
      if (localMoviesList && localMoviesList.length > 0) {
        return;
      }
      try {
        const res = await fetch("/api/proxy/sync/source-movies", {
          headers: { "Authorization": `Bearer ${token}` }
        });
        if (res.ok) {
          const data = await res.json();
          localMoviesList = Array.isArray(data) ? data : data.results || [];
        }
      } catch (err) {
        console.error("Error loading local movies", err);
      }
    }

    const performSourceSearch = () => {
      const q = sourceSearchInput.value.trim().toLowerCase();
      if (!q) {
        renderSourceSearchResults(localShowsList);
        return;
      }
      const filtered = localShowsList.filter(show => 
        show.title.toLowerCase().includes(q) || 
        (show.original_title && show.original_title.toLowerCase().includes(q)) || 
        show.tmdb_id.toString().includes(q)
      );
      renderSourceSearchResults(filtered);
    };

    sourceSearchBtn.addEventListener("click", performSourceSearch);
    sourceSearchInput.addEventListener("keydown", (e) => {
      if (e.key === "Enter") {
        e.preventDefault();
        performSourceSearch();
      }
    });

    function renderSourceSearchResults(results: any[]) {
      sourceSearchResultsContainer.innerHTML = "";
      if (results.length === 0) {
        sourceSearchResultsContainer.innerHTML = '<div class="col-span-full text-center text-xs text-zinc-500 py-6">No matching local shows found.</div>';
        sourceSearchResultsContainer.classList.remove("hidden");
        return;
      }

      results.forEach(show => {
        const card = document.createElement("div");
        card.className = "flex flex-col p-2 bg-zinc-900 border border-zinc-800 rounded-xl hover:border-zinc-700 cursor-pointer transition text-left group";
        
        let imgHtml = `<div class="aspect-[2/3] w-full rounded-lg bg-zinc-950 overflow-hidden mb-2 border border-zinc-800 flex items-center justify-center text-[10px] text-zinc-650 font-bold">NO ART</div>`;
        if (show.poster_path) {
          imgHtml = `
            <div class="aspect-[2/3] w-full rounded-lg bg-zinc-950 overflow-hidden mb-2 border border-zinc-800 shadow-sm relative">
              <img src="${show.poster_path}" alt="" class="w-full h-full object-cover group-hover:scale-105 transition-all duration-300" loading="lazy" />
            </div>
          `;
        }

        const year = show.first_air_date ? new Date(show.first_air_date).getFullYear() : "N/A";

        card.innerHTML = `
          ${imgHtml}
          <span class="text-[8px] font-bold text-blue-400 uppercase tracking-wider">Local ID: ${show.tmdb_id}</span>
          <h4 class="text-zinc-200 font-bold truncate text-xs mt-0.5" title="${show.title}">${show.title}</h4>
          <span class="text-[10px] text-zinc-500 font-medium">${year}</span>
        `;

        card.addEventListener("click", () => selectSourceShow(show));
        sourceSearchResultsContainer.appendChild(card);
      });
      sourceSearchResultsContainer.classList.remove("hidden");
    }

    function selectSourceShow(show: any) {
      selectedLocalShowObj = show;
      selectedLocalSeasonNum = null;

      // Show Selected Card
      sourceSelectedTitle.textContent = show.title;
      const year = show.first_air_date ? new Date(show.first_air_date).getFullYear() : "N/A";
      sourceSelectedMeta.textContent = `${year} • TMDB ID: ${show.tmdb_id}`;
      
      if (show.poster_path) {
        sourceSelectedPoster.src = show.poster_path;
        sourceSelectedPoster.classList.remove("hidden");
        sourceSelectedNoPoster.classList.add("hidden");
      } else {
        sourceSelectedPoster.classList.add("hidden");
        sourceSelectedNoPoster.classList.remove("hidden");
      }

      sourceSearchResultsContainer.classList.add("hidden");
      sourceSearchInput.classList.add("hidden");
      sourceSearchBtn.classList.add("hidden");
      sourceSelectedCard.classList.remove("hidden");

      renderSourceSeasonButtons(show.seasons_meta || []);
    }

    sourceChangeBtn.addEventListener("click", () => {
      selectedLocalShowObj = null;
      selectedLocalSeasonNum = null;
      sourceSelectedCard.classList.add("hidden");
      sourceSeasonGroup.classList.add("hidden");
      sourceSearchInput.classList.remove("hidden");
      sourceSearchBtn.classList.remove("hidden");
      sourceSearchResultsContainer.classList.remove("hidden");
      renderSourceSearchResults(localShowsList);
      validateForm();
    });

    function renderSourceSeasonButtons(seasons: any[]) {
      sourceSeasonButtons.innerHTML = "";
      if (seasons.length === 0) {
        sourceSeasonButtons.innerHTML = '<span class="text-xs text-zinc-500">No seasons found for this show.</span>';
        sourceSeasonGroup.classList.remove("hidden");
        return;
      }

      seasons.forEach(season => {
        const label = season.season_number === 0 ? "Specials" : `Season ${season.season_number}`;
        const btn = document.createElement("button");
        btn.type = "button";
        btn.className = "px-3.5 py-2 border border-zinc-800 hover:border-zinc-700 bg-zinc-900/60 hover:bg-zinc-800 text-zinc-300 font-bold text-xs rounded-xl cursor-pointer transition active:scale-95";
        btn.textContent = `${label} (${season.episode_count || 0} eps)`;
        
        btn.addEventListener("click", () => {
          // Reset previous button styles
          sourceSeasonButtons.querySelectorAll("button").forEach(b => {
            b.className = "px-3.5 py-2 border border-zinc-800 hover:border-zinc-700 bg-zinc-900/60 hover:bg-zinc-800 text-zinc-300 font-bold text-xs rounded-xl cursor-pointer transition active:scale-95";
          });
          // Set active style
          btn.className = "px-3.5 py-2 border border-blue-800 bg-blue-950/40 text-blue-300 font-bold text-xs rounded-xl cursor-pointer transition shadow-md";
          selectedLocalSeasonNum = season.season_number;
          validateForm();
        });

        sourceSeasonButtons.appendChild(btn);
      });
      sourceSeasonGroup.classList.remove("hidden");
    }

    sourceShowTmdbInput.addEventListener("input", validateForm);
    sourceSeasonInput.addEventListener("input", validateForm);
    targetShowTmdbInput.addEventListener("input", validateForm);
    targetSeasonInput.addEventListener("input", validateForm);

    // Manual Source Show Lookup
    sourceShowLookupBtn.addEventListener("click", async () => {
      const tmdbId = sourceShowTmdbInput.value.trim();
      if (!tmdbId) return;

      sourceShowLookupBtn.textContent = "...";
      try {
        const res = await fetch(`/api/proxy/sync/tmdb-show-preview/${tmdbId}`, {
          headers: { "Authorization": `Bearer ${token}` }
        });
        if (res.ok) {
          const data = await res.json();
          sourceManualTitle.textContent = data.title;
          const year = data.first_air_date ? new Date(data.first_air_date).getFullYear() : 'N/A';
          sourceManualMeta.textContent = `${year} • TMDB ID: ${data.tmdb_id}`;
          
          if (data.poster_path) {
            sourceManualPoster.src = data.poster_path;
            sourceManualPoster.classList.remove("hidden");
            sourceManualNoPoster.classList.add("hidden");
          } else {
            sourceManualPoster.classList.add("hidden");
            sourceManualNoPoster.classList.remove("hidden");
          }
          sourceManualPreview.classList.remove("hidden");
        } else {
          window.showToast?.("Show not found on TMDB", "error");
          sourceManualPreview.classList.add("hidden");
        }
      } catch (err) {
        window.showToast?.("Error fetching show", "error");
        sourceManualPreview.classList.add("hidden");
      } finally {
        sourceShowLookupBtn.textContent = "Lookup";
      }
    });

    // Manual Target Show Lookup
    targetShowLookupBtn.addEventListener("click", async () => {
      const tmdbId = targetShowTmdbInput.value.trim();
      if (!tmdbId) return;

      targetShowLookupBtn.textContent = "...";
      try {
        const res = await fetch(`/api/proxy/sync/tmdb-show-preview/${tmdbId}`, {
          headers: { "Authorization": `Bearer ${token}` }
        });
        if (res.ok) {
          const data = await res.json();
          targetManualTitle.textContent = data.title;
          const year = data.first_air_date ? new Date(data.first_air_date).getFullYear() : 'N/A';
          targetManualMeta.textContent = `${year} • TMDB ID: ${data.tmdb_id}`;
          
          if (data.poster_path) {
            targetManualPoster.src = data.poster_path;
            targetManualPoster.classList.remove("hidden");
            targetManualNoPoster.classList.add("hidden");
          } else {
            targetManualPoster.classList.add("hidden");
            targetManualNoPoster.classList.remove("hidden");
          }
          targetManualPreview.classList.remove("hidden");
        } else {
          window.showToast?.("Show not found on TMDB", "error");
          targetManualPreview.classList.add("hidden");
        }
      } catch (err) {
        window.showToast?.("Error fetching show", "error");
        targetManualPreview.classList.add("hidden");
      } finally {
        targetShowLookupBtn.textContent = "Lookup";
      }
    });

    // Target TMDB Search Action
    const performSearch = async () => {
      const q = targetSearchInput.value.trim();
      if (!q) return;

      targetSearchBtn.textContent = "Searching...";
      try {
        if (/^\d+$/.test(q)) {
          // Direct TMDB ID lookup
          const res = await fetch(`/api/proxy/sync/tmdb-show-preview/${q}`, {
            headers: { "Authorization": `Bearer ${token}` }
          });
          if (res.ok) {
            const data = await res.json();
            const normalizedResult = {
              tmdb_id: data.tmdb_id,
              title: data.title,
              poster_path: data.poster_path,
              release_date: data.first_air_date
            };
            renderSearchResults([normalizedResult]);
            return;
          }
        }

        // Standard text search fallback
        const res = await fetch(`/api/proxy/media/search?type=series&q=${encodeURIComponent(q)}`, {
          headers: { "Authorization": `Bearer ${token}` }
        });
        if (res.ok) {
          const data = await res.json();
          renderSearchResults(data.results || []);
        } else {
          window.showToast?.("Failed to fetch search results", "error");
        }
      } catch (err) {
        window.showToast?.("Error searching target shows", "error");
      } finally {
        targetSearchBtn.textContent = "Search";
      }
    };

    targetSearchBtn.addEventListener("click", performSearch);
    targetSearchInput.addEventListener("keydown", (e) => {
      if (e.key === "Enter") {
        e.preventDefault();
        performSearch();
      }
    });

    function renderSearchResults(results: any[]) {
      searchResultsContainer.innerHTML = "";
      if (results.length === 0) {
        searchResultsContainer.innerHTML = '<div class="col-span-full text-center text-xs text-zinc-500 py-6">No matching shows found on TMDB.</div>';
        searchResultsContainer.classList.remove("hidden");
        return;
      }

      results.forEach(show => {
        const card = document.createElement("div");
        card.className = "flex flex-col p-2 bg-zinc-900 border border-zinc-800 rounded-xl hover:border-zinc-700 cursor-pointer transition text-left group";
        
        let imgHtml = `<div class="aspect-[2/3] w-full rounded-lg bg-zinc-950 overflow-hidden mb-2 border border-zinc-800 flex items-center justify-center text-[10px] text-zinc-650 font-bold">NO ART</div>`;
        if (show.poster_path) {
          imgHtml = `
            <div class="aspect-[2/3] w-full rounded-lg bg-zinc-950 overflow-hidden mb-2 border border-zinc-800 shadow-sm relative">
              <img src="${show.poster_path}" alt="" class="w-full h-full object-cover group-hover:scale-105 transition-all duration-300" loading="lazy" />
            </div>
          `;
        }

        const year = show.release_date ? new Date(show.release_date).getFullYear() : "N/A";

        card.innerHTML = `
          ${imgHtml}
          <span class="text-[8px] font-bold text-blue-400 uppercase tracking-wider">TMDB: ${show.tmdb_id}</span>
          <h4 class="text-zinc-200 font-bold truncate text-xs mt-0.5" title="${show.title}">${show.title}</h4>
          <span class="text-[10px] text-zinc-500 font-medium">${year}</span>
        `;

        card.addEventListener("click", () => selectTargetShow(show));
        searchResultsContainer.appendChild(card);
      });
      searchResultsContainer.classList.remove("hidden");
    }

    async function selectTargetShow(show: any) {
      targetSelectedShowObj = show;
      targetSelectedSeasonNum = null;

      // Show Selected Card
      targetSelectedTitle.textContent = show.title;
      const year = show.release_date ? new Date(show.release_date).getFullYear() : "N/A";
      targetSelectedMeta.textContent = `${year} • TMDB ID: ${show.tmdb_id}`;
      
      if (show.poster_path) {
        targetSelectedPoster.src = show.poster_path;
        targetSelectedPoster.classList.remove("hidden");
        targetSelectedNoPoster.classList.add("hidden");
      } else {
        targetSelectedPoster.classList.add("hidden");
        targetSelectedNoPoster.classList.remove("hidden");
      }

      searchResultsContainer.classList.add("hidden");
      targetSearchInput.classList.add("hidden");
      targetSearchBtn.classList.add("hidden");
      targetSelectedCard.classList.remove("hidden");

      // Fetch Target Show Seasons List
      try {
        const res = await fetch(`/api/proxy/shows/${show.tmdb_id}`, {
          headers: { "Authorization": `Bearer ${token}` }
        });
        if (res.ok) {
          const detail = await res.json();
          renderTargetSeasonButtons(detail.seasons_meta || []);
        } else {
          window.showToast?.("Failed to fetch target show seasons details", "error");
        }
      } catch (err) {
        window.showToast?.("Error fetching target seasons list", "error");
      }
    }

    targetChangeBtn.addEventListener("click", () => {
      targetSelectedShowObj = null;
      targetSelectedSeasonNum = null;
      targetSelectedCard.classList.add("hidden");
      targetSeasonGroup.classList.add("hidden");
      targetSearchInput.classList.remove("hidden");
      targetSearchBtn.classList.remove("hidden");
      searchResultsContainer.classList.remove("hidden");
      validateForm();
    });

    function renderTargetSeasonButtons(seasons: any[]) {
      targetSeasonButtons.innerHTML = "";
      if (seasons.length === 0) {
        targetSeasonButtons.innerHTML = '<span class="text-xs text-zinc-500">No seasons found for this show.</span>';
        targetSeasonGroup.classList.remove("hidden");
        return;
      }

      seasons.forEach(season => {
        const label = season.season_number === 0 ? "Specials" : `Season ${season.season_number}`;
        const btn = document.createElement("button");
        btn.type = "button";
        btn.className = "px-3.5 py-2 border border-zinc-800 hover:border-zinc-700 bg-zinc-900/60 hover:bg-zinc-800 text-zinc-300 font-bold text-xs rounded-xl cursor-pointer transition active:scale-95";
        btn.textContent = `${label} (${season.episode_count || 0} eps)`;
        
        btn.addEventListener("click", () => {
          targetSeasonButtons.querySelectorAll("button").forEach(b => {
            b.className = "px-3.5 py-2 border border-zinc-800 hover:border-zinc-700 bg-zinc-900/60 hover:bg-zinc-800 text-zinc-300 font-bold text-xs rounded-xl cursor-pointer transition active:scale-95";
          });
          btn.className = "px-3.5 py-2 border border-blue-800 bg-blue-950/40 text-blue-300 font-bold text-xs rounded-xl cursor-pointer transition shadow-md";
          targetSelectedSeasonNum = season.season_number;
          validateForm();
        });

        targetSeasonButtons.appendChild(btn);
      });

      // Add a manual input fallback for anthologies or unlisted seasons
      const manualDiv = document.createElement("div");
      manualDiv.className = "flex items-center gap-2 mt-3 p-3 bg-zinc-900/50 border border-zinc-800 rounded-xl";
      manualDiv.innerHTML = `
        <span class="text-xs font-bold text-zinc-500 whitespace-nowrap">Not listed?</span>
        <input type="number" id="manual-target-season" placeholder="Season #" class="w-24 bg-zinc-950 border border-zinc-800 rounded-lg px-2 py-1.5 text-zinc-200 text-xs focus:border-blue-500 focus:outline-none transition" />
        <button type="button" id="manual-target-season-btn" class="px-3 py-1.5 bg-zinc-800 hover:bg-zinc-700 text-zinc-300 font-bold rounded-lg text-xs transition cursor-pointer">Use</button>
      `;
      targetSeasonButtons.appendChild(manualDiv);

      const manualInput = manualDiv.querySelector("#manual-target-season") as HTMLInputElement;
      const manualBtn = manualDiv.querySelector("#manual-target-season-btn")!;
      manualBtn.addEventListener("click", () => {
        const val = parseInt(manualInput.value);
        if (!isNaN(val) && val >= 0) {
          targetSeasonButtons.querySelectorAll("button").forEach(b => {
            if (b.id !== "manual-target-season-btn") {
              b.className = "px-3.5 py-2 border border-zinc-800 hover:border-zinc-700 bg-zinc-900/60 hover:bg-zinc-800 text-zinc-300 font-bold text-xs rounded-xl cursor-pointer transition active:scale-95";
            }
          });
          manualBtn.className = "px-3 py-1.5 bg-blue-900 hover:bg-blue-800 text-blue-200 font-bold rounded-lg text-xs transition cursor-pointer shadow-md border border-blue-700";
          targetSelectedSeasonNum = val;
          validateForm();
        }
      });

      targetSeasonGroup.classList.remove("hidden");
    }

    function validateForm() {
      let isSourceValid = false;
      if (sourceMode === "select") {
        isSourceValid = !!selectedLocalShowObj && selectedLocalSeasonNum !== null;
      } else {
        isSourceValid = !!sourceShowTmdbInput.value && !!sourceSeasonInput.value;
      }

      let isTargetValid = false;
      if (sourceMode === "select") {
        isTargetValid = !!targetSelectedShowObj && targetSelectedSeasonNum !== null;
      } else {
        isTargetValid = !!targetShowTmdbInput.value && !!targetSeasonInput.value;
      }

      saveRemapBtn.disabled = !(isSourceValid && isTargetValid);
    }

    function resetModalState() {
      sourceMode = "select";
      sourceSelectGroup.classList.remove("hidden");
      sourceManualGroup.classList.add("hidden");
      toggleSourceModeBtn.textContent = "Toggle Manual TMDB Input";

      sourceSearchInput.value = "";
      sourceSearchInput.classList.remove("hidden");
      sourceSearchBtn.classList.remove("hidden");
      sourceSearchResultsContainer.innerHTML = "";
      sourceSearchResultsContainer.classList.add("hidden");
      sourceSelectedCard.classList.add("hidden");
      sourceSeasonGroup.classList.add("hidden");
      sourceSeasonButtons.innerHTML = "";
      
      sourceShowTmdbInput.value = "";
      sourceSeasonInput.value = "";
      sourceManualPreview.classList.add("hidden");

      targetSelectGroup.classList.remove("hidden");
      targetManualGroup.classList.add("hidden");
      targetSearchInput.value = "";
      targetSearchInput.classList.remove("hidden");
      targetSearchBtn.classList.remove("hidden");
      searchResultsContainer.innerHTML = "";
      searchResultsContainer.classList.add("hidden");
      targetSelectedCard.classList.add("hidden");
      targetSeasonGroup.classList.add("hidden");
      targetSeasonButtons.innerHTML = "";

      targetShowTmdbInput.value = "";
      targetSeasonInput.value = "";
      targetManualPreview.classList.add("hidden");

      selectedLocalShowObj = null;
      selectedLocalSeasonNum = null;
      targetSelectedShowObj = null;
      targetSelectedSeasonNum = null;

      saveRemapBtn.disabled = true;
    }

    // Save and Apply Remap
    saveRemapBtn.addEventListener("click", async () => {
      let sourceTmdbId: number;
      let sourceSeasonNum: number;
      let targetTmdbId: number;
      let targetSeasonNum: number;

      if (sourceMode === "select") {
        sourceTmdbId = selectedLocalShowObj.tmdb_id;
        sourceSeasonNum = selectedLocalSeasonNum!;
        targetTmdbId = targetSelectedShowObj.tmdb_id;
        targetSeasonNum = targetSelectedSeasonNum!;
      } else {
        sourceTmdbId = parseInt(sourceShowTmdbInput.value);
        sourceSeasonNum = parseInt(sourceSeasonInput.value);
        targetTmdbId = parseInt(targetShowTmdbInput.value);
        targetSeasonNum = parseInt(targetSeasonInput.value);
      }

      saveRemapBtn.disabled = true;
      saveRemapBtn.textContent = "Saving...";

      try {
        const createRes = await fetch("/api/proxy/sync/season-overrides", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            "Authorization": `Bearer ${token}`
          },
          body: JSON.stringify({
            source_show_tmdb_id: sourceTmdbId,
            source_season_number: sourceSeasonNum,
            target_show_tmdb_id: targetTmdbId,
            target_season_number: targetSeasonNum
          })
        });

        if (!createRes.ok) {
          const detail = await createRes.json();
          window.showToast?.(detail.detail || "Failed to create Season Override", "error");
          saveRemapBtn.disabled = false;
          saveRemapBtn.textContent = "Save & Apply Remap";
          return;
        }

        const override = await createRes.json();
        saveRemapBtn.textContent = "Applying Override...";

        const applyRes = await fetch(`/api/proxy/sync/season-overrides/${override.id}/apply`, {
          method: "POST",
          headers: { "Authorization": `Bearer ${token}` }
        });

        if (applyRes.ok) {
          const result = await applyRes.json();
          window.showToast?.(`Remapped successfully! Remapped ${result.remapped} episode(s).`, "success");
          closeModal();
          setTimeout(() => window.location.reload(), 1000);
        } else {
          window.showToast?.("Remap saved, but failed to apply metadata shift.", "error");
          closeModal();
          setTimeout(() => window.location.reload(), 1000);
        }
      } catch (err) {
        window.showToast?.("Error saving custom season override", "error");
        saveRemapBtn.disabled = false;
        saveRemapBtn.textContent = "Save & Apply Remap";
      }
    });


    // Custom Rename Modal Elements
    const renameModal = document.getElementById("rename-modal")!;
    const addRenameBtn = document.getElementById("add-rename-btn")!;
    const closeRenameModalBtn = document.getElementById("close-rename-modal-btn")!;
    const cancelRenameModalBtn = document.getElementById("cancel-rename-modal-btn")!;
    const saveRenameBtn = document.getElementById("save-rename-btn") as HTMLButtonElement;

    const renameTypeMovie = document.getElementById("rename-type-movie")!;
    const renameTypeShow = document.getElementById("rename-type-show")!;
    const renameTypeSeason = document.getElementById("rename-type-season")!;
    const renameTypeEpisode = document.getElementById("rename-type-episode")!;
    const renameTypeSection = document.getElementById("rename-type-section")!;

    const renameShowSearch = document.getElementById("rename-show-search") as HTMLInputElement;
    const renameShowSearchBtn = document.getElementById("rename-show-search-btn")!;
    const renameShowResults = document.getElementById("rename-show-results")!;
    
    const renameSelectedShowCard = document.getElementById("rename-selected-show-card")!;
    const renameSelectedShowPoster = document.getElementById("rename-selected-show-poster") as HTMLImageElement;
    const renameSelectedShowTitle = document.getElementById("rename-selected-show-title")!;
    const renameSelectedShowYear = document.getElementById("rename-selected-show-year")!;
    const renameChangeShowBtn = document.getElementById("rename-change-show-btn")!;

    const renameSeasonSection = document.getElementById("rename-season-section")!;
    const renameSeasonButtons = document.getElementById("rename-season-buttons")!;

    const renameEpisodeSection = document.getElementById("rename-episode-section")!;
    const renameEpisodeContainer = document.getElementById("rename-episode-container")!;
    
    const renameCustomTitleInput = document.getElementById("rename-custom-title-input") as HTMLInputElement;

    // Custom Rename State
    let renameType: "show" | "season" | "episode" | "movie" = "show";
    let renameSelectedShow: any = null;
    let renameSelectedSeason: number | null = null;
    let renameSelectedEpisode: any = null;

    // Open Custom Rename Modal
    addRenameBtn.addEventListener("click", () => {
      resetRenameModal();
      renameModal.classList.remove("opacity-0", "pointer-events-none");
      fetchRenameLocalMedia();
    });

    // Close Custom Rename Modal
    const closeRenameModal = () => {
      renameModal.classList.add("opacity-0", "pointer-events-none");
    };
    closeRenameModalBtn.addEventListener("click", closeRenameModal);
    cancelRenameModalBtn.addEventListener("click", closeRenameModal);
    renameModal.addEventListener("click", (e) => {
      if (e.target === renameModal) closeRenameModal();
    });

    // Toggle Rename Type Tab Selection
    function selectRenameType(type: "show" | "season" | "episode" | "movie") {
      renameType = type;
      
      // Update Tab Styles
      [renameTypeMovie, renameTypeShow, renameTypeSeason, renameTypeEpisode].forEach(btn => {
        btn.className = "flex-1 px-4 py-2.5 rounded-xl border border-zinc-800 bg-zinc-900/40 text-zinc-400 font-bold text-xs transition cursor-pointer text-center";
      });

      const activeBtn = type === "movie" ? renameTypeMovie : type === "show" ? renameTypeShow : type === "season" ? renameTypeSeason : renameTypeEpisode;
      activeBtn.className = "flex-1 px-4 py-2.5 rounded-xl border border-indigo-500/30 bg-indigo-600/10 text-zinc-100 font-bold text-xs transition cursor-pointer text-center";

      // Show/Hide Sections
      if (type === "show" || type === "movie") {
        renameSeasonSection.classList.add("hidden");
        renameEpisodeSection.classList.add("hidden");
      } else if (type === "season") {
        renameSeasonSection.classList.remove("hidden");
        renameEpisodeSection.classList.add("hidden");
        if (renameSelectedShow) {
          renderRenameSeasonButtons(renameSelectedShow.seasons_meta || []);
        }
      } else if (type === "episode") {
        renameSeasonSection.classList.remove("hidden");
        renameEpisodeSection.classList.remove("hidden");
        if (renameSelectedShow) {
          renderRenameSeasonButtons(renameSelectedShow.seasons_meta || []);
        }
      }

      validateRenameForm();
    }

    renameTypeMovie.addEventListener("click", () => selectRenameType("movie"));
    renameTypeShow.addEventListener("click", () => selectRenameType("show"));
    renameTypeSeason.addEventListener("click", () => selectRenameType("season"));
    renameTypeEpisode.addEventListener("click", () => selectRenameType("episode"));

    function fetchRenameLocalMedia() {
      fetchLocalShows();
      fetchLocalMovies();
    }

    const performRenameShowSearch = () => {
      const q = renameShowSearch.value.trim().toLowerCase();
      if (!q) {
        renderRenameShowResults([...localShowsList, ...localMoviesList]);
        return;
      }
      const filteredShows = localShowsList.filter(show => 
        show.title.toLowerCase().includes(q) || 
        (show.original_title && show.original_title.toLowerCase().includes(q)) || 
        show.tmdb_id.toString().includes(q)
      );
      const filteredMovies = localMoviesList.filter(movie => 
        movie.title.toLowerCase().includes(q) || 
        (movie.tmdb_title && movie.tmdb_title.toLowerCase().includes(q)) || 
        movie.tmdb_id.toString().includes(q)
      );
      renderRenameShowResults([...filteredShows, ...filteredMovies]);
    };

    renameShowSearchBtn.addEventListener("click", performRenameShowSearch);
    renameShowSearch.addEventListener("keydown", (e) => {
      if (e.key === "Enter") {
        e.preventDefault();
        performRenameShowSearch();
      }
    });

    function renderRenameShowResults(results: any[]) {
      renameShowResults.innerHTML = "";
      if (results.length === 0) {
        renameShowResults.innerHTML = '<div class="col-span-full text-center text-xs text-zinc-500 py-4">No matching local media found.</div>';
        renameShowResults.classList.remove("hidden");
        return;
      }

      results.forEach(media => {
        const isMovie = !media.first_air_date && (media.release_date || media.tmdb_title);
        const card = document.createElement("div");
        card.className = "flex items-center gap-3 p-2 bg-zinc-900 border border-zinc-800 rounded-xl hover:border-zinc-700 cursor-pointer transition text-left group";
        
        let posterHtml = `<div class="w-8 h-12 rounded bg-zinc-950 flex items-center justify-center text-[7px] text-zinc-750 font-bold shrink-0">NO ART</div>`;
        if (media.poster_path) {
          posterHtml = `<img src="${media.poster_path}" class="w-8 h-12 rounded object-cover shrink-0" />`;
        }

        const year = (media.first_air_date || media.release_date) ? new Date(media.first_air_date || media.release_date).getFullYear() : "N/A";
        const typeLabel = isMovie ? "MOVIE" : "SHOW";

        card.innerHTML = `
          ${posterHtml}
          <div class="min-w-0">
            <span class="text-[7px] font-black px-1.5 py-0.5 rounded ${isMovie ? 'bg-blue-900/30 text-blue-400' : 'bg-indigo-900/30 text-indigo-400'}">${typeLabel}</span>
            <h4 class="text-zinc-200 font-bold truncate text-xs mt-0.5" title="${media.title}">${media.title}</h4>
            <span class="text-[9px] text-zinc-500">${year} • ID: ${media.tmdb_id}</span>
          </div>
        `;

        card.addEventListener("click", () => selectRenameShow(media));
        renameShowResults.appendChild(card);
      });
      renameShowResults.classList.remove("hidden");
    }

    function selectRenameShow(media: any) {
      renameSelectedShow = media;
      renameSelectedSeason = null;
      renameSelectedEpisode = null;
      
      const isMovie = !media.first_air_date && (media.release_date || media.tmdb_title);

      renameSelectedShowTitle.textContent = media.title;
      const year = (media.first_air_date || media.release_date) ? new Date(media.first_air_date || media.release_date).getFullYear() : "N/A";
      renameSelectedShowYear.textContent = `${year} • TMDB ID: ${media.tmdb_id}`;
      if (media.poster_path) {
        renameSelectedShowPoster.src = media.poster_path;
        renameSelectedShowPoster.classList.remove("hidden");
      } else {
        renameSelectedShowPoster.classList.add("hidden");
      }

      renameShowSearch.classList.add("hidden");
      renameShowSearchBtn.classList.add("hidden");
      renameShowResults.classList.add("hidden");
      renameSelectedShowCard.classList.remove("hidden");
      renameTypeSection.classList.remove("hidden");

      if (isMovie) {
        renameTypeMovie.classList.remove("hidden");
        renameTypeShow.classList.add("hidden");
        renameTypeSeason.classList.add("hidden");
        renameTypeEpisode.classList.add("hidden");
        selectRenameType("movie");
      } else {
        renameTypeMovie.classList.add("hidden");
        renameTypeShow.classList.remove("hidden");
        renameTypeSeason.classList.remove("hidden");
        renameTypeEpisode.classList.remove("hidden");
        selectRenameType("show");
      }

      validateRenameForm();
    }

    renameChangeShowBtn.addEventListener("click", () => {
      renameSelectedShow = null;
      renameSelectedSeason = null;
      renameSelectedEpisode = null;

      renameSelectedShowCard.classList.add("hidden");
      renameShowSearch.classList.remove("hidden");
      renameShowSearchBtn.classList.remove("hidden");
      renameShowResults.classList.remove("hidden");
      renameTypeSection.classList.add("hidden");
      
      renameSeasonSection.classList.add("hidden");
      renameEpisodeSection.classList.add("hidden");

      renderRenameShowResults([...localShowsList, ...localMoviesList]);
      validateRenameForm();
    });

    function renderRenameSeasonButtons(seasons: any[]) {
      renameSeasonButtons.innerHTML = "";
      if (seasons.length === 0) {
        renameSeasonButtons.innerHTML = '<span class="text-xs text-zinc-500">No seasons found for this show.</span>';
        return;
      }

      seasons.forEach(season => {
        const label = season.season_number === 0 ? "Specials" : `Season ${season.season_number}`;
        const btn = document.createElement("button");
        btn.type = "button";
        btn.className = "px-3 py-1.5 border border-zinc-800 hover:border-zinc-700 bg-zinc-900/60 hover:bg-zinc-800 text-zinc-300 font-bold text-xs rounded-xl cursor-pointer transition active:scale-95";
        btn.textContent = `${label}`;
        
        btn.addEventListener("click", () => {
          renameSeasonButtons.querySelectorAll("button").forEach(b => {
            b.className = "px-3 py-1.5 border border-zinc-800 hover:border-zinc-700 bg-zinc-900/60 hover:bg-zinc-800 text-zinc-300 font-bold text-xs rounded-xl cursor-pointer transition active:scale-95";
          });
          btn.className = "px-3 py-1.5 border border-blue-800 bg-blue-950/40 text-blue-300 font-bold text-xs rounded-xl cursor-pointer transition shadow-md";
          renameSelectedSeason = season.season_number;
          
          if (renameType === "episode") {
            fetchRenameEpisodes(renameSelectedShow.tmdb_id, season.season_number);
          }
          validateRenameForm();
        });

        renameSeasonButtons.appendChild(btn);
      });
    }

    async function fetchRenameEpisodes(showTmdbId: number, seasonNumber: number) {
      renameEpisodeContainer.innerHTML = '<div class="text-xs text-zinc-500 py-4 text-center">Loading episodes...</div>';
      try {
        const res = await fetch(`/api/proxy/shows/${showTmdbId}/season/${seasonNumber}`, {
          headers: { "Authorization": `Bearer ${token}` }
        });
        if (res.ok) {
          const data = await res.json();
          renderRenameEpisodes(data.episodes || []);
        } else {
          renameEpisodeContainer.innerHTML = '<div class="text-xs text-red-400 py-4 text-center">Failed to load episodes.</div>';
        }
      } catch (err) {
        renameEpisodeContainer.innerHTML = '<div class="text-xs text-red-400 py-4 text-center">Error loading episodes.</div>';
      }
    }

    function renderRenameEpisodes(episodes: any[]) {
      renameEpisodeContainer.innerHTML = "";
      const localEps = episodes.filter(ep => ep.id !== null);
      if (localEps.length === 0) {
        renameEpisodeContainer.innerHTML = '<div class="text-xs text-zinc-500 py-4 text-center">No collected episodes in library for this season.</div>';
        validateRenameForm();
        return;
      }

      localEps.forEach(ep => {
        const div = document.createElement("div");
        div.className = "flex items-center justify-between p-3 bg-zinc-900 border border-zinc-800 hover:border-zinc-700 rounded-xl cursor-pointer transition active:scale-[0.99]";
        
        let posterHtml = `<div class="w-12 h-8 rounded bg-zinc-950 flex items-center justify-center text-[8px] text-zinc-750 font-bold shrink-0">NO ART</div>`;
        if (ep.poster_path) {
          posterHtml = `<img src="${ep.poster_path}" class="w-12 h-8 rounded object-cover shrink-0 border border-zinc-800" />`;
        }

        div.innerHTML = `
          <div class="flex items-center gap-3 min-w-0">
            ${posterHtml}
            <div class="min-w-0">
              <span class="text-[9px] font-black uppercase text-indigo-400">Episode ${ep.episode_number}</span>
              <h4 class="text-zinc-200 font-bold text-xs truncate" title="${ep.title}">${ep.title}</h4>
            </div>
          </div>
        `;

        div.addEventListener("click", () => {
          renameEpisodeContainer.querySelectorAll("div").forEach(d => {
            d.className = "flex items-center justify-between p-3 bg-zinc-900 border border-zinc-800 hover:border-zinc-700 rounded-xl cursor-pointer transition active:scale-[0.99]";
          });
          div.className = "flex items-center justify-between p-3 bg-blue-950/20 border border-blue-800 rounded-xl cursor-pointer transition active:scale-[0.99]";
          renameSelectedEpisode = ep;
          validateRenameForm();
        });

        renameEpisodeContainer.appendChild(div);
      });
      validateRenameForm();
    }

    renameCustomTitleInput.addEventListener("input", validateRenameForm);

    function validateRenameForm() {
      let isValid = false;
      const hasTitle = renameCustomTitleInput.value.trim().length > 0;
      
      if (renameType === "show" || renameType === "movie") {
        isValid = !!renameSelectedShow && hasTitle;
      } else if (renameType === "season") {
        isValid = !!renameSelectedShow && renameSelectedSeason !== null && hasTitle;
      } else if (renameType === "episode") {
        isValid = !!renameSelectedShow && renameSelectedSeason !== null && !!renameSelectedEpisode && hasTitle;
      }

      saveRenameBtn.disabled = !isValid;
    }

    function resetRenameModal() {
      renameType = "show";
      renameSelectedShow = null;
      renameSelectedSeason = null;
      renameSelectedEpisode = null;

      // Reset tabs
      renameTypeMovie.classList.add("hidden");
      renameTypeShow.classList.remove("hidden");
      renameTypeSeason.classList.remove("hidden");
      renameTypeEpisode.classList.remove("hidden");

      renameTypeShow.className = "flex-1 px-4 py-2.5 rounded-xl border border-indigo-500/30 bg-indigo-600/10 text-zinc-100 font-bold text-xs transition cursor-pointer text-center";
      renameTypeSeason.className = "flex-1 px-4 py-2.5 rounded-xl border border-zinc-800 bg-zinc-900/40 text-zinc-400 font-bold text-xs transition cursor-pointer text-center";
      renameTypeEpisode.className = "flex-1 px-4 py-2.5 rounded-xl border border-zinc-800 bg-zinc-900/40 text-zinc-400 font-bold text-xs transition cursor-pointer text-center";

      renameShowSearch.value = "";
      renameShowSearch.classList.remove("hidden");
      renameShowSearchBtn.classList.remove("hidden");
      renameShowResults.innerHTML = "";
      renameShowResults.classList.add("hidden");
      
      renameSelectedShowCard.classList.add("hidden");
      renameTypeSection.classList.add("hidden");
      renameSeasonSection.classList.add("hidden");
      renameSeasonButtons.innerHTML = "";
      renameEpisodeSection.classList.add("hidden");
      renameEpisodeContainer.innerHTML = "";
      renameCustomTitleInput.value = "";
      saveRenameBtn.disabled = true;
    }

    // Save Custom Rename Action
    saveRenameBtn.addEventListener("click", async () => {
      const customTitle = renameCustomTitleInput.value.trim();
      const body: any = {};

      if (renameType === "show") {
        body.show_tmdb_id = renameSelectedShow.tmdb_id;
        body.custom_title = customTitle;
      } else if (renameType === "movie") {
        body.media_id = renameSelectedShow.id;
        body.custom_title = customTitle;
      } else if (renameType === "season") {
        body.show_tmdb_id = renameSelectedShow.tmdb_id;
        body.season_number = renameSelectedSeason;
        body.season_custom_name = customTitle;
      } else if (renameType === "episode") {
        body.media_id = renameSelectedEpisode.id;
        body.custom_title = customTitle;
      }

      saveRenameBtn.disabled = true;
      saveRenameBtn.textContent = "Saving...";

      try {
        const res = await fetch("/api/proxy/sync/custom-title", {
          method: "PATCH",
          headers: {
            "Content-Type": "application/json",
            "Authorization": `Bearer ${token}`
          },
          body: JSON.stringify(body)
        });

        if (res.ok) {
          window.showToast?.("Custom rename applied successfully", "success");
          closeRenameModal();
          setTimeout(() => window.location.reload(), 800);
        } else {
          const detail = await res.json();
          window.showToast?.(detail.detail || "Failed to apply custom rename", "error");
          saveRenameBtn.disabled = false;
          saveRenameBtn.textContent = "Save Custom Rename";
        }
      } catch (err) {
        window.showToast?.("Error saving custom rename", "error");
        saveRenameBtn.disabled = false;
        saveRenameBtn.textContent = "Save Custom Rename";
      }
    });

    // Setup direct actions on existing items (Apply and Delete)
    document.querySelectorAll("[data-apply-id]").forEach(button => {
      button.addEventListener("click", async () => {
        const id = button.getAttribute("data-apply-id");
        if (!id) return;

        const icon = button.querySelector("svg");
        if (icon) icon.classList.add("animate-spin");
        button.setAttribute("disabled", "true");

        try {
          const res = await fetch(`/api/proxy/sync/season-overrides/${id}/apply`, {
            method: "POST",
            headers: { "Authorization": `Bearer ${token}` }
          });
          if (res.ok) {
            const data = await res.json();
            window.showToast?.(`Applied mapping successfully! Remapped ${data.remapped} episodes.`, "success");
          } else {
            window.showToast?.("Failed to apply season remapping override.", "error");
          }
        } catch (err) {
          window.showToast?.("Error applying override.", "error");
        } finally {
          if (icon) icon.classList.remove("animate-spin");
          button.removeAttribute("disabled");
        }
      });
    });

    document.querySelectorAll("[data-delete-id]").forEach(button => {
      button.addEventListener("click", async () => {
        const id = button.getAttribute("data-delete-id");
        if (!id) return;

        if (!confirm("Are you sure you want to delete this season override? Any previously remapped episodes will remain, but future sync operations will revert to standard mapping.")) {
          return;
        }

        try {
          const res = await fetch(`/api/proxy/sync/season-overrides/${id}`, {
            method: "DELETE",
            headers: { "Authorization": `Bearer ${token}` }
          });
          if (res.ok) {
            window.showToast?.("Override deleted successfully", "success");
            setTimeout(() => window.location.reload(), 600);
          } else {
            window.showToast?.("Failed to delete season override", "error");
          }
        } catch (err) {
          window.showToast?.("Error deleting override", "error");
        }
      });
    });

    // Episode Overrides direct actions
    document.querySelectorAll("[data-ep-apply-id]").forEach(button => {
      button.addEventListener("click", async () => {
        const id = button.getAttribute("data-ep-apply-id");
        if (!id) return;

        const icon = button.querySelector("svg");
        if (icon) icon.classList.add("animate-spin");
        button.setAttribute("disabled", "true");

        try {
          const res = await fetch(`/api/proxy/sync/episode-overrides/${id}/apply`, {
            method: "POST",
            headers: { "Authorization": `Bearer ${token}` }
          });
          if (res.ok) {
            const data = await res.json();
            window.showToast?.(`Applied episode mapping successfully!`, "success");
          } else {
            window.showToast?.("Failed to apply episode remapping override.", "error");
          }
        } catch (err) {
          window.showToast?.("Error applying override.", "error");
        } finally {
          if (icon) icon.classList.remove("animate-spin");
          button.removeAttribute("disabled");
        }
      });
    });

    document.querySelectorAll("[data-ep-delete-id]").forEach(button => {
      button.addEventListener("click", async () => {
        const id = button.getAttribute("data-ep-delete-id");
        if (!id) return;

        if (!confirm("Are you sure you want to delete this episode override?")) {
          return;
        }

        try {
          const res = await fetch(`/api/proxy/sync/episode-overrides/${id}`, {
            method: "DELETE",
            headers: { "Authorization": `Bearer ${token}` }
          });
          if (res.ok) {
            window.showToast?.("Override deleted successfully", "success");
            setTimeout(() => window.location.reload(), 600);
          } else {
