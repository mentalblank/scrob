                  Show
                </button>
                <button id="rename-type-season" class="flex-1 px-4 py-2.5 rounded-xl border border-zinc-800 bg-zinc-900/40 text-zinc-400 font-bold text-xs transition cursor-pointer text-center">
                  Season
