      button.addEventListener("click", async () => {
        const payloadStr = button.getAttribute("data-payload");
        if (!payloadStr) return;
        const item = JSON.parse(payloadStr);

        const newName = prompt(`Enter new title for ${item.context} (Currently: ${item.custom_title})`, item.custom_title);
        if (newName === null || newName.trim() === item.custom_title) return; // cancelled or unchanged

        const body: any = { custom_title: newName.trim() === '' ? null : newName.trim() };
        
        if (item.type === 'show') {
          body.show_tmdb_id = item.show_tmdb_id;
        } else if (item.type === 'season') {
          body.show_tmdb_id = item.show_tmdb_id;
          body.season_number = item.season_number;
          body.season_custom_name = body.custom_title;
          delete body.custom_title;
        } else if (item.type === 'episode') {
          body.media_id = item.media_id;
        }

        try {
          const res = await fetch('/api/proxy/sync/custom-title', {
            method: 'PATCH',
            headers: {
              'Content-Type': 'application/json',
              'Authorization': `Bearer ${token}`
            },
            body: JSON.stringify(body)
          });
          
          if (res.ok) {
            window.showToast?.("Custom title updated successfully", "success");
            setTimeout(() => window.location.reload(), 600);
          } else {
            window.showToast?.("Failed to update custom title", "error");
          }
        } catch (e) {
          window.showToast?.("Error updating custom title", "error");
        }
