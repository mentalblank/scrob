---
import Base from "../layouts/Base.astro";
import MediaCard from "../components/MediaCard.astro";
import InfiniteScroll from "../components/InfiniteScroll.astro";
import VisibilityFilters from "../components/VisibilityFilters.astro";
import { api, type MediaItem } from "../lib/api";



const { token } = Astro.locals;
Astro.response.headers.set("Cache-Control", "no-store");
const page = parseInt(Astro.url.searchParams.get("page") || "1");
const filter = Astro.url.searchParams.get("filter") || "my-shows";

let data: { results: MediaItem[]; page: number; total_pages: number; total_results: number } = {
  results: [],
  page: 1,
  total_pages: 1,
  total_results: 0,
};
let error = "";

try {
  if (filter === "all") {
    data = await api.media.onAirToday(page, token);
  } else {
    data = await api.media.airingTodayCollected(page, token);
  }
} catch (e: unknown) {
  error = e instanceof Error ? e.message : "Failed to load";
}
---

<Base title={`Airing Today — Page ${page}`}>
  <div class="mb-8 flex flex-col md:flex-row md:items-end justify-between gap-4">
    <div>
      <h1 class="text-3xl font-bold text-zinc-100 mb-2">Airing Today</h1>
      <p class="text-zinc-500">TV shows with episodes airing today</p>
    </div>

    <div class="flex items-center gap-3">
      <div class="flex items-center gap-1 bg-zinc-900 border border-zinc-800 rounded-xl p-1 w-fit h-fit">
        <a
          href="/airing-today?filter=my-shows"
          class={`px-4 py-1.5 rounded-lg text-sm font-semibold transition-colors active:scale-95 active:opacity-70 ${
            filter === "my-shows"
              ? "bg-blue-600 text-white"
              : "text-zinc-400 hover:text-zinc-100"
          }`}
        >
          My Shows
        </a>
        <a
          href="/airing-today?filter=all"
          class={`px-4 py-1.5 rounded-lg text-sm font-semibold transition-colors active:scale-95 active:opacity-70 ${
            filter === "all"
              ? "bg-blue-600 text-white"
              : "text-zinc-400 hover:text-zinc-100"
          }`}
        >
          All Shows
        </a>
      </div>
      <VisibilityFilters />
    </div>
  </div>

  {error && (
    <div class="bg-red-500/10 border border-red-500 text-red-500 p-4 rounded-lg mb-8">
      {error}
    </div>
  )}

  <div id="media-grid" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-6">
    {data.results.map((item) => (
      <MediaCard item={item} />
    ))}
  </div>

  <InfiniteScroll
    type={filter === "all" ? "airing_today" : "airing_today_collected"}
    currentPage={data.page}
    totalPages={data.total_pages}
  />
</Base>

<script>
</script>
