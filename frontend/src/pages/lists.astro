---
import Base from "../layouts/Base.astro";
import ListCard from "../components/ListCard.astro";
import { api, type UserList, type PublicList } from "../lib/api";
export const prerender = false;

const { token, user } = Astro.locals;
Astro.response.headers.set("Cache-Control", "no-store");

let lists: UserList[] = [];
let publicLists: PublicList[] = [];
let error = "";

try {
  const [myData, pubData] = await Promise.all([
    api.lists.getAll(token!),
    api.lists.getPublic(token!),
  ]);
  lists = myData.lists;
  publicLists = pubData.lists.filter((l) => l.username !== user?.username);
} catch (e: unknown) {
  error = e instanceof Error ? e.message : String(e);
}
---

<Base title="My Lists">
  <div>
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-6 mb-10">
      <div class="flex items-center gap-4">
        <h1 class="text-3xl font-black text-zinc-100 tracking-tight flex items-center gap-3">
          <span class="w-1.5 h-8 bg-blue-600 rounded-full"></span>
          My Lists
        </h1>
        <span id="lists-count" class="text-zinc-500 font-bold bg-zinc-900 px-3 py-1 rounded-full text-sm">{lists.length}</span>
      </div>
      
      <div class="flex items-center gap-3 flex-1 md:max-w-md">
        <div class="relative flex-1">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-zinc-500">
            <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
          </svg>
          <input
            type="text"
            id="search-lists"
            placeholder="Search lists..."
            class="w-full bg-zinc-900 border border-zinc-800 rounded-xl pl-10 pr-4 py-2.5 text-sm text-zinc-100 focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all placeholder:text-zinc-500"
          />
        </div>
        <button
          id="new-list-btn"
          class="flex items-center gap-2 px-5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white font-bold rounded-xl transition-all shadow-lg shadow-blue-600/20 active:scale-95 text-sm cursor-pointer whitespace-nowrap"
        >
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
          </svg>
          New List
        </button>
      </div>
    </div>

    {error && (
      <div class="bg-red-500/10 border border-red-500/20 text-red-400 p-4 rounded-2xl mb-8 text-sm">
        {error}
      </div>
    )}

    <!-- Create List Modal -->
    <div id="create-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4">
      <div id="modal-backdrop" class="absolute inset-0 bg-black/70 backdrop-blur-sm"></div>
      <div class="relative bg-zinc-900 border border-zinc-800 rounded-3xl p-8 w-full max-w-md shadow-2xl">
        <h2 class="text-xl font-black text-zinc-100 mb-6">Create New List</h2>
        <form id="create-form" class="space-y-4">
          <div>
            <label for="list-name" class="block text-xs font-bold text-zinc-400 uppercase tracking-widest mb-2">Name</label>
            <input
              type="text"
              id="list-name"
              placeholder="My Watchlist"
              maxlength="255"
              required
              class="w-full bg-zinc-950 border border-zinc-800 rounded-xl px-4 py-3 text-zinc-100 focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all"
            />
          </div>
          <div>
            <label for="list-desc" class="block text-xs font-bold text-zinc-400 uppercase tracking-widest mb-2">Description <span class="text-zinc-400 normal-case font-normal tracking-normal">(optional)</span></label>
            <textarea
              id="list-desc"
              placeholder="What's this list about?"
              rows="2"
              class="w-full bg-zinc-950 border border-zinc-800 rounded-xl px-4 py-3 text-zinc-100 focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all resize-none"
            ></textarea>
          </div>
          <div>
            <label class="block text-xs font-bold text-zinc-400 uppercase tracking-widest mb-3 text-center">Privacy</label>
            <div class="grid grid-cols-3 gap-2">
              <label class="relative flex flex-col items-center p-3 rounded-xl border border-zinc-800 bg-zinc-950 cursor-pointer transition-all hover:bg-zinc-900 group">
                <input type="radio" name="privacy_level" value="private" checked class="sr-only peer" />
                <div class="absolute inset-0 rounded-xl border-2 border-transparent peer-checked:border-blue-600 transition-all"></div>
                <span class="text-[10px] font-black uppercase tracking-widest text-zinc-500 peer-checked:text-blue-400 mb-1">Private</span>
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 text-zinc-400 peer-checked:text-blue-500">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 1 0-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H6.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25Z" />
                </svg>
              </label>
              <label class="relative flex flex-col items-center p-3 rounded-xl border border-zinc-800 bg-zinc-950 cursor-pointer transition-all hover:bg-zinc-900 group">
                <input type="radio" name="privacy_level" value="friends_only" class="sr-only peer" />
                <div class="absolute inset-0 rounded-xl border-2 border-transparent peer-checked:border-blue-600 transition-all"></div>
                <span class="text-[10px] font-black uppercase tracking-widest text-zinc-500 peer-checked:text-blue-400 mb-1">Friends</span>
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 text-zinc-400 peer-checked:text-blue-500">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.998 5.998 0 0 0-12 0m12 0c0-1.723-.699-3.283-1.838-4.412m-1.148-1.148A5.988 5.988 0 0 1 12 12c-1.353 0-2.585.449-3.568 1.206m8.114-1.83c.915 0 1.656-.74 1.656-1.656V6.142c0-.915-.74-1.656-1.656-1.656H12M8.114 11.372A5.988 5.988 0 0 0 12 12c1.353 0 2.585-.449 3.568-1.206m-8.114 1.83a6.062 6.062 0 0 1-1.062-1.062m1.062 1.062c-1.139 1.129-1.838 2.689-1.838 4.412m3.114-10.43c0-.915.74-1.656 1.656-1.656h3.114c.915 0 1.656.74 1.656 1.656V6.142c0 .915-.74 1.656-1.656 1.656H12" />
                </svg>
              </label>
              <label class="relative flex flex-col items-center p-3 rounded-xl border border-zinc-800 bg-zinc-950 cursor-pointer transition-all hover:bg-zinc-900 group">
                <input type="radio" name="privacy_level" value="public" class="sr-only peer" />
                <div class="absolute inset-0 rounded-xl border-2 border-transparent peer-checked:border-blue-600 transition-all"></div>
                <span class="text-[10px] font-black uppercase tracking-widest text-zinc-500 peer-checked:text-blue-400 mb-1">Public</span>
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 text-zinc-400 peer-checked:text-blue-500">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 0 0 8.716-6.747M12 21a9.004 9.004 0 0 1-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 0 1 7.843 4.582M12 3a8.997 8.997 0 0 0-7.843 4.582m15.686 0A11.953 11.953 0 0 1 12 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0 1 21 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0 1 12 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 0 1 3 12c0-.778.099-1.533.284-2.253" />
                </svg>
              </label>
            </div>
          </div>
          <div id="create-error" class="hidden text-xs text-red-400 bg-red-500/10 border border-red-500/20 rounded-lg px-3 py-2"></div>
          <div class="flex gap-3 pt-2">
            <button
              type="button"
              id="cancel-btn"
              class="flex-1 px-4 py-3 bg-zinc-800 hover:bg-zinc-700 text-zinc-300 font-bold rounded-xl transition-all text-sm cursor-pointer"
            >
              Cancel
            </button>
            <button
              type="submit"
              id="create-submit-btn"
              class="flex-1 px-4 py-3 bg-blue-600 hover:bg-blue-500 text-white font-bold rounded-xl transition-all text-sm cursor-pointer disabled:opacity-50"
            >
              Create List
            </button>
          </div>
        </form>
      </div>
    </div>

    <!-- Lists Grid -->
    {lists.length === 0 && !error ? (
      <div class="text-center py-24 bg-zinc-900/20 border border-zinc-800/50 border-dashed rounded-3xl">
        <div class="text-5xl mb-4">📋</div>
        <h2 class="text-xl font-bold text-zinc-100 mb-2">No lists yet</h2>
        <p class="text-zinc-500 mb-6">Create your first list to start organising movies and shows.</p>
        <button
          id="empty-new-list-btn"
          class="px-6 py-3 bg-blue-600 hover:bg-blue-500 text-white font-bold rounded-xl transition-all shadow-lg shadow-blue-600/20 active:scale-95 cursor-pointer"
        >
          Create a List
        </button>
      </div>
    ) : (
      <div id="lists-grid" class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        {lists.map((list) => (
          <div class="group relative" data-list-id={list.id}>
            <ListCard
              id={list.id}
              name={list.name}
              description={list.description}
              privacy_level={list.privacy_level}
              item_count={list.item_count}
              preview_posters={list.preview_posters}
            />
            <button
              class="delete-list-btn absolute top-3 right-3 p-1.5 rounded-lg text-zinc-500 hover:text-red-400 hover:bg-red-500/10 transition-colors cursor-pointer z-10"
              data-list-id={list.id}
              data-list-name={list.name}
              aria-label="Delete list"
            >
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
                <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
              </svg>
            </button>
          </div>
        ))}
      </div>
    )}

    {publicLists.length > 0 && (
      <div class="mt-16 pt-10 border-t border-zinc-800/50">
        <h2 class="text-sm font-black text-zinc-400 uppercase tracking-widest mb-6">From the Community</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          {publicLists.map((list) => (
            <ListCard
              id={list.id}
              name={list.name}
              description={list.description}
              privacy_level={list.privacy_level}
              item_count={list.item_count}
              preview_posters={list.preview_posters}
              username={list.username}
            />
          ))}
        </div>
      </div>
    )}
  </div>
</Base>

<script define:vars={{ token }}>
  const modal = document.getElementById('create-modal');
  const createForm = document.getElementById('create-form');
  const cancelBtn = document.getElementById('cancel-btn');
  const createError = document.getElementById('create-error');
  const submitBtn = document.getElementById('create-submit-btn');
  const listsGrid = document.getElementById('lists-grid');

  function openModal() {
    modal.classList.remove('hidden');
    document.getElementById('list-name').focus();
  }

  function closeModal() {
    modal.classList.add('hidden');
    createForm.reset();
    createError.classList.add('hidden');
  }

  document.getElementById('new-list-btn')?.addEventListener('click', openModal);
  document.getElementById('empty-new-list-btn')?.addEventListener('click', openModal);
  cancelBtn?.addEventListener('click', closeModal);
  document.getElementById('modal-backdrop')?.addEventListener('click', closeModal);
  
  // --- Search lists ---
  const searchListsInput = document.getElementById('search-lists');
  const listsCount = document.getElementById('lists-count');
  
  searchListsInput?.addEventListener('input', () => {
    const q = searchListsInput.value.toLowerCase().trim();
    const cards = document.querySelectorAll('#lists-grid > div');
    let visibleCount = 0;
    
    cards.forEach(card => {
      const name = card.querySelector('h3')?.textContent?.toLowerCase() || '';
      const desc = card.querySelector('p')?.textContent?.toLowerCase() || '';
      const isVisible = name.includes(q) || desc.includes(q);
      card.classList.toggle('hidden', !isVisible);
      if (isVisible) visibleCount++;
    });
    
    if (listsCount) listsCount.textContent = visibleCount;
  });

  createForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const name = document.getElementById('list-name').value.trim();
    const description = document.getElementById('list-desc').value.trim() || null;
    const privacyLevel = document.querySelector('input[name="privacy_level"]:checked').value;

    if (!name) return;

    submitBtn.disabled = true;
    submitBtn.textContent = 'Creating...';
    createError.classList.add('hidden');

    try {
      const res = await fetch(`/api/proxy/lists`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
        body: JSON.stringify({ name, description, privacy_level: privacyLevel }),
      });

      if (!res.ok) {
        const err = await res.json();
        throw new Error(err.detail || 'Failed to create list');
      }

      const list = await res.json();
      closeModal();
      window.location.href = `/list/${list.id}`;
    } catch (err) {
      createError.textContent = err.message;
      createError.classList.remove('hidden');
      submitBtn.disabled = false;
      submitBtn.textContent = 'Create List';
    }
  });

  document.querySelectorAll('.delete-list-btn').forEach(btn => {
    btn.addEventListener('click', async (e) => {
      e.preventDefault();
      const listId = btn.getAttribute('data-list-id');
      const listName = btn.getAttribute('data-list-name');

      const ok = await window.showConfirm(`Delete "${listName}"?`, 'This cannot be undone.');
      if (!ok) return;

      btn.disabled = true;
      try {
        const res = await fetch(`/api/proxy/lists/${listId}`, {
          method: 'DELETE',
          headers: { 'Authorization': `Bearer ${token}` },
        });
        if (res.ok) {
          const card = document.querySelector(`[data-list-id="${listId}"]`);
          card?.remove();
          // Update count
          const count = document.querySelectorAll('#lists-grid > div:not(.hidden)').length;
          if (listsCount) listsCount.textContent = count;
        }
      } catch (err) {
        console.error('Failed to delete list', err);
        btn.disabled = false;
      }
    });
  });
</script>
