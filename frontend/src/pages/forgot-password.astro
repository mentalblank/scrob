---
import Base from "../layouts/Base.astro";
import ThemeToggle from "../components/ThemeToggle.astro";
import { api } from "../lib/api";

let submitted = false;
let error = "";

if (Astro.request.method === "POST") {
  try {
    const data = await Astro.request.formData();
    const email = data.get("email")?.toString() ?? "";
    await api.auth.forgotPassword(email);
    submitted = true;
  } catch (e: unknown) {
    error = e instanceof Error ? e.message : "Something went wrong. Please try again.";
  }
}
---

<Base title="Forgot Password" hideNav>
  <div class="max-w-md mx-auto mt-16 p-8 bg-zinc-900/40 border border-zinc-800 rounded-3xl shadow-2xl backdrop-blur-md relative">
    <ThemeToggle />

    <div class="flex flex-col items-center mb-6">
      <img src="/scrob.png" alt="Scrob Logo" class="w-36 object-contain mb-2" />
      <span class="text-zinc-100 font-bold text-xl tracking-tight">Scrob</span>
    </div>

    <h1 class={`text-3xl font-bold mb-6 text-zinc-100 ${submitted ? "text-center" : ""}`}>
      {submitted ? "Check your inbox" : "Forgot password"}
    </h1>

    {error && (
      <div class="bg-red-500/10 border border-red-500 text-red-500 p-3 rounded-lg mb-6">
        {error}
      </div>
    )}

    {submitted ? (
      <div class="text-center py-2">
        <div class="w-14 h-14 bg-zinc-800 rounded-full flex items-center justify-center mx-auto mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-7 h-7 text-zinc-300">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
          </svg>
        </div>
        <p class="text-sm text-zinc-400 mb-6">
          If that email is registered, we've sent a reset link.<br />
          The link expires in <strong class="text-zinc-300">1 hour</strong>.
        </p>
        <a href="/login" class="text-sm text-zinc-400 hover:text-zinc-100 transition-colors">Back to login</a>
      </div>
    ) : (
      <form method="POST" class="space-y-4">
        <div>
          <label for="email" class="block text-sm font-medium text-zinc-400 mb-1">Email</label>
          <input
            type="email"
            name="email"
            id="email"
            required
            autofocus
            class="w-full bg-zinc-800 border border-zinc-700 rounded-lg px-4 py-3 text-zinc-100 focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all"
          />
        </div>
        <button
          type="submit"
          class="w-full bg-blue-600 hover:bg-blue-500 text-white font-bold py-3 rounded-xl transition-all shadow-lg shadow-blue-600/20 active:scale-95 duration-200 cursor-pointer mt-4"
        >
          Send reset link
        </button>
      </form>
    )}

    {!submitted && (
      <div class="mt-6 text-center text-sm text-zinc-500">
        <a href="/login" class="text-zinc-400 hover:text-zinc-100 transition-colors">Back to login</a>
      </div>
    )}
  </div>
</Base>