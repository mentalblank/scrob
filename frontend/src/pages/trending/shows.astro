---
import Base from "../../layouts/Base.astro";
import MediaCard from "../../components/MediaCard.astro";
import VisibilityFilters from "../../components/VisibilityFilters.astro";
import Pagination from "../../components/Pagination.astro";
import InfiniteScroll from "../../components/InfiniteScroll.astro";
import { api, type MediaItem } from "../../lib/api";



const { token } = Astro.locals;
const profile = await api.profile.get(token!);
const paginationType = profile?.pagination_type ?? "infinite_scroll";
Astro.response.headers.set("Cache-Control", "no-store");
const page = parseInt(Astro.url.searchParams.get("page") || "1");

let trending: { results: MediaItem[]; page: number; total_pages: number } = { results: [], page: 1, total_pages: 1 };
let error = "";

try {
  trending = await api.media.trendingShows(page, token);
} catch (e: any) {
  error = e.message;
}
---

<Base title={`Trending Shows — Page ${page}`}>
  <div class="flex items-center justify-between mb-8">
    <div>
      <h1 class="text-3xl font-bold text-zinc-100 mb-2">Trending Shows</h1>
      <p class="text-zinc-500">Popular TV shows right now on TMDB</p>
    </div>
    <div class="flex items-center gap-2">
      <VisibilityFilters />
    </div>
  </div>

  {error && (
    <div class="bg-red-500/10 border border-red-500 text-red-500 p-4 rounded-lg mb-8">
      {error}
    </div>
  )}

  <div id="media-grid" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-6">
    {trending.results.map((item) => (
      <MediaCard item={item} />
    ))}
  </div>

  {paginationType === "pagination" ? (
    <Pagination
      currentPage={trending.page}
      totalPages={trending.total_pages}
      baseUrl="/trending/shows"
    />
  ) : (
    <InfiniteScroll
      type="trending_shows"
      currentPage={trending.page}
      totalPages={trending.total_pages}
    />
  )}
</Base>

<script>
</script>
