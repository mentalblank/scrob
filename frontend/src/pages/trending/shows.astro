---
import Base from "../../layouts/Base.astro";
import MediaCard from "../../components/MediaCard.astro";
import Pagination from "../../components/Pagination.astro";
import { api, type MediaItem } from "../../lib/api";

const { token } = Astro.locals;
Astro.response.headers.set("Cache-Control", "no-store");
const page = parseInt(Astro.url.searchParams.get("page") || "1");

let trending: { results: MediaItem[]; page: number; total_pages: number } = { results: [], page: 1, total_pages: 1 };
let error = "";

try {
  trending = await api.media.trendingShows(page, token);
} catch (e: any) {
  error = e.message;
}
---

<Base title={`Trending Shows — Page ${page}`}>
  <div class="mb-8">
    <h1 class="text-3xl font-bold text-zinc-100 mb-2">Trending Shows</h1>
    <p class="text-zinc-500">Popular shows right now on TMDB</p>
  </div>

  {error && (
    <div class="bg-red-500/10 border border-red-500 text-red-500 p-4 rounded-lg mb-8">
      {error}
    </div>
  )}

  <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-6">
    {trending.results.map((item) => (
      <MediaCard item={item} />
    ))}
  </div>

  <Pagination
    currentPage={trending.page}
    totalPages={trending.total_pages}
    baseUrl="/trending/shows"
  />
</Base>

<script>
</script>
