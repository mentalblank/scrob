---
import Base from "../../layouts/Base.astro";
import MediaCard from "../../components/MediaCard.astro";
import MediaListCard from "../../components/MediaListCard.astro";
import ViewToggle from "../../components/ViewToggle.astro";
import VisibilityFilters from "../../components/VisibilityFilters.astro";
import Pagination from "../../components/Pagination.astro";
import { api, type MediaItem } from "../../lib/api";

const viewPreference = Astro.cookies.get("media_view_preference")?.value === "list" ? "list" : "grid";

const { token } = Astro.locals;
Astro.response.headers.set("Cache-Control", "no-store");
const page = parseInt(Astro.url.searchParams.get("page") || "1");

let trending: { results: MediaItem[]; page: number; total_pages: number } = { results: [], page: 1, total_pages: 1 };
let error = "";

try {
  trending = await api.media.trendingMovies(page, token);
} catch (e: any) {
  error = e.message;
}
---

<Base title={`Trending Movies — Page ${page}`}>
  <div class="flex items-center justify-between mb-8">
    <div>
      <h1 class="text-3xl font-bold text-zinc-100 mb-2">Trending Movies</h1>
      <p class="text-zinc-500">Popular movies right now on TMDB</p>
    </div>
    <div class="flex items-center gap-2">
      <VisibilityFilters />
      <ViewToggle currentView={viewPreference} />
    </div>
  </div>

  {error && (
    <div class="bg-red-500/10 border border-red-500 text-red-500 p-4 rounded-lg mb-8">
      {error}
    </div>
  )}

  {viewPreference === "list" ? (
    <div class="flex flex-col gap-4">
      {trending.results.map((item) => (
        <MediaListCard item={item} />
      ))}
    </div>
  ) : (
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-6">
      {trending.results.map((item) => (
        <MediaCard item={item} />
      ))}
    </div>
  )}

  <Pagination
    currentPage={trending.page}
    totalPages={trending.total_pages}
    baseUrl="/trending/movies"
  />
</Base>

<script>
</script>
