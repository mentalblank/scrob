---
import { api } from "../lib/api";

// Create a PIN, stash its id in a cookie, redirect to app.plex.tv to authenticate.

let errorMsg = "";

// Public origin from forwarded headers so the callback works behind a proxy.
const host = Astro.request.headers.get("x-forwarded-host") ?? Astro.url.host;
const proto = Astro.request.headers.get("x-forwarded-proto") ?? Astro.url.protocol.replace(":", "");
const redirectUri = `${proto}://${host}/plex-callback`;

try {
  const { auth_url, pin_id } = await api.auth.plexAuthorize(false, redirectUri);

  Astro.cookies.set("plex_pin", pin_id, {
    path: "/",
    httpOnly: true,
    secure: import.meta.env.PROD,
    sameSite: "lax",
    maxAge: 600, // 10 minutes
  });

  return Astro.redirect(auth_url);
} catch (e: unknown) {
  errorMsg = e instanceof Error ? e.message : "Failed to start Plex sign-in";
}
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Plex Sign-in Error</title>
  </head>
  <body>
    <p>{errorMsg}</p>
    <a href="/login">Back to login</a>
  </body>
</html>
