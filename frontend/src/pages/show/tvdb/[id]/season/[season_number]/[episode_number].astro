---
import Base from "../../../../../../layouts/Base.astro";
import ActionBar from "../../../../../../components/ActionBar.astro";
import CommentsSection from "../../../../../../components/CommentsSection.astro";
import VideoPlayer from "../../../../../../components/VideoPlayer.astro";
import ManualScrobble from "../../../../../../components/ManualScrobble.astro";
import ProgressStrip from "../../../../../../components/ProgressStrip.astro";
import { api, type TvdbEpisodeDetail } from "../../../../../../lib/api";

export const prerender = false;

const { id, season_number, episode_number } = Astro.params;
const { token } = Astro.locals;
Astro.response.headers.set("Cache-Control", "no-store");

let episode: TvdbEpisodeDetail | null = null;
let error = "";

try {
  episode = await api.shows.getTvdbEpisode(Number(id), Number(season_number), Number(episode_number), token);
} catch (e: any) {
  error = e.message;
}

if (!episode && !error) {
  return Astro.redirect("/404");
}

if (episode) {
  const primaryMetadataSource = Astro.cookies.get("primary_metadata_source")?.value || "tmdb";
  if (primaryMetadataSource === "tmdb" && episode.show?.tmdb_id_cross) {
    return Astro.redirect(`/show/${episode.show.tmdb_id_cross}/season/${season_number}/${episode_number}`);
  }
}

const show = episode?.show;
const season = episode?.season;
const seasonName = season?.name || `Season ${season_number}`;
const thumbnail = episode?.image_url || show?.poster_path || null;

const validSeasons = (show?.seasons_meta || [])
  .filter((s: any) => s.season_number > 0 && s.episode_count > 0);
const isSingleSeason = validSeasons.length === 1;

const hasPlayableTmdbId = show?.tmdb_id_cross != null;
const activeButtonsCount = [
  episode && episode.in_library && hasPlayableTmdbId,
  true, // ManualScrobble is always rendered
  episode && episode.in_library
].filter(Boolean).length;
---

<Base title={episode ? `${show?.title} — ${seasonName} — ${episode.name ?? `Episode ${episode_number}`}` : "Episode Details"}>
  {error && !episode && (
    <div class="max-w-md mx-auto mt-20 text-center">
      <div class="bg-red-500/10 border border-red-500/20 text-red-500 p-6 rounded-2xl mb-6">
        <p class="font-bold text-lg mb-2">Oops!</p>
        <p class="text-sm opacity-80">{error}</p>
      </div>
      <a href="/" class="text-blue-500 hover:underline">Return to Dashboard</a>
    </div>
  )}

  {episode && (
    <div class="relative">
      <!-- Backdrop from show -->
      {show?.backdrop_path && (
        <div class="absolute -top-20 md:-top-32 left-1/2 -translate-x-1/2 w-screen h-[600px] overflow-hidden" style="mask-image: linear-gradient(to bottom, transparent 0%, black 15%, black 60%, transparent 100%); -webkit-mask-image: linear-gradient(to bottom, transparent 0%, black 15%, black 60%, transparent 100%);">
          <div class="absolute inset-0 bg-gradient-to-t from-[var(--color-hero-fade)] via-[var(--color-hero-fade)]/40 to-transparent z-10"></div>
          <img
            src={show.backdrop_path}
            alt=""
            class="w-full h-full object-cover opacity-50 blur-[1px]"
            loading="eager"
            decoding="async"
          />
        </div>
      )}

      <div class="relative z-20">
        <!-- Breadcrumb -->
        <nav class="flex items-center gap-2 text-sm text-zinc-400 mb-8 overflow-hidden whitespace-nowrap">
          <a href="/shows" class="hover:text-zinc-100 transition shrink-0">Shows</a>
          <span class="text-zinc-700">/</span>
          <a href={`/show/tvdb/${id}`} class="hover:text-zinc-100 transition truncate">{show?.title}</a>
          {!isSingleSeason && (
            <>
              <span class="text-zinc-700 shrink-0">/</span>
              <a href={`/show/tvdb/${id}/season/${season_number}`} class="hover:text-zinc-100 transition shrink-0">{seasonName}</a>
            </>
          )}
          <span class="text-zinc-700 shrink-0">/</span>
          <span class="text-zinc-100 font-bold shrink-0">Episode {episode_number}</span>
        </nav>

        <!-- Title & Pagination -->
        <div class="mb-10 flex flex-col md:flex-row md:items-center justify-between gap-4">
          <div class="min-w-0">
            <h1 class="text-3xl md:text-5xl font-black text-zinc-100 tracking-tight leading-tight text-center md:text-left">{episode.name ?? `Episode ${episode_number}`}</h1>
          </div>
          
          {(() => {
            const currentEpisode = Number(episode_number);
            const currentSeasonNum = Number(season_number);
            const episodes = (episode.episodes || [])
              .sort((a, b) => a.episode_number - b.episode_number);
            const currentIndex = episodes.findIndex((e) => e.episode_number === currentEpisode);
            const prevEp = currentIndex > 0 ? episodes[currentIndex - 1] : null;
            const nextEp = currentIndex < episodes.length - 1 ? episodes[currentIndex + 1] : null;

            const validSeasons = (show?.seasons_meta || [])
              .filter((s: any) => s.season_number > 0 && s.episode_count > 0)
              .sort((a: any, b: any) => a.season_number - b.season_number);
            const seasonIdx = validSeasons.findIndex((s: any) => s.season_number === currentSeasonNum);

            let nextSeasonLink = null;
            let prevSeasonLink = null;

            if (!nextEp && seasonIdx !== -1 && seasonIdx < validSeasons.length - 1) {
              const nextSeasonMeta = validSeasons[seasonIdx + 1];
              nextSeasonLink = `/show/tvdb/${id}/season/${nextSeasonMeta.season_number}/1`;
            }
            if (!prevEp && seasonIdx > 0) {
              const prevSeasonMeta = validSeasons[seasonIdx - 1];
              prevSeasonLink = `/show/tvdb/${id}/season/${prevSeasonMeta.season_number}/${prevSeasonMeta.episode_count}`;
            }

            const hasNavigation = episodes.length > 1 || nextSeasonLink || prevSeasonLink;

            if (!hasNavigation) return null;

            return (
              <div class="flex items-center justify-center md:justify-start gap-2 shrink-0">
                {prevEp ? (
                  <a href={`/show/tvdb/${id}/season/${season_number}/${prevEp.episode_number}`} class="flex items-center gap-1.5 px-3 py-2 bg-zinc-900/60 backdrop-blur-xl border border-zinc-800/50 rounded-xl text-zinc-400 hover:text-zinc-100 hover:border-blue-500/50 hover:bg-zinc-800/60 active:scale-95 active:opacity-70 transition-all text-sm font-bold">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12 15.75 4.5" />
                    </svg>
                    <span class="hidden sm:inline">E{prevEp.episode_number}</span>
                  </a>
                ) : prevSeasonLink ? (
                  <a href={prevSeasonLink} class="flex items-center gap-1.5 px-3 py-2 bg-zinc-900/60 backdrop-blur-xl border border-zinc-800/50 rounded-xl text-zinc-400 hover:text-zinc-100 hover:border-blue-500/50 hover:bg-zinc-800/60 active:scale-95 active:opacity-70 transition-all text-sm font-bold" title="Last episode of previous season">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12 15.75 4.5" />
                    </svg>
                    <span class="hidden sm:inline">Prev Season</span>
                  </a>
                ) : null}

                <span class="px-3 py-2 bg-blue-600/20 backdrop-blur-xl border border-blue-500/30 rounded-xl text-blue-400 text-sm font-black">
                  E{currentEpisode}
                </span>

                {nextEp ? (
                  <a href={`/show/tvdb/${id}/season/${season_number}/${nextEp.episode_number}`} class="flex items-center gap-1.5 px-3 py-2 bg-zinc-900/60 backdrop-blur-xl border border-zinc-800/50 rounded-xl text-zinc-400 hover:text-zinc-100 hover:border-blue-500/50 hover:bg-zinc-800/60 active:scale-95 active:opacity-70 transition-all text-sm font-bold">
                    <span class="hidden sm:inline">E{nextEp.episode_number}</span>
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4">
                      <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
                    </svg>
                  </a>
                ) : nextSeasonLink ? (
                  <a href={nextSeasonLink} class="flex items-center gap-1.5 px-3 py-2 bg-zinc-900/60 backdrop-blur-xl border border-zinc-800/50 rounded-xl text-zinc-400 hover:text-zinc-100 hover:border-blue-500/50 hover:bg-zinc-800/60 active:scale-95 active:opacity-70 transition-all text-sm font-bold" title="First episode of next season">
                    <span class="hidden sm:inline">Next Season</span>
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4">
                      <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
                    </svg>
                  </a>
                ) : null}
              </div>
            );
          })()}
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12 items-start mb-16">
          <!-- LEFT COLUMN: Thumbnail & Actions Sidebar -->
          <div class="lg:col-span-4 space-y-6">
            <!-- Thumbnail -->
            <div class="w-full shrink-0">
              <div class="aspect-video rounded-2xl overflow-hidden shadow-2xl border border-zinc-800 bg-zinc-900 ring-1 ring-white/10 relative">
                {thumbnail ? (
                  <button id="poster-zoom-btn" class="w-full h-full group/poster block cursor-zoom-in" aria-label={`Enlarge thumbnail`}>
                    <img
                      src={thumbnail}
                      alt={episode.name ?? `Episode ${episode_number}`}
                      class="w-full h-full object-cover transition-transform duration-300 group-hover/poster:scale-105"
                      loading="eager"
                      decoding="async"
                    />
                    <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover/poster:opacity-100 transition-opacity duration-200 bg-black/30">
                      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-8 h-8 text-white drop-shadow-lg">
                        <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607ZM10.5 7.5v6m3-3h-6" />
                      </svg>
                    </div>

                    {episode.progress_percent !== undefined && episode.progress_percent !== null && episode.progress_percent > 0 && (
                      <div class="absolute bottom-0 left-0 right-0 h-1.5 bg-zinc-800/80">
                        <div class="h-full bg-blue-500 rounded-r-full" style={`width: ${episode.progress_percent}%`}></div>
                      </div>
                    )}
                  </button>
                ) : (
                  <div class="w-full h-full flex flex-col items-center justify-center text-zinc-400 p-4 text-center">
                    <span class="text-4xl mb-2">📺</span>
                    <span class="text-sm font-medium">No Thumbnail</span>
                  </div>
                )}
              </div>
            </div>

            <!-- ActionBar -->
            <div class="bg-zinc-900/20 border border-zinc-800/50 backdrop-blur-sm p-4 rounded-2xl space-y-4">
              <ActionBar
                tmdbId={episode.tvdb_id ?? Number(id)}
                mediaType="episode"
                watched={episode.watched ?? false}
                inLists={episode.in_lists ?? []}
                inLibrary={episode.in_library ?? false}
                collectionPct={episode.in_library ? 100 : 0}
                showTmdbId={show?.tmdb_id_cross ?? -Number(id)}
                seasonNumber={Number(season_number)}
                episodeNumber={Number(episode_number)}
                requestEnabled={episode.request_enabled ?? false}
                requestStatus={episode.request_status ?? null}
                mediaId={episode.id ?? null}
                userRating={episode.user_rating ?? null}
                isBlocked={episode.is_blocked ?? false}
                isDropped={episode.is_dropped ?? false}
              />

              {episode && episode.progress_percent !== undefined && episode.progress_percent !== null && episode.progress_percent > 0 && (
                <div class="pt-2 border-t border-zinc-800/60">
                  <ProgressStrip
                    progressPct={episode.progress_percent}
                    title="Playback Progress"
                    currentDuration={episode.runtime ? episode.runtime * (episode.progress_percent / 100) : undefined}
                    totalDuration={episode.runtime ?? undefined}
                    className="mt-0"
                  />
                </div>
              )}
            </div>

            <!-- Action Buttons Container (Play, Session, Refresh) -->
            {activeButtonsCount > 0 && (
              <div class={`grid gap-2 w-full grid-cols-${activeButtonsCount}`}>
                {episode.in_library && show?.tmdb_id_cross != null && (
                  <VideoPlayer
                    tmdbId={show.tmdb_id_cross}
                    mediaId={episode.id}
                    mediaType="episode"
                    inLibrary={episode.in_library ?? false}
                    title={`${show?.title} — ${episode.name ?? `Episode ${episode_number}`}`}
                    token={token || ""}
                  />
                )}
                <ManualScrobble
                  tmdbId={show?.tmdb_id_cross}
                  mediaId={episode.id}
                  mediaType="episode"
                  runtime={episode.runtime}
                  title={episode.name ?? `Episode ${episode_number}`}
                  showTmdbId={show?.tmdb_id_cross}
                  seasonNumber={Number(season_number)}
                  episodeNumber={Number(episode_number)}
                />
                {episode.in_library && (
                  <button
                    id="refresh-metadata-btn"
                    class="w-full h-11 flex items-center justify-center gap-2 px-5 text-sm font-bold leading-none text-zinc-400 hover:text-zinc-100 bg-zinc-900/60 hover:bg-zinc-800/80 border border-zinc-800 hover:border-zinc-700 rounded-xl transition-all duration-200 cursor-pointer"
                  >
                    <svg id="refresh-icon" xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8"/>
                      <path d="M21 3v5h-5"/>
                      <path d="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16"/>
                      <path d="M8 16H3v5"/>
                    </svg>
                    <span id="refresh-label">Refresh Metadata</span>
                  </button>
                )}
              </div>
            )}
          </div>

          <!-- RIGHT COLUMN: Details & Cast -->
          <div class="lg:col-span-8 space-y-8">
            <div class="flex flex-wrap items-center gap-3">
              <p class="text-lg text-blue-400 font-bold tracking-wide uppercase">{show?.title}</p>
              <span class="px-3 py-1 bg-blue-600/20 border border-blue-600/30 text-blue-400 text-[10px] font-black rounded-full uppercase tracking-widest">
                S{String(season_number).padStart(2, '0')}E{String(episode_number).padStart(2, '0')}
              </span>
            </div>

            <div class="flex flex-wrap items-center gap-2.5 md:gap-4 text-zinc-300 text-xs md:text-sm bg-zinc-900/40 p-2.5 md:p-3 rounded-xl border border-zinc-800/50 backdrop-blur-sm w-fit">
              {episode.air_date && (
                <span class="font-bold">
                  {new Date(episode.air_date).toLocaleDateString(undefined, { year: 'numeric', month: 'long', day: 'numeric' })}
                </span>
              )}
              {episode.runtime && (
                <span class="flex items-center gap-1.5 font-medium">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4 text-zinc-500">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                  </svg>
                  {episode.runtime} min
                </span>
              )}
              {!!episode.play_count && (
                <span id="play-count-badge" class="inline-flex items-center px-2.5 py-1 bg-zinc-950 hover:bg-zinc-900 border border-zinc-850 hover:border-zinc-700 text-zinc-400 hover:text-zinc-100 text-xs font-bold rounded-lg cursor-pointer transition-all duration-200" title="Click to view/remove specific plays" data-tmdb-id={show?.tmdb_id_cross ?? ""} data-media-id={episode.id} data-media-type="episode">
                  {episode.play_count} {episode.play_count === 1 ? 'Play' : 'Plays'}
                </span>
              )}
            </div>

            <!-- Library info -->
            {(() => {
              const hasLibraryTags = episode.library && (
                episode.library.resolution ||
                episode.library.video_codec ||
                episode.library.audio_codec ||
                episode.library.audio_channels ||
                episode.library.audio_languages?.length ||
                episode.library.subtitle_languages?.length
              );
              return hasLibraryTags && (
                <div class="flex flex-wrap gap-2">
                  {[
                    episode.library?.resolution,
                    episode.library?.video_codec,
                    episode.library?.audio_codec,
                    episode.library?.audio_channels,
                  ].filter(Boolean).map(tag => (
                    <span class="px-3 py-1 md:py-1.5 bg-zinc-900 border border-zinc-800 text-zinc-400 text-[10px] md:text-xs rounded-lg font-mono font-bold">
                      {tag}
                    </span>
                  ))}
                  {episode.library?.audio_languages?.map((lang: string) => (
                    <span class="px-3 py-1 md:py-1.5 bg-zinc-900 border border-zinc-800 text-zinc-400 text-[10px] md:text-xs rounded-lg font-mono font-bold flex items-center gap-1.5">
                      <span class="opacity-50">🔊</span> {lang}
                    </span>
                  ))}
                  {episode.library?.subtitle_languages?.map((lang: string) => (
                    <span class="px-3 py-1 md:py-1.5 bg-zinc-900 border border-zinc-800 text-zinc-400 text-[10px] md:text-xs rounded-lg font-mono font-bold flex items-center gap-1.5">
                      <span class="opacity-50">💬</span> {lang}
                    </span>
                  ))}
                </div>
              );
            })()}

            {episode.overview && (
              <div class="space-y-3">
                <h2 class="text-sm font-black text-zinc-500 uppercase tracking-[0.2em] flex items-center gap-2">
                  <span class="w-2 h-2 bg-blue-500 rounded-full"></span>
                  Overview
                </h2>
                <p class="text-zinc-350 leading-relaxed text-base md:text-lg opacity-90">
                  {episode.overview}
                </p>
              </div>
            )}

            <CommentsSection
              mediaType="series"
              tmdbId={Number(id)}
              seasonNumber={Number(season_number)}
              episodeNumber={Number(episode_number)}
            />

            <!-- Cast -->
            {episode.cast?.length > 0 && (
              <div class="space-y-6">
                <h2 class="text-2xl font-black text-zinc-100 tracking-tighter uppercase flex items-center gap-3">
                  <span class="w-1.5 h-6 bg-blue-600 rounded-full"></span>
                  Cast
                </h2>
                <div class="grid grid-cols-3 xs:grid-cols-4 sm:grid-cols-5 xl:grid-cols-6 gap-3">
                  {episode.cast.map((person) => (
                    person.person_id ? (
                      <a
                        href={`/person/tvdb/${person.person_id}`}
                        class="group/cast bg-zinc-900/20 border border-zinc-800/40 p-2 rounded-2xl hover:bg-zinc-800/40 hover:border-blue-500/50 transition-all duration-500 hover:shadow-2xl hover:shadow-blue-900/10 active:scale-95 active:opacity-70 flex flex-col h-full"
                      >
                        <div class="aspect-square w-full rounded-xl overflow-hidden mb-2 ring-2 ring-zinc-800/50 group-hover/cast:ring-blue-500 transition-all duration-500 shadow-lg">
                          {person.profile_path ? (
                            <img
                              src={person.profile_path}
                              alt={person.name}
                              class="w-full h-full object-cover group-hover/cast:scale-110 transition-transform duration-700"
                              loading="lazy"
                              decoding="async"
                            />
                          ) : (
                            <div class="w-full h-full bg-zinc-800 flex items-center justify-center text-zinc-400 text-2xl">👤</div>
                          )}
                        </div>
                        <div class="flex-1 flex flex-col items-center justify-center text-center px-0.5 py-1">
                          <p class="text-xs font-black text-zinc-100 group-hover/cast:text-blue-400 transition-colors line-clamp-2 leading-tight">{person.name}</p>
                          <p class="text-[10px] text-zinc-500 font-bold uppercase tracking-wider line-clamp-2 opacity-80 mt-0.5">{person.character}</p>
                        </div>
                      </a>
                    ) : (
                      <div class="bg-zinc-900/20 border border-zinc-800/40 p-2 rounded-2xl flex flex-col h-full">
                        <div class="aspect-square w-full rounded-xl overflow-hidden mb-2 ring-2 ring-zinc-800/50 shadow-lg">
                          {person.profile_path ? (
                            <img
                              src={person.profile_path}
                              alt={person.name}
                              class="w-full h-full object-cover"
                              loading="lazy"
                              decoding="async"
                            />
                          ) : (
                            <div class="w-full h-full bg-zinc-800 flex items-center justify-center text-zinc-400 text-2xl">👤</div>
                          )}
                        </div>
                        <div class="flex-1 flex flex-col items-center justify-center text-center px-0.5 py-1">
                          <p class="text-xs font-black text-zinc-100 line-clamp-2 leading-tight">{person.name}</p>
                          <p class="text-[10px] text-zinc-500 font-bold uppercase tracking-wider line-clamp-2 opacity-80 mt-0.5">{person.character}</p>
                        </div>
                      </div>
                    )
                  ))}
                </div>
              </div>
            )}

          </div>
        </div>
      </div>
    </div>
  )}
</Base>

{thumbnail && (
  <div id="poster-modal" class="fixed inset-0 z-[999] flex items-center justify-center hidden" role="dialog" aria-modal="true">
    <div id="poster-modal-backdrop" class="absolute inset-0 bg-black/90 backdrop-blur-sm cursor-pointer"></div>
    <img
      src={thumbnail}
      alt={episode?.name ?? `Episode ${episode_number}`}
      class="relative max-h-[90vh] max-w-[90vw] md:max-w-[70vw] object-contain rounded-2xl shadow-2xl ring-1 ring-white/10"
    />
    <button
      id="poster-modal-close"
      class="absolute top-4 right-4 p-2 rounded-full bg-black/60 hover:bg-black/80 text-white/70 hover:text-white transition-all duration-200 cursor-pointer"
      aria-label="Close"
    >
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-5 h-5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
      </svg>
    </button>
  </div>
)}

<script define:vars={{ token: Astro.locals.token }}>
  const badge = document.getElementById('play-count-badge');

  if (badge) {
    const tmdbId = badge.getAttribute('data-tmdb-id');
    const mediaId = badge.getAttribute('data-media-id');
    const mediaType = badge.getAttribute('data-media-type');

    badge.addEventListener('click', () => {
      if ((window as any).openWatchHistoryModal) {
        (window as any).openWatchHistoryModal(null, tmdbId || null, mediaType, mediaId || null);
      }
    });
  }
</script>

<script>
  const zoomBtn = document.getElementById('poster-zoom-btn');
  const modal = document.getElementById('poster-modal');
  const backdrop = document.getElementById('poster-modal-backdrop');
  const closeBtn = document.getElementById('poster-modal-close');
  if (zoomBtn && modal) {
    const openModal = () => { modal.classList.remove('hidden'); document.body.style.overflow = 'hidden'; };
    const closeModal = () => { modal.classList.add('hidden'); document.body.style.overflow = ''; };
    zoomBtn.addEventListener('click', openModal);
    backdrop?.addEventListener('click', closeModal);
    closeBtn?.addEventListener('click', closeModal);
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });
  }
</script>

<script define:vars={{ tvdbId: id, token: Astro.locals.token }}>
  const btn = document.getElementById('refresh-metadata-btn');
  if (btn) {
    btn.addEventListener('click', async () => {
      const icon = document.getElementById('refresh-icon');
      const label = document.getElementById('refresh-label');
      if (!label || !icon) return;

      btn.setAttribute('disabled', 'true');
      btn.classList.add('opacity-60', 'cursor-not-allowed');
      icon.classList.add('animate-spin');
      label.textContent = 'Refreshing...';

      try {
        const res = await fetch(`/api/proxy/shows/tvdb/${tvdbId}/refresh`, {
          method: 'POST',
          headers: { 'Authorization': `Bearer ${token}` },
        });
        if (!res.ok) {
          const data = await res.json().catch(() => ({}));
          throw new Error(data.detail || 'Refresh failed');
        }
        label.textContent = 'Done!';
        icon.classList.remove('animate-spin');
        setTimeout(() => { window.location.reload(); }, 800);
      } catch (err) {
        icon.classList.remove('animate-spin');
        label.textContent = 'Refresh failed';
        btn.removeAttribute('disabled');
        btn.classList.remove('opacity-60', 'cursor-not-allowed');
        setTimeout(() => { label.textContent = 'Refresh Metadata'; }, 3000);
      }
    });
  }
</script>
