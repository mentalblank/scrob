---
import Base from "../../layouts/Base.astro";
import MediaRow from "../../components/MediaRow.astro";
import ActionBar from "../../components/ActionBar.astro";
import MediaCard from "../../components/MediaCard.astro";
import VisibilityFilters from "../../components/VisibilityFilters.astro";
import CommentsSection from "../../components/CommentsSection.astro";
import ProgressStrip from "../../components/ProgressStrip.astro";
import { api, type Show } from "../../lib/api";
export const prerender = false;

const { id } = Astro.params;
const { token } = Astro.locals;

Astro.response.headers.set("Cache-Control", "no-store");

let show: Show | null = null;
let error = "";

try {
  show = await api.shows.get(Number(id), token);
} catch (e: any) {
  error = e.message;
}

if (!show && !error) {
    return Astro.redirect("/404");
}

const seasons = Object.entries(show?.seasons ?? {}).sort(
  ([a], [b]) => Number(a.replace("season_", "")) - Number(b.replace("season_", ""))
);

// Progress stats
const allEpisodes = Object.values(show?.seasons ?? {}).flat();
const watchedEpisodesCount = allEpisodes.filter(e => e.watched).length;
const totalEpisodesCount = show?.seasons_meta?.reduce((acc, s) => acc + s.episode_count, 0) || allEpisodes.length;
const remainingEpisodesCount = totalEpisodesCount - watchedEpisodesCount;
const remainingDuration = allEpisodes
  .filter(e => !e.watched)
  .reduce((acc, e) => acc + (e.runtime || 0), 0);
const overallProgress = totalEpisodesCount > 0 ? (watchedEpisodesCount / totalEpisodesCount) * 100 : 0;
const showProgress = overallProgress > 0; // Show progress even if 100% to match GridCard behavior

const year = show?.first_air_date?.slice(0, 4) ?? null;
const rating = show?.tmdb_rating ? show.tmdb_rating.toFixed(1) : null;
const langNames = new Intl.DisplayNames(["en"], { type: "language" });
const originalLanguage = show?.original_language
  ? langNames.of(show.original_language) ?? show.original_language
  : null;
---

<Base title={show?.title || "Show Details"}>
  {error && !show && (
    <div class="max-w-md mx-auto mt-20 text-center">
        <div class="bg-red-500/10 border border-red-500/20 text-red-500 p-6 rounded-2xl mb-6">
            <p class="font-bold text-lg mb-2">Oops!</p>
            <p class="text-sm opacity-80">{error}</p>
        </div>
        <a href="/" class="text-blue-500 hover:underline">Return to Dashboard</a>
    </div>
  )}

  {show && (
    <div class="relative">
      <!-- Backdrop -->
      {show.backdrop_path && (
        <div class="absolute -top-8 left-1/2 -translate-x-1/2 w-screen h-[600px] overflow-hidden" style="mask-image: linear-gradient(to bottom, black 50%, transparent 100%); -webkit-mask-image: linear-gradient(to bottom, black 50%, transparent 100%);" data-adult-backdrop={show.adult ? "true" : undefined}>
          <div class="absolute inset-0 bg-gradient-to-t from-zinc-950 via-zinc-950/40 to-transparent z-10"></div>
          <img
            src={show.backdrop_path}
            alt=""
            class="w-full h-full object-cover opacity-50 blur-[1px]"
            loading="eager"
            decoding="async"
          />
        </div>
      )}

      <div class="relative z-20">
        <nav class="flex items-center gap-2 text-sm text-zinc-400 mb-8 overflow-hidden whitespace-nowrap">
          <a href="/shows" class="hover:text-zinc-100 transition shrink-0">Shows</a>
          <span class="text-zinc-700">/</span>
          <span class="text-zinc-100 font-bold truncate">{show.title}</span>
        </nav>

        <div class="flex flex-col md:flex-row gap-8 lg:gap-12">
          <!-- Poster -->
            <div class="w-full md:w-1/3 lg:w-1/4 shrink-0">
              <div class="aspect-[2/3] rounded-2xl overflow-hidden border border-white/10 shadow-2xl relative group/poster">
                {show.poster_path ? (
                  <img
                    src={show.poster_path}
                    alt={show.title}
                    class="w-full h-full object-cover transition-transform duration-700 group-hover/poster:scale-110"
                  />
                ) : (
                  <div class="w-full h-full bg-zinc-900 flex flex-col items-center justify-center text-zinc-500 gap-2">
                    <span class="text-5xl">📺</span>
                    <span class="text-xs font-bold uppercase tracking-widest">No Poster</span>
                  </div>
                )}
                {showProgress && (
                  <div class="absolute bottom-0 left-0 right-0 h-1.5 bg-zinc-800/80">
                    <div class="h-full bg-blue-500 rounded-r-full" style={`width: ${overallProgress}%`}></div>
                  </div>
                )}
              </div>
            </div>

          <!-- Info -->
          <div class="flex-1 min-w-0 pt-4">
            <h1 class="text-4xl md:text-6xl font-black text-zinc-100 mb-3 tracking-tight leading-none">{show.title}</h1>

            {show.tagline && (
              <p class="text-xl italic text-zinc-400 mb-8 font-light leading-relaxed">"{show.tagline}"</p>
            )}

            <div class="flex flex-wrap items-center gap-3 mb-10">
              <div class="flex flex-wrap items-center gap-4 text-zinc-300 text-sm bg-zinc-900/40 p-3 rounded-xl border border-zinc-800/50 backdrop-blur-sm">
                {year && <span class="font-bold">{year}</span>}
                {rating && (
                  <span class="flex items-center gap-1.5 text-yellow-400 font-black">
                    <span class="text-lg leading-none">★</span> {rating}
                  </span>
                )}
                <span class="font-medium text-zinc-400">{show.seasons_meta?.length || seasons.length} Seasons</span>
                {show.age_rating && (
                  <span class="px-2 py-0.5 border border-zinc-600 rounded text-[10px] font-black text-zinc-400 tracking-widest">
                    {show.age_rating}
                  </span>
                )}
                {show.imdb_id && (
                  <a href={`https://www.imdb.com/title/${show.imdb_id}/`} target="_blank" rel="noopener noreferrer" class="px-2 py-0.5 bg-[#f5c518] rounded text-[10px] font-black text-black tracking-widest hover:bg-[#e6b800] transition-colors">
                    IMDb
                  </a>
                )}
                {show.status && (
                  <span class="capitalize px-2 py-0.5 bg-zinc-800 border border-zinc-700 rounded text-[10px] font-black text-zinc-400 tracking-widest">
                    {show.status}
                  </span>
                )}
                <span class="text-[10px] font-black text-zinc-400 uppercase tracking-widest px-2 py-0.5 bg-zinc-800/50 rounded border border-zinc-800">
                  Show
                </span>
                {showProgress && (
                  <span class="text-xs font-bold text-blue-500 tabular-nums bg-blue-500/10 px-2 py-0.5 rounded border border-blue-500/20">
                    {Math.round(overallProgress)}%
                  </span>
                )}
                {originalLanguage && (
                  <span class="flex items-center gap-1.5 font-medium text-zinc-400">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4 text-zinc-500">
                      <path stroke-linecap="round" stroke-linejoin="round" d="m10.5 21 5.25-11.25L21 21m-9-3h7.5M3 5.621a48.474 48.474 0 0 1 6-.371m0 0c1.12 0 2.233.038 3.334.114M9 5.25V3m3.334 2.364C11.176 10.658 7.69 15.08 3 17.502m9.334-12.138c.896.061 1.785.147 2.666.257m-4.589 8.495a18.023 18.023 0 0 1-3.827-5.802" />
                    </svg>
                    {originalLanguage}
                  </span>
                )}
              </div>
              {(() => { const n = show.networks?.find(n => n.logo_path); return n ? <div class="bg-zinc-900/40 p-3 rounded-xl border border-zinc-800/50 backdrop-blur-sm flex items-center"><img src={n.logo_path!} alt={n.name} title={n.name} class="h-5 max-w-[80px] object-contain" loading="lazy" /></div> : null; })()}
            </div>

            <div class="mb-6">
                <div class="flex flex-col lg:flex-row lg:items-end justify-between gap-6">
                    <div class="flex-1">
                        <ActionBar
                          tmdbId={Number(id)}
                          mediaType="series"
                          watched={show.watched ?? false}
                          inLists={show.in_lists ?? []}
                          inLibrary={show.in_library ?? false}
                          collectionPct={show.collection_pct ?? 0}
                          showTmdbId={Number(id)}
                          isMonitored={show.is_monitored ?? false}
                          requestEnabled={show.request_enabled ?? false}
                          userRating={show.user_rating ?? null}
                        />
                    </div>
                    {showProgress && (
                      <div class="w-full lg:w-64">
                        <ProgressStrip
                          watchedEpisodesCount={watchedEpisodesCount}
                          totalEpisodesCount={totalEpisodesCount}
                          remainingDuration={remainingDuration}
                          className="mt-0"
                        />
                      </div>
                    )}
                </div>
            </div>

            {show.in_library && (
              <div class="mb-8">
                <button
                  id="refresh-metadata-btn"
                  class="flex items-center gap-2 px-4 py-2 text-sm font-bold text-zinc-400 hover:text-zinc-100 bg-zinc-900/60 hover:bg-zinc-800/80 border border-zinc-800 hover:border-zinc-700 rounded-xl transition-all duration-200 cursor-pointer"
                >
                  <svg id="refresh-icon" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8"/>
                    <path d="M21 3v5h-5"/>
                    <path d="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16"/>
                    <path d="M8 16H3v5"/>
                  </svg>
                  <span id="refresh-label">Refresh Metadata</span>
                </button>
              </div>
            )}

            <div class="mb-12">
              <h2 class="text-xl font-black text-zinc-100 mb-4 flex items-center gap-2 uppercase tracking-tight">
                <span class="w-2 h-2 bg-blue-500 rounded-full"></span>
                Overview
              </h2>
              <p class="text-zinc-300 leading-relaxed text-lg max-w-4xl font-medium opacity-90">
                {show.overview}
              </p>
            </div>

            {show.genres?.length > 0 && (
              <div class="flex flex-wrap gap-2 mb-12">
                {show.genres.map(g => (
                  <span class="px-4 py-1.5 bg-zinc-900/80 border border-zinc-800 hover:border-zinc-700 transition-colors text-zinc-400 text-xs rounded-full font-bold uppercase tracking-widest">
                    {g}
                  </span>
                ))}
              </div>
            )}

            <!-- Where to Watch -->
            {show.where_to_watch && show.where_to_watch.length > 0 && (
              <div class="mb-8">
                <h2 class="text-sm font-black text-zinc-500 mb-3 uppercase tracking-widest">Where to Watch</h2>
                <div class="flex flex-wrap gap-2">
                  {show.where_to_watch.map(s => (
                    <div class="flex items-center gap-2 px-3 py-1.5 bg-zinc-900 border border-zinc-800 rounded-lg">
                      {s.logo ? (
                        <img src={s.logo} alt={s.name} class="w-5 h-5 rounded object-cover" />
                      ) : (
                        <span class="text-zinc-400 text-xs">
                          {s.type === "plex" ? "🟡" : s.type === "jellyfin" ? "🟣" : s.type === "emby" ? "🟢" : "▶"}
                        </span>
                      )}
                      <span class="text-zinc-300 text-xs font-semibold">{s.name}</span>
                    </div>
                  ))}
                </div>
              </div>
            )}
          </div>
        </div>

        <!-- Seasons -->
        <div class="mt-24">
          <div class="flex items-center justify-between mb-10 border-b border-zinc-900 pb-6">
            <h2 class="text-3xl font-black text-zinc-100 tracking-tighter uppercase">Seasons</h2>
            <VisibilityFilters />
          </div>
          
          <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-6">
              {(show.seasons_meta || seasons.map(([k]) => ({ season_number: Number(k.replace("season_","")), name: `Season ${k.replace("season_","")}`, overview: null, poster_path: null, episode_count: 0, air_date: null }))).map((s) => {
                const seasonNum = s.season_number;
                const episodes = show.seasons?.[`season_${seasonNum}`] || [];
                const poster = s.poster_path || show.poster_path;
                const seasonState = show.season_states?.[seasonNum] ?? { watched: false, in_library: episodes.length > 0, collection_pct: 0, user_rating: null };
                const watchedCount = episodes.filter(e => e.watched).length;
                const progressPct = episodes.length > 0 ? (watchedCount / episodes.length) * 100 : (seasonState.watched ? 100 : 0);

                return (
                  <MediaCard
                    item={{
                      id: null,
                      tmdb_id: Number(id),
                      type: "season",
                      title: s.name || `Season ${seasonNum}`,
                      show_title: show.title,
                      poster_path: poster,
                      total_episodes_count: s.episode_count || episodes.length,
                      watched_episodes_count: watchedCount,
                      show_tmdb_id: Number(id),
                      season_number: seasonNum,
                      watched: seasonState.watched,
                      in_library: seasonState.in_library,
                      collection_pct: seasonState.collection_pct,
                    }}
                  />
                );
              })}
            </div>
        </div>

        <!-- Cast -->
        {show.cast?.length > 0 && (
          <div class="mt-24 border-zinc-900 pt-16">
            <div class="flex items-center justify-between mb-10">
              <h2 class="text-3xl font-black text-zinc-100 tracking-tighter uppercase">Top Cast</h2>
            </div>
            <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-6">
              {show.cast.slice(0, 12).map((person) => (
                <a href={`/person/${person.tmdb_id}`} class="group/cast bg-zinc-900/20 border border-zinc-800/40 p-4 rounded-3xl hover:bg-zinc-800/40 hover:border-blue-500/50 transition-all duration-500 hover:shadow-2xl hover:shadow-blue-900/10 active:scale-95 active:opacity-70">
                  <div class="aspect-square w-full rounded-2xl overflow-hidden mb-5 ring-2 ring-zinc-800/50 group-hover/cast:ring-blue-500 transition-all duration-500 shadow-lg">
                    {person.profile_path ? (
                      <img
                        src={person.profile_path}
                        alt={person.name}
                        class="w-full h-full object-cover group-hover/cast:scale-110 transition-transform duration-700"
                        loading="lazy"
                        decoding="async"
                      />
                    ) : (
                      <div class="w-full h-full bg-zinc-800 flex items-center justify-center text-zinc-400 text-4xl">
                        👤
                      </div>
                    )}
                  </div>
                  <div class="space-y-1.5 text-center">
                    <p class="text-sm font-black text-zinc-100 group-hover/cast:text-blue-400 transition-colors line-clamp-1 leading-tight">{person.name}</p>
                    <p class="text-[11px] text-zinc-500 font-bold uppercase tracking-wider line-clamp-1 opacity-80">{person.character}</p>
                  </div>
                </a>
              ))}
            </div>
          </div>
        )}

        <CommentsSection
          mediaType="series"
          tmdbId={show.tmdb_id}
        />

        <div id="recommendations-container" data-type="series" data-id={show.tmdb_id}></div>
      </div>
    </div>
  )}
</Base>

<script>
  // Async load recommendations
  const container = document.getElementById('recommendations-container');
  if (container) {
    const { type, id } = container.dataset;
    fetch(`/partials/recommendations?type=${type}&id=${id}`)
      .then(res => {
        if (res.status === 200) return res.text();
        return null;
      })
      .then(html => {
        // Safe: html is a server-rendered Astro partial; Astro auto-escapes all values.
        // Do NOT add raw user data to this partial without going through Astro templates.
        if (html) container.innerHTML = html;
      })
      .catch(err => console.error('Failed to load recommendations', err));
  }
</script>

<script define:vars={{ showId: id, token: Astro.locals.token }}>
  const btn = document.getElementById('refresh-metadata-btn');
  if (btn) {
    btn.addEventListener('click', async () => {
      const icon = document.getElementById('refresh-icon');
      const label = document.getElementById('refresh-label');
      if (!label || !icon) return;

      btn.setAttribute('disabled', 'true');
      btn.classList.add('opacity-60', 'cursor-not-allowed');
      icon.classList.add('animate-spin');
      label.textContent = 'Refreshing...';

      try {
        const res = await fetch(`/api/proxy/shows/${showId}/refresh`, {
          method: 'POST',
          headers: { 'Authorization': `Bearer ${token}` },
        });
        if (!res.ok) {
          const data = await res.json().catch(() => ({}));
          throw new Error(data.detail || 'Refresh failed');
        }
        label.textContent = 'Done!';
        icon.classList.remove('animate-spin');
        setTimeout(() => { window.location.reload(); }, 800);
      } catch (err) {
        icon.classList.remove('animate-spin');
        label.textContent = 'Refresh failed';
        btn.removeAttribute('disabled');
        btn.classList.remove('opacity-60', 'cursor-not-allowed');
        setTimeout(() => { label.textContent = 'Refresh Metadata'; }, 3000);
      }
    });
  }
</script>
