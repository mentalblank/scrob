---
import Base from "../../../../layouts/Base.astro";
import ErrorState from "../../../../components/ErrorState.astro";
import PosterModal from "../../../../components/PosterModal.astro";
import RefreshMetadataButton from "../../../../components/RefreshMetadataButton.astro";
import ActionBar from "../../../../components/ActionBar.astro";
import VisibilityFilters from "../../../../components/VisibilityFilters.astro";
import CommentsSection from "../../../../components/CommentsSection.astro";
import EpisodeCard from "../../../../components/EpisodeCard.astro";
import ProgressStrip from "../../../../components/ProgressStrip.astro";
import VideoPlayer from "../../../../components/VideoPlayer.astro";
import { api, type Season, type MediaItem } from "../../../../lib/api";
import { parseShowId } from "../../../../lib/normalize";
export const prerender = false;

const { id, season_number } = Astro.params;
const { token } = Astro.locals;

Astro.response.headers.set("Cache-Control", "no-store");

const { provider, numericId: resolvedShowId, uri: fetchKey } = parseShowId(id);
const primaryMetadataSource = Astro.cookies.get("primary_metadata_source")?.value || "tmdb";
let season: Season | null = null;
let error = "";

try {
  season = await api.shows.getSeason(fetchKey, Number(season_number), token);
  if (season && provider !== "tvdb" && primaryMetadataSource === "tvdb" && (season as any).show?.tvdb_id) {
    season = await api.shows.getSeason(`tvdb:s:${(season as any).show.tvdb_id}`, Number(season_number), token);
  }
} catch (e: any) {
  error = e.message;
}

if (!season && !error) {
  return Astro.redirect("/404");
}

const show = season?.show;

// Hide placeholder episodes: no title AND no air date
const visibleEpisodes = (season?.episodes ?? []).filter((ep) => {
  const t = (ep.title ?? "").trim();
  const d = (ep.air_date ?? "").trim();
  return t !== "" || d !== "";
});

// Progress stats
const watchedEpisodesCount = visibleEpisodes.filter(e => e.watched).length || 0;
const totalEpisodesCount = visibleEpisodes.length || 0;
const remainingDuration = visibleEpisodes
  .filter(e => !e.watched)
  .reduce((acc, e) => acc + (e.runtime || 0), 0) || 0;
const progressPct = totalEpisodesCount > 0 ? (watchedEpisodesCount / totalEpisodesCount) * 100 : 0;
const showProgress = progressPct > 0;

let hasExternalPlayback = false;
try {
  if (token) {
    const conns = await api.auth.getConnections(token);
    hasExternalPlayback = conns.some(c => c.external_server_url);
  }
} catch {}
---

<Base title={season ? `${show?.title} — ${season.name}` : "Season Details"}>
  {error && !season && <ErrorState error={error} />}

  {season && (
    <div class="relative">
      <!-- Backdrop -->
      {(season.backdrop_path || show?.backdrop_path) && (
        <div class="absolute -top-20 md:-top-32 left-1/2 -translate-x-1/2 w-screen h-[600px] overflow-hidden" style="mask-image: linear-gradient(to bottom, transparent 0%, black 15%, black 60%, transparent 100%); -webkit-mask-image: linear-gradient(to bottom, transparent 0%, black 15%, black 60%, transparent 100%);" data-adult-backdrop={show?.adult ? "true" : undefined}>
          <div class="absolute inset-0 bg-gradient-to-t from-[var(--color-hero-fade)] via-[var(--color-hero-fade)]/40 to-transparent z-10"></div>
          <img
            src={season.backdrop_path || show?.backdrop_path}
            alt=""
            class="w-full h-full object-cover opacity-50 blur-[1px]"
            loading="eager"
            decoding="async"
          />
        </div>
      )}

      <div class="relative z-20">
        <nav class="flex items-center gap-2 text-sm text-zinc-400 mb-8 overflow-hidden whitespace-nowrap">
          <a href="/shows" class="hover:text-zinc-100 transition">Shows</a>
          <span class="text-zinc-700">/</span>
          <a href={`/show/${id}`} class="hover:text-zinc-100 transition truncate">{show?.title}</a>
          <span class="text-zinc-700">/</span>
          <span class="text-zinc-100 font-bold">{season.name}</span>
        </nav>

        <!-- Title & Pagination -->
        <div class="mb-10 flex flex-col md:flex-row md:items-center justify-between gap-4">
          <h1 class="text-4xl md:text-6xl font-black text-zinc-100 tracking-tight leading-none text-center md:text-left">{season.name}</h1>
          {show?.seasons_meta && show.seasons_meta.length > 1 && (
            <div class="flex items-center justify-center md:justify-start gap-2 shrink-0">
              {(() => {
                const currentSeason = Number(season_number);
                const validSeasons = show.seasons_meta
                  .filter((s) => s.season_number > 0 && s.episode_count > 0)
                  .sort((a, b) => a.season_number - b.season_number);
                const currentIndex = validSeasons.findIndex((s) => s.season_number === currentSeason);
                const prevSeason = currentIndex > 0 ? validSeasons[currentIndex - 1] : null;
                const nextSeason = currentIndex < validSeasons.length - 1 ? validSeasons[currentIndex + 1] : null;
                
                return (
                  <>
                    {prevSeason && (
                      <a href={`/show/${id}/season/${prevSeason.season_number}`} class="flex items-center gap-1.5 px-3 py-2 bg-zinc-900/60 backdrop-blur-xl border border-zinc-800/50 rounded-xl text-zinc-400 hover:text-zinc-100 hover:border-blue-500/50 hover:bg-zinc-800/60 active:scale-95 active:opacity-70 transition-all text-sm font-bold">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12 15.75 4.5" />
                        </svg>
                        <span class="hidden sm:inline">S{prevSeason.season_number}</span>
                      </a>
                    )}
                    
                    <span class="season-pill px-3 py-2 bg-blue-600/20 backdrop-blur-xl border border-blue-500/30 rounded-xl text-blue-400 text-sm font-black">
                      S{currentSeason}
                    </span>
                    
                    {nextSeason && (
                      <a href={`/show/${id}/season/${nextSeason.season_number}`} class="flex items-center gap-1.5 px-3 py-2 bg-zinc-900/60 backdrop-blur-xl border border-zinc-800/50 rounded-xl text-zinc-400 hover:text-zinc-100 hover:border-blue-500/50 hover:bg-zinc-800/60 active:scale-95 active:opacity-70 transition-all text-sm font-bold">
                        <span class="hidden sm:inline">S{nextSeason.season_number}</span>
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4">
                          <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
                        </svg>
                      </a>
                    )}
                  </>
                );
              })()}
            </div>
          )}
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12 items-start mb-16">
          <!-- LEFT COLUMN: Poster & Actions Sidebar -->
          <div class="lg:col-span-4 space-y-6 min-w-0">
            <!-- Poster -->
            <div class="w-64 lg:w-full max-w-full shrink-0 mx-auto lg:mx-0">
              <div class="aspect-[2/3] rounded-2xl overflow-hidden shadow-2xl border border-zinc-800 bg-zinc-900 ring-1 ring-white/10 relative">
                {(season.poster_path || show?.poster_path) ? (
                  <button id="poster-zoom-btn" class="w-full h-full group/poster block cursor-zoom-in" aria-label={`Enlarge poster for ${season.name}`}>
                    <img src={season.poster_path || show?.poster_path} alt={season.name} class="w-full h-full object-cover transition-transform duration-300 group-hover/poster:scale-105" />
                    <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover/poster:opacity-100 transition-opacity duration-200 bg-black/30">
                      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-8 h-8 text-white drop-shadow-lg">
                        <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607ZM10.5 7.5v6m3-3h-6" />
                      </svg>
                    </div>
                  </button>
                ) : (
                  <div class="w-full h-full flex flex-col items-center justify-center text-zinc-400 p-4 text-center">
                    <span class="text-4xl mb-2">📺</span>
                    <span class="text-sm font-medium">No Poster Available</span>
                  </div>
                )}
                {showProgress && (
                  <div class="absolute bottom-0 left-0 right-0 h-1.5 bg-zinc-800/80">
                    <div class="h-full bg-blue-500 rounded-r-full" style={`width: ${progressPct}%`}></div>
                  </div>
                )}
              </div>
            </div>

            <!-- ActionBar & Progress -->
            <div class="bg-zinc-900/20 border border-zinc-800/50 backdrop-blur-sm p-4 rounded-2xl space-y-4">
              <ActionBar
                uriId={season?.show?.uri_id ?? fetchKey}
                tmdbId={season?.show?.tmdb_id || (provider === "tmdb" ? resolvedShowId : undefined)}
                mediaType="series"
                watched={season.season_watched ?? false}
                inLists={season.season_in_lists ?? []}
                inLibrary={season.season_in_library ?? season.show_in_library ?? false}
                collectionPct={season.season_collection_pct ?? season.show_collection_pct ?? 0}
                watchPct={season.season_watch_pct ?? 0}
                seasonNumber={Number(season_number)}
                showUriId={season?.show?.uri_id ?? fetchKey}
                showTmdbId={season?.show?.tmdb_id || (provider === "tmdb" ? resolvedShowId : undefined)}
                isMonitored={season.show_is_monitored ?? false}
                requestEnabled={season.show_request_enabled ?? false}
                requestStatus={season.show_request_status ?? null}
                userRating={season.season_user_rating ?? null}
                hideBlock={false}
                isBlocked={season.is_blocked ?? false}
                isDropped={season.is_dropped ?? false}
              />
              {showProgress && (
                <div class="pt-2 border-t border-zinc-800/60">
                  <ProgressStrip
                    watchedEpisodesCount={watchedEpisodesCount}
                    totalEpisodesCount={totalEpisodesCount}
                    remainingDuration={remainingDuration}
                    className="mt-0"
                  />
                </div>
              )}
            </div>

            <!-- Refresh Metadata Button -->
            {season.show_in_library && (
              <div class={`grid gap-2 ${hasExternalPlayback ? 'grid-cols-2' : 'grid-cols-1'}`}>
                {hasExternalPlayback && (
                  <VideoPlayer
                    uriId={(show as any)?.uri_id ?? fetchKey}
                    tmdbId={resolvedShowId}
                    mediaType="season"
                    seasonNumber={Number(season_number)}
                    inLibrary={season.show_in_library}
                    title={`${show?.title || "Unknown Show"} - Season ${season_number}`}
                    token={token || ""}
                    secondary={false}
                  />
                )}
                <RefreshMetadataButton refreshUrl={`/api/proxy/shows/${id}/refresh`} showRefreshBtn={season.show_in_library} />
              </div>
            )}
          </div>

          <!-- RIGHT COLUMN: Details & Episodes -->
          <div class="lg:col-span-8 space-y-8">
            <div class="flex flex-wrap items-center gap-3">
              <p class="accent-label text-lg text-blue-400 font-bold tracking-wide uppercase">{show?.title}</p>
              <span class="season-pill px-3 py-1 bg-blue-600/20 border border-blue-600/30 text-blue-400 text-[10px] font-black rounded-full uppercase tracking-widest">
                Season {season_number}
              </span>
            </div>

            <div class="flex flex-wrap items-center gap-2.5 md:gap-4 text-zinc-300 text-xs md:text-sm bg-zinc-900/40 p-2.5 md:p-3 rounded-xl border border-zinc-800/50 backdrop-blur-sm w-fit">
              <span class="font-bold text-zinc-300">{visibleEpisodes.length} Episodes</span>
              {season.tmdb_rating != null && season.tmdb_rating > 0 && (
                <span class="flex items-center gap-1.5 text-yellow-400 font-black">
                  <span class="text-sm md:text-base leading-none">★</span> {season.tmdb_rating.toFixed(1)}
                </span>
              )}
              {season.air_date && (
                <span>Premiered {new Date(season.air_date).toLocaleDateString(undefined, { year: 'numeric', month: 'long', day: 'numeric' })}</span>
              )}
            </div>

            {season.overview && (
              <div class="max-w-3xl">
                <h2 class="text-xl font-black text-zinc-100 mb-3 flex items-center gap-2 uppercase tracking-tight">
                  <span class="w-2 h-2 bg-blue-500 rounded-full"></span>
                  Season Overview
                </h2>
                <p class="text-zinc-300 leading-relaxed text-lg opacity-90">{season.overview}</p>
              </div>
            )}

            <div class="space-y-6">
              <div class="border-b border-zinc-900 pb-4 mb-4 flex items-center justify-between">
                <h2 class="text-2xl font-black text-zinc-100 tracking-tighter uppercase flex items-center gap-3">
                  <span class="w-1.5 h-6 bg-blue-600 rounded-full"></span>
                  Episodes
                </h2>
                <VisibilityFilters />
              </div>
              
              <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-6">
                {visibleEpisodes.map((ep) => {
                  const item: MediaItem = {
                    ...ep,
                    type: "episode",
                    release_date: ep.air_date,
                    show_title: show?.title,
                    show_uri_id: season?.show?.uri_id ?? id,
                    show_poster_path: show?.poster_path || null,
                    show_backdrop_path: show?.backdrop_path || null,
                    season_number: Number(season_number),
                    collection_pct: ep.in_library ? 100 : 0,
                    library: null,
                  };
                  return <EpisodeCard item={item} />;
                })}
              </div>
            </div>

            <CommentsSection
              mediaType="series"
              uriId={season?.show?.uri_id ?? fetchKey}
              seasonNumber={Number(season_number)}
            />
          </div>
        </div>
      </div>
    </div>
  )}
</Base>

<PosterModal posterPath={season?.poster_path || show?.poster_path} title={season?.name || ""} />





<script define:vars={{ showId: id, seasonNum: season_number, token: Astro.locals.token, currentTitle: season?.name }}>
  const renameSeasonBtn = document.getElementById('rename-season-btn');
  if (renameSeasonBtn) {
    renameSeasonBtn.addEventListener('click', async () => {
      const newName = prompt('Enter a custom title for this season (leave empty to reset to default TMDB title):', currentTitle);
      if (newName === null) return; // Cancelled

      try {
        const res = await fetch('/api/proxy/sync/custom-title', {
          method: 'PATCH',
          headers: {
            'Content-Type': 'application/json',
            'Authorization': `Bearer ${token}`
          },
          body: JSON.stringify({
            show_uri_id: showId,
            season_number: Number(seasonNum),
            season_custom_name: newName.trim() === '' ? null : newName.trim()
          })
        });
        if (res.ok) {
          window.location.reload();
        } else {
          window.showToast?.('Failed to rename season', 'error');
        }
      } catch (err) {
        window.showToast?.('Error renaming season', 'error');
      }
    });
  }
</script>