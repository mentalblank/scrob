---
import Base from "../../../../layouts/Base.astro";
import ActionBar from "../../../../components/ActionBar.astro";
import VisibilityFilters from "../../../../components/VisibilityFilters.astro";
import CommentsSection from "../../../../components/CommentsSection.astro";
import EpisodeCard from "../../../../components/EpisodeCard.astro";
import ProgressStrip from "../../../../components/ProgressStrip.astro";
import { api, type Season, type MediaItem } from "../../../../lib/api";
export const prerender = false;

const { id, season_number } = Astro.params;
const { token } = Astro.locals;

Astro.response.headers.set("Cache-Control", "no-store");

let season: Season | null = null;
let error = "";

try {
  season = await api.shows.getSeason(Number(id), Number(season_number), token);
} catch (e: any) {
  error = e.message;
}

if (!season && !error) {
  return Astro.redirect("/404");
}

const show = season?.show;

// Progress stats
const watchedEpisodesCount = season?.episodes?.filter(e => e.watched).length || 0;
const totalEpisodesCount = season?.episodes?.length || 0;
const remainingDuration = season?.episodes
  ?.filter(e => !e.watched)
  ?.reduce((acc, e) => acc + (e.runtime || 0), 0) || 0;
const progressPct = totalEpisodesCount > 0 ? (watchedEpisodesCount / totalEpisodesCount) * 100 : 0;
const showProgress = progressPct > 0;
---

<Base title={season ? `${show?.title} — ${season.name}` : "Season Details"}>
  {error && !season && (
    <div class="max-w-md mx-auto mt-20 text-center">
      <div class="bg-red-500/10 border border-red-500/20 text-red-500 p-6 rounded-2xl mb-6">
        <p class="font-bold text-lg mb-2">Oops!</p>
        <p class="text-sm opacity-80">{error}</p>
      </div>
      <a href="/" class="text-blue-500 hover:underline">Return to Dashboard</a>
    </div>
  )}

  {season && (
    <div class="relative">
      <!-- Backdrop -->
      {(season.backdrop_path || show?.backdrop_path) && (
        <div class="absolute -top-8 left-1/2 -translate-x-1/2 w-screen h-[500px] overflow-hidden" style="mask-image: linear-gradient(to bottom, black 50%, transparent 100%); -webkit-mask-image: linear-gradient(to bottom, black 50%, transparent 100%);">
          <div class="absolute inset-0 bg-gradient-to-t from-zinc-950 via-zinc-950/80 to-transparent z-10"></div>
          <img src={season.backdrop_path || show.backdrop_path} alt="" class="w-full h-full object-cover opacity-30 blur-[1px]" />
        </div>
      )}

      <div class="relative z-20">
        <nav class="flex items-center gap-2 text-sm text-zinc-400 mb-8 overflow-hidden whitespace-nowrap">
          <a href="/shows" class="hover:text-zinc-100 transition">Shows</a>
          <span class="text-zinc-700">/</span>
          <a href={`/show/${id}`} class="hover:text-zinc-100 transition truncate">{show?.title}</a>
          <span class="text-zinc-700">/</span>
          <span class="text-zinc-100 font-bold">{season.name}</span>
        </nav>

        <div class="flex flex-col md:flex-row gap-8 lg:gap-12 mb-16">
            <div class="w-56 shrink-0 mx-auto md:mx-0">
              <div class="aspect-[2/3] rounded-2xl overflow-hidden shadow-2xl border border-zinc-800 bg-zinc-900 ring-1 ring-white/10 relative">
                {(season.poster_path || show?.poster_path) ? (
                  <img src={season.poster_path || show?.poster_path} alt={season.name} class="w-full h-full object-cover" />
                ) : (
                  <div class="w-full h-full flex flex-col items-center justify-center text-zinc-400 p-4 text-center">
                    <span class="text-4xl mb-2">📺</span>
                    <span class="text-sm font-medium">No Poster Available</span>
                  </div>
                )}
                {showProgress && (
                  <div class="absolute bottom-0 left-0 right-0 h-1.5 bg-zinc-800/80">
                    <div class="h-full bg-blue-500 rounded-r-full" style={`width: ${progressPct}%`}></div>
                  </div>
                )}
              </div>
            </div>

          <div class="flex-1 pt-4 text-center md:text-left">
            <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 mb-2">
              <h1 class="text-4xl md:text-5xl font-black text-zinc-100 tracking-tight">{season.name}</h1>
              
              {show?.seasons_meta && show.seasons_meta.length > 1 && (
                <div class="flex items-center gap-2 shrink-0">
                  {(() => {
                    const currentSeason = Number(season_number);
                    const validSeasons = show.seasons_meta
                      .filter((s) => s.season_number > 0)
                      .sort((a, b) => a.season_number - b.season_number);
                    const currentIndex = validSeasons.findIndex((s) => s.season_number === currentSeason);
                    const prevSeason = currentIndex > 0 ? validSeasons[currentIndex - 1] : null;
                    const nextSeason = currentIndex < validSeasons.length - 1 ? validSeasons[currentIndex + 1] : null;
                    
                    return (
                      <>
                        {prevSeason && (
                          <a href={`/show/${id}/season/${prevSeason.season_number}`} class="flex items-center gap-1.5 px-3 py-2 bg-zinc-900/60 border border-zinc-800/50 rounded-xl text-zinc-400 hover:text-zinc-100 hover:border-blue-500/50 hover:bg-zinc-800/60 active:scale-95 active:opacity-70 transition-all text-sm font-bold">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4">
                              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12 15.75 4.5" />
                            </svg>
                            <span class="hidden sm:inline">S{prevSeason.season_number}</span>
                          </a>
                        )}
                        
                        <span class="px-3 py-2 bg-blue-600/20 border border-blue-500/30 rounded-xl text-blue-400 text-sm font-black">
                          S{currentSeason}
                        </span>
                        
                        {nextSeason && (
                          <a href={`/show/${id}/season/${nextSeason.season_number}`} class="flex items-center gap-1.5 px-3 py-2 bg-zinc-900/60 border border-zinc-800/50 rounded-xl text-zinc-400 hover:text-zinc-100 hover:border-blue-500/50 hover:bg-zinc-800/60 active:scale-95 active:opacity-70 transition-all text-sm font-bold">
                            <span class="hidden sm:inline">S{nextSeason.season_number}</span>
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4">
                              <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
                            </svg>
                          </a>
                        )}
                      </>
                    );
                  })()}
                </div>
              )}
            </div>
            
            <p class="text-lg text-blue-400 font-bold mb-6 tracking-wide uppercase">{show?.title}</p>
            
            <div class="flex flex-wrap justify-center md:justify-start items-center gap-4 text-zinc-400 text-sm mb-8 bg-zinc-900/40 p-3 rounded-xl border border-zinc-800/50 backdrop-blur-sm inline-flex">
              <span class="font-bold text-zinc-300">{season.episodes?.length || 0} Episodes</span>
              {season.tmdb_rating != null && season.tmdb_rating > 0 && (
                <span class="flex items-center gap-1.5 text-yellow-400 font-black">
                  <span class="text-base leading-none">★</span> {season.tmdb_rating.toFixed(1)}
                </span>
              )}
              {season.air_date && (
                <>
                  <span>Premiered {new Date(season.air_date).toLocaleDateString(undefined, { year: 'numeric', month: 'long', day: 'numeric' })}</span>
                </>
              )}
              <span class="text-[10px] font-black text-zinc-400 uppercase tracking-widest px-2 py-0.5 bg-zinc-800/50 rounded border border-zinc-800">
                Season
              </span>
            </div>

            <div class="mb-6">
                <div class="flex flex-col lg:flex-row lg:items-end justify-between gap-6">
                    <div class="flex-1">
                      <ActionBar
                        tmdbId={Number(id)}
                        mediaType="series"
                        watched={season.season_watched ?? false}
                        inLists={[]}
                        inLibrary={season.season_in_library ?? season.show_in_library ?? false}
                        collectionPct={season.season_collection_pct ?? season.show_collection_pct ?? 0}
                        seasonNumber={Number(season_number)}
                        isMonitored={season.show_is_monitored ?? false}
                        requestEnabled={false}
                        hideLists={false}
                        userRating={season.season_user_rating ?? null}
                        hideBlock={true}
                      />
                    </div>
                    {showProgress && (
                      <div class="w-full lg:w-64">
                        <ProgressStrip
                          watchedEpisodesCount={watchedEpisodesCount}
                          totalEpisodesCount={totalEpisodesCount}
                          remainingDuration={remainingDuration}
                          className="mt-0"
                        />
                      </div>
                    )}
                </div>
            </div>

            {season.show_in_library && (
              <div class="mb-6">
                <button
                  id="refresh-metadata-btn"
                  class="flex items-center gap-2 px-4 py-2 text-sm font-bold text-zinc-400 hover:text-zinc-100 bg-zinc-900/60 hover:bg-zinc-800/80 border border-zinc-800 hover:border-zinc-700 rounded-xl transition-all duration-200 cursor-pointer"
                >
                  <svg id="refresh-icon" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8"/>
                    <path d="M21 3v5h-5"/>
                    <path d="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16"/>
                    <path d="M8 16H3v5"/>
                  </svg>
                  <span id="refresh-label">Refresh Metadata</span>
                </button>
              </div>
            )}

            {season.overview && (
              <div class="max-w-3xl">
                <h2 class="text-sm font-black text-zinc-500 uppercase tracking-[0.2em] mb-3">Season Overview</h2>
                <p class="text-zinc-300 leading-relaxed text-lg opacity-90">{season.overview}</p>
              </div>
            )}
          </div>
        </div>

        <CommentsSection
          mediaType="series"
          tmdbId={Number(id)}
          seasonNumber={Number(season_number)}
        />

        <div class="space-y-12">
          <div class="border-b border-zinc-900 pb-6 mb-8 flex items-center justify-between">
            <h2 class="text-3xl font-black text-zinc-100 tracking-tighter uppercase flex items-center gap-3">
              <span class="w-1.5 h-6 bg-blue-600 rounded-full"></span>
              Episodes
            </h2>
            <VisibilityFilters />
          </div>
          
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
              {season.episodes?.map((ep) => {
                const item: MediaItem = {
                  ...ep,
                  type: "episode",
                  release_date: ep.air_date,
                  show_title: show?.title,
                  show_tmdb_id: Number(id),
                  show_poster_path: show?.poster_path || null,
                  show_backdrop_path: show?.backdrop_path || null,
                  season_number: Number(season_number),
                  collection_pct: ep.in_library ? 100 : 0,
                  library: null,
                };
                return <EpisodeCard item={item} />;
              })}
            </div>
        </div>
      </div>
    </div>
  )}
</Base>

<script define:vars={{ showId: id, token: Astro.locals.token }}>
  const btn = document.getElementById('refresh-metadata-btn');
  if (btn) {
    btn.addEventListener('click', async () => {
      const icon = document.getElementById('refresh-icon');
      const label = document.getElementById('refresh-label');
      if (!label || !icon) return;

      btn.setAttribute('disabled', 'true');
      btn.classList.add('opacity-60', 'cursor-not-allowed');
      icon.classList.add('animate-spin');
      label.textContent = 'Refreshing...';

      try {
        const res = await fetch(`/api/proxy/shows/${showId}/refresh`, {
          method: 'POST',
          headers: { 'Authorization': `Bearer ${token}` },
        });
        if (!res.ok) {
          const data = await res.json().catch(() => ({}));
          throw new Error(data.detail || 'Refresh failed');
        }
        label.textContent = 'Done!';
        icon.classList.remove('animate-spin');
        setTimeout(() => { window.location.reload(); }, 800);
      } catch (err) {
        icon.classList.remove('animate-spin');
        label.textContent = 'Refresh failed';
        btn.removeAttribute('disabled');
        btn.classList.remove('opacity-60', 'cursor-not-allowed');
        setTimeout(() => { label.textContent = 'Refresh Metadata'; }, 3000);
      }
    });
  }
</script>
