---
import Base from "../../../../../layouts/Base.astro";
import ActionBar from "../../../../../components/ActionBar.astro";
import CommentsSection from "../../../../../components/CommentsSection.astro";
import VideoPlayer from "../../../../../components/VideoPlayer.astro";
import { api, type EpisodeDetail } from "../../../../../lib/api";

export const prerender = false;

const { id, season_number, episode_number } = Astro.params;
const { token } = Astro.locals;
Astro.response.headers.set("Cache-Control", "no-store");

let episode: EpisodeDetail | null = null;
let error = "";

try {
  episode = await api.shows.getEpisode(Number(id), Number(season_number), Number(episode_number), token);
} catch (e: any) {
  error = e.message;
}

if (!episode && !error) {
  return Astro.redirect("/404");
}

const show = episode?.show;
const rating = episode?.tmdb_rating ? episode.tmdb_rating.toFixed(1) : null;
const thumbnail = episode?.still_path || show?.poster_path || null;
---

<Base title={episode ? `${show?.title} — ${episode.title}` : "Episode Details"}>
  {error && !episode && (
    <div class="max-w-md mx-auto mt-20 text-center">
      <div class="bg-red-500/10 border border-red-500/20 text-red-500 p-6 rounded-2xl mb-6">
        <p class="font-bold text-lg mb-2">Oops!</p>
        <p class="text-sm opacity-80">{error}</p>
      </div>
      <a href="/" class="text-blue-500 hover:underline">Return to Dashboard</a>
    </div>
  )}

  {episode && (
    <div class="relative">
      <!-- Backdrop from show -->
      {show?.backdrop_path && (
        <div class="absolute -top-8 left-1/2 -translate-x-1/2 w-screen h-[500px] overflow-hidden" style="mask-image: linear-gradient(to bottom, black 50%, transparent 100%); -webkit-mask-image: linear-gradient(to bottom, black 50%, transparent 100%);">
          <div class="absolute inset-0 bg-gradient-to-t from-zinc-950 via-zinc-950/60 to-transparent z-10"></div>
          <img src={show.backdrop_path} alt="" class="w-full h-full object-cover opacity-30 blur-[1px]" />
        </div>
      )}

      <div class="relative z-20">
        <!-- Breadcrumb -->
        <nav class="flex items-center gap-2 text-sm text-zinc-400 mb-8 overflow-hidden whitespace-nowrap">
          <a href="/shows" class="hover:text-zinc-100 transition shrink-0">Shows</a>
          <span class="text-zinc-700">/</span>
          <a href={`/show/${id}`} class="hover:text-zinc-100 transition truncate">{show?.title}</a>
          <span class="text-zinc-700 shrink-0">/</span>
          <a href={`/show/${id}/season/${season_number}`} class="hover:text-zinc-100 transition shrink-0">Season {season_number}</a>
          <span class="text-zinc-700 shrink-0">/</span>
          <span class="text-zinc-100 font-bold shrink-0">Episode {episode_number}</span>
        </nav>

        <div class="flex flex-col md:flex-row gap-8 lg:gap-12 mb-16">
          <!-- Thumbnail -->
          <div class="w-full md:w-80 shrink-0">
            <div class="aspect-video rounded-2xl overflow-hidden shadow-2xl border border-zinc-800 bg-zinc-900 ring-1 ring-white/10">
              {thumbnail ? (
                <img
                  src={thumbnail}
                  alt={episode.title}
                  class="w-full h-full object-cover"
                  loading="eager"
                  decoding="async"
                />
              ) : (
                <div class="w-full h-full flex flex-col items-center justify-center text-zinc-400 p-4 text-center">
                  <span class="text-4xl mb-2">📺</span>
                  <span class="text-sm font-medium">No Thumbnail</span>
                </div>
              )}
            </div>
          </div>

          <!-- Info -->
          <div class="flex-1 min-w-0 pt-2">
            <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-4 mb-2">
              <div class="min-w-0">
                <h1 class="text-3xl md:text-5xl font-black text-zinc-100 mb-2 tracking-tight leading-tight">{episode.title}</h1>
                <div class="flex flex-wrap items-center gap-3">
                  <p class="text-lg text-blue-400 font-bold tracking-wide uppercase">{show?.title}</p>
                   <span class="px-3 py-1 bg-blue-600/20 border border-blue-600/30 text-blue-400 text-[10px] font-black rounded-full uppercase tracking-widest">
                     S{String(season_number).padStart(2, '0')}E{String(episode_number).padStart(2, '0')}
                   </span>
                 </div>
              </div>
              
              {episode.episodes && episode.episodes.length > 1 && (
                <div class="flex items-center gap-2 shrink-0">
                  {(() => {
                    const currentEpisode = Number(episode_number);
                    const episodes = episode.episodes
                      .sort((a, b) => a.episode_number - b.episode_number);
                    const currentIndex = episodes.findIndex((e) => e.episode_number === currentEpisode);
                    const prevEp = currentIndex > 0 ? episodes[currentIndex - 1] : null;
                    const nextEp = currentIndex < episodes.length - 1 ? episodes[currentIndex + 1] : null;
                    
                    return (
                      <>
                        {prevEp && (
                          <a href={`/show/${id}/season/${season_number}/${prevEp.episode_number}`} class="flex items-center gap-1.5 px-3 py-2 bg-zinc-900/60 border border-zinc-800/50 rounded-xl text-zinc-400 hover:text-zinc-100 hover:border-blue-500/50 hover:bg-zinc-800/60 active:scale-95 active:opacity-70 transition-all text-sm font-bold">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4">
                              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12 15.75 4.5" />
                            </svg>
                            <span class="hidden sm:inline">E{prevEp.episode_number}</span>
                          </a>
                        )}
                        
                        <span class="px-3 py-2 bg-blue-600/20 border border-blue-500/30 rounded-xl text-blue-400 text-sm font-black">
                          E{currentEpisode}
                        </span>
                        
                        {nextEp && (
                          <a href={`/show/${id}/season/${season_number}/${nextEp.episode_number}`} class="flex items-center gap-1.5 px-3 py-2 bg-zinc-900/60 border border-zinc-800/50 rounded-xl text-zinc-400 hover:text-zinc-100 hover:border-blue-500/50 hover:bg-zinc-800/60 active:scale-95 active:opacity-70 transition-all text-sm font-bold">
                            <span class="hidden sm:inline">E{nextEp.episode_number}</span>
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4">
                              <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
                            </svg>
                          </a>
                        )}
                      </>
                    );
                  })()}
                </div>
              )}
            </div>

            <div class="flex flex-wrap items-center gap-4 text-zinc-300 text-sm mb-8 bg-zinc-900/40 p-3 rounded-xl border border-zinc-800/50 backdrop-blur-sm inline-flex">
              {episode.air_date && (
                <span class="font-bold">
                  {new Date(episode.air_date).toLocaleDateString(undefined, { year: 'numeric', month: 'long', day: 'numeric' })}
                </span>
              )}
              {rating && (
                <span class="flex items-center gap-1.5 text-yellow-400 font-black">
                  <span class="text-lg leading-none">★</span> {rating}
                </span>
              )}
              {episode.runtime && (
                <span class="flex items-center gap-1.5 font-medium">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4 text-zinc-500">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                  </svg>
                  {episode.runtime} min
                </span>
              )}
            </div>

            <div class="mb-4">
              <ActionBar
                tmdbId={episode.tmdb_id}
                mediaType="episode"
                watched={episode.watched ?? false}
                inLists={episode.in_lists ?? []}
                inLibrary={episode.in_library ?? false}
                collectionPct={episode.collection_pct ?? (episode.in_library ? 100 : 0)}
                showTmdbId={Number(id)}
                seasonNumber={Number(season_number)}
                episodeNumber={Number(episode_number)}
                mediaId={episode.id ?? null}
                userRating={episode.user_rating ?? null}
                hideBlock={true}
              />
            </div>

            {episode.in_library && (
              <div class="mb-4 flex flex-wrap gap-2">
                <button
                  id="refresh-metadata-btn"
                  class="flex items-center gap-2 px-4 py-2 text-sm font-bold text-zinc-400 hover:text-zinc-100 bg-zinc-900/60 hover:bg-zinc-800/80 border border-zinc-800 hover:border-zinc-700 rounded-xl transition-all duration-200 cursor-pointer"
                >
                  <svg id="refresh-icon" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8"/>
                    <path d="M21 3v5h-5"/>
                    <path d="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16"/>
                    <path d="M8 16H3v5"/>
                  </svg>
                  <span id="refresh-label">Refresh Metadata</span>
                </button>

                <VideoPlayer
                  tmdbId={episode.tmdb_id}
                  mediaType="episode"
                  inLibrary={episode.in_library ?? false}
                  title={`${show?.title} — ${episode.title}`}
                  token={token}
                />
              </div>
            )}

            <!-- Library info -->
            {episode.library && (
              <div class="mb-8 flex flex-wrap gap-2">
                {[
                  episode.library.resolution,
                  episode.library.video_codec,
                  episode.library.audio_codec,
                  episode.library.audio_channels,
                ].filter(Boolean).map(tag => (
                  <span class="px-3 py-1.5 bg-zinc-900 border border-zinc-800 text-zinc-400 text-xs rounded-lg font-mono font-bold">
                    {tag}
                  </span>
                ))}
                {episode.library.audio_languages?.map((lang: string) => (
                  <span class="px-3 py-1.5 bg-zinc-900 border border-zinc-800 text-zinc-400 text-xs rounded-lg font-mono font-bold flex items-center gap-1.5">
                    <span class="opacity-50">🔊</span> {lang}
                  </span>
                ))}
                {episode.library.subtitle_languages?.map((lang: string) => (
                  <span class="px-3 py-1.5 bg-zinc-900 border border-zinc-800 text-zinc-400 text-xs rounded-lg font-mono font-bold flex items-center gap-1.5">
                    <span class="opacity-50">💬</span> {lang}
                  </span>
                ))}
              </div>
            )}

            {episode.overview && (
              <div>
                <h2 class="text-xl font-black text-zinc-100 mb-4 flex items-center gap-2 uppercase tracking-tight">
                  <span class="w-2 h-2 bg-blue-500 rounded-full"></span>
                  Overview
                </h2>
                <p class="text-zinc-300 leading-relaxed text-lg max-w-3xl font-medium opacity-90">
                  {episode.overview}
                </p>
              </div>
            )}
          </div>
        </div>

        <CommentsSection
          mediaType="series"
          tmdbId={Number(id)}
          seasonNumber={Number(season_number)}
          episodeNumber={Number(episode_number)}
        />

        <!-- Cast -->
        {episode.cast?.length > 0 && (
          <div class="mt-8 border-t border-zinc-900 pt-16">
            <h2 class="text-3xl font-black text-zinc-100 tracking-tighter uppercase mb-10">Cast</h2>
            <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-6">
              {episode.cast.map((person) => (
                <a href={`/person/${person.tmdb_id}`} class="group/cast bg-zinc-900/20 border border-zinc-800/40 p-4 rounded-3xl hover:bg-zinc-800/40 hover:border-blue-500/50 transition-all duration-500 hover:shadow-2xl hover:shadow-blue-900/10 active:scale-95 active:opacity-70">
                  <div class="aspect-square w-full rounded-2xl overflow-hidden mb-5 ring-2 ring-zinc-800/50 group-hover/cast:ring-blue-500 transition-all duration-500 shadow-lg">
                    {person.profile_path ? (
                      <img
                        src={person.profile_path}
                        alt={person.name}
                        class="w-full h-full object-cover group-hover/cast:scale-110 transition-transform duration-700"
                        loading="lazy"
                        decoding="async"
                      />
                    ) : (
                      <div class="w-full h-full bg-zinc-800 flex items-center justify-center text-zinc-400 text-4xl">👤</div>
                    )}
                  </div>
                  <div class="space-y-1.5 text-center">
                    <p class="text-sm font-black text-zinc-100 group-hover/cast:text-blue-400 transition-colors line-clamp-1 leading-tight">{person.name}</p>
                    <p class="text-[11px] text-zinc-500 font-bold uppercase tracking-wider line-clamp-1 opacity-80">{person.character}</p>
                  </div>
                </a>
              ))}
            </div>
          </div>
        )}

        <!-- Guest Stars -->
        {episode.guest_stars?.length > 0 && (
          <div class="mt-16">
            <h2 class="text-3xl font-black text-zinc-100 tracking-tighter uppercase mb-10">Guest Stars</h2>
            <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-6">
              {episode.guest_stars.map((person) => (
                <a href={`/person/${person.tmdb_id}`} class="group/cast bg-zinc-900/20 border border-zinc-800/40 p-4 rounded-3xl hover:bg-zinc-800/40 hover:border-blue-500/50 transition-all duration-500 hover:shadow-2xl hover:shadow-blue-900/10 active:scale-95 active:opacity-70">
                  <div class="aspect-square w-full rounded-2xl overflow-hidden mb-5 ring-2 ring-zinc-800/50 group-hover/cast:ring-blue-500 transition-all duration-500 shadow-lg">
                    {person.profile_path ? (
                      <img
                        src={person.profile_path}
                        alt={person.name}
                        class="w-full h-full object-cover group-hover/cast:scale-110 transition-transform duration-700"
                        loading="lazy"
                        decoding="async"
                      />
                    ) : (
                      <div class="w-full h-full bg-zinc-800 flex items-center justify-center text-zinc-400 text-4xl">👤</div>
                    )}
                  </div>
                  <div class="space-y-1.5 text-center">
                    <p class="text-sm font-black text-zinc-100 group-hover/cast:text-blue-400 transition-colors line-clamp-1 leading-tight">{person.name}</p>
                    <p class="text-[11px] text-zinc-500 font-bold uppercase tracking-wider line-clamp-1 opacity-80">{person.character}</p>
                  </div>
                </a>
              ))}
            </div>
          </div>
        )}

      </div>
    </div>
  )}

</Base>

<script define:vars={{ showId: id, token: Astro.locals.token }}>
  const btn = document.getElementById('refresh-metadata-btn');
  if (btn) {
    btn.addEventListener('click', async () => {
      const icon = document.getElementById('refresh-icon');
      const label = document.getElementById('refresh-label');
      if (!label || !icon) return;

      btn.setAttribute('disabled', 'true');
      btn.classList.add('opacity-60', 'cursor-not-allowed');
      icon.classList.add('animate-spin');
      label.textContent = 'Refreshing...';

      try {
        const res = await fetch(`/api/proxy/shows/${showId}/refresh`, {
          method: 'POST',
          headers: { 'Authorization': `Bearer ${token}` },
        });
        if (!res.ok) {
          const data = await res.json().catch(() => ({}));
          throw new Error(data.detail || 'Refresh failed');
        }
        label.textContent = 'Done!';
        icon.classList.remove('animate-spin');
        setTimeout(() => { window.location.reload(); }, 800);
      } catch (err) {
        icon.classList.remove('animate-spin');
        label.textContent = 'Refresh failed';
        btn.removeAttribute('disabled');
        btn.classList.remove('opacity-60', 'cursor-not-allowed');
        setTimeout(() => { label.textContent = 'Refresh Metadata'; }, 3000);
      }
    });
  }
</script>
