            {(item.type === 'movie' || item.type === 'episode') && (
              <ManualScrobble
                tmdbId={item.tmdb_id}
                mediaType={item.type}
                runtime={item.runtime}
                title={item.title}
                showTmdbId={item.show_tmdb_id}
                seasonNumber={item.season_number}
                episodeNumber={item.episode_number}
