                      <div class="space-y-1 text-center">
                        <p class="text-xs font-bold text-zinc-100 group-hover/cast:text-blue-400 transition-colors line-clamp-2 leading-tight">{person.name}</p>
                        <p class="text-[10px] text-zinc-500 font-bold uppercase tracking-wider line-clamp-2 opacity-85">{person.character}</p>
