            <div id="recommendations-container" data-type={item.type} data-id={item.uri_id ?? (item.type === 'movie' ? `tmdb:m:${item.tmdb_id}` : `tmdb:s:${item.tmdb_id}`)} class="pt-8 border-t border-zinc-800/60"></div>
          </div>
        </div>
      </div>
