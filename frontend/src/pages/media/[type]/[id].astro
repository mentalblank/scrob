            {showComments && (
              <div class="pt-8 border-t border-zinc-800/60">
                <CommentsSection
                  mediaType={item.type}
                  uriId={item.uri_id ?? (item.type === 'movie' ? `tmdb:m:${item.tmdb_id}` : item.show_tmdb_id ? `tmdb:s:${item.show_tmdb_id}` : `tmdb:s:${item.tmdb_id}`)}
