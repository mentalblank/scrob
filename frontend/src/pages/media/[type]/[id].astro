  {isMovie && item?.status && (
    <div id="release-schedule-popover" class="hidden absolute z-50 w-52 bg-zinc-900 border border-zinc-700 rounded-xl shadow-2xl overflow-hidden">
      <div class="px-3 pt-2.5 pb-2 border-b border-zinc-800">
        <p class="text-[10px] font-black text-zinc-500 tracking-widest uppercase">Release Schedule</p>
      </div>
      <div class="px-3 py-2.5 flex flex-col gap-2">
        <div class="flex items-center justify-between gap-2">
          <span class="text-zinc-500 text-xs">Theatrical</span>
          {theatricalDate ? (
            <span class={`text-xs font-mono font-bold ${isPast(theatricalDate) ? "text-zinc-300" : "text-blue-400"}`}>{fmtDate(theatricalDate)}</span>
          ) : (
            <span class="text-xs text-zinc-600">—</span>
          )}
        </div>
        <div class="flex items-center justify-between gap-2">
          <span class="text-zinc-500 text-xs">Digital</span>
          {digitalDate ? (
            <span class={`text-xs font-mono font-bold ${isPast(digitalDate) ? "text-zinc-300" : "text-blue-400"}`}>{fmtDate(digitalDate)}</span>
          ) : (
            <span class="text-xs text-zinc-600">—</span>
          )}
        </div>
        <div class="flex items-center justify-between gap-2">
          <span class="text-zinc-500 text-xs">Physical</span>
          {physicalDate ? (
            <span class={`text-xs font-mono font-bold ${isPast(physicalDate) ? "text-zinc-300" : "text-blue-400"}`}>{fmtDate(physicalDate)}</span>
          ) : (
            <span class="text-xs text-zinc-600">—</span>
          )}
        </div>
      </div>
    </div>
  )}
</Base>

<script>
  // Async load recommendations
  const container = document.getElementById('recommendations-container');
  if (container) {
    const { type, id } = container.dataset;
    fetch(`/partials/recommendations?type=${type}&id=${id}`)
      .then(res => {
        if (res.status === 200) return res.text();
        return null;
      })
      .then(html => {
        // Safe: html is a server-rendered Astro partial; Astro auto-escapes all values.
        // Do NOT add raw user data to this partial without going through Astro templates.
        if (html) container.innerHTML = html;
      })
      .catch(err => console.error('Failed to load recommendations', err));
  }
</script>

<PosterModal posterPath={item?.poster_path} title={item?.title || ""} />

<script define:vars={{ token: Astro.locals.token }}>
  const badge = document.getElementById('play-count-badge');

  if (badge) {
    const uriId = badge.getAttribute('data-uri-id');
    const mediaType = badge.getAttribute('data-media-type');
    const mediaId = badge.getAttribute('data-media-id');
    const showUri = badge.getAttribute('data-show-uri');
    const season = badge.getAttribute('data-season');
    const episode = badge.getAttribute('data-episode');

    badge.addEventListener('click', () => {
      if (window["openWatchHistoryModal"]) {
        window["openWatchHistoryModal"](null, uriId, mediaType, mediaId, showUri, season, episode);
      }
    });
  }
</script>





<script define:vars={{ trailerYoutubeId }}>
  if (trailerYoutubeId) {
    const trailerBtn    = document.getElementById('trailer-btn');
    const trailerDialog = document.getElementById('trailer-dialog');
    const trailerClose  = document.getElementById('trailer-close');
    const trailerIframe = document.getElementById('trailer-iframe');

    function openTrailer() {
      if (!trailerIframe || !trailerDialog) return;
      trailerIframe.src = `https://www.youtube-nocookie.com/embed/${trailerYoutubeId}?autoplay=1&rel=0`;
      trailerDialog.showModal();
    }

    function closeTrailer() {
      if (!trailerIframe || !trailerDialog) return;
      trailerIframe.src = '';
      trailerDialog.close();
    }

    trailerBtn?.addEventListener('click', openTrailer);
    trailerClose?.addEventListener('click', closeTrailer);
    trailerDialog?.addEventListener('click', (e) => { if (e.target === trailerDialog) closeTrailer(); });
  }
</script>

<script>
  if (window.innerWidth < 768) {
    document.querySelectorAll('.watch-providers-details').forEach(el => {
      el.removeAttribute('open');
    });
  }
</script>

<script define:vars={{ tmdbId: id }}>
  document.querySelectorAll('.wtw-local-link').forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      const connectionId = btn.getAttribute('data-connection-id');
      document.dispatchEvent(new CustomEvent(`start-playback-${tmdbId}`, {
        detail: { connectionId: connectionId ? parseInt(connectionId) : undefined }
      }));
    });
  });
</script>

<script>
  const releaseBtn = document.getElementById('release-schedule-btn');
  const releasePopover = document.getElementById('release-schedule-popover');

  if (releaseBtn && releasePopover) {
    releaseBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      const hidden = releasePopover.classList.toggle('hidden');
      if (!hidden) {
        const rect = releaseBtn.getBoundingClientRect();
        const popW = releasePopover.offsetWidth;
        const left = Math.min(rect.left + window.scrollX, window.innerWidth - popW - 8);
        releasePopover.style.left = `${Math.max(8, left)}px`;
        releasePopover.style.top = `${rect.bottom + window.scrollY + 6}px`;
      }
    });
    document.addEventListener('click', (e) => {
      if (!releasePopover.classList.contains('hidden') && !releasePopover.contains(e.target as Node)) {
        releasePopover.classList.add('hidden');
      }
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') releasePopover.classList.add('hidden');
    });
  }
</script>