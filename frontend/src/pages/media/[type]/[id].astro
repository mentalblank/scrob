                inLists={item.in_lists ?? []}
                inLibrary={item.in_library ?? false}
                collectionPct={item.collection_pct ?? 0}
                showTmdbId={item.show_tmdb_id}
                seasonNumber={item.season_number}
                episodeNumber={item.episode_number}
                isMonitored={item.is_monitored ?? false}
