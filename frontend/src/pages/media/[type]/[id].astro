            <!-- Genres -->
            {item.genres?.length > 0 && (
              <div class="flex flex-wrap gap-2">
                {item.genres.map((g: string) => (
                  <span class="px-3 py-1 bg-zinc-900/60 border border-zinc-800/80 hover:border-zinc-700 text-zinc-400 text-xs rounded-full font-bold uppercase tracking-wider transition-colors">
