---
import Base from "../../../layouts/Base.astro";
import MediaRow from "../../../components/MediaRow.astro";
import ActionBar from "../../../components/ActionBar.astro";
import CommentsSection from "../../../components/CommentsSection.astro";
import VideoPlayer from "../../../components/VideoPlayer.astro";
import ManualScrobble from "../../../components/ManualScrobble.astro";
import { api, type MediaItem } from "../../../lib/api";
export const prerender = false;

const { type, id } = Astro.params;
const { token } = Astro.locals;
Astro.response.headers.set("Cache-Control", "no-store");

let item: MediaItem | null = null;
let error = "";

try {
  item = await api.media.get(type!, Number(id), token);
} catch (e: any) {
  error = e.message;
}

if (!item && !error) {
    return Astro.redirect("/404");
}

const year = item?.release_date?.slice(0, 4) ?? null;
const rating = item?.tmdb_rating ? item.tmdb_rating.toFixed(1) : null;
const isEpisode = item?.type === "episode";
const collection = item?.collection;
const showRefreshBtn = item?.in_library && (item.type === "movie" || (isEpisode && !!item.show_tmdb_id));
const langNames = new Intl.DisplayNames(["en"], { type: "language" });
const originalLanguage = item?.original_language
  ? langNames.of(item.original_language) ?? item.original_language
  : null;
const refreshUrl = isEpisode
  ? `/api/proxy/shows/${item?.show_tmdb_id}/refresh`
  : `/api/proxy/media/movie/${item?.tmdb_id}/refresh`;
const trailerYoutubeId = item?.trailer_youtube_id ?? null;
const tmdbUrl = isEpisode
  ? (item?.show_tmdb_id ? `https://www.themoviedb.org/tv/${item.show_tmdb_id}` : null)
  : `https://www.themoviedb.org/movie/${item?.tmdb_id}`;
const logoPath = item?.logo_path ?? null;
---

<Base title={item?.title || "Media Details"}>
  {error && !item && (
    <div class="max-w-md mx-auto mt-20 text-center">
        <div class="bg-red-500/10 border border-red-500/20 text-red-500 p-6 rounded-2xl mb-6">
            <p class="font-bold text-lg mb-2">Oops!</p>
            <p class="text-sm opacity-80">{error}</p>
        </div>
        <a href="/" class="text-blue-500 hover:underline">Return to Dashboard</a>
    </div>
  )}

  {item && (
    <div class="relative">
      <!-- Backdrop -->
      {item.backdrop_path && (
        <div class="absolute -top-8 left-1/2 -translate-x-1/2 w-screen h-[600px] overflow-hidden" style="mask-image: linear-gradient(to bottom, black 50%, transparent 100%); -webkit-mask-image: linear-gradient(to bottom, black 50%, transparent 100%);" data-adult-backdrop={item.adult ? "true" : undefined}>
          <div class="absolute inset-0 bg-gradient-to-t from-zinc-950 via-zinc-950/40 to-transparent z-10"></div>
          <img
            src={item.backdrop_path}
            alt=""
            class="w-full h-full object-cover opacity-50 blur-[1px]"
            loading="eager"
            decoding="async"
          />
        </div>
      )}

      <div class="relative z-20">
        <nav class="flex items-center gap-2 text-sm text-zinc-400 mb-8 overflow-hidden whitespace-nowrap">
          {isEpisode ? (
            <a href="/shows" class="hover:text-zinc-100 transition shrink-0">Shows</a>
          ) : (
            <a href="/movies" class="hover:text-zinc-100 transition shrink-0">Movies</a>
          )}
          <span class="text-zinc-700">/</span>
          <span class="text-zinc-100 font-bold truncate">{item.title}</span>
        </nav>

        <div class="flex flex-col md:flex-row gap-8 lg:gap-12">
          <!-- Poster -->
          <div class="w-64 shrink-0 mx-auto md:mx-0">
            <div class="aspect-[2/3] rounded-2xl overflow-hidden shadow-2xl border border-zinc-800 bg-zinc-900 ring-1 ring-white/10 relative" data-adult={item.adult ? "true" : undefined}>
              {item.poster_path ? (
                <button id="poster-zoom-btn" class="w-full h-full group/poster block cursor-zoom-in" aria-label={`Enlarge poster for ${item.title}`}>
                  <img
                    src={item.poster_path}
                    alt={item.title}
                    class="w-full h-full object-cover transition-transform duration-300 group-hover/poster:scale-105"
                    loading="eager"
                    decoding="async"
                  />
                  <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover/poster:opacity-100 transition-opacity duration-200 bg-black/30">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-8 h-8 text-white drop-shadow-lg">
                      <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607ZM10.5 7.5v6m3-3h-6" />
                    </svg>
                  </div>
                </button>
              ) : (
                <div class="w-full h-full flex flex-col items-center justify-center text-zinc-400 p-4 text-center">
                  <span class="text-4xl mb-2">🎬</span>
                  <span class="text-sm font-medium">No Poster Available</span>
                </div>
              )}
            </div>
          </div>

          <!-- Info -->
          <div class="flex-1 min-w-0 pt-4 text-center md:text-left flex flex-col items-center md:items-start">
            {isEpisode && (
              <div class="inline-flex items-center justify-center gap-2 px-3 py-1 bg-purple-600/10 border border-purple-600/30 text-purple-400 text-xs font-bold rounded-full mb-4 uppercase tracking-wider">
                Season {item.season_number} · Episode {item.episode_number}
              </div>
            )}
            
            {logoPath ? (
              <div class="mb-3 flex flex-col items-center md:items-start">
                <img
                  src={logoPath}
                  alt={item.title}
                  class="max-h-28 max-w-xs md:max-w-sm object-contain drop-shadow-2xl mx-auto md:mx-0"
                  loading="eager"
                  decoding="async"
                />
                <h1 class="sr-only">{item.title}</h1>
              </div>
            ) : (
              <h1 class="text-4xl md:text-6xl font-black text-zinc-100 mb-3 tracking-tight leading-none text-center md:text-left">{item.title}</h1>
            )}

            {item.tagline && (
              <p class="text-xl italic text-zinc-400 mb-8 font-light leading-relaxed text-center md:text-left">"{item.tagline}"</p>
            )}

            <div class="flex flex-wrap items-center justify-center md:justify-start gap-3 mb-10">
              <div class="flex flex-wrap items-center justify-center md:justify-start gap-4 text-zinc-300 text-sm bg-zinc-900/40 p-3 rounded-xl border border-zinc-800/50 backdrop-blur-sm">
                {year && <span class="font-bold">{year}</span>}
                {rating && (
                  <span class="flex items-center gap-1.5 text-yellow-400 font-black item-rating">
                    <span class="text-lg leading-none">★</span> {rating}
                  </span>
                )}
                {item.runtime && (
                  <span class="flex items-center gap-1.5 font-medium">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4 text-zinc-500">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                    </svg>
                    {item.runtime} min
                  </span>
                )}
                {item.age_rating && (
                  <span class="px-2 py-0.5 border border-zinc-600 rounded text-[10px] font-black text-zinc-400 tracking-widest">
                    {item.age_rating}
                  </span>
                )}
                {item.imdb_id && (
                  <a href={`https://www.imdb.com/title/${item.imdb_id}/`} target="_blank" rel="noopener noreferrer" class="px-2 py-0.5 bg-[#f5c518] rounded text-[10px] font-black text-black tracking-widest hover:bg-[#e6b800] transition-colors">
                    IMDb
                  </a>
                )}
                {tmdbUrl && (
                  <a href={tmdbUrl} target="_blank" rel="noopener noreferrer" class="px-2 py-0.5 bg-[#01b4e4] rounded text-[10px] font-black text-black tracking-widest hover:bg-[#00a8d8] transition-colors">
                    TMDB
                  </a>
                )}
                {item.status && (
                  <span class="capitalize px-2 py-0.5 bg-zinc-800 border border-zinc-700 rounded text-[10px] font-black text-zinc-400 tracking-widest">
                    {item.status}
                  </span>
                )}
                {originalLanguage && (
                  <span class="flex items-center gap-1.5 font-medium text-zinc-400">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4 text-zinc-500">
                      <path stroke-linecap="round" stroke-linejoin="round" d="m10.5 21 5.25-11.25L21 21m-9-3h7.5M3 5.621a48.474 48.474 0 0 1 6-.371m0 0c1.12 0 2.233.038 3.334.114M9 5.25V3m3.334 2.364C11.176 10.658 7.69 15.08 3 17.502m9.334-12.138c.896.061 1.785.147 2.666.257m-4.589 8.495a18.023 18.023 0 0 1-3.827-5.802" />
                    </svg>
                    {originalLanguage}
                  </span>
                )}
              </div>
              {!isEpisode && (() => { const c = item.production_companies?.find(c => c.logo_path); return c ? <div class="bg-zinc-900/40 p-3 rounded-xl border border-zinc-800/50 backdrop-blur-sm flex items-center"><img src={c.logo_path!} alt={c.name} title={c.name} class="h-5 max-w-[80px] object-contain" loading="lazy" /></div> : null; })()}
            </div>

            <div class="mb-4 w-full flex justify-center md:justify-start">
              <ActionBar
                tmdbId={item.tmdb_id}
                mediaType={item.type}
                watched={item.watched ?? false}
                inLists={item.in_lists ?? []}
                inLibrary={item.in_library ?? false}
                collectionPct={item.collection_pct ?? 0}
                showTmdbId={item.show_tmdb_id}
                seasonNumber={item.season_number}
                episodeNumber={item.episode_number}
                isMonitored={item.is_monitored ?? false}
                requestEnabled={item.request_enabled ?? false}
                mediaId={item.id}
                userRating={item.user_rating ?? null}
                isBlocked={item.is_blocked ?? false}
              />
            </div>

            {(item.type === 'movie' || item.type === 'episode') && (
              <div class="w-full flex justify-center md:justify-start">
                <ManualScrobble
                  tmdbId={item.tmdb_id}
                  mediaType={item.type}
                  runtime={item.runtime}
                  title={item.title}
                  showTmdbId={item.show_tmdb_id}
                  seasonNumber={item.season_number}
                  episodeNumber={item.episode_number}
                />
              </div>
            )}

            {(showRefreshBtn || ((item.type === "movie" || item.type === "episode") && item.in_library) || trailerYoutubeId) && (
              <div class="mb-4 flex flex-wrap gap-2 justify-center md:justify-start">
                {showRefreshBtn && (
                  <button
                    id="refresh-metadata-btn"
                    class="flex items-center gap-2 px-4 py-2 text-sm font-bold text-zinc-400 hover:text-zinc-100 bg-zinc-900/60 hover:bg-zinc-800/80 border border-zinc-800 hover:border-zinc-700 rounded-xl transition-all duration-200 cursor-pointer"
                  >
                    <svg id="refresh-icon" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8"/>
                      <path d="M21 3v5h-5"/>
                      <path d="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16"/>
                      <path d="M8 16H3v5"/>
                    </svg>
                    <span id="refresh-label">Refresh Metadata</span>
                  </button>
                )}
                {(item.type === "movie" || item.type === "episode") && (
                  <VideoPlayer
                    tmdbId={item.tmdb_id}
                    mediaType={item.type}
                    inLibrary={item.in_library ?? false}
                    title={item.title}
                    token={token}
                  />
                )}
                {trailerYoutubeId && (
                  <button
                    id="trailer-btn"
                    class="flex items-center gap-2 px-4 py-2 text-sm font-bold text-white bg-red-600/80 hover:bg-red-500/90 border border-red-500/30 hover:border-red-400/60 rounded-xl transition-all duration-200 cursor-pointer shadow-lg shadow-red-900/20"
                  >
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                      <path d="M21.543 6.498C22 8.28 22 12 22 12s0 3.72-.457 5.502c-.254.985-.997 1.76-1.938 2.022C17.896 20 12 20 12 20s-5.893 0-7.605-.476c-.945-.266-1.687-1.04-1.938-2.022C2 15.72 2 12 2 12s0-3.72.457-5.502c.254-.985.997-1.76 1.938-2.022C6.107 4 12 4 12 4s5.896 0 7.605.476c.945.266 1.687 1.04 1.938 2.022ZM10 15.5l6-3.5-6-3.5v7Z"/>
                    </svg>
                    View Trailer
                  </button>
                )}
              </div>
            )}

            {trailerYoutubeId && (
              <div class="mb-4">
                <dialog
                  id="trailer-dialog"
                  data-youtube-id={trailerYoutubeId}
                  class="fixed inset-0 z-50 w-full max-w-4xl mx-auto my-auto bg-zinc-950 border border-zinc-800 rounded-2xl shadow-2xl p-0 backdrop:bg-black/80"
                >
                  <div class="flex items-center justify-between px-5 py-3 border-b border-zinc-800">
                    <span class="text-sm font-bold text-zinc-100 flex items-center gap-2">
                      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="#ff0000">
                        <path d="M21.543 6.498C22 8.28 22 12 22 12s0 3.72-.457 5.502c-.254.985-.997 1.76-1.938 2.022C17.896 20 12 20 12 20s-5.893 0-7.605-.476c-.945-.266-1.687-1.04-1.938-2.022C2 15.72 2 12 2 12s0-3.72.457-5.502c.254-.985.997-1.76 1.938-2.022C6.107 4 12 4 12 4s5.896 0 7.605.476c.945.266 1.687 1.04 1.938 2.022ZM10 15.5l6-3.5-6-3.5v7Z"/>
                      </svg>
                      Official Trailer
                    </span>
                    <button id="trailer-close" class="text-zinc-400 hover:text-zinc-100 transition p-1 rounded-lg hover:bg-zinc-800 cursor-pointer">
                      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M18 6 6 18M6 6l12 12"/>
                      </svg>
                    </button>
                  </div>
                  <div class="relative bg-black" style="padding-bottom: 56.25%;">
                    <iframe
                      id="trailer-iframe"
                      class="absolute inset-0 w-full h-full"
                      src=""
                      title="Official Trailer"
                      frameborder="0"
                      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                      allowfullscreen
                    ></iframe>
                  </div>
                </dialog>
              </div>
            )}

            <!-- Library info -->
            {(!!item.play_count || item.library) && (
              <div class="mb-4 flex flex-wrap gap-2 justify-center md:justify-start">
                {!!item.play_count && (
                  <span id="play-count-badge" class="inline-flex items-center px-3 py-1.5 bg-zinc-900 border border-zinc-800 text-zinc-400 text-xs rounded-lg font-bold cursor-pointer hover:bg-zinc-800/80 hover:text-zinc-100 hover:border-zinc-700 transition-all duration-200" title="Click to view/remove specific plays" data-tmdb-id={item.tmdb_id} data-media-type={item.type}>
                    {item.play_count} {item.play_count === 1 ? 'Play' : 'Plays'}
                  </span>
                )}
                {item.library && [
                  item.library.resolution,
                  item.library.video_codec,
                  item.library.audio_codec,
                  item.library.audio_channels,
                ].filter(Boolean).map(tag => (
                  <span class="px-3 py-1.5 bg-zinc-900 border border-zinc-800 text-zinc-400 text-xs rounded-lg font-mono font-bold">
                    {tag}
                  </span>
                ))}
                {item.library?.audio_languages?.map((lang: string) => (
                  <span class="px-3 py-1.5 bg-zinc-900 border border-zinc-800 text-zinc-400 text-xs rounded-lg font-mono font-bold flex items-center gap-1.5">
                    <span class="opacity-50">🔊</span> {lang}
                  </span>
                ))}
                {item.library?.subtitle_languages?.map((lang: string) => (
                  <span class="px-3 py-1.5 bg-zinc-900 border border-zinc-800 text-zinc-400 text-xs rounded-lg font-mono font-bold flex items-center gap-1.5">
                    <span class="opacity-50">💬</span> {lang}
                  </span>
                ))}
              </div>
            )}

            <!-- Where to Watch -->
            {item.where_to_watch && item.where_to_watch.length > 0 && (() => {
              const subscribed = item.where_to_watch.filter(s => s.is_subscribed);
              const others = item.where_to_watch.filter(s => !s.is_subscribed);
              
              return (
                <div class="mb-10 w-full flex flex-col items-center md:items-start">
                  <h2 class="text-sm font-black text-zinc-500 mb-4 uppercase tracking-widest flex items-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 8V6a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v2"/><path d="M2 12V4"/><path d="M22 12V4"/><path d="M2 12v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-6"/><path d="M2 12h20"/><path d="M7 15h.01"/><path d="M11 15h.01"/><path d="M15 15h.01"/><path d="M19 15h.01"/><path d="M7 18h.01"/><path d="M11 18h.01"/><path d="M15 18h.01"/><path d="M19 18h.01"/></svg>
                    Where to Watch
                  </h2>
                  
                  <div class="space-y-6 w-full flex flex-col items-center md:items-start">
                    {subscribed.length > 0 && (
                      <div class="space-y-3 w-full">
                        <p class="text-[10px] font-bold text-blue-400 uppercase tracking-wider text-center md:text-left">Your Services</p>
                        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-2">
                          {subscribed.map(s => (
                            <div class="flex items-center gap-2.5 p-2.5 bg-zinc-900/60 border border-zinc-800 rounded-xl hover:border-blue-500/30 transition-colors group">
                              {s.logo ? (
                                <img src={s.logo} alt={s.name} class="w-6 h-6 rounded-md object-cover shadow-lg" />
                              ) : (
                                <div class="w-6 h-6 bg-zinc-800 rounded-md flex items-center justify-center text-[10px]">
                                  {s.type === "plex" ? "🟡" : s.type === "jellyfin" ? "🟣" : s.type === "emby" ? "🟢" : "▶"}
                                </div>
                              )}
                              <div class="min-w-0 text-left">
                                <p class="text-zinc-200 text-xs font-bold truncate group-hover:text-blue-400 transition-colors">{s.name}</p>
                                <p class="text-[9px] text-zinc-500 font-bold uppercase tracking-tighter truncate">{s.category === 'flatrate' ? 'Stream' : s.category === 'local' ? 'Local' : s.category}</p>
                              </div>
                            </div>
                          ))}
                        </div>
                      </div>
                    )}

                    {others.length > 0 && (
                      <div class="space-y-3 w-full flex flex-col items-center md:items-start">
                        <p class="text-[10px] font-bold text-zinc-500 uppercase tracking-wider text-center md:text-left">{subscribed.length > 0 ? "Other Options" : "Available On"}</p>
                        <div class="flex flex-wrap gap-2 justify-center md:justify-start">
                          {others.map(s => (
                            <div class="flex items-center gap-2 px-3 py-1.5 bg-zinc-900/40 border border-zinc-800/50 rounded-lg hover:border-zinc-700 transition-colors group">
                              {s.logo ? (
                                <img src={s.logo} alt={s.name} class="w-4 h-4 rounded-sm object-cover opacity-70 group-hover:opacity-100 transition-opacity" />
                              ) : (
                                <span class="text-[10px]">▶</span>
                              )}
                              <span class="text-zinc-400 text-[11px] font-medium group-hover:text-zinc-200 transition-colors">{s.name}</span>
                              <span class="text-[9px] text-zinc-600 font-bold uppercase ml-1">{s.category === 'flatrate' ? 'Stream' : s.category}</span>
                            </div>
                          ))}
                        </div>
                      </div>
                    )}
                  </div>
                </div>
              );
            })()}

            <div class="mb-12 flex flex-col items-center md:items-start text-center md:text-left">
              <h2 class="text-xl font-black text-zinc-100 mb-4 flex items-center gap-2 uppercase tracking-tight">
                <span class="w-2 h-2 bg-blue-500 rounded-full"></span>
                Overview
              </h2>
              <p class="text-zinc-300 leading-relaxed text-lg max-w-4xl font-medium opacity-90">
                {item.overview}
              </p>
            </div>

            {item.genres?.length > 0 && (
              <div class="flex flex-wrap gap-2 mb-12 justify-center md:justify-start">
                {item.genres.map((g: string) => (
                  <span class="px-4 py-1.5 bg-zinc-900/80 border border-zinc-800 hover:border-zinc-700 transition-colors text-zinc-400 text-xs rounded-full font-bold uppercase tracking-widest">
                    {g}
                  </span>
                ))}
              </div>
            )}
          </div>
        </div>

        <!-- Cast -->
        {item.cast?.length > 0 && (
          <div class="mt-24 border-zinc-900 pt-16">
            <div class="flex items-center justify-between mb-10">
              <h2 class="text-3xl font-black text-zinc-100 tracking-tighter uppercase">Top Cast</h2>
            </div>
            <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-6">
              {item.cast.slice(0, 12).map((person) => (
                <a href={`/person/${person.tmdb_id}`} class="group/cast bg-zinc-900/20 border border-zinc-800/40 p-4 rounded-3xl hover:bg-zinc-800/40 hover:border-blue-500/50 transition-all duration-500 hover:shadow-2xl hover:shadow-blue-900/10 active:scale-95 active:opacity-70">
                  <div class="aspect-square w-full rounded-2xl overflow-hidden mb-5 ring-2 ring-zinc-800/50 group-hover/cast:ring-blue-500 transition-all duration-500 shadow-lg">
                    {person.profile_path ? (
                      <img
                        src={person.profile_path}
                        alt={person.name}
                        class="w-full h-full object-cover group-hover/cast:scale-110 transition-transform duration-700"
                        loading="lazy"
                        decoding="async"
                      />
                    ) : (
                      <div class="w-full h-full bg-zinc-800 flex items-center justify-center text-zinc-400 text-4xl">
                        👤
                      </div>
                    )}
                  </div>
                  <div class="space-y-1.5 text-center">
                    <p class="text-sm font-black text-zinc-100 group-hover/cast:text-blue-400 transition-colors line-clamp-1 leading-tight">{person.name}</p>
                    <p class="text-[11px] text-zinc-500 font-bold uppercase tracking-wider line-clamp-1 opacity-80">{person.character}</p>
                  </div>
                </a>
              ))}
            </div>
          </div>
        )}

        {collection && collection.parts?.length > 1 && (
          <div class="mt-32">
            <MediaRow
              title={collection.name}
              items={collection.parts.filter((p) => p.tmdb_id !== item.tmdb_id)}
              href={`/collection/${collection.id}`}
            />
          </div>
        )}

        <CommentsSection
          mediaType={item.type}
          tmdbId={item.tmdb_id}
          seasonNumber={isEpisode ? item.season_number : undefined}
          episodeNumber={isEpisode ? item.episode_number : undefined}
        />

        <div id="recommendations-container" data-type={item.type} data-id={item.tmdb_id}></div>
      </div>
    </div>
  )}
</Base>

<script>
  // Async load recommendations
  const container = document.getElementById('recommendations-container');
  if (container) {
    const { type, id } = container.dataset;
    fetch(`/partials/recommendations?type=${type}&id=${id}`)
      .then(res => {
        if (res.status === 200) return res.text();
        return null;
      })
      .then(html => {
        // Safe: html is a server-rendered Astro partial; Astro auto-escapes all values.
        // Do NOT add raw user data to this partial without going through Astro templates.
        if (html) container.innerHTML = html;
      })
      .catch(err => console.error('Failed to load recommendations', err));
  }
</script>

