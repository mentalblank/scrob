                ))}
              </div>
            )}

            <!-- Cast -->
            {item.cast?.length > 0 && (
              <div class="pt-8 border-t border-zinc-800/60">
                <div class="flex items-center justify-between mb-6">
                  <h2 class="text-xl font-black text-zinc-100 tracking-tight uppercase">Top Cast</h2>
                </div>
                <div class="grid grid-cols-2 xs:grid-cols-3 sm:grid-cols-4 lg:grid-cols-4 gap-3">
                  {item.cast.slice(0, 12).map((person) => (
                    <a href={personUrl(person.tmdb_id, person.tvdb_id || person.person_id, primaryMetadataSource === 'tvdb')} class="group/cast bg-zinc-900/20 border border-zinc-800/40 p-3 rounded-2xl hover:bg-zinc-800/40 hover:border-blue-500/50 transition-all duration-300 active:scale-95 active:opacity-70 flex flex-col h-full">
                      <div class="aspect-square w-full rounded-xl overflow-hidden mb-3 ring-1 ring-zinc-800/50 group-hover/cast:ring-blue-500 transition-all duration-300 shadow-md">
