<div id="play-history-modal" class="fixed inset-0 z-[999] flex items-center justify-center hidden" role="dialog" aria-modal="true">
  <div id="play-history-backdrop" class="absolute inset-0 bg-black/75 backdrop-blur-sm cursor-pointer"></div>
  
  <div class="relative w-full max-w-md mx-4 bg-zinc-950 border border-zinc-800 rounded-2xl shadow-2xl overflow-hidden flex flex-col max-h-[80vh] z-10">
    <div class="p-4 border-b border-zinc-800 flex items-center justify-between">
      <h3 class="text-sm font-bold text-zinc-100 flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="text-indigo-500">
          <circle cx="12" cy="12" r="10"/>
          <polyline points="12 6 12 12 16 14"/>
        </svg>
        Play History
      </h3>
      <button
        id="play-history-close"
        class="p-1 rounded-lg hover:bg-zinc-800 text-zinc-400 hover:text-zinc-100 transition-colors cursor-pointer"
        aria-label="Close"
      >
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <div id="play-history-list" class="p-4 overflow-y-auto space-y-3 flex-1 scrollbar-thin">
      <div class="text-zinc-500 text-sm text-center py-8">Loading history...</div>
    </div>
  </div>
</div>

<script define:vars={{ token: Astro.locals.token }}>
  const badge = document.getElementById('play-count-badge');
  const historyModal = document.getElementById('play-history-modal');
  const historyBackdrop = document.getElementById('play-history-backdrop');
  const historyClose = document.getElementById('play-history-close');
  const historyList = document.getElementById('play-history-list');

  if (badge && historyModal) {
    const tmdbId = badge.getAttribute('data-tmdb-id');
    const mediaType = badge.getAttribute('data-media-type');

    function openModal() {
      historyModal.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
      loadHistory();
    }

    function closeModal() {
      historyModal.classList.add('hidden');
      document.body.style.overflow = '';
    }

    badge.addEventListener('click', openModal);
    historyBackdrop?.addEventListener('click', closeModal);
    historyClose?.addEventListener('click', closeModal);
    
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !historyModal.classList.contains('hidden')) {
        closeModal();
      }
    });

    async function loadHistory() {
      if (!historyList) return;
      historyList.innerHTML = '<div class="text-zinc-500 text-sm text-center py-8 flex justify-center items-center gap-2"><svg class="animate-spin h-5 w-5 text-zinc-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>Loading history...</div>';

      try {
        const res = await fetch(`/api/proxy/history/item/events?tmdb_id=${tmdbId}&media_type=${mediaType}`, {
          headers: { 'Authorization': `Bearer ${token}` }
        });
        if (!res.ok) throw new Error('Failed to fetch play history');
        const data = await res.json();
        
        if (!data.events || data.events.length === 0) {
          historyList.innerHTML = '<div class="text-zinc-500 text-sm text-center py-8">No play history found.</div>';
          return;
        }

        const formatter = new Intl.DateTimeFormat(undefined, {
          dateStyle: 'medium',
          timeStyle: 'short'
        });

        historyList.innerHTML = '';
        data.events.forEach(event => {
          const row = document.createElement('div');
          row.className = 'flex items-center justify-between p-3 bg-zinc-900/60 border border-zinc-800/80 rounded-xl hover:border-zinc-700/80 transition-colors';
          row.id = `play-event-${event.id}`;
          
          const info = document.createElement('div');
          info.className = 'flex flex-col gap-0.5';
          
          const dateSpan = document.createElement('span');
          dateSpan.className = 'text-sm font-semibold text-zinc-200';
          dateSpan.textContent = formatter.format(new Date(event.watched_at));
          
          const detailsSpan = document.createElement('span');
          detailsSpan.className = 'text-xs text-zinc-500';
          detailsSpan.textContent = event.completed ? 'Completed' : `In progress (${Math.round((event.progress_percent || 0) * 100)}%)`;
          
          info.appendChild(dateSpan);
          info.appendChild(detailsSpan);
          
          const deleteBtn = document.createElement('button');
          deleteBtn.className = 'delete-play-btn p-2 rounded-lg bg-red-950/20 hover:bg-red-900/30 text-red-400 border border-red-950/50 hover:border-red-800/60 transition-all duration-200 cursor-pointer flex items-center justify-center';
          deleteBtn.setAttribute('title', 'Remove this play from history');
          deleteBtn.setAttribute('data-event-id', event.id);
          deleteBtn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4"><path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" /></svg>';
          
          deleteBtn.addEventListener('click', async () => {
            if (!confirm('Are you sure you want to remove this play from your history?')) return;
            
            deleteBtn.setAttribute('disabled', 'true');
            deleteBtn.innerHTML = '<svg class="animate-spin h-4 w-4 text-red-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>';
            
            try {
              const delRes = await fetch(`/api/proxy/history/event/${event.id}`, {
                method: 'DELETE',
                headers: { 'Authorization': `Bearer ${token}` }
              });
              if (!delRes.ok) throw new Error('Failed to delete play event');
              
              const delData = await delRes.json();
              
              row.remove();
              
              const count = delData.remaining_count;
              if (count > 0) {
                badge.childNodes[0].textContent = `${count} ${count === 1 ? 'Play' : 'Plays'}`;
              } else {
                badge.remove();
                closeModal();
                window.location.reload();
              }
            } catch (err) {
              alert('Failed to delete play: ' + err.message);
              deleteBtn.removeAttribute('disabled');
              deleteBtn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4"><path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" /></svg>';
            }
          });
          
          row.appendChild(info);
          row.appendChild(deleteBtn);
          historyList.appendChild(row);
        });

      } catch (err) {
        historyList.innerHTML = `<div class="text-red-400 text-sm text-center py-8">Failed to load play history: ${err.message}</div>`;
      }
    }
  }
</script>

<script>
  const zoomBtn = document.getElementById('poster-zoom-btn');
  const modal = document.getElementById('poster-modal');
  const backdrop = document.getElementById('poster-modal-backdrop');
  const closeBtn = document.getElementById('poster-modal-close');

  if (zoomBtn && modal) {
    function openModal() {
      modal.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
    }
    function closeModal() {
      modal.classList.add('hidden');
      document.body.style.overflow = '';
    }

    zoomBtn.addEventListener('click', openModal);
    backdrop?.addEventListener('click', closeModal);
    closeBtn?.addEventListener('click', closeModal);
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });
  }
</script>

<script define:vars={{ refreshUrl, showRefreshBtn, token: Astro.locals.token }}>
  if (showRefreshBtn) {
    const btn = document.getElementById('refresh-metadata-btn');
    if (btn) {
      btn.addEventListener('click', async () => {
        const icon = document.getElementById('refresh-icon');
        const label = document.getElementById('refresh-label');
        if (!label || !icon) return;

        btn.setAttribute('disabled', 'true');
        btn.classList.add('opacity-60', 'cursor-not-allowed');
        icon.classList.add('animate-spin');
        label.textContent = 'Refreshing...';

        try {
          const res = await fetch(refreshUrl, {
            method: 'POST',
            headers: { 'Authorization': `Bearer ${token}` },
          });
          if (!res.ok) {
            const data = await res.json().catch(() => ({}));
            throw new Error(data.detail || 'Refresh failed');
          }
          label.textContent = 'Done!';
          icon.classList.remove('animate-spin');
          setTimeout(() => { window.location.reload(); }, 800);
        } catch (err) {
          icon.classList.remove('animate-spin');
          label.textContent = 'Refresh failed';
          btn.removeAttribute('disabled');
          btn.classList.remove('opacity-60', 'cursor-not-allowed');
          setTimeout(() => { label.textContent = 'Refresh Metadata'; }, 3000);
        }
      });
    }
  }

</script>

<script define:vars={{ trailerYoutubeId }}>
  if (trailerYoutubeId) {
    const trailerBtn    = document.getElementById('trailer-btn');
    const trailerDialog = document.getElementById('trailer-dialog');
    const trailerClose  = document.getElementById('trailer-close');
    const trailerIframe = document.getElementById('trailer-iframe');

    function openTrailer() {
      if (!trailerIframe || !trailerDialog) return;
      trailerIframe.src = `https://www.youtube-nocookie.com/embed/${trailerYoutubeId}?autoplay=1&rel=0`;
      trailerDialog.showModal();
    }

    function closeTrailer() {
      if (!trailerIframe || !trailerDialog) return;
      trailerIframe.src = '';
      trailerDialog.close();
    }

    trailerBtn?.addEventListener('click', openTrailer);
    trailerClose?.addEventListener('click', closeTrailer);
    trailerDialog?.addEventListener('click', (e) => { if (e.target === trailerDialog) closeTrailer(); });
  }
</script>
