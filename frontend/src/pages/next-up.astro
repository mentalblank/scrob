---
import Base from "../layouts/Base.astro";
import MediaCard from "../components/MediaCard.astro";
import MediaListCard from "../components/MediaListCard.astro";
import ViewToggle from "../components/ViewToggle.astro";
import { api, type MediaItem } from "../lib/api";
export const prerender = false;

const viewPreference = Astro.cookies.get("media_view_preference")?.value === "list" ? "list" : "grid";

const { token } = Astro.locals;
Astro.response.headers.set("Cache-Control", "no-store");

let nextUp: MediaItem[] = [];
let error = "";

try {
  const data = await api.history.nextUp(token);
  nextUp = data?.next_up ?? [];
} catch (e: any) {
  error = e.message;
}
---

<Base title="Next Up">
  <div class="flex items-center justify-between mb-8">
    <div>
      <h1 class="text-3xl font-bold text-zinc-100 mb-2">Next Up</h1>
      <p class="text-zinc-500">Continue where you left off</p>
    </div>
    <ViewToggle currentView={viewPreference} />
  </div>

  {error && (
    <div class="bg-red-500/10 border border-red-500 text-red-500 p-4 rounded-lg mb-8">
      {error}
    </div>
  )}

  {nextUp.length === 0 && !error && (
    <div class="text-center py-20 text-zinc-500">
      <p class="text-lg">Nothing to watch next.</p>
      <p class="text-sm mt-2">Start watching a show to see your next episodes here.</p>
    </div>
  )}

  {viewPreference === "list" ? (
    <div class="flex flex-col gap-4">
      {nextUp.map((item) => (
        <MediaListCard item={item} />
      ))}
    </div>
  ) : (
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-6">
      {nextUp.map((item) => (
        <MediaCard item={item} />
      ))}
    </div>
  )}
</Base>

<script>
</script>
