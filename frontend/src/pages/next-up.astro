---
import Base from "../layouts/Base.astro";
import MediaCard from "../components/MediaCard.astro";
import { api, type MediaItem } from "../lib/api";

export const prerender = false;

const { token } = Astro.locals;
Astro.response.headers.set("Cache-Control", "no-store");

let items: MediaItem[] = [];
let error = "";

try {
  const data = await api.history.nextUp(token, undefined, true);
  items = data?.next_up ?? [];
} catch (e: unknown) {
  error = e instanceof Error ? e.message : "Failed to load";
}

const isHidden = (item: MediaItem) =>
  item.next_up_hidden === true || item.is_dropped === true || item.is_blocked === true;
const hasVisible = items.some((i) => !isHidden(i));
---

<Base title="Next Up">
  <div class="mb-8 flex items-center justify-between gap-4">
    <div>
      <h1 class="page-title mb-2">Next Up</h1>
      <p class="text-zinc-500">Continue where you left off</p>
    </div>
    <button
      id="toggle-hidden-btn"
      class="flex items-center gap-2 px-4 py-2 text-sm font-bold text-zinc-400 bg-zinc-900 border border-zinc-800 rounded-xl hover:border-zinc-600 hover:text-zinc-200 transition-all cursor-pointer shrink-0"
    >
      <svg id="toggle-icon" xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M9.88 9.88a3 3 0 1 0 4.24 4.24"/><path d="M10.73 5.08A10.43 10.43 0 0 1 12 5c7 0 10 7 10 7a13.16 13.16 0 0 1-1.67 2.68"/>
        <path d="M6.61 6.61A13.526 13.526 0 0 0 2 12s3 7 10 7a9.74 9.74 0 0 0 5.39-1.61"/><line x1="2" x2="22" y1="2" y2="22"/>
      </svg>
      <span id="toggle-label">Show dropped</span>
    </button>
  </div>

  {error && (
    <div class="bg-red-500/10 border border-red-500 text-red-500 p-4 rounded-lg mb-8">
      {error}
    </div>
  )}

  <div id="next-up-grid" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-6">
    {items.map((item) => (
      <div data-nu-wrapper data-next-up-hidden={isHidden(item) ? "true" : "false"} class={isHidden(item) ? "hidden" : ""}>
        <MediaCard item={item} />
      </div>
    ))}
  </div>

  <div id="empty-state" class={hasVisible ? "hidden text-center py-20 text-zinc-500" : "text-center py-20 text-zinc-500"}>
    <p class="text-lg">Nothing to watch next.</p>
    <p class="text-sm mt-2">Start watching a show to see your next episodes here.</p>
  </div>
</Base>

<script>
  let showingHidden = false;

  const grid = document.getElementById("next-up-grid")!;
  const empty = document.getElementById("empty-state")!;

  function syncWrapper(w: HTMLElement, hidden: boolean) {
    w.dataset.nextUpHidden = hidden ? "true" : "false";
    if (hidden && !showingHidden) {
      w.classList.add("hidden");
      w.classList.remove("opacity-50");
    } else if (hidden && showingHidden) {
      w.classList.remove("hidden");
      w.classList.add("opacity-50");
    } else {
      w.classList.remove("hidden", "opacity-50");
    }
  }

  function updateEmptyState() {
    const wrappers = grid.querySelectorAll<HTMLElement>("[data-nu-wrapper]");
    const anyVisible = [...wrappers].some((w) => w.dataset.nextUpHidden === "false");
    const anyHidden = [...wrappers].some((w) => w.dataset.nextUpHidden === "true");
    const isEmpty = !anyVisible && (!showingHidden || !anyHidden);
    empty.classList.toggle("hidden", !isEmpty);
    grid.classList.toggle("hidden", isEmpty);
  }

  // React to drop/block changes fired by the global card handler
  window.addEventListener("unified-block-changed", (e: Event) => {
    const { uriId, tmdbId, mediaType, isDropped, isBlocked } = (e as CustomEvent).detail;
    if (mediaType !== "series" && mediaType !== "episode") return;

    const card = uriId
      ? grid.querySelector(`[data-card][data-show-uri-id="${CSS.escape(uriId)}"], [data-card][data-uri-id="${CSS.escape(uriId)}"]`)
      : grid.querySelector(`[data-card][data-show-tmdb-id="${tmdbId}"], [data-card][data-tmdb-id="${tmdbId}"]`);
    const wrapper = card?.closest<HTMLElement>("[data-nu-wrapper]");
    if (!wrapper) return;

    syncWrapper(wrapper, isDropped || isBlocked);
    updateEmptyState();
  });

  // Toggle: show/hide dropped items in-place, no refetch
  document.getElementById("toggle-hidden-btn")!.addEventListener("click", () => {
    showingHidden = !showingHidden;

    document.getElementById("toggle-label")!.textContent = showingHidden ? "Hide dropped" : "Show dropped";
    document.getElementById("toggle-icon")!.innerHTML = showingHidden
      ? `<path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/>`
      : `<path d="M9.88 9.88a3 3 0 1 0 4.24 4.24"/><path d="M10.73 5.08A10.43 10.43 0 0 1 12 5c7 0 10 7 10 7a13.16 13.16 0 0 1-1.67 2.68"/><path d="M6.61 6.61A13.526 13.526 0 0 0 2 12s3 7 10 7a9.74 9.74 0 0 0 5.39-1.61"/><line x1="2" x2="22" y1="2" y2="22"/>`;

    grid.querySelectorAll<HTMLElement>('[data-nu-wrapper][data-next-up-hidden="true"]').forEach((w) => syncWrapper(w, true));
    updateEmptyState();
  });

  updateEmptyState();
</script>
