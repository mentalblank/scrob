  function setupSettingsForm() {
    const form = document.getElementById('settings-form');
    const saveBtn = document.getElementById('save-settings-btn');
    if (!form || !saveBtn) return;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      saveBtn.disabled = true;
      const originalText = saveBtn.textContent;
      saveBtn.textContent = 'Saving...';

      try {
        const saves = [];

        // 1. Gather library selections
        // ONLY gather and save if the list has actually loaded (not showing "Loading..." or error)
        const jellyfinList = document.getElementById('jellyfin-libraries-list');
        if (jellyfinList && !jellyfinList.classList.contains('italic') && jellyfinList.querySelector('.library-checkbox')) {
          const ids = [...jellyfinList.querySelectorAll('.library-checkbox:checked')].map(cb => cb.getAttribute('data-id'));
          saves.push(fetch(`/api/proxy/sync/jellyfin/libraries`, {
            method: 'PUT',
            headers: { 'Authorization': `Bearer ${token}`, 'Content-Type': 'application/json' },
            body: JSON.stringify({ library_ids: ids }),
          }));
        }

        const embyList = document.getElementById('emby-libraries-list');
        if (embyList && !embyList.classList.contains('italic') && embyList.querySelector('.library-checkbox')) {
          const ids = [...embyList.querySelectorAll('.library-checkbox:checked')].map(cb => cb.getAttribute('data-id'));
          saves.push(fetch(`/api/proxy/sync/emby/libraries`, {
            method: 'PUT',
            headers: { 'Authorization': `Bearer ${token}`, 'Content-Type': 'application/json' },
            body: JSON.stringify({ library_ids: ids }),
          }));
        }

        const plexList = document.getElementById('plex-libraries-list');
        if (plexList && !plexList.classList.contains('italic') && plexList.querySelector('.library-checkbox')) {
          const keys = [...plexList.querySelectorAll('.library-checkbox:checked')].map(cb => cb.getAttribute('data-id'));
          saves.push(fetch(`/api/proxy/sync/plex/libraries`, {
            method: 'PUT',
            headers: { 'Authorization': `Bearer ${token}`, 'Content-Type': 'application/json' },
            body: JSON.stringify({ library_keys: keys }),
          }));
        }

        // 2. Gather general settings
        const formData = new FormData(form);
        const settings = {
          tmdb_api_key: formData.get('tmdb_api_key') || null,
          jellyfin_url: formData.get('jellyfin_url') || null,
          jellyfin_token: formData.get('jellyfin_token') || null,
          jellyfin_user_id: formData.get('jellyfin_user_id') || null,
          emby_url: formData.get('emby_url') || null,
          emby_token: formData.get('emby_token') || null,
          emby_user_id: formData.get('emby_user_id') || null,
          plex_url: formData.get('plex_url') || null,
          plex_token: formData.get('plex_token') || null,
          plex_username: formData.get('plex_username') || null,
          
          radarr_url: formData.get('radarr_url') || null,
          radarr_token: formData.get('radarr_token') || null,
          radarr_root_folder: formData.get('radarr_root_folder') || null,
          radarr_quality_profile: formData.get('radarr_quality_profile') ? parseInt(formData.get('radarr_quality_profile')) : null,
          radarr_tags: formData.getAll('radarr_tags').map(id => parseInt(id)),

          sonarr_url: formData.get('sonarr_url') || null,
          sonarr_token: formData.get('sonarr_token') || null,
          sonarr_root_folder: formData.get('sonarr_root_folder') || null,
          sonarr_quality_profile: formData.get('sonarr_quality_profile') ? parseInt(formData.get('sonarr_quality_profile')) : null,
          sonarr_tags: formData.getAll('sonarr_tags').map(id => parseInt(id)),
          sonarr_season_folder: formData.get('sonarr_season_folder') === 'true',

          trakt_client_id: formData.get('trakt_client_id') || null,
          trakt_client_secret: formData.get('trakt_client_secret') || null,

          jellyfin_auto_sync_interval: formData.get('jellyfin_auto_sync_interval') ? parseInt(formData.get('jellyfin_auto_sync_interval') as string) : null,
          emby_auto_sync_interval: formData.get('emby_auto_sync_interval') ? parseInt(formData.get('emby_auto_sync_interval') as string) : null,
          plex_auto_sync_interval: formData.get('plex_auto_sync_interval') ? parseInt(formData.get('plex_auto_sync_interval') as string) : null,
        };

        // Collect boolean checkboxes (sync prefs + app preferences)
        const syncKeys = [
          'plex_sync_collection', 'plex_sync_watched', 'plex_sync_ratings', 'plex_sync_playback',
          'jellyfin_sync_collection', 'jellyfin_sync_watched', 'jellyfin_sync_ratings', 'jellyfin_sync_playback',
          'emby_sync_collection', 'emby_sync_watched', 'emby_sync_ratings', 'emby_sync_playback',
          'plex_push_watched', 'plex_push_ratings',
          'jellyfin_push_watched', 'jellyfin_push_ratings',
          'emby_push_watched', 'emby_push_ratings',
          'trakt_sync_watched', 'trakt_sync_ratings',
          'trakt_push_watched', 'trakt_push_ratings',
          'blur_explicit',
        ] as const;
        const syncPrefs: Record<string, boolean> = {};
        for (const key of syncKeys) {
          const el = form.querySelector<HTMLInputElement>(`[name="${key}"]`);
          if (el) syncPrefs[key] = el.checked;
        }

        // Sync blur_explicit to a cookie (read server-side by Base.astro) and apply immediately
        const blurEl = form.querySelector<HTMLInputElement>('[name="blur_explicit"]');
        if (blurEl) {
          const val = blurEl.checked ? 'true' : 'false';
          document.cookie = `blur_explicit=${val}; path=/; SameSite=Lax; Max-Age=31536000`;
          document.documentElement.classList.toggle('blur-explicit', blurEl.checked);
        }

        saves.push(fetch(`/api/proxy/auth/settings`, {
          method: 'PATCH',
          headers: { 'Authorization': `Bearer ${token}`, 'Content-Type': 'application/json' },
          body: JSON.stringify({ ...settings, ...syncPrefs }),
        }));

        const results = await Promise.all(saves);
        const failed = results.find(r => !r.ok);
        
        if (failed) {
          const data = await failed.json();
          throw new Error(data.detail || 'Failed to update settings');
        }

        showMessage('Settings updated successfully!');
      } catch (e) {
        showMessage(e.message, 'error');
      } finally {
        saveBtn.disabled = false;
        saveBtn.textContent = originalText;
      }
    });
  }

  function setupPasswordForm() {
    const form = document.getElementById('password-form');
    const updateBtn = document.getElementById('update-password-btn');
    if (!form || !updateBtn) return;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const formData = new FormData(form);
      const current_password = formData.get('current_password') || null;
      const new_password = formData.get('new_password');
      const confirm_password = formData.get('confirm_password');

      if (new_password !== confirm_password) {
        showMessage('New passwords do not match', 'error');
        return;
      }

      updateBtn.disabled = true;
      const originalText = updateBtn.textContent;
      updateBtn.textContent = 'Updating...';

      try {
        const res = await fetch(`/api/proxy/auth/change-password`, {
          method: 'POST',
          headers: { 'Authorization': `Bearer ${token}`, 'Content-Type': 'application/json' },
          body: JSON.stringify({ current_password, new_password }),
        });

        if (res.ok) {
          showMessage('Password updated successfully!');
          form.reset();
        } else {
          const data = await res.json();
          throw new Error(data.detail || 'Failed to update password');
        }
      } catch (e) {
        showMessage(e.message, 'error');
      } finally {
        updateBtn.disabled = false;
        updateBtn.textContent = originalText;
      }
    });
  }

  const COPY_ICON = `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.666 3.888A2.25 2.25 0 0013.5 2.25h-3c-1.03 0-1.9.693-2.166 1.638m7.332 0c.055.194.084.4.084.612v0a.75.75 0 01-.75.75H9a.75.75 0 01-.75-.75v0c0-.212.03-.418.084-.612m7.332 0c.646.049 1.288.11 1.927.184 1.1.128 1.907 1.077 1.907 2.185V19.5a2.25 2.25 0 01-2.25 2.25H6.75A2.25 2.25 0 014.5 19.5V6.257c0-1.108.806-2.057 1.907-2.185a48.208 48.208 0 011.927-.184" /></svg>`;
  const CHECK_ICON = `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>`;

  function flashCopied(btn: HTMLElement): void {
    btn.innerHTML = CHECK_ICON;
    btn.classList.add('bg-green-900', 'border-green-700', 'text-green-400');
    btn.classList.remove('bg-zinc-800', 'hover:bg-zinc-700', 'border-zinc-700', 'text-zinc-300');
    setTimeout(() => {
      btn.innerHTML = COPY_ICON;
      btn.classList.remove('bg-green-900', 'border-green-700', 'text-green-400');
      btn.classList.add('bg-zinc-800', 'hover:bg-zinc-700', 'border-zinc-700', 'text-zinc-300');
    }, 2000);
  }

  function setupApiKey() {
    const copyBtn = document.getElementById('copy-api-key-btn');
    const regenBtn = document.getElementById('regenerate-api-key-btn');
    const keyInput = document.getElementById('scrob_api_key');

    if (copyBtn && keyInput) {
      copyBtn.addEventListener('click', async () => {
        try {
          await navigator.clipboard.writeText((keyInput as HTMLInputElement).value);
          flashCopied(copyBtn as HTMLElement);
        } catch {
          showMessage('Could not copy to clipboard', 'error');
        }
      });
    }

    if (regenBtn && keyInput) {
      regenBtn.addEventListener('click', async () => {
        if (!confirm('Are you sure you want to regenerate your API key? The old key will stop working immediately.')) return;

        regenBtn.disabled = true;
        const originalText = regenBtn.textContent;
        regenBtn.textContent = 'Regenerating...';

        try {
          const res = await fetch(`/api/proxy/auth/api-key/regenerate`, {
            method: 'POST',
            headers: { 'Authorization': `Bearer ${token}` },
          });
          if (!res.ok) {
            const data = await res.json();
            throw new Error(data.detail || 'Failed to regenerate key');
          }
          const data = await res.json();
          keyInput.value = data.api_key;
          showMessage('API key regenerated successfully!');
        } catch (e) {
          showMessage(e.message, 'error');
        } finally {
          regenBtn.disabled = false;
          regenBtn.textContent = originalText;
        }
      });
    }
  }

  function setupHealButton() {
    const btn = document.getElementById('heal-btn');
    const modal = document.getElementById('heal-modal');
    const cancelBtn = document.getElementById('cancel-heal');
    const confirmBtn = document.getElementById('confirm-heal');
    if (!btn || !modal || !cancelBtn || !confirmBtn) return;

    btn.addEventListener('click', () => {
      modal.classList.remove('hidden');
      modal.classList.add('flex');
    });

    cancelBtn.addEventListener('click', () => {
      modal.classList.add('hidden');
      modal.classList.remove('flex');
    });

    confirmBtn.addEventListener('click', async () => {
      modal.classList.add('hidden');
      modal.classList.remove('flex');
      btn.disabled = true;
      const originalText = btn.textContent;
      btn.textContent = 'Healing...';
      try {
        const res = await fetch('/api/proxy/sync/heal', {
          method: 'POST',
          headers: { 'Authorization': `Bearer ${token}` },
        });
        if (res.ok) {
          showMessage('Metadata heal started — it will run in the background.');
        } else {
          const data = await res.json();
          throw new Error(data.detail || 'Failed to start heal');
        }
      } catch (e) {
        showMessage(e.message, 'error');
      } finally {
        btn.disabled = false;
        btn.textContent = originalText;
      }
    });
  }

  function setupPlexWebhookUrl() {
    const input = document.getElementById('plex-webhook-url') as HTMLInputElement | null;
    const copyBtn = document.getElementById('copy-plex-webhook-btn');
    const keyInput = document.getElementById('scrob_api_key') as HTMLInputElement | null;

    if (!input || !keyInput) return;

    const apiKey = keyInput.value;
    const webhookUrl = `${window.location.origin}/api/proxy/webhooks/plex?api_key=${encodeURIComponent(apiKey)}`;
    input.value = webhookUrl;

    if (copyBtn) {
      copyBtn.addEventListener('click', async () => {
        try {
          await navigator.clipboard.writeText(input.value);
          flashCopied(copyBtn as HTMLElement);
        } catch {
          showMessage('Could not copy to clipboard', 'error');
        }
      });
    }
  }

  function setupEmbyWebhookUrl() {
    const input = document.getElementById('emby-webhook-url') as HTMLInputElement | null;
    const copyBtn = document.getElementById('copy-emby-webhook-btn');
    const keyInput = document.getElementById('scrob_api_key') as HTMLInputElement | null;

    if (!input || !keyInput) return;

    const apiKey = keyInput.value;
    const webhookUrl = `${window.location.origin}/api/proxy/webhooks/emby?api_key=${encodeURIComponent(apiKey)}`;
    input.value = webhookUrl;

    if (copyBtn) {
      copyBtn.addEventListener('click', async () => {
        try {
          await navigator.clipboard.writeText(input.value);
          flashCopied(copyBtn as HTMLElement);
        } catch {
          showMessage('Could not copy to clipboard', 'error');
        }
      });
    }
  }

  function setupJellyfinWebhookUrl() {
    const input = document.getElementById('jellyfin-webhook-url') as HTMLInputElement | null;
    const copyBtn = document.getElementById('copy-jellyfin-webhook-btn');
    const keyInput = document.getElementById('scrob_api_key') as HTMLInputElement | null;

    if (!input || !keyInput) return;

    const apiKey = keyInput.value;
    const webhookUrl = `${window.location.origin}/api/proxy/webhooks/jellyfin?api_key=${encodeURIComponent(apiKey)}`;
    input.value = webhookUrl;

    if (copyBtn) {
      copyBtn.addEventListener('click', async () => {
        try {
          await navigator.clipboard.writeText(input.value);
          flashCopied(copyBtn as HTMLElement);
        } catch {
          showMessage('Could not copy to clipboard', 'error');
        }
      });
    }
  }

  function setupCollapsibleRows() {
    document.querySelectorAll('.collapsible-header').forEach(header => {
      header.addEventListener('click', () => {
        const targetId = header.getAttribute('data-target');
        const body = targetId ? document.getElementById(targetId) : null;
        if (!body) return;
        const isOpen = !body.classList.contains('hidden');
        if (isOpen) {
          body.classList.add('hidden');
          header.querySelector('.collapsible-chevron')?.classList.remove('rotate-180');
        } else {
          body.classList.remove('hidden');
          header.querySelector('.collapsible-chevron')?.classList.add('rotate-180');
        }
      });
    });
  }

  setupAccentSwatches();
  setupActions();
  setupPasswordToggles();
  loadLibraries();
  setupSettingsForm();
  setupPasswordForm();

  // Sync blur_explicit cookie from the server-rendered value on page load.
  // Picks up changes made on another device/browser.
  const blurToggle = document.getElementById('blur-explicit-toggle') as HTMLInputElement | null;
  if (blurToggle) {
    const val = blurToggle.checked ? 'true' : 'false';
    document.cookie = `blur_explicit=${val}; path=/; SameSite=Lax; Max-Age=31536000`;
    document.documentElement.classList.toggle('blur-explicit', blurToggle.checked);
  }
  setupApiKey();
  setupHealButton();
  setupCollapsibleRows();
  setupPlexWebhookUrl();
  setupJellyfinWebhookUrl();
  setupEmbyWebhookUrl();
  checkConnections();
  loadSyncWarnings();
  loadLastSynced();

  document.addEventListener('astro:after-swap', () => {
    setupAccentSwatches();
    setupActions();
    setupPasswordToggles();
    loadLibraries();
    setupSettingsForm();
    setupPasswordForm();
    setupApiKey();
    setupHealButton();
    setupCollapsibleRows();
    setupPlexWebhookUrl();
    setupJellyfinWebhookUrl();
    setupEmbyWebhookUrl();
    checkConnections();
    loadSyncWarnings();
    loadLastSynced();
  });

  async function loadLastSynced() {
    const appData = document.getElementById('app-data') as HTMLElement | null;
    const token = appData?.dataset.token ?? '';
    if (!token) return;

    try {
      const res = await fetch('/api/proxy/sync/status', {
        headers: { 'Authorization': `Bearer ${token}` },
      });
      if (!res.ok) return;
      const jobs: any[] = await res.json();

      function timeAgo(dateStr: string): string {
        const diff = Math.floor((Date.now() - new Date(dateStr).getTime()) / 1000);
        if (diff < 60) return 'just now';
        if (diff < 3600) return `${Math.floor(diff / 60)}m ago`;
        if (diff < 86400) return `${Math.floor(diff / 3600)}h ago`;
        return `${Math.floor(diff / 86400)}d ago`;
      }

      for (const source of ['jellyfin', 'emby', 'plex'] as const) {
        const el = document.getElementById(`${source}-last-sync`);
        if (!el) continue;
        const job = jobs.find(j => j.source === source && (j.status === 'completed' || j.status === 'failed'));
        if (!job) continue;
        const label = job.status === 'failed' ? `failed ${timeAgo(job.updated_at)}` : `synced ${timeAgo(job.updated_at)}`;
        el.textContent = label;
        el.classList.remove('hidden');
      }
    } catch {
      // non-fatal
    }
  }

  async function loadSyncWarnings() {
    const appData = document.getElementById('app-data') as HTMLElement | null;
    const token = appData?.dataset.token ?? '';
    if (!token) return;

    try {
      const res = await fetch('/api/proxy/sync/status', {
        headers: { 'Authorization': `Bearer ${token}` },
      });
      if (!res.ok) return;
      const jobs: any[] = await res.json();

      for (const source of ['plex', 'jellyfin', 'emby'] as const) {
        const container = document.getElementById(`${source}-sync-warnings`);
        if (!container) continue;

        // Find the most recent completed job for this source that has warnings
        const job = jobs.find(j => j.source === source && j.status === 'completed' && j.warnings?.length > 0);
        if (!job) { container.classList.add('hidden'); continue; }

        const warnings: any[] = job.warnings;
        const date = new Date(job.updated_at).toLocaleString(undefined, { dateStyle: 'short', timeStyle: 'short' });
        const detailsId = `${source}-warnings-details`;

        container.classList.remove('hidden');
        container.innerHTML = `
          <div class="rounded-xl border border-amber-500/20 bg-amber-500/5 overflow-hidden">
            <button
              type="button"
              class="w-full flex items-center justify-between px-4 py-3 text-left hover:bg-amber-500/10 transition-colors cursor-pointer"
              onclick="const d=document.getElementById('${detailsId}');const c=this.querySelector('.warn-chevron');d.classList.toggle('hidden');c.classList.toggle('rotate-180');"
            >
              <div class="flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-amber-400 shrink-0"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><path d="M12 9v4"/><path d="M12 17h.01"/></svg>
                <span class="text-xs font-semibold uppercase tracking-wider text-amber-400">${warnings.length} show${warnings.length > 1 ? 's' : ''} couldn't be fully synced</span>
                <span class="text-xs text-zinc-500">· ${escapeHtml(date)}</span>
              </div>
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="warn-chevron w-4 h-4 text-amber-500/60 transition-transform shrink-0">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
              </svg>
            </button>
            <div id="${detailsId}" class="hidden border-t border-amber-500/15 px-4 py-3 space-y-2">
              <p class="text-xs text-zinc-500 mb-3">${source === 'plex' ? 'Plex' : source === 'emby' ? 'Emby' : 'Jellyfin'} title shown. These seasons weren't found on TMDB — the show may be split into separate series there. You can fix this by manually matching in Plex/TMDB, or by using the manual collect button on the episode page.</p>
              ${warnings.map((w: any) => `
                <div class="flex items-start gap-3 py-1.5 border-b border-zinc-800/60 last:border-0">
                  <div class="flex-1 min-w-0">
                    <span class="text-sm text-zinc-200 font-medium">${escapeHtml(w.show)}</span>
                    <span class="ml-2 text-xs text-zinc-500">Season${w.seasons.length > 1 ? 's' : ''} ${escapeHtml(w.seasons.join(', '))}</span>
                  </div>
                  <span class="text-xs text-zinc-500 shrink-0">${w.affected_episodes} ep${w.affected_episodes !== 1 ? 's' : ''}</span>
                </div>
              `).join('')}
            </div>
          </div>
        `;
      }
    } catch (_) { /* non-critical */ }
  }

  function escapeHtml(s: string): string {
    return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }
</script>

<script>
  import QRCode from 'qrcode';

  const appData = document.getElementById('app-data') as HTMLElement | null;
  const token: string = appData?.dataset.token ?? '';

  let pendingTotpSecret = '';

  function show2faSetupError(msg: string) {
    const el = document.getElementById('2fa-setup-error');
    if (!el) return;
    el.textContent = msg;
    el.classList.remove('hidden');
  }

  function hide2faSetupError() {
    document.getElementById('2fa-setup-error')?.classList.add('hidden');
  }

  function show2faDisableError(msg: string) {
    const el = document.getElementById('2fa-disable-error');
    if (!el) return;
    el.textContent = msg;
    el.classList.remove('hidden');
  }

  function setup2fa() {
    // Enable flow
    const enableBtn = document.getElementById('enable-2fa-btn');
    const setupPanel = document.getElementById('2fa-setup-panel');
    const cancelSetupBtn = document.getElementById('cancel-2fa-setup-btn');
    const confirmEnableBtn = document.getElementById('confirm-enable-2fa-btn') as HTMLButtonElement | null;
    const verifyInput = document.getElementById('totp-verify-code') as HTMLInputElement | null;
    const secretDisplay = document.getElementById('totp-secret-display');
    const qrCanvas = document.getElementById('totp-qr-canvas') as HTMLCanvasElement | null;
    const newCodesPanel = document.getElementById('2fa-new-codes-panel');
    const newCodesGrid = document.getElementById('2fa-new-codes-grid');
    const newCodesDoneBtn = document.getElementById('2fa-new-codes-done-btn');

    enableBtn?.addEventListener('click', async () => {
      enableBtn.textContent = 'Loading...';
      (enableBtn as HTMLButtonElement).disabled = true;
      hide2faSetupError();

      try {
        const res = await fetch(`/api/proxy/auth/2fa/setup`, {
          method: 'POST',
          headers: { 'Authorization': `Bearer ${token}` },
        });
        if (!res.ok) {
          const data = await res.json();
          throw new Error(data.detail || 'Failed to start 2FA setup');
        }
        const data = await res.json() as { provisioning_uri: string; secret: string };
        pendingTotpSecret = data.secret;

        if (secretDisplay) secretDisplay.textContent = data.secret;

        if (qrCanvas) {
          await QRCode.toCanvas(qrCanvas, data.provisioning_uri, {
            width: 160,
            margin: 1,
            color: { dark: '#000000', light: '#ffffff' },
          });
        }

        setupPanel?.classList.remove('hidden');
      } catch (e: unknown) {
        show2faSetupError(e instanceof Error ? e.message : 'Setup failed');
      } finally {
        enableBtn.textContent = 'Enable 2FA';
        (enableBtn as HTMLButtonElement).disabled = false;
      }
    });

    cancelSetupBtn?.addEventListener('click', () => {
      setupPanel?.classList.add('hidden');
      pendingTotpSecret = '';
      hide2faSetupError();
      if (verifyInput) verifyInput.value = '';
    });

    confirmEnableBtn?.addEventListener('click', async () => {
      const code = verifyInput?.value.trim() ?? '';
      if (!code || !pendingTotpSecret) return;

      confirmEnableBtn.disabled = true;
      const orig = confirmEnableBtn.textContent;
      confirmEnableBtn.textContent = 'Verifying...';
      hide2faSetupError();

      try {
        const res = await fetch(`/api/proxy/auth/2fa/enable`, {
          method: 'POST',
          headers: { 'Authorization': `Bearer ${token}`, 'Content-Type': 'application/json' },
          body: JSON.stringify({ secret: pendingTotpSecret, code }),
        });
        if (!res.ok) {
          const data = await res.json();
          throw new Error(data.detail || 'Invalid code');
        }
        const data = await res.json() as { codes: { id: number; code: string; used: boolean }[] };

        setupPanel?.classList.add('hidden');

        if (newCodesGrid) {
          newCodesGrid.innerHTML = data.codes
            .map(bc => `<span class="font-mono text-sm px-3 py-1.5 rounded-lg border border-zinc-700 bg-zinc-900 text-zinc-300">${escapeHtml(bc.code)}</span>`)
            .join('');
        }
        newCodesPanel?.classList.remove('hidden');
      } catch (e: unknown) {
        show2faSetupError(e instanceof Error ? e.message : 'Failed to enable 2FA');
      } finally {
        confirmEnableBtn.disabled = false;
        confirmEnableBtn.textContent = orig;
      }
    });

    newCodesDoneBtn?.addEventListener('click', () => {
      window.location.reload();
    });

    // Disable flow
    const disableBtn = document.getElementById('disable-2fa-btn');
    const disablePanel = document.getElementById('2fa-disable-panel');
    const cancelDisableBtn = document.getElementById('cancel-disable-2fa-btn');
    const confirmDisableBtn = document.getElementById('confirm-disable-2fa-btn') as HTMLButtonElement | null;
    const disableCodeInput = document.getElementById('totp-disable-code') as HTMLInputElement | null;

    disableBtn?.addEventListener('click', () => {
      disablePanel?.classList.remove('hidden');
      disableBtn.classList.add('hidden');
    });

    cancelDisableBtn?.addEventListener('click', () => {
      disablePanel?.classList.add('hidden');
      disableBtn?.classList.remove('hidden');
      if (disableCodeInput) disableCodeInput.value = '';
      document.getElementById('2fa-disable-error')?.classList.add('hidden');
    });

    confirmDisableBtn?.addEventListener('click', async () => {
      const code = disableCodeInput?.value.trim() ?? '';
      if (!code) return;

      confirmDisableBtn.disabled = true;
      const orig = confirmDisableBtn.textContent;
      confirmDisableBtn.textContent = 'Disabling...';
      document.getElementById('2fa-disable-error')?.classList.add('hidden');

      try {
        const res = await fetch(`/api/proxy/auth/2fa/disable`, {
          method: 'POST',
          headers: { 'Authorization': `Bearer ${token}`, 'Content-Type': 'application/json' },
          body: JSON.stringify({ code }),
        });
        if (!res.ok) {
          const data = await res.json();
          throw new Error(data.detail || 'Failed to disable 2FA');
        }
        window.location.reload();
      } catch (e: unknown) {
        show2faDisableError(e instanceof Error ? e.message : 'Failed to disable 2FA');
        confirmDisableBtn.disabled = false;
        confirmDisableBtn.textContent = orig;
      }
    });
  }

  setup2fa();
  document.addEventListener('astro:after-swap', setup2fa);
</script>
