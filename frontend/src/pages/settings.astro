                        <button type="button" class="password-toggle absolute right-2 top-1/2 -translate-y-1/2 text-zinc-500 hover:text-zinc-300 p-1 cursor-pointer transition-colors" aria-label="Toggle password visibility">
                          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 eye-icon"><path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.644C3.412 7.943 7.213 5 12 5c4.787 0 8.588 2.943 9.964 6.678.066.18.066.362 0 .544C20.588 16.057 16.787 19 12 19c-4.787 0-8.588-2.943-9.964-6.678z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 eye-slash-icon hidden"><path stroke-linecap="round" stroke-linejoin="round" d="M3.98 8.223A10.477 10.477 0 001.934 12C3.226 16.338 7.244 19.5 12 19.5c.993 0 1.953-.138 2.863-.395M6.228 6.228A10.45 10.45 0 0112 4.5c4.756 0 8.773 3.162 10.065 7.498a10.523 10.523 0 01-4.293 5.774M6.228 6.228L3 3m3.228 3.228l3.65 3.65m7.894 7.894L21 21m-3.228-3.228l-3.65-3.65m0 0a3 3 0 10-4.243-4.243m4.242 4.242L9.88 9.88" /></svg>
                        </button>
                      </div>
                    </div>
                  </div>
                  <div class="space-y-4">
                    <div class="space-y-2">
                      <label for="radarr_root_folder" class="block text-sm font-medium text-zinc-400">Root Folder</label>
                      <select name="radarr_root_folder" id="radarr_root_folder" class="w-full bg-zinc-900 border border-zinc-800 rounded-lg px-4 py-3 text-zinc-100 focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all appearance-none">
                        <option value="">-- Select Folder --</option>
                        {settings.radarr_root_folder && <option value={settings.radarr_root_folder} selected>{settings.radarr_root_folder}</option>}
                      </select>
                    </div>
                    <div class="space-y-2">
                      <label for="radarr_quality_profile" class="block text-sm font-medium text-zinc-400">Quality Profile</label>
                      <select name="radarr_quality_profile" id="radarr_quality_profile" class="w-full bg-zinc-900 border border-zinc-800 rounded-lg px-4 py-3 text-zinc-100 focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all appearance-none">
                        <option value="">-- Select Profile --</option>
                        {settings.radarr_quality_profile && <option value={settings.radarr_quality_profile} selected>Profile ID: {settings.radarr_quality_profile}</option>}
                      </select>
                    </div>
                    <div class="space-y-2">
                      <label class="block text-sm font-medium text-zinc-400">Tags</label>
                      <div id="radarr_tags_list" class="flex flex-wrap gap-2 min-h-[42px] p-2 bg-zinc-900 border border-zinc-800 rounded-lg">
                        <span class="text-xs text-zinc-500 italic px-2 py-1">Fetch profiles to see tags</span>
                        {settings.radarr_tags?.map(tid => (
                          <input type="hidden" name="radarr_tags" value={tid} />
                        ))}
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <!-- Sonarr collapsible row -->
            <div class="border border-zinc-800 rounded-2xl overflow-hidden">
              <div class="collapsible-header flex items-center justify-between px-6 py-4 hover:bg-zinc-900/40 cursor-pointer transition-colors select-none" data-target="sonarr-body">
                <div class="flex items-center gap-3 pointer-events-none">
                  <span class="w-2 h-2 bg-blue-500 rounded-full shrink-0"></span>
                  <div class="flex flex-col gap-0.5">
                    <span class="font-medium text-zinc-200">Sonarr</span>
                    <span id="sonarr-conn-status" class="hidden text-xs font-normal px-1.5 py-0.5 rounded self-start pointer-events-auto"></span>
                  </div>
                </div>
                <div class="flex items-center gap-2">
                  <div class="flex gap-2" onclick="event.stopPropagation()">
                    <button type="button" data-action="test_sonarr" class="js-action-btn text-sm bg-zinc-800 hover:bg-zinc-700 text-zinc-300 border border-zinc-700 px-3 py-1.5 rounded-lg transition-colors cursor-pointer disabled:opacity-50">Test & Fetch</button>
                  </div>
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class={`collapsible-chevron w-4 h-4 text-zinc-500 transition-transform pointer-events-none ml-1 shrink-0 ${sonarrConfigured ? 'rotate-180' : ''}`}>
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
                  </svg>
                </div>
              </div>
              <div id="sonarr-body" class={`border-t border-zinc-800 ${sonarrConfigured ? '' : 'hidden'}`}>
                <div class="grid md:grid-cols-2 gap-8 px-6 py-6">
                  <div class="space-y-4">
                    <div class="space-y-2">
                      <label for="sonarr_url" class="block text-sm font-medium text-zinc-400">Server URL</label>
                      <input type="url" name="sonarr_url" id="sonarr_url" placeholder="http://192.168.1.100:8989" value={settings.sonarr_url || ""} class="w-full bg-zinc-900 border border-zinc-800 rounded-lg px-4 py-3 text-zinc-100 focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all" />
                    </div>
                    <div class="space-y-2">
                      <label for="sonarr_token" class="block text-sm font-medium text-zinc-400">API Key</label>
                      <div class="relative group/field">
                        <input type="password" name="sonarr_token" id="sonarr_token" value={settings.sonarr_token || ""} class="w-full bg-zinc-900 border border-zinc-800 rounded-lg pl-4 pr-10 py-3 text-zinc-100 focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all" />
                        <button type="button" class="password-toggle absolute right-2 top-1/2 -translate-y-1/2 text-zinc-500 hover:text-zinc-300 p-1 cursor-pointer transition-colors" aria-label="Toggle password visibility">
                          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 eye-icon"><path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.644C3.412 7.943 7.213 5 12 5c4.787 0 8.588 2.943 9.964 6.678.066.18.066.362 0 .544C20.588 16.057 16.787 19 12 19c-4.787 0-8.588-2.943-9.964-6.678z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 eye-slash-icon hidden"><path stroke-linecap="round" stroke-linejoin="round" d="M3.98 8.223A10.477 10.477 0 001.934 12C3.226 16.338 7.244 19.5 12 19.5c.993 0 1.953-.138 2.863-.395M6.228 6.228A10.45 10.45 0 0112 4.5c4.756 0 8.773 3.162 10.065 7.498a10.523 10.523 0 01-4.293 5.774M6.228 6.228L3 3m3.228 3.228l3.65 3.65m7.894 7.894L21 21m-3.228-3.228l-3.65-3.65m0 0a3 3 0 10-4.243-4.243m4.242 4.242L9.88 9.88" /></svg>
                        </button>
                      </div>
                    </div>
                  </div>
                  <div class="space-y-4">
                    <div class="space-y-2">
                      <label for="sonarr_root_folder" class="block text-sm font-medium text-zinc-400">Root Folder</label>
                      <select name="sonarr_root_folder" id="sonarr_root_folder" class="w-full bg-zinc-900 border border-zinc-800 rounded-lg px-4 py-3 text-zinc-100 focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all appearance-none">
                        <option value="">-- Select Folder --</option>
                        {settings.sonarr_root_folder && <option value={settings.sonarr_root_folder} selected>{settings.sonarr_root_folder}</option>}
                      </select>
                    </div>
                    <div class="space-y-2">
                      <label for="sonarr_quality_profile" class="block text-sm font-medium text-zinc-400">Quality Profile</label>
                      <select name="sonarr_quality_profile" id="sonarr_quality_profile" class="w-full bg-zinc-900 border border-zinc-800 rounded-lg px-4 py-3 text-zinc-100 focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all appearance-none">
                        <option value="">-- Select Profile --</option>
                        {settings.sonarr_quality_profile && <option value={settings.sonarr_quality_profile} selected>Profile ID: {settings.sonarr_quality_profile}</option>}
                      </select>
                    </div>
                    <div class="space-y-2">
                      <label class="block text-sm font-medium text-zinc-400">Tags</label>
                      <div id="sonarr_tags_list" class="flex flex-wrap gap-2 min-h-[42px] p-2 bg-zinc-900 border border-zinc-800 rounded-lg">
                        <span class="text-xs text-zinc-500 italic px-2 py-1">Fetch profiles to see tags</span>
                        {settings.sonarr_tags?.map(tid => (
                          <input type="hidden" name="sonarr_tags" value={tid} />
                        ))}
                      </div>
                    </div>
                    <label class="flex items-center justify-between gap-3 p-3 bg-zinc-900 border border-zinc-800 rounded-lg cursor-pointer hover:bg-zinc-800/60 transition-colors">
                      <span class="text-sm text-zinc-300">Use season folders</span>
                      <input type="checkbox" name="sonarr_season_folder" id="sonarr_season_folder" value="true" class="sr-only peer" checked={settings.sonarr_season_folder !== false} />
                      <div class="relative w-10 h-5 bg-zinc-700 peer-checked:bg-blue-600 rounded-full transition-colors pointer-events-none shrink-0 after:content-[''] after:absolute after:top-0.5 after:left-0.5 after:w-4 after:h-4 after:bg-white after:rounded-full after:transition-transform peer-checked:after:translate-x-5"></div>
                    </label>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <div class="pt-6">
            <button
              id="save-settings-btn"
              type="submit"
              class="w-full sm:w-auto bg-zinc-100 text-zinc-950 font-bold px-8 py-3 rounded-xl hover:bg-zinc-200 transition-colors cursor-pointer disabled:opacity-50"
            >
              Save Changes
            </button>
          </div>
        </form>
      </section>

      <!-- Appearance -->
      <section>
        <h2 class="text-xl font-semibold text-zinc-100 mb-4 border-b border-zinc-800 pb-2">Appearance</h2>
        <div class="space-y-6">
          <div class="flex items-start justify-between gap-6 p-4 bg-zinc-900/60 rounded-xl border border-zinc-800">
            <div>
              <p class="text-sm font-semibold text-zinc-100 mb-1">Blur explicit content</p>
              <p class="text-xs text-zinc-400">Blur posters flagged as adult content by TMDB. Click a blurred poster to reveal it.</p>
            </div>
            <label class="relative inline-flex items-center shrink-0 cursor-pointer mt-0.5">
              <input
                type="checkbox"
                name="blur_explicit"
                id="blur-explicit-toggle"
                class="sr-only peer"
                checked={settings.blur_explicit !== false}
              />
              <div class="w-11 h-6 bg-zinc-700 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-blue-500"></div>
            </label>
          </div>
          <div>
            <p class="text-sm text-zinc-400">Accent color</p>
            <div class="flex flex-wrap gap-3 mt-3" id="accent-swatches">
              {[
                { id: 'blue',   label: 'Blue',   color: '#3b82f6' },
                { id: 'purple', label: 'Purple', color: '#a855f7' },
                { id: 'pink',   label: 'Pink',   color: '#ec4899' },
                { id: 'red',    label: 'Red',    color: '#ef4444' },
                { id: 'green',  label: 'Green',  color: '#22c55e' },
                { id: 'yellow', label: 'Yellow', color: '#eab308' },
                { id: 'orange', label: 'Orange', color: '#f97316' },
              ].map(({ id, label, color }) => (
                <button
                  type="button"
                  data-accent-id={id}
                  class="accent-swatch flex items-center gap-2.5 px-5 py-3 rounded-xl border border-zinc-800 bg-zinc-900 hover:border-zinc-600 transition-all cursor-pointer text-sm text-zinc-400 hover:text-zinc-100"
                >
                  <span class="w-5 h-5 rounded-full shrink-0" style={`background-color: ${color}`}></span>
                  {label}
                </button>
              ))}
            </div>
          </div>
        </div>
      </section>

      <!-- Two-Factor Authentication -->
      <section id="2fa-section">
        <h2 class="text-xl font-semibold text-zinc-100 mb-4 border-b border-zinc-800 pb-2">Two-Factor Authentication</h2>

        {!me.totp_enabled ? (
          <div class="space-y-4">
            <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 bg-zinc-900/40 border border-zinc-800 rounded-2xl p-6">
              <div>
                <h3 class="font-semibold text-zinc-100 mb-1">Authenticator App</h3>
                <p class="text-sm text-zinc-400">Protect your account with a time-based one-time password (TOTP) from any authenticator app.</p>
              </div>
              <button
                type="button"
                id="enable-2fa-btn"
                class="w-full sm:w-auto sm:shrink-0 px-6 py-3 bg-zinc-100 text-zinc-950 font-bold rounded-xl hover:bg-zinc-200 transition-colors cursor-pointer text-sm"
              >
                Enable 2FA
              </button>
            </div>

            <!-- Setup panel (hidden until "Enable 2FA" is clicked) -->
            <div id="2fa-setup-panel" class="hidden border border-zinc-700 rounded-2xl p-6 space-y-5 bg-zinc-900/30">
              <div class="text-sm text-zinc-400">
                Scan the QR code with your authenticator app (Google Authenticator, Authy, etc.), then enter the 6-digit code to confirm.
              </div>

              <div class="flex flex-col md:flex-row gap-6 items-start">
                <div class="shrink-0">
                  <canvas id="totp-qr-canvas" class="rounded-lg bg-white p-2" width="160" height="160"></canvas>
                </div>
                <div class="space-y-3 flex-1">
                  <div>
                    <p class="text-xs text-zinc-500 mb-1">Manual entry key</p>
                    <code id="totp-secret-display" class="block bg-zinc-950 border border-zinc-800 rounded-lg px-3 py-2 text-zinc-300 font-mono text-sm tracking-widest break-all select-all"></code>
                  </div>
                  <div class="space-y-2">
                    <label for="totp-verify-code" class="block text-sm font-medium text-zinc-400">Verification Code</label>
                    <input
                      type="text"
                      id="totp-verify-code"
                      autocomplete="one-time-code"
                      inputmode="numeric"
                      maxlength="6"
                      placeholder="000000"
                      class="w-full bg-zinc-900 border border-zinc-800 rounded-lg px-4 py-3 text-zinc-100 font-mono tracking-widest focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all"
                    />
                  </div>
                  <div class="flex gap-3">
                    <button
                      type="button"
                      id="confirm-enable-2fa-btn"
                      class="px-5 py-2 bg-zinc-100 text-zinc-950 font-bold rounded-lg hover:bg-zinc-200 transition-colors cursor-pointer text-sm disabled:opacity-50"
                    >
                      Verify &amp; Enable
                    </button>
                    <button
                      type="button"
                      id="cancel-2fa-setup-btn"
                      class="px-5 py-2 bg-zinc-800 hover:bg-zinc-700 text-zinc-300 border border-zinc-700 rounded-lg text-sm transition-colors cursor-pointer"
                    >
                      Cancel
                    </button>
                  </div>
                  <p id="2fa-setup-error" class="hidden text-sm text-red-400"></p>
                </div>
              </div>
            </div>

            <!-- Backup codes shown after successful enable (hidden initially) -->
            <div id="2fa-new-codes-panel" class="hidden border border-green-500/30 bg-green-500/5 rounded-2xl p-6 space-y-4">
              <div class="flex items-center gap-2 text-green-400 font-semibold">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                2FA Enabled
              </div>
              <p class="text-sm text-zinc-400">Save these backup codes somewhere safe. Each can only be used once. They cannot be shown again — regenerate them in settings if needed.</p>
              <div id="2fa-new-codes-grid" class="grid grid-cols-2 gap-2"></div>
              <button
                type="button"
                id="2fa-new-codes-done-btn"
                class="px-5 py-2 bg-zinc-100 text-zinc-950 font-bold rounded-lg hover:bg-zinc-200 transition-colors cursor-pointer text-sm"
              >
                Done — reload page
              </button>
            </div>
          </div>
        ) : (
          <div class="space-y-4">
            <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 bg-zinc-900/40 border border-zinc-800 rounded-2xl p-6">
              <div class="flex items-center gap-3">
                <span class="w-2.5 h-2.5 rounded-full bg-green-500 shrink-0"></span>
                <div>
                  <h3 class="font-semibold text-zinc-100">2FA is enabled</h3>
                  <p class="text-sm text-zinc-400">Your account is protected with an authenticator app.</p>
                </div>
              </div>
              <button
                type="button"
                id="disable-2fa-btn"
                class="shrink-0 px-5 py-2 bg-red-600/10 hover:bg-red-600/20 text-red-400 border border-red-500/30 font-bold rounded-lg text-sm transition-colors cursor-pointer"
              >
                Disable 2FA
              </button>
            </div>

            <!-- Disable confirmation (hidden initially) -->
            <div id="2fa-disable-panel" class="hidden border border-zinc-700 rounded-2xl p-6 space-y-4 bg-zinc-900/30">
              <p class="text-sm text-zinc-400">Enter your authenticator code or a backup code to disable 2FA.</p>
              <div class="flex gap-3 items-end">
                <div class="space-y-2 flex-1">
                  <label for="totp-disable-code" class="block text-sm font-medium text-zinc-400">Code</label>
                  <input
                    type="text"
                    id="totp-disable-code"
                    autocomplete="one-time-code"
                    placeholder="000000 or XXXX-XXXX"
                    class="w-full bg-zinc-900 border border-zinc-800 rounded-lg px-4 py-3 text-zinc-100 font-mono tracking-widest focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all"
                  />
                </div>
                <button
                  type="button"
                  id="confirm-disable-2fa-btn"
                  class="px-5 py-2 bg-red-600 hover:bg-red-500 text-white font-bold rounded-lg text-sm transition-colors cursor-pointer disabled:opacity-50"
                >
                  Confirm
                </button>
                <button
                  type="button"
                  id="cancel-disable-2fa-btn"
                  class="px-5 py-2 bg-zinc-800 hover:bg-zinc-700 text-zinc-300 border border-zinc-700 rounded-lg text-sm transition-colors cursor-pointer"
                >
                  Cancel
                </button>
              </div>
              <p id="2fa-disable-error" class="hidden text-sm text-red-400"></p>
            </div>

            <!-- Backup codes -->
            <details class="group border border-zinc-800 rounded-2xl bg-zinc-900/20 overflow-hidden">
              <summary class="flex items-center justify-between px-6 py-4 cursor-pointer list-none select-none hover:bg-zinc-900/40 transition-colors">
                <span class="font-medium text-zinc-300">Backup Codes</span>
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 text-zinc-500 transition-transform group-open:rotate-180">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
                </svg>
              </summary>
              <div class="px-6 pb-6 space-y-4">
                <p class="text-sm text-zinc-500">Used codes are shown with strikethrough and cannot be reused. Keep these somewhere safe.</p>
                <div class="grid grid-cols-2 gap-2">
                  {backupCodes.map((bc) => (
                    <span class={`font-mono text-sm px-3 py-1.5 rounded-lg border ${bc.used ? "text-zinc-400 border-zinc-800 line-through" : "text-zinc-300 border-zinc-700 bg-zinc-900"}`}>
                      {bc.code}
                    </span>
                  ))}
                </div>
              </div>
            </details>
          </div>
        )}
      </section>

      <!-- Maintenance -->
      <section>
        <h2 class="text-xl font-semibold text-zinc-100 mb-4 border-b border-zinc-800 pb-2">Maintenance</h2>
        <div class="space-y-3 max-w-xl">
          <div class="flex items-center justify-between bg-zinc-900 border border-zinc-800 rounded-xl px-5 py-4">
            <div>
              <p class="text-sm font-medium text-zinc-200">Heal missing metadata</p>
              <p class="text-xs text-zinc-500 mt-0.5">Re-fetches posters and dates for collection items that are missing them due to TMDB errors during sync.</p>
            </div>
            <button
              id="heal-btn"
              type="button"
              disabled={!hasTmdbKey}
              title={!hasTmdbKey ? "TMDB API Key is required" : ""}
              class="ml-4 shrink-0 text-sm px-4 py-2 rounded-lg transition-colors cursor-pointer disabled:opacity-50 bg-blue-600/20 hover:bg-blue-600/30 text-blue-400 border border-blue-500/30"
            >
              Heal
            </button>
          </div>
        </div>
      </section>

      <!-- API Key -->
      <section>
        <h2 class="text-xl font-semibold text-zinc-100 mb-4 border-b border-zinc-800 pb-2">API Key</h2>
        <div class="space-y-4 max-w-xl">
          <p class="text-sm text-zinc-400">Use this key to authenticate requests to the Scrob API. Keep it secret — if it leaks, regenerate it immediately.</p>
          <div class="space-y-2">
            <label for="scrob_api_key" class="block text-sm font-medium text-zinc-400">Your API Key</label>
            <div class="flex gap-2">
              <div class="relative flex-1 group/field">
                <input
                  type="password"
                  id="scrob_api_key"
                  readonly
                  value={me.api_key}
                  class="w-full bg-zinc-900 border border-zinc-800 rounded-lg pl-4 pr-10 py-3 text-zinc-100 font-mono text-sm focus:outline-none cursor-default select-all"
                />
                <button
                  type="button"
                  class="password-toggle absolute right-2 top-1/2 -translate-y-1/2 text-zinc-500 hover:text-zinc-300 p-1 cursor-pointer transition-colors"
                  aria-label="Toggle key visibility"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 eye-icon">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.644C3.412 7.943 7.213 5 12 5c4.787 0 8.588 2.943 9.964 6.678.066.18.066.362 0 .544C20.588 16.057 16.787 19 12 19c-4.787 0-8.588-2.943-9.964-6.678z" />
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
