          <div class="flex items-start justify-between gap-6 p-4 bg-zinc-900/60 rounded-xl border border-zinc-800">
            <div>
              <p class="text-sm font-semibold text-zinc-100 mb-1">Blur explicit content</p>
              <p class="text-xs text-zinc-400">Blur posters flagged as adult content by TMDB. Click a blurred poster to reveal it.</p>
            </div>
            <label class="relative inline-flex items-center shrink-0 cursor-pointer mt-0.5">
              <input
                type="checkbox"
                name="blur_explicit"
                id="blur-explicit-toggle"
                class="sr-only peer"
                checked={settings.blur_explicit !== false}
              />
              <div class="w-11 h-6 bg-zinc-700 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-blue-500"></div>
            </label>
          </div>
          <div>
            <p class="text-sm text-zinc-400">Accent color</p>
            <div class="flex flex-wrap gap-3 mt-3" id="accent-swatches">
              {[
                { id: 'blue',   label: 'Blue',   color: '#3b82f6' },
                { id: 'purple', label: 'Purple', color: '#a855f7' },
                { id: 'pink',   label: 'Pink',   color: '#ec4899' },
                { id: 'red',    label: 'Red',    color: '#ef4444' },
                { id: 'green',  label: 'Green',  color: '#22c55e' },
                { id: 'yellow', label: 'Yellow', color: '#eab308' },
                { id: 'orange', label: 'Orange', color: '#f97316' },
              ].map(({ id, label, color }) => (
                <button
                  type="button"
                  data-accent-id={id}
                  class="accent-swatch flex items-center gap-2.5 px-5 py-3 rounded-xl border border-zinc-800 bg-zinc-900 hover:border-zinc-600 transition-all cursor-pointer text-sm text-zinc-400 hover:text-zinc-100"
                >
                  <span class="w-5 h-5 rounded-full shrink-0" style={`background-color: ${color}`}></span>
                  {label}
                </button>
              ))}
            </div>
          </div>
        </div>
      </section>

      <!-- Maintenance -->
      <section>
        <h2 class="text-xl font-semibold text-zinc-100 mb-4 border-b border-zinc-800 pb-2">Maintenance</h2>
        <div class="space-y-3 max-w-xl">
          <div class="flex items-center justify-between bg-zinc-900 border border-zinc-800 rounded-xl px-5 py-4">
            <div>
              <p class="text-sm font-medium text-zinc-200">Heal missing metadata</p>
              <p class="text-xs text-zinc-500 mt-0.5">Re-fetches posters and dates for collection items that are missing them due to TMDB errors during sync.</p>
            </div>
            <button
              id="heal-btn"
              type="button"
              disabled={!hasTmdbKey}
              title={!hasTmdbKey ? "TMDB API Key is required" : ""}
              class="ml-4 shrink-0 text-sm px-4 py-2 rounded-lg transition-colors cursor-pointer disabled:opacity-50 bg-blue-600/20 hover:bg-blue-600/30 text-blue-400 border border-blue-500/30"
            >
              Heal
            </button>
          </div>
        </div>
      </section>

      <!-- API Key -->
      <section>
        <h2 class="text-xl font-semibold text-zinc-100 mb-4 border-b border-zinc-800 pb-2">API Key</h2>
        <div class="space-y-4 max-w-xl">
          <p class="text-sm text-zinc-400">Use this key to authenticate requests to the Scrob API. Keep it secret — if it leaks, regenerate it immediately.</p>
          <div class="space-y-2">
            <label for="scrob_api_key" class="block text-sm font-medium text-zinc-400">Your API Key</label>
            <div class="flex gap-2">
              <div class="relative flex-1 group/field">
                <input
                  type="password"
                  id="scrob_api_key"
                  readonly
                  value={me.api_key}
                  class="w-full bg-zinc-900 border border-zinc-800 rounded-lg pl-4 pr-10 py-3 text-zinc-100 font-mono text-sm focus:outline-none cursor-default select-all"
                />
                <button
                  type="button"
                  class="password-toggle absolute right-2 top-1/2 -translate-y-1/2 text-zinc-500 hover:text-zinc-300 p-1 cursor-pointer transition-colors"
                  aria-label="Toggle key visibility"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 eye-icon">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.644C3.412 7.943 7.213 5 12 5c4.787 0 8.588 2.943 9.964 6.678.066.18.066.362 0 .544C20.588 16.057 16.787 19 12 19c-4.787 0-8.588-2.943-9.964-6.678z" />
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 eye-slash-icon hidden">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3.98 8.223A10.477 10.477 0 001.934 12C3.226 16.338 7.244 19.5 12 19.5c.993 0 1.953-.138 2.863-.395M6.228 6.228A10.45 10.45 0 0112 4.5c4.756 0 8.773 3.162 10.065 7.498a10.523 10.523 0 01-4.293 5.774M6.228 6.228L3 3m3.228 3.228l3.65 3.65m7.894 7.894L21 21m-3.228-3.228l-3.65-3.65m0 0a3 3 0 10-4.243-4.243m4.242 4.242L9.88 9.88" />
                  </svg>
                </button>
              </div>
              <button
                type="button"
                id="copy-api-key-btn"
                title="Copy to clipboard"
                class="px-3 py-2 bg-zinc-800 hover:bg-zinc-700 border border-zinc-700 text-zinc-300 rounded-lg transition-colors cursor-pointer"
              >
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15.666 3.888A2.25 2.25 0 0013.5 2.25h-3c-1.03 0-1.9.693-2.166 1.638m7.332 0c.055.194.084.4.084.612v0a.75.75 0 01-.75.75H9a.75.75 0 01-.75-.75v0c0-.212.03-.418.084-.612m7.332 0c.646.049 1.288.11 1.927.184 1.1.128 1.907 1.077 1.907 2.185V19.5a2.25 2.25 0 01-2.25 2.25H6.75A2.25 2.25 0 014.5 19.5V6.257c0-1.108.806-2.057 1.907-2.185a48.208 48.208 0 011.927-.184" />
                </svg>
              </button>
            </div>
          </div>
          <button
            type="button"
            id="regenerate-api-key-btn"
            class="px-4 py-2 bg-zinc-800 hover:bg-zinc-700 text-zinc-300 border border-zinc-700 rounded-lg text-sm transition-colors cursor-pointer disabled:opacity-50"
          >
            Regenerate Key
          </button>
        </div>
      </section>

      <!-- Security -->
      <section id="2fa-section">
        <h2 class="text-xl font-semibold text-zinc-100 mb-4 border-b border-zinc-800 pb-2">Security</h2>
        <h3 class="text-base font-semibold text-zinc-300 mb-3">Two-Factor Authentication</h3>

        {!me.totp_enabled ? (
          <div class="space-y-4">
            <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 bg-zinc-900/40 border border-zinc-800 rounded-2xl p-6">
              <div>
                <h3 class="font-semibold text-zinc-100 mb-1">Authenticator App</h3>
                <p class="text-sm text-zinc-400">Protect your account with a time-based one-time password (TOTP) from any authenticator app.</p>
              </div>
              <button
                type="button"
                id="enable-2fa-btn"
                class="w-full sm:w-auto sm:shrink-0 px-6 py-3 bg-zinc-100 text-zinc-950 font-bold rounded-xl hover:bg-zinc-200 transition-colors cursor-pointer text-sm"
              >
                Enable 2FA
              </button>
            </div>

            <!-- Setup panel (hidden until "Enable 2FA" is clicked) -->
            <div id="2fa-setup-panel" class="hidden border border-zinc-700 rounded-2xl p-6 space-y-5 bg-zinc-900/30">
              <div class="text-sm text-zinc-400">
                Scan the QR code with your authenticator app (Google Authenticator, Authy, etc.), then enter the 6-digit code to confirm.
              </div>

              <div class="flex flex-col md:flex-row gap-6 items-start">
                <div class="shrink-0">
                  <canvas id="totp-qr-canvas" class="rounded-lg bg-white p-2" width="160" height="160"></canvas>
                </div>
                <div class="space-y-3 flex-1">
                  <div>
                    <p class="text-xs text-zinc-500 mb-1">Manual entry key</p>
                    <code id="totp-secret-display" class="block bg-zinc-950 border border-zinc-800 rounded-lg px-3 py-2 text-zinc-300 font-mono text-sm tracking-widest break-all select-all"></code>
                  </div>
                  <div class="space-y-2">
                    <label for="totp-verify-code" class="block text-sm font-medium text-zinc-400">Verification Code</label>
                    <input
                      type="text"
                      id="totp-verify-code"
                      autocomplete="one-time-code"
                      inputmode="numeric"
                      maxlength="6"
                      placeholder="000000"
                      class="w-full bg-zinc-900 border border-zinc-800 rounded-lg px-4 py-3 text-zinc-100 font-mono tracking-widest focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all"
                    />
                  </div>
                  <div class="flex gap-3">
                    <button
                      type="button"
                      id="confirm-enable-2fa-btn"
                      class="px-5 py-2 bg-zinc-100 text-zinc-950 font-bold rounded-lg hover:bg-zinc-200 transition-colors cursor-pointer text-sm disabled:opacity-50"
                    >
                      Verify &amp; Enable
                    </button>
                    <button
                      type="button"
                      id="cancel-2fa-setup-btn"
                      class="px-5 py-2 bg-zinc-800 hover:bg-zinc-700 text-zinc-300 border border-zinc-700 rounded-lg text-sm transition-colors cursor-pointer"
                    >
                      Cancel
                    </button>
                  </div>
                  <p id="2fa-setup-error" class="hidden text-sm text-red-400"></p>
                </div>
              </div>
            </div>

            <!-- Backup codes shown after successful enable (hidden initially) -->
            <div id="2fa-new-codes-panel" class="hidden border border-green-500/30 bg-green-500/5 rounded-2xl p-6 space-y-4">
              <div class="flex items-center gap-2 text-green-400 font-semibold">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                2FA Enabled
              </div>
              <p class="text-sm text-zinc-400">Save these backup codes somewhere safe. Each can only be used once. They cannot be shown again — regenerate them in settings if needed.</p>
              <div id="2fa-new-codes-grid" class="grid grid-cols-2 gap-2"></div>
              <button
                type="button"
                id="2fa-new-codes-done-btn"
                class="px-5 py-2 bg-zinc-100 text-zinc-950 font-bold rounded-lg hover:bg-zinc-200 transition-colors cursor-pointer text-sm"
              >
                Done — reload page
              </button>
            </div>
          </div>
        ) : (
          <div class="space-y-4">
            <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 bg-zinc-900/40 border border-zinc-800 rounded-2xl p-6">
              <div class="flex items-center gap-3">
                <span class="w-2.5 h-2.5 rounded-full bg-green-500 shrink-0"></span>
                <div>
                  <h3 class="font-semibold text-zinc-100">2FA is enabled</h3>
                  <p class="text-sm text-zinc-400">Your account is protected with an authenticator app.</p>
                </div>
              </div>
              <button
                type="button"
                id="disable-2fa-btn"
                class="shrink-0 px-5 py-2 bg-red-600/10 hover:bg-red-600/20 text-red-400 border border-red-500/30 font-bold rounded-lg text-sm transition-colors cursor-pointer"
              >
                Disable 2FA
              </button>
            </div>

            <!-- Disable confirmation (hidden initially) -->
            <div id="2fa-disable-panel" class="hidden border border-zinc-700 rounded-2xl p-6 space-y-4 bg-zinc-900/30">
              <p class="text-sm text-zinc-400">Enter your authenticator code or a backup code to disable 2FA.</p>
              <div class="flex gap-3 items-end">
                <div class="space-y-2 flex-1">
                  <label for="totp-disable-code" class="block text-sm font-medium text-zinc-400">Code</label>
                  <input
                    type="text"
                    id="totp-disable-code"
                    autocomplete="one-time-code"
                    placeholder="000000 or XXXX-XXXX"
                    class="w-full bg-zinc-900 border border-zinc-800 rounded-lg px-4 py-3 text-zinc-100 font-mono tracking-widest focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all"
                  />
                </div>
                <button
                  type="button"
                  id="confirm-disable-2fa-btn"
                  class="px-5 py-2 bg-red-600 hover:bg-red-500 text-white font-bold rounded-lg text-sm transition-colors cursor-pointer disabled:opacity-50"
                >
                  Confirm
                </button>
                <button
                  type="button"
                  id="cancel-disable-2fa-btn"
                  class="px-5 py-2 bg-zinc-800 hover:bg-zinc-700 text-zinc-300 border border-zinc-700 rounded-lg text-sm transition-colors cursor-pointer"
                >
                  Cancel
                </button>
              </div>
              <p id="2fa-disable-error" class="hidden text-sm text-red-400"></p>
            </div>

            <!-- Backup codes -->
            <details class="group border border-zinc-800 rounded-2xl bg-zinc-900/20 overflow-hidden">
              <summary class="flex items-center justify-between px-6 py-4 cursor-pointer list-none select-none hover:bg-zinc-900/40 transition-colors">
                <span class="font-medium text-zinc-300">Backup Codes</span>
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 text-zinc-500 transition-transform group-open:rotate-180">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
                </svg>
              </summary>
              <div class="px-6 pb-6 space-y-4">
                <p class="text-sm text-zinc-500">Used codes are shown with strikethrough and cannot be reused. Keep these somewhere safe.</p>
                <div class="grid grid-cols-2 gap-2">
                  {backupCodes.map((bc) => (
                    <span class={`font-mono text-sm px-3 py-1.5 rounded-lg border ${bc.used ? "text-zinc-400 border-zinc-800 line-through" : "text-zinc-300 border-zinc-700 bg-zinc-900"}`}>
                      {bc.code}
                    </span>
                  ))}
                </div>
              </div>
            </details>
          </div>
        )}

        <h3 class="text-base font-semibold text-zinc-300 mt-8 mb-3">Change Password</h3>
        <form id="password-form" class="space-y-6 max-w-md">
          <div class="space-y-4">
            {me.has_password && <div class="space-y-2">
              <label for="current_password" class="block text-sm font-medium text-zinc-400">Current Password</label>
              <div class="relative group/field">
                <input
                  type="password"
                  name="current_password"
                  id="current_password"
                  required
                  class="w-full bg-zinc-900 border border-zinc-800 rounded-lg pl-4 pr-10 py-3 text-zinc-100 focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all"
                />
                <button
                  type="button"
                  class="password-toggle absolute right-2 top-1/2 -translate-y-1/2 text-zinc-500 hover:text-zinc-300 p-1 cursor-pointer transition-colors"
                  aria-label="Toggle password visibility"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 eye-icon"><path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.644C3.412 7.943 7.213 5 12 5c4.787 0 8.588 2.943 9.964 6.678.066.18.066.362 0 .544C20.588 16.057 16.787 19 12 19c-4.787 0-8.588-2.943-9.964-6.678z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 eye-slash-icon hidden"><path stroke-linecap="round" stroke-linejoin="round" d="M3.98 8.223A10.477 10.477 0 001.934 12C3.226 16.338 7.244 19.5 12 19.5c.993 0 1.953-.138 2.863-.395M6.228 6.228A10.45 10.45 0 0112 4.5c4.756 0 8.773 3.162 10.065 7.498a10.523 10.523 0 01-4.293 5.774M6.228 6.228L3 3m3.228 3.228l3.65 3.65m7.894 7.894L21 21m-3.228-3.228l-3.65-3.65m0 0a3 3 0 10-4.243-4.243m4.242 4.242L9.88 9.88" /></svg>
                </button>
              </div>
            </div>}
            <div class="space-y-2">
              <label for="new_password" class="block text-sm font-medium text-zinc-400">New Password</label>
              <div class="relative group/field">
                <input
                  type="password"
                  name="new_password"
                  id="new_password"
                  required
                  class="w-full bg-zinc-900 border border-zinc-800 rounded-lg pl-4 pr-10 py-3 text-zinc-100 focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all"
                />
                <button
                  type="button"
                  class="password-toggle absolute right-2 top-1/2 -translate-y-1/2 text-zinc-500 hover:text-zinc-300 p-1 cursor-pointer transition-colors"
                  aria-label="Toggle password visibility"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 eye-icon"><path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.644C3.412 7.943 7.213 5 12 5c4.787 0 8.588 2.943 9.964 6.678.066.18.066.362 0 .544C20.588 16.057 16.787 19 12 19c-4.787 0-8.588-2.943-9.964-6.678z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 eye-slash-icon hidden"><path stroke-linecap="round" stroke-linejoin="round" d="M3.98 8.223A10.477 10.477 0 001.934 12C3.226 16.338 7.244 19.5 12 19.5c.993 0 1.953-.138 2.863-.395M6.228 6.228A10.45 10.45 0 0112 4.5c4.756 0 8.773 3.162 10.065 7.498a10.523 10.523 0 01-4.293 5.774M6.228 6.228L3 3m3.228 3.228l3.65 3.65m7.894 7.894L21 21m-3.228-3.228l-3.65-3.65m0 0a3 3 0 10-4.243-4.243m4.242 4.242L9.88 9.88" /></svg>
                </button>
              </div>
            </div>
            <div class="space-y-2">
              <label for="confirm_password" class="block text-sm font-medium text-zinc-400">Confirm New Password</label>
              <div class="relative group/field">
                <input
                  type="password"
                  name="confirm_password"
                  id="confirm_password"
                  required
                  class="w-full bg-zinc-900 border border-zinc-800 rounded-lg pl-4 pr-10 py-3 text-zinc-100 focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all"
                />
                <button
                  type="button"
                  class="password-toggle absolute right-2 top-1/2 -translate-y-1/2 text-zinc-500 hover:text-zinc-300 p-1 cursor-pointer transition-colors"
                  aria-label="Toggle password visibility"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 eye-icon"><path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.644C3.412 7.943 7.213 5 12 5c4.787 0 8.588 2.943 9.964 6.678.066.18.066.362 0 .544C20.588 16.057 16.787 19 12 19c-4.787 0-8.588-2.943-9.964-6.678z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 eye-slash-icon hidden"><path stroke-linecap="round" stroke-linejoin="round" d="M3.98 8.223A10.477 10.477 0 001.934 12C3.226 16.338 7.244 19.5 12 19.5c.993 0 1.953-.138 2.863-.395M6.228 6.228A10.45 10.45 0 0112 4.5c4.756 0 8.773 3.162 10.065 7.498a10.523 10.523 0 01-4.293 5.774M6.228 6.228L3 3m3.228 3.228l3.65 3.65m7.894 7.894L21 21m-3.228-3.228l-3.65-3.65m0 0a3 3 0 10-4.243-4.243m4.242 4.242L9.88 9.88" /></svg>
                </button>
              </div>
            </div>
          </div>
          <div class="pt-2">
            <button
              id="update-password-btn"
              type="submit"
              class="bg-zinc-800 text-zinc-100 font-bold px-8 py-2 rounded-lg hover:bg-zinc-700 transition-colors cursor-pointer border border-zinc-700 disabled:opacity-50"
            >
              Update Password
            </button>
          </div>
        </form>
      </section>

      <!-- Data Management -->
      <section>
        <h2 class="text-xl font-semibold text-zinc-100 mb-4 border-b border-zinc-800 pb-2">Data Management</h2>
        <div class="bg-zinc-900/40 border border-zinc-800 rounded-2xl p-6 flex flex-col md:flex-row items-center justify-between gap-6">
          <div>
            <h3 class="text-lg font-bold text-zinc-100 mb-1">Clear Watch History</h3>
            <p class="text-zinc-400 text-sm">This will permanently delete all your watch history and progress. Your collection and ratings will not be affected.</p>
          </div>
          <button
            type="button"
            id="clear-history-btn"
            class="px-6 py-3 bg-red-600/10 hover:bg-red-600/20 text-red-500 border border-red-500/30 font-bold rounded-xl transition-all cursor-pointer whitespace-nowrap"
          >
            Clear History
          </button>
        </div>
      </section>

      <!-- Danger Zone -->
      <section>
        <h2 class="text-xl font-semibold text-red-500 mb-4 border-b border-red-500/20 pb-2">Danger Zone</h2>
        <div class="bg-red-500/5 border border-red-500/10 rounded-2xl p-6 flex flex-col md:flex-row items-center justify-between gap-6">
          <div>
            <h3 class="text-lg font-bold text-zinc-100 mb-1">Delete Account</h3>
            <p class="text-zinc-400 text-sm">Once you delete your account, there is no going back. All your data will be permanently removed.</p>
          </div>
          <button
            type="button"
            id="delete-account-btn"
            class="px-6 py-3 bg-red-600 hover:bg-red-500 text-zinc-100 font-bold rounded-xl transition-all shadow-lg shadow-red-600/20 active:scale-95 whitespace-nowrap cursor-pointer"
          >
            Delete Account
          </button>
        </div>
      </section>
    </div>
  </div>

  <!-- Delete Confirmation Modal -->
  <div id="heal-modal" class="fixed inset-0 bg-zinc-950/80 backdrop-blur-sm z-[100] hidden items-center justify-center p-4">
    <div class="bg-zinc-900 border border-zinc-800 rounded-3xl p-8 max-w-md w-full shadow-2xl">
      <h2 class="text-2xl font-bold text-zinc-100 mb-2">Heal missing metadata?</h2>
      <p class="text-zinc-400 mb-8 text-sm leading-relaxed">
        This will re-fetch posters and dates for collection items that are missing them. It runs in the background and may take a few minutes.
      </p>
      <div class="flex gap-3">
        <button type="button" id="cancel-heal" class="flex-1 px-6 py-3 bg-zinc-800 hover:bg-zinc-700 text-zinc-100 font-bold rounded-xl transition-all cursor-pointer">
          Cancel
        </button>
        <button type="button" id="confirm-heal" class="flex-1 px-6 py-3 bg-blue-600 hover:bg-blue-500 text-zinc-100 font-bold rounded-xl transition-all cursor-pointer">
          Heal
        </button>
      </div>
    </div>
  </div>

  <div id="delete-modal" class="fixed inset-0 bg-zinc-950/80 backdrop-blur-sm z-[100] hidden items-center justify-center p-4">
    <div class="bg-zinc-900 border border-zinc-800 rounded-3xl p-8 max-w-md w-full shadow-2xl">
      <h2 class="text-2xl font-bold text-zinc-100 mb-2">Are you sure?</h2>
      <p class="text-zinc-400 mb-8 text-sm leading-relaxed">
        This will permanently delete your account and remove all your data. This action cannot be undone.
      </p>
      <div class="flex gap-3">
        <button type="button" id="cancel-delete" class="flex-1 px-6 py-3 bg-zinc-800 hover:bg-zinc-700 text-zinc-100 font-bold rounded-xl transition-all cursor-pointer">
          Cancel
        </button>
        <button type="button" id="confirm-delete" class="flex-1 px-6 py-3 bg-red-600 hover:bg-red-500 text-zinc-100 font-bold rounded-xl transition-all cursor-pointer">
          Yes, delete
        </button>
      </div>
    </div>
  </div>
</section>

<script>
  const appData = document.getElementById('app-data');
  const token = appData?.dataset.token ?? '';

  function esc(s) {
    if (s == null) return '';
    return String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  }

  function showMessage(text, type = 'success') {
    const msg = document.getElementById('js-message');
    if (!msg) return;
    msg.textContent = text;
    msg.className = `p-4 rounded-lg mb-8 ${
      type === 'success' 
        ? 'bg-green-500/10 border border-green-500 text-green-500' 
        : 'bg-red-500/10 border border-red-500 text-red-500'
    }`;
    msg.classList.remove('hidden');
    window.scrollTo({ top: 0, behavior: 'smooth' });
    
    // Always hide after 4 seconds
    if (window._messageTimeout) clearTimeout(window._messageTimeout);
    window._messageTimeout = setTimeout(() => msg.classList.add('hidden'), 4000);
  }

  function setConnStatus(id, state) {
    const el = document.getElementById(id);
    if (!el) return;
    el.classList.remove('hidden');
    if (state === 'checking') {
      el.textContent = 'Checking…';
      el.className = 'text-xs font-normal px-1.5 py-0.5 rounded bg-zinc-700 text-zinc-400';
    } else if (state === 'connected') {
      el.textContent = '● Connected';
      el.className = 'text-xs font-normal px-1.5 py-0.5 rounded bg-green-500/15 text-green-400';
    } else if (state === 'disconnected') {
      el.textContent = '● Disconnected';
      el.className = 'text-xs font-normal px-1.5 py-0.5 rounded bg-red-500/15 text-red-400';
    }
  }

  function populateSelect(selectId, options, currentValue) {
    const sel = document.getElementById(selectId);
    if (!sel) return;
    sel.innerHTML = '<option value="">-- Select --</option>' + options.map(o => {
      const val = String(o.value ?? o.path ?? o.id ?? '');
      const label = o.label ?? o.name ?? o.path ?? val;
      const selected = val === String(currentValue ?? '') ? 'selected' : '';
      return `<option value="${esc(val)}" ${selected}>${esc(label)}</option>`;
    }).join('');
  }

  async function checkConnections() {
    if (!token) return;
    const traktConnected = !!document.getElementById('trakt-disconnect-btn');
    const radarrConfigured = !!document.getElementById('radarr_url')?.value;
    const sonarrConfigured = !!document.getElementById('sonarr_url')?.value;
    const mediaServerIds = Array.from(document.querySelectorAll<HTMLElement>('[data-connection-id]'))
      .map(el => el.getAttribute('data-connection-id'))
      .filter(Boolean) as string[];
    if (!radarrConfigured && !sonarrConfigured && !traktConnected && mediaServerIds.length === 0) return;

    if (radarrConfigured) setConnStatus('radarr-conn-status', 'checking');
    if (sonarrConfigured) setConnStatus('sonarr-conn-status', 'checking');
    if (traktConnected) setConnStatus('trakt-conn-status', 'checking');
    for (const id of mediaServerIds) setConnStatus(`conn-status-${id}`, 'checking');

    try {
      const res = await fetch('/api/proxy/auth/connection-status', {
        headers: { 'Authorization': `Bearer ${token}` }
      });
      if (!res.ok) return;
      const data = await res.json();

      if (data.radarr?.configured) {
        setConnStatus('radarr-conn-status', data.radarr.connected ? 'connected' : 'disconnected');
        if (data.radarr.connected) {
          const currentFolder = document.getElementById('radarr_root_folder')?.value;
          const currentProfile = document.getElementById('radarr_quality_profile')?.value;
          populateSelect('radarr_root_folder', (data.radarr.root_folders ?? []).map(f => ({
            value: f.path,
            label: `${f.path} (${(f.freeSpace / 1024 ** 3).toFixed(1)} GB free)`
          })), currentFolder);
          populateSelect('radarr_quality_profile', data.radarr.quality_profiles ?? [], currentProfile);
          const tagContainer = document.getElementById('radarr_tags_list');
          const selectedTags = Array.from(tagContainer?.querySelectorAll('input[name="radarr_tags"]') ?? []).map(i => parseInt(i.value));
          renderTags('radarr_tags_list', data.radarr.tags, selectedTags, 'radarr');
        }
      }
      if (data.sonarr?.configured) {
        setConnStatus('sonarr-conn-status', data.sonarr.connected ? 'connected' : 'disconnected');
        if (data.sonarr.connected) {
          const currentFolder = document.getElementById('sonarr_root_folder')?.value;
          const currentProfile = document.getElementById('sonarr_quality_profile')?.value;
          populateSelect('sonarr_root_folder', (data.sonarr.root_folders ?? []).map(f => ({
            value: f.path,
            label: `${f.path} (${(f.freeSpace / 1024 ** 3).toFixed(1)} GB free)`
          })), currentFolder);
          populateSelect('sonarr_quality_profile', data.sonarr.quality_profiles ?? [], currentProfile);
          const tagContainer = document.getElementById('sonarr_tags_list');
          const selectedTags = Array.from(tagContainer?.querySelectorAll('input[name="sonarr_tags"]') ?? []).map(i => parseInt(i.value));
          renderTags('sonarr_tags_list', data.sonarr.tags, selectedTags, 'sonarr');
        }
      }
      if (data.trakt?.configured) {
        setConnStatus('trakt-conn-status', data.trakt.connected ? 'connected' : 'disconnected');
      }
      for (const cs of (data.connections ?? [])) {
        setConnStatus(`conn-status-${cs.id}`, cs.connected ? 'connected' : 'disconnected');
        if (cs.connected) loadLibraries(String(cs.id));
      }
    } catch {
      // Non-fatal — status badges stay hidden
    }
  }


  async function loadLibraries(connId: string) {
    const card = document.querySelector(`[data-connection-id="${connId}"]`);
    const picker = card?.querySelector('.conn-library-picker');
    const connType = picker?.getAttribute('data-conn-type') ?? '';
    const listEl = card?.querySelector('.conn-libraries-list') as HTMLElement | null;
    if (!listEl) return;
    listEl.textContent = 'Loading…';
    listEl.classList.add('italic', 'text-zinc-500');
    try {
      const res = await fetch(`/api/proxy/sync/connection/${connId}/libraries`, {
        headers: { 'Authorization': `Bearer ${token}` }
      });
      if (res.ok) {
        const data = await res.json();
        const idKey = connType === 'plex' ? 'key' : 'id';
        listEl.classList.remove('italic', 'text-zinc-500');
        if (!data.libraries?.length) {
          listEl.innerHTML = '<span class="not-italic text-zinc-500 text-sm">No supported libraries found.</span>';
          return;
        }
        listEl.innerHTML = data.libraries.map((lib: any) => `
          <label class="flex items-center gap-2 cursor-pointer group px-2 py-1.5 rounded-lg border border-transparent hover:bg-zinc-800/50 transition-colors">
            <input type="checkbox" class="library-checkbox w-4 h-4 rounded accent-blue-500 cursor-pointer" data-id="${esc(String(lib[idKey]))}" ${lib.selected ? 'checked' : ''} />
            <span class="text-zinc-300 group-hover:text-zinc-100 transition-colors not-italic">
              ${esc(lib.name)}
              <span class="text-zinc-400 text-xs ml-1">${lib.type === 'movies' || lib.type === 'movie' ? 'Movies' : 'Shows'}</span>
            </span>
          </label>
        `).join('');
        listEl.querySelectorAll('label').forEach(label => {
          const cb = label.querySelector('input') as HTMLInputElement;
          const updateStyle = () => {
            label.classList.toggle('bg-blue-500/10', cb.checked);
            label.classList.toggle('border-blue-500/30', cb.checked);
            label.classList.toggle('hover:bg-zinc-800/50', !cb.checked);
            label.classList.toggle('border-transparent', !cb.checked);
          };
          cb.addEventListener('change', updateStyle);
          updateStyle();
        });
      } else {
        listEl.classList.remove('italic');
        listEl.textContent = 'Could not load libraries.';
      }
    } catch {
      listEl.classList.remove('italic');
      listEl.textContent = 'Could not reach server.';
    }
  }

  function renderTags(containerId, tags, selectedIds, prefix) {
    const container = document.getElementById(containerId);
    if (!container) return;
    
    if (!tags || tags.length === 0) {
      container.innerHTML = '<span class="text-xs text-zinc-500 italic px-2 py-1">No tags found</span>';
      return;
    }

    container.innerHTML = tags.map(tag => {
      const isSelected = selectedIds.includes(tag.id);
      return `
        <label class="group relative flex items-center gap-1.5 px-2 py-1 bg-zinc-800 hover:bg-zinc-700 border border-zinc-700 rounded-md cursor-pointer transition-colors ${isSelected ? 'ring-1 ring-blue-500 border-blue-500/50 bg-blue-500/10' : ''}">
          <input type="checkbox" name="${prefix}_tags" value="${esc(String(tag.id))}" ${isSelected ? 'checked' : ''} class="hidden tag-checkbox" />
          <span class="text-xs font-medium text-zinc-300 group-hover:text-zinc-100">${esc(tag.label)}</span>
        </label>
      `;
    }).join('');

    // Add click listeners to update styling
    container.querySelectorAll('label').forEach(label => {
      const cb = label.querySelector('input');
      cb.addEventListener('change', () => {
        if (cb.checked) {
          label.classList.add('ring-1', 'ring-blue-500', 'border-blue-500/50', 'bg-blue-500/10');
        } else {
          label.classList.remove('ring-1', 'ring-blue-500', 'border-blue-500/50', 'bg-blue-500/10');
        }
      });
    });
  }

  function setupActions() {
    const btns = document.querySelectorAll('.js-action-btn');
    btns.forEach(btn => {
      // Clean up previous listeners if any (important for Astro View Transitions)
      const newBtn = btn.cloneNode(true);
      if (btn.parentNode) {
        btn.parentNode.replaceChild(newBtn, btn);
      }
      
      newBtn.addEventListener('click', async () => {
        const action = newBtn.getAttribute('data-action');
        newBtn.disabled = true;
        const originalText = newBtn.textContent;
        newBtn.textContent = '...';

        try {
          let url = '';
          let method = 'POST';

          if (action === 'test_tmdb') {
            const val = document.getElementById('tmdb_api_key').value;
            url = `/api/proxy/auth/test-tmdb?key=${encodeURIComponent(val)}`;
          } else if (action === 'test_connection') {
            const connId = newBtn.getAttribute('data-conn-id');
            const connType = newBtn.getAttribute('data-conn-type');
            const card = document.querySelector(`[data-connection-id="${connId}"]`);
            const u = (card?.querySelector('.conn-url-input') as HTMLInputElement)?.value || '';
            const t = (card?.querySelector('.conn-token-input') as HTMLInputElement)?.value || '';
            const ui = (card?.querySelector('.conn-user-id-input') as HTMLInputElement)?.value || '';
            let testEndpoint: string;
            if (connType === 'plex') {
              testEndpoint = `/api/proxy/auth/test-plex?url=${encodeURIComponent(u)}&token=${encodeURIComponent(t)}`;
            } else if (connType === 'emby') {
              testEndpoint = `/api/proxy/auth/test-emby?url=${encodeURIComponent(u)}&token=${encodeURIComponent(t)}&user_id=${encodeURIComponent(ui)}`;
            } else {
              testEndpoint = `/api/proxy/auth/test-jellyfin?url=${encodeURIComponent(u)}&token=${encodeURIComponent(t)}&user_id=${encodeURIComponent(ui)}`;
            }
            const testRes = await fetch(testEndpoint, { method: 'POST', headers: { 'Authorization': `Bearer ${token}` } });
            const testData = await testRes.json();
            if (testRes.ok) {
              showMessage(testData.message || 'Connection successful!');
              if (connId) setConnStatus(`conn-status-${connId}`, 'connected');
            } else {
              if (connId) setConnStatus(`conn-status-${connId}`, 'disconnected');
              throw new Error(testData.detail || 'Connection test failed');
            }
            return;
          } else if (action === 'save_connection') {
            const connId = newBtn.getAttribute('data-conn-id');
            const card = document.querySelector(`[data-connection-id="${connId}"]`);
            const body: Record<string, any> = {
              url: (card?.querySelector('.conn-url-input') as HTMLInputElement)?.value || undefined,
              token: (card?.querySelector('.conn-token-input') as HTMLInputElement)?.value || undefined,
              server_user_id: (card?.querySelector('.conn-user-id-input') as HTMLInputElement)?.value || null,
              server_username: (card?.querySelector('.conn-username-input') as HTMLInputElement)?.value || null,
              auto_sync_interval: (() => {
                const v = (card?.querySelector('.conn-auto-sync') as HTMLSelectElement)?.value;
                return v ? parseInt(v) : null;
              })(),
            };
            card?.querySelectorAll('.conn-pref-checkbox').forEach((cb: any) => {
              body[cb.getAttribute('data-pref')] = cb.checked;
            });
            const saveRes = await fetch(`/api/proxy/auth/connections/${connId}`, {
              method: 'PATCH',
              headers: { 'Authorization': `Bearer ${token}`, 'Content-Type': 'application/json' },
              body: JSON.stringify(body),
            });
            if (!saveRes.ok) {
              const err = await saveRes.json();
              throw new Error(err.detail || 'Failed to save connection');
            }
            // Save libraries if they've been loaded
            const libList = card?.querySelector('.conn-libraries-list');
            if (libList && libList.querySelector('.library-checkbox')) {
              const picker = card?.querySelector('.conn-library-picker');
              const pickerType = picker?.getAttribute('data-conn-type');
              const ids = [...libList.querySelectorAll('.library-checkbox:checked')].map((cb: any) => cb.getAttribute('data-id'));
              const libPayload = pickerType === 'plex' ? { library_keys: ids } : { library_ids: ids };
              await fetch(`/api/proxy/sync/connection/${connId}/libraries`, {
                method: 'PUT',
                headers: { 'Authorization': `Bearer ${token}`, 'Content-Type': 'application/json' },
                body: JSON.stringify(libPayload),
              });
            }
            showMessage('Connection saved!');
            return;
          } else if (action === 'delete_connection') {
            const connId = newBtn.getAttribute('data-conn-id');
            const connName = newBtn.getAttribute('data-conn-name');
            if (!confirm(`Delete connection "${connName}"? This cannot be undone.`)) return;
            const delRes = await fetch(`/api/proxy/auth/connections/${connId}`, {
              method: 'DELETE',
              headers: { 'Authorization': `Bearer ${token}` },
            });
            if (!delRes.ok) {
              const err = await delRes.json();
              throw new Error(err.detail || 'Failed to delete connection');
            }
            document.querySelector(`[data-connection-id="${connId}"]`)?.remove();
            showMessage('Connection deleted.');
            return;
          } else if (action === 'sync_connection') {
            const connId = newBtn.getAttribute('data-conn-id');
            url = `/api/proxy/sync/connection/${connId}`;
          } else if (action === 'test_radarr') {
            const u = document.getElementById('radarr_url').value;
            const t = document.getElementById('radarr_token').value;
            setConnStatus('radarr-conn-status', 'checking');
            // First test connection
            const testRes = await fetch(`/api/proxy/auth/test-radarr?url=${encodeURIComponent(u)}&token=${encodeURIComponent(t)}`, {
              method: 'POST',
              headers: { 'Authorization': `Bearer ${token}` }
            });
            if (!testRes.ok) {
              setConnStatus('radarr-conn-status', 'disconnected');
              throw new Error((await testRes.json()).detail || 'Failed to connect to Radarr');
            }
            
            // Then fetch profiles
            const profRes = await fetch(`/api/proxy/auth/radarr/profiles?url=${encodeURIComponent(u)}&token=${encodeURIComponent(t)}`, {
              headers: { 'Authorization': `Bearer ${token}` }
            });
            const profData = await profRes.json();
            
            // Populate selects
            const rootSelect = document.getElementById('radarr_root_folder');
            const qualSelect = document.getElementById('radarr_quality_profile');
            if (rootSelect) {
              const current = rootSelect.value;
              rootSelect.innerHTML = '<option value="">-- Select Folder --</option>' + 
                profData.root_folders.map(f => `<option value="${esc(f.path)}" ${f.path === current ? 'selected' : ''}>${esc(f.path)} (${(f.freeSpace / 1024**3).toFixed(1)}GB free)</option>`).join('');
            }
            if (qualSelect) {
              const current = qualSelect.value;
              qualSelect.innerHTML = '<option value="">-- Select Profile --</option>' + 
                profData.quality_profiles.map(p => `<option value="${esc(String(p.id))}" ${String(p.id) === current ? 'selected' : ''}>${esc(p.name)}</option>`).join('');
            }
            
            // Populate tags
            const tagContainer = document.getElementById('radarr_tags_list');
            const selectedTags = Array.from(tagContainer.querySelectorAll('input[name="radarr_tags"]')).map(i => parseInt(i.value));
            renderTags('radarr_tags_list', profData.tags, selectedTags, 'radarr');

            setConnStatus('radarr-conn-status', 'connected');
            showMessage('Radarr connection successful and profiles fetched!');
            return;
          } else if (action === 'test_sonarr') {
            const u = document.getElementById('sonarr_url').value;
            const t = document.getElementById('sonarr_token').value;
            setConnStatus('sonarr-conn-status', 'checking');
            // First test connection
            const testRes = await fetch(`/api/proxy/auth/test-sonarr?url=${encodeURIComponent(u)}&token=${encodeURIComponent(t)}`, {
              method: 'POST',
              headers: { 'Authorization': `Bearer ${token}` }
            });
            if (!testRes.ok) {
              setConnStatus('sonarr-conn-status', 'disconnected');
              throw new Error((await testRes.json()).detail || 'Failed to connect to Sonarr');
            }
            
            // Then fetch profiles
            const profRes = await fetch(`/api/proxy/auth/sonarr/profiles?url=${encodeURIComponent(u)}&token=${encodeURIComponent(t)}`, {
              headers: { 'Authorization': `Bearer ${token}` }
            });
            const profData = await profRes.json();
            
            // Populate selects
            const rootSelect = document.getElementById('sonarr_root_folder');
            const qualSelect = document.getElementById('sonarr_quality_profile');
            if (rootSelect) {
              const current = rootSelect.value;
              rootSelect.innerHTML = '<option value="">-- Select Folder --</option>' + 
                profData.root_folders.map(f => `<option value="${esc(f.path)}" ${f.path === current ? 'selected' : ''}>${esc(f.path)} (${(f.freeSpace / 1024**3).toFixed(1)}GB free)</option>`).join('');
            }
            if (qualSelect) {
              const current = qualSelect.value;
              qualSelect.innerHTML = '<option value="">-- Select Profile --</option>' + 
                profData.quality_profiles.map(p => `<option value="${esc(String(p.id))}" ${String(p.id) === current ? 'selected' : ''}>${esc(p.name)}</option>`).join('');
            }

            // Populate tags
            const tagContainer = document.getElementById('sonarr_tags_list');
            const selectedTags = Array.from(tagContainer.querySelectorAll('input[name="sonarr_tags"]')).map(i => parseInt(i.value));
            renderTags('sonarr_tags_list', profData.tags, selectedTags, 'sonarr');

            setConnStatus('sonarr-conn-status', 'connected');
            showMessage('Sonarr connection successful and profiles fetched!');
            return;
          } else if (action === 'sync_trakt') {
            url = `/api/proxy/trakt/sync`;
          }

          const res = await fetch(url, {
            method,
            headers: { 'Authorization': `Bearer ${token}` }
          });
          const data = await res.json();

          if (res.ok) {
            showMessage(data.message || 'Action successful!');
          } else {
            throw new Error(data.detail || 'Action failed');
          }
        } catch (e) {
          showMessage(e.message, 'error');
        } finally {
          newBtn.disabled = false;
          newBtn.textContent = originalText;
        }
      });
    });

    // Trakt Device Auth
    function setupTraktAuth() {
      const connectBtn = document.getElementById('trakt-connect-btn');
      const disconnectBtn = document.getElementById('trakt-disconnect-btn');

      if (connectBtn) {
        connectBtn.onclick = async () => {
          connectBtn.disabled = true;
          connectBtn.textContent = 'Starting…';
          try {
            // If credentials aren't saved yet, save them from the input fields first
            const clientIdInput = document.getElementById('trakt_client_id') as HTMLInputElement | null;
            const clientSecretInput = document.getElementById('trakt_client_secret') as HTMLInputElement | null;
            const clientId = clientIdInput?.value.trim() || '';
            const clientSecret = clientSecretInput?.value.trim() || '';
            if (clientId && clientSecret) {
              const saveRes = await fetch('/api/proxy/auth/settings', {
                method: 'PATCH',
                headers: { 'Authorization': `Bearer ${token}`, 'Content-Type': 'application/json' },
                body: JSON.stringify({ trakt_client_id: clientId, trakt_client_secret: clientSecret }),
              });
              if (!saveRes.ok) {
                const err = await saveRes.json();
                throw new Error(err.detail || 'Failed to save Trakt credentials');
              }
            }

            const res = await fetch('/api/proxy/trakt/auth/device/start', {
              method: 'POST',
              headers: { 'Authorization': `Bearer ${token}` },
            });
            if (!res.ok) {
              const err = await res.json();
              throw new Error(err.detail || 'Failed to start Trakt auth');
            }
            const data = await res.json();

            const panel = document.getElementById('trakt-auth-panel');
            const urlEl = document.getElementById('trakt-verify-url');
            const codeEl = document.getElementById('trakt-user-code');
            const statusEl = document.getElementById('trakt-auth-status');
            if (panel) panel.classList.remove('hidden');
            if (urlEl) urlEl.textContent = data.verification_url;
            if (codeEl) codeEl.textContent = data.user_code;
            connectBtn.textContent = 'Waiting…';

            // Poll for token
            const interval = (data.interval || 5) * 1000;
            const deadline = Date.now() + data.expires_in * 1000;
            const poll = async () => {
              if (Date.now() > deadline) {
                if (statusEl) statusEl.textContent = 'Authorization timed out. Please try again.';
                connectBtn.disabled = false;
                connectBtn.textContent = 'Connect Trakt';
                return;
              }
              try {
                const pollRes = await fetch('/api/proxy/trakt/auth/device/poll', {
                  method: 'POST',
                  headers: { 'Authorization': `Bearer ${token}` },
                });
                if (pollRes.ok) {
                  const pollData = await pollRes.json();
                  if (pollData.status === 'connected') {
                    if (statusEl) statusEl.textContent = 'Connected! Reloading…';
                    window.location.reload();
                    return;
                  }
                } else {
                  const err = await pollRes.json();
                  if (statusEl) statusEl.textContent = `Error: ${err.detail || 'Authorization failed'}`;
                  connectBtn.disabled = false;
                  connectBtn.textContent = 'Connect Trakt';
                  return;
                }
              } catch (e) {}
              setTimeout(poll, interval);
            };
            setTimeout(poll, interval);
          } catch (e) {
            showMessage(e.message, 'error');
            connectBtn.disabled = false;
            connectBtn.textContent = 'Connect Trakt';
          }
        };
      }

      if (disconnectBtn) {
        disconnectBtn.onclick = async () => {
          if (!confirm('Disconnect Trakt? This will remove your Trakt tokens from Scrob.')) return;
          disconnectBtn.disabled = true;
          disconnectBtn.textContent = 'Disconnecting…';
          try {
            await fetch('/api/proxy/trakt/auth/disconnect', {
              method: 'DELETE',
              headers: { 'Authorization': `Bearer ${token}` },
            });
            window.location.reload();
          } catch (e) {
            showMessage('Failed to disconnect Trakt', 'error');
            disconnectBtn.disabled = false;
            disconnectBtn.textContent = 'Disconnect';
          }
        };
      }
    }
    setupTraktAuth();

    // Delete Account Logic
    const deleteBtn = document.getElementById('delete-account-btn');
    const modal = document.getElementById('delete-modal');
    const cancelBtn = document.getElementById('cancel-delete');
    const confirmBtn = document.getElementById('confirm-delete');
    const clearHistoryBtn = document.getElementById('clear-history-btn');

    if (clearHistoryBtn) {
      clearHistoryBtn.onclick = async () => {
        if (!confirm('Are you sure you want to clear your entire watch history? This cannot be undone.')) return;
        
        clearHistoryBtn.disabled = true;
        clearHistoryBtn.textContent = 'Clearing...';
        
        try {
          const res = await fetch(`/api/proxy/history`, {
            method: 'DELETE',
            headers: { 'Authorization': `Bearer ${token}` }
          });
          if (res.ok) {
            showMessage('Watch history cleared successfully!');
          } else {
            const data = await res.json();
            throw new Error(data.detail || 'Failed to clear history');
          }
        } catch (e) {
          showMessage(e.message, 'error');
        } finally {
          clearHistoryBtn.disabled = false;
          clearHistoryBtn.textContent = 'Clear History';
        }
      };
    }

    if (deleteBtn && modal && cancelBtn && confirmBtn) {
      deleteBtn.onclick = () => {
        modal.classList.remove('hidden');
        modal.classList.add('flex');
      };

      cancelBtn.onclick = () => {
        modal.classList.add('hidden');
        modal.classList.remove('flex');
      };

      confirmBtn.onclick = async () => {
        confirmBtn.disabled = true;
        confirmBtn.textContent = 'Deleting...';
        try {
          const res = await fetch(`/api/proxy/auth/me`, {
            method: 'DELETE',
            headers: { 'Authorization': `Bearer ${token}` }
          });
          if (res.ok) {
            window.location.href = '/logout';
          } else {
            const data = await res.json();
            throw new Error(data.detail || 'Failed to delete account');
          }
        } catch (e) {
          showMessage(e.message, 'error');
          modal.classList.add('hidden');
          modal.classList.remove('flex');
          confirmBtn.disabled = false;
          confirmBtn.textContent = 'Yes, delete';
        }
      };
    }
  }

  function setupPasswordToggles() {
    const toggles = document.querySelectorAll('.password-toggle');
    toggles.forEach(toggle => {
      toggle.addEventListener('click', () => {
        const input = toggle.parentElement?.querySelector('input');
        if (!input) return;

        const isPassword = input.type === 'password';
        input.type = isPassword ? 'text' : 'password';

        const eyeIcon = toggle.querySelector('.eye-icon');
        const eyeSlashIcon = toggle.querySelector('.eye-slash-icon');

        if (isPassword) {
          eyeIcon?.classList.add('hidden');
          eyeSlashIcon?.classList.remove('hidden');
        } else {
          eyeIcon?.classList.remove('hidden');
          eyeSlashIcon?.classList.add('hidden');
        }
      });
    });
  }

  function setupAccentSwatches() {
    const saved = localStorage.getItem('accentTheme') || 'blue';

    function applyAccent(id) {
      if (id === 'blue') {
        document.documentElement.removeAttribute('data-accent');
      } else {
        document.documentElement.setAttribute('data-accent', id);
      }
      localStorage.setItem('accentTheme', id);

      document.querySelectorAll('.accent-swatch').forEach(btn => {
        const isActive = btn.getAttribute('data-accent-id') === id;
        btn.classList.toggle('border-zinc-100', isActive);
        btn.classList.toggle('text-zinc-100', isActive);
        btn.classList.toggle('border-zinc-800', !isActive);
        btn.classList.toggle('text-zinc-400', !isActive);
      });
    }

    applyAccent(saved);

    document.querySelectorAll('.accent-swatch').forEach(btn => {
      btn.addEventListener('click', () => applyAccent(btn.getAttribute('data-accent-id')));
    });
  }

  function setupVisibilityToggles() {
    document.querySelectorAll('[data-v-group]').forEach(group => {
      const input = group.querySelector('input') as HTMLInputElement;
      group.querySelectorAll('button').forEach(btn => {
        btn.addEventListener('click', () => {
          const action = btn.getAttribute('data-v-action');
          if (!action) return;
          input.value = action;
          group.querySelectorAll('button').forEach(b => {
            b.classList.remove('bg-blue-600', 'text-white', 'shadow-lg');
            b.classList.add('text-zinc-500', 'hover:text-zinc-300');
          });
          btn.classList.add('bg-blue-600', 'text-white', 'shadow-lg');
          btn.classList.remove('text-zinc-500', 'hover:text-zinc-300');
        });
      });
    });
  }

  function renderLibraryCheckboxes(containerId, libraries, idKey) {
    const container = document.getElementById(containerId);
    if (!container) return;
    
    // Clear loading state
    container.classList.remove('italic', 'text-zinc-500');
    
    if (!libraries.length) {
      container.innerHTML = '<span class="not-italic text-zinc-500 text-sm">No supported libraries found.</span>';
      return;
    }
    
    container.innerHTML = libraries.map(lib => `
      <label class="flex items-center gap-2 cursor-pointer group px-2 py-1.5 rounded-lg border border-transparent hover:bg-zinc-800/50 transition-colors">
        <input
          type="checkbox"
          class="library-checkbox w-4 h-4 rounded accent-blue-500 cursor-pointer"
          data-id="${esc(String(lib[idKey]))}"
          ${lib.selected ? 'checked' : ''}
        />
        <span class="text-zinc-300 group-hover:text-zinc-100 transition-colors not-italic">
          ${esc(lib.name)}
          <span class="text-zinc-400 text-xs ml-1">${lib.type === 'movies' || lib.type === 'movie' ? 'Movies' : 'Shows'}</span>
        </span>
      </label>
    `).join('');

    // Add click listeners to update styling for visual feedback
    container.querySelectorAll('label').forEach(label => {
      const cb = label.querySelector('input') as HTMLInputElement;
      const updateStyle = () => {
        if (cb.checked) {
          label.classList.add('bg-blue-500/10', 'border-blue-500/30');
          label.classList.remove('hover:bg-zinc-800/50', 'border-transparent');
        } else {
          label.classList.remove('bg-blue-500/10', 'border-blue-500/30');
          label.classList.add('hover:bg-zinc-800/50', 'border-transparent');
        }
      };
      
      cb.addEventListener('change', updateStyle);
      updateStyle(); // init
    });
  }

  function setupConnections() {
    const apiKey = (document.getElementById('scrob_api_key') as HTMLInputElement | null)?.value ?? '';

    // Set webhook URLs and wire copy buttons for all existing connection cards
    document.querySelectorAll('[data-connection-id]').forEach(card => {
      const connId = card.getAttribute('data-connection-id');
      const webhookInput = card.querySelector('.conn-webhook-url') as HTMLInputElement | null;
      const connType = webhookInput?.getAttribute('data-conn-type') ?? '';
      if (webhookInput && connId && connType) {
        webhookInput.value = `${window.location.origin}/api/proxy/webhooks/${connType}/${connId}?api_key=${encodeURIComponent(apiKey)}`;
      }
      const copyBtn = card.querySelector('.conn-copy-webhook');
      if (copyBtn && webhookInput) {
        copyBtn.addEventListener('click', async () => {
          try {
            await navigator.clipboard.writeText(webhookInput.value);
            flashCopied(copyBtn as HTMLElement);
          } catch {
            showMessage('Could not copy to clipboard', 'error');
          }
        });
      }
    });

    // Add Connection toggle
    const addBtn = document.getElementById('add-connection-btn');
    const addForm = document.getElementById('add-connection-form');
    const cancelBtn = document.getElementById('cancel-add-connection-btn');
    if (addBtn && addForm) {
      addBtn.addEventListener('click', () => {
        addForm.classList.toggle('hidden');
      });
    }
    if (cancelBtn && addForm) {
      cancelBtn.addEventListener('click', () => addForm.classList.add('hidden'));
    }

    // Show/hide user_id vs username based on new connection type
    const typeSelect = document.getElementById('new-conn-type') as HTMLSelectElement | null;
    const userIdRow = document.getElementById('new-conn-user-id-row');
    const usernameRow = document.getElementById('new-conn-username-row');
    const updateTypeFields = () => {
      const isPlex = typeSelect?.value === 'plex';
      userIdRow?.classList.toggle('hidden', isPlex);
      usernameRow?.classList.toggle('hidden', !isPlex);
    };
    typeSelect?.addEventListener('change', updateTypeFields);
    updateTypeFields();

    // Test new connection button
    const testNewBtn = document.getElementById('test-new-connection-btn');
    if (testNewBtn) {
      testNewBtn.addEventListener('click', async () => {
        const type = typeSelect?.value ?? 'jellyfin';
        const u = (document.getElementById('new-conn-url') as HTMLInputElement)?.value || '';
        const t = (document.getElementById('new-conn-token') as HTMLInputElement)?.value || '';
        const ui = (document.getElementById('new-conn-user-id') as HTMLInputElement)?.value || '';
        testNewBtn.disabled = true;
        const orig = testNewBtn.textContent;
        testNewBtn.textContent = '...';
        try {
          let ep: string;
          if (type === 'plex') {
            ep = `/api/proxy/auth/test-plex?url=${encodeURIComponent(u)}&token=${encodeURIComponent(t)}`;
          } else if (type === 'emby') {
            ep = `/api/proxy/auth/test-emby?url=${encodeURIComponent(u)}&token=${encodeURIComponent(t)}&user_id=${encodeURIComponent(ui)}`;
          } else {
            ep = `/api/proxy/auth/test-jellyfin?url=${encodeURIComponent(u)}&token=${encodeURIComponent(t)}&user_id=${encodeURIComponent(ui)}`;
          }
          const res = await fetch(ep, { method: 'POST', headers: { 'Authorization': `Bearer ${token}` } });
          const data = await res.json();
          if (res.ok) showMessage(data.message || 'Connection successful!');
          else throw new Error(data.detail || 'Connection test failed');
        } catch (e: any) {
          showMessage(e.message, 'error');
        } finally {
          testNewBtn.disabled = false;
          testNewBtn.textContent = orig;
        }
      });
    }

    // Create connection button
    const createBtn = document.getElementById('create-connection-btn');
    if (createBtn) {
      createBtn.addEventListener('click', async () => {
        const name = (document.getElementById('new-conn-name') as HTMLInputElement)?.value.trim();
        const type = typeSelect?.value ?? 'jellyfin';
        const u = (document.getElementById('new-conn-url') as HTMLInputElement)?.value.trim();
        const t = (document.getElementById('new-conn-token') as HTMLInputElement)?.value.trim();
        const ui = (document.getElementById('new-conn-user-id') as HTMLInputElement)?.value.trim() || null;
        const un = (document.getElementById('new-conn-username') as HTMLInputElement)?.value.trim() || null;
        if (!name || !u || !t) { showMessage('Name, URL and Token are required.', 'error'); return; }

        createBtn.disabled = true;
        const orig = createBtn.textContent;
        createBtn.textContent = 'Adding…';

        const body: Record<string, any> = {
          name, type, url: u, token: t,
          sync_collection: (document.getElementById('new-sync-collection') as HTMLInputElement)?.checked ?? true,
          sync_watched: (document.getElementById('new-sync-watched') as HTMLInputElement)?.checked ?? true,
          sync_ratings: (document.getElementById('new-sync-ratings') as HTMLInputElement)?.checked ?? true,
          sync_playback: (document.getElementById('new-sync-playback') as HTMLInputElement)?.checked ?? true,
          push_watched: (document.getElementById('new-push-watched') as HTMLInputElement)?.checked ?? false,
          push_ratings: (document.getElementById('new-push-ratings') as HTMLInputElement)?.checked ?? false,
          auto_sync_interval: (() => {
            const v = (document.getElementById('new-auto-sync') as HTMLSelectElement)?.value;
            return v ? parseInt(v) : null;
          })(),
        };
        if (type === 'plex') body.server_username = un;
        else body.server_user_id = ui;

        try {
          const res = await fetch('/api/proxy/auth/connections', {
            method: 'POST',
            headers: { 'Authorization': `Bearer ${token}`, 'Content-Type': 'application/json' },
            body: JSON.stringify(body),
          });
          if (!res.ok) {
            const err = await res.json();
            throw new Error(err.detail || 'Failed to create connection');
          }
          showMessage('Connection added! Reloading…');
          setTimeout(() => window.location.reload(), 1000);
        } catch (e: any) {
          showMessage(e.message, 'error');
          createBtn.disabled = false;
          createBtn.textContent = orig;
        }
      });
    }
  }

  function setupSettingsForm() {
    const form = document.getElementById('settings-form');
    const saveBtn = document.getElementById('save-settings-btn');
    if (!form || !saveBtn) return;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      saveBtn.disabled = true;
      const originalText = saveBtn.textContent;
      saveBtn.textContent = 'Saving...';

      try {
        const saves = [];
        const appData = document.getElementById('app-data') as HTMLElement;

        // Gather general settings
        const formData = new FormData(form);
        const settings = {
          tmdb_api_key: formData.get('tmdb_api_key') || null,

          radarr_url: formData.get('radarr_url') || null,
          radarr_token: formData.get('radarr_token') || null,
          radarr_root_folder: formData.get('radarr_root_folder') || null,
          radarr_quality_profile: formData.get('radarr_quality_profile') ? parseInt(formData.get('radarr_quality_profile')) : null,
          radarr_tags: formData.getAll('radarr_tags').map(id => parseInt(id)),

          sonarr_url: formData.get('sonarr_url') || null,
          sonarr_token: formData.get('sonarr_token') || null,
          sonarr_root_folder: formData.get('sonarr_root_folder') || null,
          sonarr_quality_profile: formData.get('sonarr_quality_profile') ? parseInt(formData.get('sonarr_quality_profile')) : null,
          sonarr_tags: formData.getAll('sonarr_tags').map(id => parseInt(id)),
          sonarr_season_folder: formData.get('sonarr_season_folder') === 'true',

          trakt_client_id: formData.get('trakt_client_id') || null,
          trakt_client_secret: formData.get('trakt_client_secret') || null,
        };

        // Collect boolean checkboxes (Trakt sync prefs + app preferences)
        const syncKeys = [
          'trakt_sync_watched', 'trakt_sync_ratings', 'trakt_sync_lists',
          'trakt_push_watched', 'trakt_push_ratings', 'trakt_push_lists',
          'blur_explicit',
        ] as const;
        const syncPrefs: Record<string, boolean> = {};
        for (const key of syncKeys) {
          const el = form.querySelector<HTMLInputElement>(`[name="${key}"]`);
          if (el) syncPrefs[key] = el.checked;
        }

        // Sync blur_explicit to a cookie (read server-side by Base.astro) and apply immediately
        const blurEl = form.querySelector<HTMLInputElement>('[name="blur_explicit"]');
        if (blurEl) {
          const val = blurEl.checked ? 'true' : 'false';
          document.cookie = `blur_explicit=${val}; path=/; SameSite=Lax; Max-Age=31536000`;
          document.documentElement.classList.toggle('blur-explicit', blurEl.checked);
        }

        // Gather visibility filters
        const visibilityFilters: Record<string, string> = {};
        form.querySelectorAll('[data-v-group]').forEach(group => {
          const key = group.getAttribute('data-v-group')!;
          const input = group.querySelector(`input[name="v_${key}"]`) as HTMLInputElement;
          visibilityFilters[key] = input.value;
        });

        const updatedPreferences = {
          explore_filters: visibilityFilters
        };

        saves.push(fetch(`/api/proxy/auth/settings`, {
          method: 'PATCH',
          headers: { 'Authorization': `Bearer ${token}`, 'Content-Type': 'application/json' },
          body: JSON.stringify({ ...settings, ...syncPrefs, preferences: updatedPreferences }),
        }));

        const results = await Promise.all(saves);
        const failed = results.find(r => !r.ok);
        
        if (failed) {
          const data = await failed.json();
          throw new Error(data.detail || 'Failed to update settings');
        }

        showMessage('Settings updated successfully!');
      } catch (e) {
        showMessage(e.message, 'error');
      } finally {
        saveBtn.disabled = false;
        saveBtn.textContent = originalText;
      }
    });
  }

  function setupPasswordForm() {
    const form = document.getElementById('password-form');
    const updateBtn = document.getElementById('update-password-btn');
    if (!form || !updateBtn) return;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const formData = new FormData(form);
      const current_password = formData.get('current_password') || null;
      const new_password = formData.get('new_password');
      const confirm_password = formData.get('confirm_password');

      if (new_password !== confirm_password) {
        showMessage('New passwords do not match', 'error');
        return;
      }

      updateBtn.disabled = true;
      const originalText = updateBtn.textContent;
      updateBtn.textContent = 'Updating...';

      try {
        const res = await fetch(`/api/proxy/auth/change-password`, {
          method: 'POST',
          headers: { 'Authorization': `Bearer ${token}`, 'Content-Type': 'application/json' },
          body: JSON.stringify({ current_password, new_password }),
        });

        if (res.ok) {
          showMessage('Password updated successfully!');
          form.reset();
        } else {
          const data = await res.json();
          throw new Error(data.detail || 'Failed to update password');
        }
      } catch (e) {
        showMessage(e.message, 'error');
      } finally {
        updateBtn.disabled = false;
        updateBtn.textContent = originalText;
      }
    });
  }

  const COPY_ICON = `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.666 3.888A2.25 2.25 0 0013.5 2.25h-3c-1.03 0-1.9.693-2.166 1.638m7.332 0c.055.194.084.4.084.612v0a.75.75 0 01-.75.75H9a.75.75 0 01-.75-.75v0c0-.212.03-.418.084-.612m7.332 0c.646.049 1.288.11 1.927.184 1.1.128 1.907 1.077 1.907 2.185V19.5a2.25 2.25 0 01-2.25 2.25H6.75A2.25 2.25 0 014.5 19.5V6.257c0-1.108.806-2.057 1.907-2.185a48.208 48.208 0 011.927-.184" /></svg>`;
  const CHECK_ICON = `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>`;

  function flashCopied(btn: HTMLElement): void {
    btn.innerHTML = CHECK_ICON;
    btn.classList.add('bg-green-900', 'border-green-700', 'text-green-400');
    btn.classList.remove('bg-zinc-800', 'hover:bg-zinc-700', 'border-zinc-700', 'text-zinc-300');
    setTimeout(() => {
      btn.innerHTML = COPY_ICON;
      btn.classList.remove('bg-green-900', 'border-green-700', 'text-green-400');
      btn.classList.add('bg-zinc-800', 'hover:bg-zinc-700', 'border-zinc-700', 'text-zinc-300');
    }, 2000);
  }

  function setupApiKey() {
    const copyBtn = document.getElementById('copy-api-key-btn');
    const regenBtn = document.getElementById('regenerate-api-key-btn');
    const keyInput = document.getElementById('scrob_api_key');

    if (copyBtn && keyInput) {
      copyBtn.addEventListener('click', async () => {
        try {
          await navigator.clipboard.writeText((keyInput as HTMLInputElement).value);
          flashCopied(copyBtn as HTMLElement);
        } catch {
          showMessage('Could not copy to clipboard', 'error');
        }
      });
    }

    if (regenBtn && keyInput) {
      regenBtn.addEventListener('click', async () => {
        if (!confirm('Are you sure you want to regenerate your API key? The old key will stop working immediately.')) return;

        regenBtn.disabled = true;
        const originalText = regenBtn.textContent;
        regenBtn.textContent = 'Regenerating...';

        try {
          const res = await fetch(`/api/proxy/auth/api-key/regenerate`, {
            method: 'POST',
            headers: { 'Authorization': `Bearer ${token}` },
          });
          if (!res.ok) {
            const data = await res.json();
            throw new Error(data.detail || 'Failed to regenerate key');
          }
          const data = await res.json();
          keyInput.value = data.api_key;
          showMessage('API key regenerated successfully!');
        } catch (e) {
          showMessage(e.message, 'error');
        } finally {
          regenBtn.disabled = false;
          regenBtn.textContent = originalText;
        }
      });
    }
  }

  function setupHealButton() {
    const btn = document.getElementById('heal-btn');
    const modal = document.getElementById('heal-modal');
    const cancelBtn = document.getElementById('cancel-heal');
    const confirmBtn = document.getElementById('confirm-heal');
    if (!btn || !modal || !cancelBtn || !confirmBtn) return;

    btn.addEventListener('click', () => {
      modal.classList.remove('hidden');
      modal.classList.add('flex');
    });

    cancelBtn.addEventListener('click', () => {
      modal.classList.add('hidden');
      modal.classList.remove('flex');
    });

    confirmBtn.addEventListener('click', async () => {
      modal.classList.add('hidden');
      modal.classList.remove('flex');
      btn.disabled = true;
      const originalText = btn.textContent;
      btn.textContent = 'Healing...';
      try {
        const res = await fetch('/api/proxy/sync/heal', {
          method: 'POST',
          headers: { 'Authorization': `Bearer ${token}` },
        });
        if (res.ok) {
          showMessage('Metadata heal started — it will run in the background.');
        } else {
          const data = await res.json();
          throw new Error(data.detail || 'Failed to start heal');
        }
      } catch (e) {
        showMessage(e.message, 'error');
      } finally {
        btn.disabled = false;
        btn.textContent = originalText;
      }
    });
