---
import Base from "../../layouts/Base.astro";
import MediaCard from "../../components/MediaCard.astro";
import CommentsSection from "../../components/CommentsSection.astro";
import Pagination from "../../components/Pagination.astro";
import InfiniteScroll from "../../components/InfiniteScroll.astro";
import { api, type MediaItem } from "../../lib/api";
export const prerender = false;

const { id } = Astro.params;
const { token } = Astro.locals;
const page = Number(Astro.url.searchParams.get("page") ?? 1);

const person = await api.media.getPerson(Number(id), page, token);
const profile = await api.profile.get(token!);
const paginationType = profile?.pagination_type ?? "infinite_scroll";

const credits = person.credits || [];
const totalPages = Math.ceil(person.total_credits / person.page_size);
const baseUrl = `/person/${id}`;
---

<Base title={person.name}>
  <div class="flex flex-col md:flex-row gap-12 max-w-5xl mx-auto py-8">
    <!-- Sidebar / Photo -->
    <div class="w-full md:w-72 shrink-0">
      <div class="sticky top-8">
        {person.profile_path ? (
          <div class="relative w-full aspect-[2/3] rounded-2xl overflow-hidden shadow-2xl mb-6 group/photo">
            <button id="photo-zoom-btn" class="w-full h-full block cursor-zoom-in" aria-label={`Enlarge photo of ${person.name}`}>
              <img
                src={person.profile_path}
                alt={person.name}
                class="w-full h-full object-cover transition-transform duration-300 group-hover/photo:scale-105"
                loading="eager"
                decoding="async"
              />
              <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover/photo:opacity-100 transition-opacity duration-200 bg-black/30">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-8 h-8 text-white drop-shadow-lg">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607ZM10.5 7.5v6m3-3h-6" />
                </svg>
              </div>
            </button>
          </div>
        ) : (
          <div class="w-full aspect-[2/3] bg-zinc-900 rounded-2xl flex items-center justify-center text-6xl mb-6 border border-zinc-800">
            👤
          </div>
        )}

        <div class="space-y-6 px-2">
          <div>
            <h3 class="text-zinc-500 text-xs font-bold uppercase tracking-wider mb-1">Personal Info</h3>
            <div class="space-y-4">
              {person.known_for_department && (
                <div>
                  <p class="text-zinc-100 text-sm font-semibold">Known For</p>
                  <p class="text-zinc-400 text-sm">{person.known_for_department}</p>
                </div>
              )}
              {person.birthday && (
                <div>
                  <p class="text-zinc-100 text-sm font-semibold">Birthday</p>
                  <p class="text-zinc-400 text-sm">{person.birthday}</p>
                </div>
              )}
              {person.place_of_birth && (
                <div>
                  <p class="text-zinc-100 text-sm font-semibold">Place of Birth</p>
                  <p class="text-zinc-400 text-sm">{person.place_of_birth}</p>
                </div>
              )}
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Main Content -->
    <div class="flex-1 min-w-0">
      <div class="flex flex-wrap items-center justify-between gap-4 mb-8">
        <h1 class="page-title">{person.name}</h1>
      </div>

      {person.biography && (
        <div class="mb-12">
          <h2 class="section-headline mb-4">Biography</h2>
          <p class="text-zinc-400 leading-relaxed text-lg whitespace-pre-wrap">{person.biography}</p>
        </div>
      )}

      <div>
        <h2 class="section-headline mb-6">Known For</h2>
        <div id="credits-grid" class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
          {credits.map((item) => (
            <div class="flex flex-col gap-1">
              <MediaCard item={item as unknown as MediaItem} />
              {item.character && (
                <p class="text-xs text-zinc-500 truncate px-1">as {item.character}</p>
              )}
            </div>
          ))}
        </div>

        {paginationType === "pagination" ? (
          <Pagination
            currentPage={page}
            totalPages={totalPages}
            baseUrl={baseUrl}
          />
        ) : (
          <InfiniteScroll
            type="person_credits"
            currentPage={page}
            totalPages={totalPages}
            params={{ person_id: id, source: 'tmdb' }}
            targetSelector="#credits-grid"
            endpoint="/partials/person-credits"
          />
        )}
      </div>

      <CommentsSection
        mediaType="person"
        tmdbId={person.tmdb_id}
      />
    </div>
  </div>
</Base>

{person.profile_path && (
  <div id="photo-modal" class="fixed inset-0 z-[999] flex items-center justify-center hidden" role="dialog" aria-modal="true">
    <div id="photo-modal-backdrop" class="absolute inset-0 bg-black/90 backdrop-blur-sm cursor-pointer"></div>
    <img
      src={person.profile_path}
      alt={person.name}
      class="relative max-h-[90vh] max-w-[85vw] md:max-w-[50vw] object-contain rounded-2xl shadow-2xl ring-1 ring-white/10"
    />
    <button
      id="photo-modal-close"
      class="absolute top-4 right-4 p-2 rounded-full bg-black/60 hover:bg-black/80 text-white/70 hover:text-white transition-all duration-200 cursor-pointer"
      aria-label="Close"
    >
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-5 h-5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
      </svg>
    </button>
  </div>
)}

<script>
  const zoomBtn = document.getElementById('photo-zoom-btn');
  const modal = document.getElementById('photo-modal');
  const backdrop = document.getElementById('photo-modal-backdrop');
  const closeBtn = document.getElementById('photo-modal-close');

  if (zoomBtn && modal) {
    function openModal() {
      modal.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
    }
    function closeModal() {
      modal.classList.add('hidden');
      document.body.style.overflow = '';
    }

    zoomBtn.addEventListener('click', openModal);
    backdrop?.addEventListener('click', closeModal);
    closeBtn?.addEventListener('click', closeModal);
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });
  }
</script>
