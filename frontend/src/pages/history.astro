---
import Base from "../layouts/Base.astro";
import HistoryCard from "../components/HistoryCard.astro";
import Pagination from "../components/Pagination.astro";
import InfiniteScroll from "../components/InfiniteScroll.astro";
import { api, type WatchEvent } from "../lib/api";

const { token } = Astro.locals;
const profile = await api.profile.get(token!);
const paginationType = profile?.pagination_type ?? "infinite_scroll";
Astro.response.headers.set("Cache-Control", "no-store");
const page = Number(Astro.url.searchParams.get("page") || 1);
const type = Astro.url.searchParams.get("type") || undefined;
const use24h = Astro.cookies.get("time_format_24h")?.value === "true";

const startDate = Astro.url.searchParams.get("start_date") || undefined;
const endDate = Astro.url.searchParams.get("end_date") || undefined;
const groupBy = Astro.url.searchParams.get("group_by") || "date";

const history = await api.history.list({
  page,
  page_size: 40,
  type,
  start_date: startDate,
  end_date: endDate
}, token);

// Grouping logic
const groupedHistory = history.results.reduce<Record<string, WatchEvent[]>>((acc, event) => {
  let key = "";
  if (groupBy === "show_movie") {
    key = event.media.type === 'episode' 
      ? (event.media.show_title || event.media.title)
      : event.media.title;
  } else if (groupBy === "season") {
    key = event.media.type === 'episode'
      ? `${event.media.show_title || event.media.title} - ${event.media.season_name || `Season ${event.media.season_number}`}`
      : 'Movies';
  } else if (groupBy === "type") {
    key = event.media.type === 'episode' ? 'TV Shows' : 'Movies';
  } else {
    // default: date
    key = new Date(event.watched_at + 'Z').toLocaleDateString('en-US', {
      weekday: 'long',
      month: 'long',
      day: 'numeric',
      year: 'numeric'
    });
  }
  
  if (!acc[key]) {
    acc[key] = [];
  }
  acc[key].push(event);
  return acc;
}, {});

const groupKeys = Object.keys(groupedHistory);

const urlParams = new URLSearchParams();
if (type) urlParams.set("type", type);
if (startDate) urlParams.set("start_date", startDate);
if (endDate) urlParams.set("end_date", endDate);
if (groupBy && groupBy !== "date") urlParams.set("group_by", groupBy);

const baseUrl = `/history${urlParams.toString() ? `?${urlParams.toString()}` : ""}`;
---

<Base title="Watch History">
  <div>
    <h1 class="page-title mb-8">Watch History</h1>

    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-8 bg-zinc-900/40 p-4 rounded-2xl border border-zinc-800/80 backdrop-blur-sm">
      <!-- Type Filter Toggles -->
      <div class="flex gap-2 shrink-0">
        <a
          href={`/history?${(() => {
            const p = new URLSearchParams(urlParams);
            p.delete("type");
            p.delete("page");
            return p.toString();
          })()}`}
          class={`px-4 py-2 rounded-xl text-xs font-bold transition-all duration-200 active:scale-95 ${!type ? 'bg-zinc-100 text-zinc-900 shadow-lg shadow-zinc-100/5' : 'bg-zinc-800/50 text-zinc-400 hover:text-zinc-200 hover:bg-zinc-800 border border-zinc-800/50'}`}
        >
          All
        </a>
        <a
          href={`/history?${(() => {
            const p = new URLSearchParams(urlParams);
            p.set("type", "movie");
            p.delete("page");
            return p.toString();
          })()}`}
          class={`px-4 py-2 rounded-xl text-xs font-bold transition-all duration-200 active:scale-95 ${type === 'movie' ? 'bg-zinc-100 text-zinc-900 shadow-lg shadow-zinc-100/5' : 'bg-zinc-800/50 text-zinc-400 hover:text-zinc-200 hover:bg-zinc-800 border border-zinc-800/50'}`}
        >
          Movies
        </a>
        <a
          href={`/history?${(() => {
            const p = new URLSearchParams(urlParams);
            p.set("type", "episode");
            p.delete("page");
            return p.toString();
          })()}`}
          class={`px-4 py-2 rounded-xl text-xs font-bold transition-all duration-200 active:scale-95 ${type === 'episode' ? 'bg-zinc-100 text-zinc-900 shadow-lg shadow-zinc-100/5' : 'bg-zinc-800/50 text-zinc-400 hover:text-zinc-200 hover:bg-zinc-800 border border-zinc-800/50'}`}
        >
          Shows
        </a>
      </div>

      <!-- Controls Form: Date Pickers & Grouping -->
      <form id="history-filter-form" class="flex flex-wrap md:flex-nowrap items-center gap-4 w-full md:w-auto">
        <div class="flex items-center gap-2 w-full sm:w-auto">
          <label for="start_date" class="text-xs font-bold uppercase tracking-wider text-zinc-500 shrink-0">From</label>
          <input
            type="date"
            id="start_date"
            name="start_date"
            value={startDate || ""}
            class="px-3 py-2 bg-zinc-950 border border-zinc-800 rounded-xl text-xs font-bold text-zinc-300 focus:outline-none focus:border-blue-500/50 w-full sm:w-36 transition cursor-pointer"
          />
        </div>
        
        <div class="flex items-center gap-2 w-full sm:w-auto">
          <label for="end_date" class="text-xs font-bold uppercase tracking-wider text-zinc-500 shrink-0">To</label>
          <input
            type="date"
            id="end_date"
            name="end_date"
            value={endDate || ""}
            class="px-3 py-2 bg-zinc-950 border border-zinc-800 rounded-xl text-xs font-bold text-zinc-300 focus:outline-none focus:border-blue-500/50 w-full sm:w-36 transition cursor-pointer"
          />
        </div>

        <div class="flex items-center gap-2 w-full sm:w-auto">
          <label for="group_by" class="text-xs font-bold uppercase tracking-wider text-zinc-500 shrink-0">Group</label>
          <select
            id="group_by"
            name="group_by"
            class="px-3 py-2 bg-zinc-950 border border-zinc-800 rounded-xl text-xs font-bold text-zinc-300 focus:outline-none focus:border-blue-500/50 w-full sm:w-32 transition cursor-pointer"
          >
            <option value="date" selected={groupBy === "date"}>Date</option>
            <option value="show_movie" selected={groupBy === "show_movie"}>Show / Movie</option>
            <option value="season" selected={groupBy === "season"}>Season</option>
            <option value="type" selected={groupBy === "type"}>Media Type</option>
          </select>
        </div>
        
        {(startDate || endDate) && (
          <a
            href={`/history${type ? `?type=${type}` : ""}`}
            class="px-3 py-2 bg-red-950/20 hover:bg-red-900/30 text-red-400 border border-red-950/50 hover:border-red-900/50 rounded-xl text-xs font-bold transition-all duration-200 flex items-center gap-1 cursor-pointer"
            title="Clear date filters"
          >
            Clear
          </a>
        )}
      </form>
    </div>

    {groupKeys.length === 0 ? (
      <div class="bg-zinc-900/50 rounded-2xl p-12 text-center">
        <div class="text-zinc-500 mb-2">No history yet</div>
        <a href="/" class="text-blue-500 hover:text-blue-400 font-medium transition-colors">Go discover something</a>
      </div>
    ) : (
      <div id="history-container" class="space-y-10">
        {groupKeys.map((key) => (
          <div class="relative" data-history-group={key}>
            <h2 class="text-lg font-bold text-zinc-100 mb-4 sticky top-[72px] py-2 bg-zinc-950/80 backdrop-blur-md z-10 flex items-center gap-3 border-b border-zinc-800/50">
              {key}
            </h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6 history-grid">
              {groupedHistory[key].map((event) => (
                <HistoryCard event={event} use24h={use24h} />
              ))}
            </div>
          </div>
        ))}
      </div>
    )}

    {paginationType === "pagination" ? (
      <Pagination
        currentPage={history.page}
        totalPages={history.total_pages}
        baseUrl={baseUrl}
      />
    ) : (
      <InfiniteScroll
        type="history"
        currentPage={history.page}
        totalPages={history.total_pages}
        params={{ history_type: type, start_date: startDate, end_date: endDate, group_by: groupBy }}
        targetSelector="#history-container"
        isHistory={true}
      />
    )}
  </div>
</Base>

<script>
  const form = document.getElementById('history-filter-form') as HTMLFormElement | null;
  if (form) {
    const handleFilterChange = () => {
      const formData = new FormData(form);
      const url = new URL(window.location.href);
      
      const startDate = formData.get('start_date') as string;
      const endDate = formData.get('end_date') as string;
      const groupBy = formData.get('group_by') as string;
      
      if (startDate) url.searchParams.set('start_date', startDate);
      else url.searchParams.delete('start_date');
      
      if (endDate) url.searchParams.set('end_date', endDate);
      else url.searchParams.delete('end_date');
      
      if (groupBy && groupBy !== 'date') url.searchParams.set('group_by', groupBy);
      else url.searchParams.delete('group_by');
      
      // Reset page to 1
      url.searchParams.delete('page');
      
      window.location.href = url.toString();
    };

    form.querySelectorAll('input, select').forEach(el => {
      el.addEventListener('change', handleFilterChange);
    });
  }
</script>
