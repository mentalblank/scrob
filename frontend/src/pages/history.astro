---
import Base from "../layouts/Base.astro";
import HistoryCard from "../components/HistoryCard.astro";
import InfiniteScroll from "../components/InfiniteScroll.astro";
import { api, type WatchEvent } from "../lib/api";

const { token } = Astro.locals;
Astro.response.headers.set("Cache-Control", "no-store");
const page = Number(Astro.url.searchParams.get("page") || 1);
const type = Astro.url.searchParams.get("type") || undefined;

const history = await api.history.list({ page, page_size: 40, type }, token);

// Grouping logic
const groupedHistory = history.results.reduce<Record<string, WatchEvent[]>>((acc, event) => {
  const dateStr = new Date(event.watched_at).toLocaleDateString('en-US', {
    weekday: 'long',
    month: 'long',
    day: 'numeric',
    year: 'numeric'
  });
  
  if (!acc[dateStr]) {
    acc[dateStr] = [];
  }
  acc[dateStr].push(event);
  return acc;
}, {});

const dates = Object.keys(groupedHistory);

const baseUrl = `/history${type ? `?type=${type}` : ""}`;
---

<Base title="Watch History">
  <div>
    <h1 class="text-3xl font-bold text-zinc-100 mb-8 tracking-tight flex items-center gap-3">
      <span class="w-1.5 h-8 bg-blue-600 rounded-full"></span>
      Watch History
    </h1>

    <div class="flex gap-3 mb-8">
      <a
        href="/history"
        class={`px-4 py-1.5 rounded-full text-sm font-medium transition active:scale-95 active:opacity-70 ${!type ? 'bg-zinc-100 text-zinc-900' : 'bg-zinc-800 text-zinc-400 hover:text-zinc-100'}`}
      >
        All
      </a>
      <a
        href="/history?type=movie"
        class={`px-4 py-1.5 rounded-full text-sm font-medium transition active:scale-95 active:opacity-70 ${type === 'movie' ? 'bg-zinc-100 text-zinc-900' : 'bg-zinc-800 text-zinc-400 hover:text-zinc-100'}`}
      >
        Movies
      </a>
      <a
        href="/history?type=episode"
        class={`px-4 py-1.5 rounded-full text-sm font-medium transition active:scale-95 active:opacity-70 ${type === 'episode' ? 'bg-zinc-100 text-zinc-900' : 'bg-zinc-800 text-zinc-400 hover:text-zinc-100'}`}
      >
        Shows
      </a>
    </div>

    {dates.length === 0 ? (
      <div class="bg-zinc-900/50 rounded-2xl p-12 text-center">
        <div class="text-zinc-500 mb-2">No history yet</div>
        <a href="/" class="text-blue-500 hover:text-blue-400 font-medium transition-colors">Go discover something</a>
      </div>
    ) : (
      <div id="history-container" class="space-y-10">
        {dates.map((date) => (
          <div class="relative" data-history-date={date}>
            <h2 class="text-lg font-bold text-zinc-100 mb-4 sticky top-[72px] py-2 bg-zinc-950/80 backdrop-blur-md z-10 flex items-center gap-3 border-b border-zinc-800/50">
              {date}
            </h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6 history-grid">
              {groupedHistory[date].map((event) => (
                <HistoryCard event={event} />
              ))}
            </div>
          </div>
        ))}
      </div>
    )}

    <InfiniteScroll
      type="history"
      currentPage={history.page}
      totalPages={history.total_pages}
      params={{ history_type: type }}
      targetSelector="#history-container"
      isHistory={true}
    />
  </div>
</Base>

<script>
</script>
