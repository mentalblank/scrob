---
import Base from "../../layouts/Base.astro";
import ThemeToggle from "../../components/ThemeToggle.astro";
import PasswordToggle from "../../components/PasswordToggle.astro";
import { api } from "../../lib/api";

const { token } = Astro.params as { token: string };

let success = false;
let error = "";

if (Astro.request.method === "POST") {
  try {
    const data = await Astro.request.formData();
    const newPassword = data.get("new_password")?.toString() ?? "";
    const confirm = data.get("confirm_password")?.toString() ?? "";

    if (newPassword !== confirm) {
      error = "Passwords do not match.";
    } else if (newPassword.length < 8) {
      error = "Password must be at least 8 characters.";
    } else {
      await api.auth.resetPassword(token, newPassword);
      return Astro.redirect("/login?password_reset=true");
    }
  } catch (e: unknown) {
    const msg = e instanceof Error ? e.message : "";
    if (msg.includes("expired")) {
      error = "This reset link has expired. Please request a new one.";
    } else if (msg.includes("invalid") || msg.includes("404")) {
      error = "This reset link is invalid or has already been used.";
    } else {
      error = "Something went wrong. Please try again.";
    }
  }
}
---

<Base title="Reset Password" hideNav>
  <div class="max-w-md mx-auto mt-16 p-8 bg-zinc-900/40 border border-zinc-800 rounded-3xl shadow-2xl backdrop-blur-md relative">
    <ThemeToggle />

    <div class="flex flex-col items-center mb-6">
      <img src="/scrob.png" alt="Scrob Logo" class="w-36 object-contain mb-2" />
      <span class="text-zinc-100 font-bold text-xl tracking-tight">Scrob</span>
    </div>

    <h1 class="text-3xl font-bold mb-6 text-zinc-100">Reset password</h1>

    {error && (
      <div class="bg-red-500/10 border border-red-500 text-red-500 p-3 rounded-lg mb-6 text-sm">
        {error}
        {error.includes("expired") || error.includes("invalid") ? (
          <div class="mt-2">
            <a href="/forgot-password" class="underline hover:no-underline">Request a new link</a>
          </div>
        ) : null}
      </div>
    )}

    <form method="POST" class="space-y-4">
      <div>
        <label for="new_password" class="block text-sm font-medium text-zinc-400 mb-1">New password</label>
        <div class="relative group/field">
          <input
            type="password"
            name="new_password"
            id="new_password"
            required
            minlength="8"
            autofocus
            class="w-full bg-zinc-800 border border-zinc-700 rounded-lg pl-4 pr-10 py-3 text-zinc-100 focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all"
          />
          <PasswordToggle />
        </div>
      </div>
      <div>
        <label for="confirm_password" class="block text-sm font-medium text-zinc-400 mb-1">Confirm new password</label>
        <div class="relative group/field">
          <input
            type="password"
            name="confirm_password"
            id="confirm_password"
            required
            minlength="8"
            class="w-full bg-zinc-800 border border-zinc-700 rounded-lg pl-4 pr-10 py-3 text-zinc-100 focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all"
          />
          <PasswordToggle />
        </div>
      </div>
      <button
        type="submit"
        class="w-full bg-blue-600 hover:bg-blue-500 text-white font-bold py-3 rounded-xl transition-all shadow-lg shadow-blue-600/20 active:scale-95 duration-200 cursor-pointer mt-4"
      >
        Reset password
      </button>
    </form>

    <div class="mt-6 text-center text-sm text-zinc-500">
      <a href="/login" class="text-zinc-400 hover:text-zinc-100 transition-colors">Back to login</a>
    </div>
  </div>
</Base>