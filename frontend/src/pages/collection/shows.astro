---
import Base from "../../layouts/Base.astro";
import MediaCard from "../../components/MediaCard.astro";
import InfiniteScroll from "../../components/InfiniteScroll.astro";
import { api } from "../../lib/api";
export const prerender = false;



const sort = Astro.url.searchParams.get("sort") ?? "title";
const genre = Astro.url.searchParams.get("genre") ?? "";
const year = Astro.url.searchParams.get("year") ? Number(Astro.url.searchParams.get("year")) : undefined;
const status = Astro.url.searchParams.get("status") ?? "";
const page = Number(Astro.url.searchParams.get("page") ?? 1);
const { token } = Astro.locals;
Astro.response.headers.set("Cache-Control", "no-store");

const data = await api.shows.list({
  sort,
  page,
  ...(genre ? { genre } : {}),
  ...(year ? { year } : {}),
  ...(status ? { status } : {}),
}, token);

const TV_GENRES = [
  "Action & Adventure", "Animation", "Comedy", "Crime", "Documentary",
  "Drama", "Family", "Kids", "Mystery", "News", "Reality",
  "Sci-Fi & Fantasy", "Soap", "Talk", "War & Politics", "Western",
];

const TV_STATUSES = ["Returning Series", "In Production", "Planned", "Ended", "Canceled"];

const currentYear = new Date().getFullYear();
const years = Array.from({ length: currentYear - 1949 }, (_, i) => currentYear - i);

// Build base URL preserving active filters (without page)
const baseParams = new URLSearchParams();
baseParams.set("sort", sort);
if (genre) baseParams.set("genre", genre);
if (year) baseParams.set("year", String(year));
if (status) baseParams.set("status", status);
const baseUrl = `/collection/shows?${baseParams.toString()}`;
---

<Base title="My Shows">
  <div class="flex items-center gap-1 mb-6 bg-zinc-900 border border-zinc-800 rounded-xl p-1 w-fit">
    <a href="/shows" class="px-4 py-1.5 rounded-lg text-sm font-medium text-zinc-400 hover:text-zinc-100 transition-colors active:scale-95 active:opacity-70">Explore</a>
    <a href="/collection/shows" class="px-4 py-1.5 rounded-lg text-sm font-semibold bg-blue-600 text-white transition-colors active:scale-95 active:opacity-70">My Collection</a>
  </div>
  <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-6">
    <div class="flex items-baseline gap-3">
      <h1 class="text-3xl font-bold text-zinc-100 tracking-tight">My Shows</h1>
      <span class="text-zinc-500 font-medium">{data.total_results.toLocaleString()} total</span>
    </div>

    <!-- Sort controls -->
    <select
      id="sort-select"
      class="bg-zinc-900 border border-zinc-800 text-zinc-200 text-sm rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500 cursor-pointer"
    >
      {[
        { value: "title", label: "A–Z" },
        { value: "rating", label: "Top" },
        { value: "release_date", label: "Newest" },
        { value: "created_at", label: "Recently Added" },
        { value: "last_watched", label: "Recently Watched" },
      ].map(({ value, label }) => (
        <option value={value} selected={sort === value}>{label}</option>
      ))}
    </select>
  </div>

  <!-- Filter bar -->
  <div class="flex flex-wrap justify-between items-center gap-4 mb-8">
    <div class="flex flex-wrap gap-3 items-center">
      <select id="filter-genre" class="bg-zinc-900 border border-zinc-700 text-zinc-300 text-sm rounded-lg px-3 py-2 focus:outline-none focus:border-blue-500">
        <option value="">All Genres</option>
        {TV_GENRES.map(g => (
          <option value={g} selected={genre === g}>{g}</option>
        ))}
      </select>

      <select id="filter-year" class="bg-zinc-900 border border-zinc-700 text-zinc-300 text-sm rounded-lg px-3 py-2 focus:outline-none focus:border-blue-500">
        <option value="">All Years</option>
        {years.map(y => (
          <option value={y} selected={year === y}>{y}</option>
        ))}
      </select>

      <select id="filter-status" class="bg-zinc-900 border border-zinc-700 text-zinc-300 text-sm rounded-lg px-3 py-2 focus:outline-none focus:border-blue-500">
        <option value="">Any Status</option>
        {TV_STATUSES.map(s => (
          <option value={s} selected={status === s}>{s}</option>
        ))}
      </select>
      {(genre || year || status) && (
        <a href={`/collection/shows?sort=${sort}`} class="text-sm text-zinc-500 hover:text-zinc-300 transition">
          Clear filters
        </a>
      )}
    </div>
  </div>

  {data.results.length === 0 ? (
    <div class="bg-zinc-900/50 rounded-2xl p-12 text-center border border-dashed border-zinc-800">
      <div class="text-zinc-500 mb-4 text-lg">
        {(genre || year || status) ? "No shows match the selected filters" : "Your library is empty"}
      </div>
      {!(genre || year || status) && (
        <a href="/settings" class="inline-flex items-center px-6 py-3 bg-zinc-100 text-zinc-950 font-bold rounded-xl hover:bg-zinc-200 transition">
          Set up Sync
        </a>
      )}
    </div>
  ) : (
    <>
      <div id="media-grid" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-6">
        {data.results.map(item => <MediaCard item={{...item, type: 'series', in_library: true}} />)}
      </div>

      <InfiniteScroll
        type="collection_shows"
        currentPage={data.page}
        totalPages={data.total_pages}
        params={{ sort, genre, year, status }}
      />
    </>
  )}
</Base>

<script define:vars={{ sort, genre, year, status }}>
  function navigate() {
    const params = new URLSearchParams();
    params.set("sort", document.getElementById("sort-select").value);
    const g = document.getElementById("filter-genre").value;
    const y = document.getElementById("filter-year").value;
    const st = document.getElementById("filter-status").value;
    if (g) params.set("genre", g);
    if (y) params.set("year", y);
    if (st) params.set("status", st);
    window.location.href = `/collection/shows?${params.toString()}`;
  }

  document.getElementById("filter-genre")?.addEventListener("change", navigate);
  document.getElementById("filter-year")?.addEventListener("change", navigate);
  document.getElementById("filter-status")?.addEventListener("change", navigate);
  document.getElementById("sort-select")?.addEventListener("change", navigate);

</script>
