---
import Base from "../layouts/Base.astro";
import ContinueWatchingCard from "../components/ContinueWatchingCard.astro";
import InfiniteScroll from "../components/InfiniteScroll.astro";
import Pagination from "../components/Pagination.astro";
import { api, type ContinueWatchingItem } from "../lib/api";
export const prerender = false;

const { token } = Astro.locals;
const page = Number(Astro.url.searchParams.get("page") ?? 1);
Astro.response.headers.set("Cache-Control", "no-store");

const profile = await api.profile.get(token!);
const paginationType = profile?.pagination_type ?? "infinite_scroll";

let data = { continue_watching: [] as ContinueWatchingItem[], total_pages: 0, page: 1 };
try {
  data = await api.history.continueWatching({ page, page_size: 24 }, token);
} catch (e) {
  console.error("Failed to fetch continue watching list:", e);
}

const baseUrl = "/continue-watching";
---

<Base title="Continue Watching">
  <div class="mb-12">
    <h1 class="text-4xl font-black text-zinc-100 mb-2 tracking-tight">Continue Watching</h1>
    <p class="text-zinc-400 text-lg">Pick up where you left off across all your devices.</p>
  </div>

  {data.continue_watching.length === 0 ? (
    <div class="flex flex-col items-center justify-center py-24 bg-zinc-900/30 border border-zinc-800/50 rounded-3xl text-center">
      <div class="text-6xl mb-6 opacity-20">🍿</div>
      <h2 class="text-2xl font-bold text-zinc-300 mb-2">Nothing in progress</h2>
      <p class="text-zinc-500 max-w-sm mx-auto">Start watching a movie or show to see it here and resume anytime.</p>
    </div>
  ) : (
    <>
      <div id="media-grid" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 xl:grid-cols-8 gap-4 sm:gap-6">
        {data.continue_watching.map((item) => (
          <ContinueWatchingCard item={item} />
        ))}
      </div>

      {paginationType === "pagination" ? (
        <Pagination
          currentPage={data.page}
          totalPages={data.total_pages}
          baseUrl={baseUrl}
        />
      ) : (
        <InfiniteScroll
          type="continue_watching"
          currentPage={data.page}
          totalPages={data.total_pages}
        />
      )}
    </>
  )}
</Base>
