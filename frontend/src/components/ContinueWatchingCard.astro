---
import type { ContinueWatchingItem } from "../lib/api";

interface Props {
  item: ContinueWatchingItem;
}

const { item } = Astro.props;
const { media, progress_percent } = item;

const isEpisode = media.type === "episode";
const sxe =
  isEpisode && media.season_number != null && media.episode_number != null
    ? `S${String(media.season_number).padStart(2, "0")}E${String(media.episode_number).padStart(2, "0")}`
    : null;

const progressPct =
  progress_percent != null ? Math.round(progress_percent * 100) : 0;

const posterSrc =
  isEpisode && media.show_poster_path
    ? media.show_poster_path.startsWith("http")
      ? media.show_poster_path
      : `https://image.tmdb.org/t/p/w500${media.show_poster_path}`
    : media.poster_path
      ? media.poster_path.startsWith("http")
        ? media.poster_path
        : `https://image.tmdb.org/t/p/w500${media.poster_path}`
      : null;

const href =
  isEpisode &&
  media.show_tmdb_id &&
  media.season_number != null &&
  media.episode_number != null
    ? `/show/${media.show_tmdb_id}/season/${media.season_number}/${media.episode_number}`
    : `/media/${media.type}/${media.tmdb_id}`;
---

<div
  data-card
  data-tmdb-id={String(media.tmdb_id)}
  data-media-type={media.type}
  class="group relative block rounded-2xl overflow-hidden bg-zinc-900 border border-zinc-800 hover:border-blue-500/50 hover:shadow-2xl hover:shadow-blue-900/20 transition-all duration-300 transform hover:-translate-y-1"
>
  <a
    href={href}
    class="block active:scale-95 active:opacity-70 transition-all duration-300"
  >
    <!-- Poster -->
    <div
      class="aspect-[2/3] bg-zinc-950 relative overflow-hidden ring-1 ring-white/5 group-hover:ring-blue-500/30 transition-all duration-300"
    >
      {
        posterSrc ? (
          <img
            src={posterSrc}
            alt={media.title}
            class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
            loading="lazy"
            decoding="async"
          />
        ) : (
          <div class="w-full h-full flex flex-col items-center justify-center text-zinc-700 bg-zinc-900 p-4 text-center">
            <span class="text-3xl mb-2 opacity-30">🎬</span>
            <span class="text-xs font-bold uppercase tracking-widest">
              {media.title}
            </span>
          </div>
        )
      }

      <div
        class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"
      >
      </div>

      <!-- Progress bar -->
      <div class="absolute bottom-0 left-0 right-0 h-1.5 bg-zinc-800/80">
        <div
          class="h-full bg-blue-500 rounded-r-full"
          style={`width: ${progressPct}%`}
        >
        </div>
      </div>
    </div>

    <!-- Info -->
    <div class="p-4 bg-gradient-to-b from-zinc-900 to-zinc-950">
      {
        isEpisode && media.show_title ? (
          <h3 class="text-xs font-medium text-zinc-400 truncate mb-0.5">
            {media.show_title}
          </h3>
        ) : null
      }
      <h3
        class="text-sm font-bold text-zinc-100 truncate group-hover:text-blue-400 transition-colors leading-tight mb-1"
      >
        {media.title}
      </h3>
      <div class="flex items-center justify-between">
        <div class="flex items-center gap-2">
          {
            sxe && (
              <span class="text-[11px] font-bold text-blue-400 tracking-wide">
                {sxe}
              </span>
            )
          }
        </div>
        <span class="text-xs font-bold text-zinc-500 tabular-nums"
          >{progressPct}%</span
        >
      </div>
    </div>
  </a>

  <!-- Remove Progress Button -->
  <button
    data-action="remove-progress"
    title="Remove from Continue Watching"
    class="absolute top-2 right-2 z-10 bg-black/60 backdrop-blur-md text-zinc-400 hover:text-red-500 p-1.5 rounded-full opacity-0 group-hover:opacity-100 transition-all duration-200 border border-zinc-800 hover:border-red-500/50 cursor-pointer shadow-lg active:scale-90"
  >
    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
      <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
    </svg>
  </button>
</div>
