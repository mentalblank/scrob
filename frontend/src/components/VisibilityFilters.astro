---
import { api, type ExploreFilters, type VisibilityAction } from "../lib/api";

const { token } = Astro.locals;
const settings = await api.auth.getSettings(token!);
const prefs = settings?.preferences || {};
const isUnified = prefs.unified_filters !== false; // Default to true

// Generate a page ID from the URL
const pathname = Astro.url.pathname;
const pageId = pathname.replace(/^\//, '').replace(/\//g, '_') || 'home';

const currentFilters: ExploreFilters = (isUnified ? prefs.explore_filters : prefs[`explore_filters_${pageId}`]) || {
  watched: 'show',
  unwatched: 'show',
  collected: 'show',
  uncollected: 'show',
  listed: 'show',
  unlisted: 'show'
};

const options: { key: keyof ExploreFilters; label: string }[] = [
  { key: 'watched', label: 'Watched' },
  { key: 'unwatched', label: 'Not Watched' },
  { key: 'collected', label: 'In Library' },
  { key: 'uncollected', label: 'Not In Library' },
  { key: 'listed', label: 'Listed' },
  { key: 'unlisted', label: 'Not Listed' },
];
---

<div class="relative inline-block" id="visibility-filters-container" data-page-id={pageId} data-is-unified={isUnified ? "true" : "false"}>
  <button
    id="visibility-toggle-btn"
    class="flex items-center gap-2 px-3 py-2 bg-zinc-900/40 border border-zinc-800/80 hover:border-zinc-700 rounded-xl text-sm text-zinc-300 transition-all hover:bg-zinc-900/60 hover:text-zinc-200 active:scale-95 cursor-pointer"
    title="Visibility Filters"
  >
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/>
    </svg>
    <span class="hidden sm:inline">Visibility</span>
  </button>

  <div
    id="visibility-popover"
    class="hidden absolute right-0 top-full mt-2 w-[calc(100vw-2rem)] sm:w-72 bg-zinc-900/85 border border-zinc-800/85 rounded-3xl shadow-2xl backdrop-blur-xl z-50 overflow-hidden"
  >
    <div class="px-4 py-3 border-b border-zinc-800/60 flex items-center justify-between bg-zinc-950/20">
      <div class="flex flex-col">
        <span class="text-xs font-bold text-zinc-400 uppercase tracking-widest">Visibility Filters</span>
        {!isUnified && <span class="text-[10px] text-zinc-500 font-medium">Independent for this page</span>}
      </div>
      <button id="visibility-close" class="text-zinc-500 hover:text-zinc-200 transition cursor-pointer">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
      </button>
    </div>
    
    <div class="p-2 flex flex-col gap-1">
      {options.map(({ key, label }) => (
        <div class="flex items-center justify-between p-2 rounded-xl hover:bg-zinc-800/30 transition-colors">
          <span class="text-xs font-medium text-zinc-300">{label}</span>
          <div class="flex items-center bg-zinc-950/60 border border-zinc-850 rounded-xl p-0.5" data-filter-group={key}>
            {['show', 'fade', 'hide'].map((action) => (
              <button
                data-action={action}
                class={`px-3 py-1 text-[10px] font-bold uppercase rounded-xl transition-all cursor-pointer ${currentFilters[key] === action ? 'bg-blue-600 text-white shadow-md shadow-blue-500/20' : 'text-zinc-500 hover:text-zinc-300'}`}
              >
                {action}
              </button>
            ))}
          </div>
        </div>
      ))}
    </div>

    <div class="p-3 border-t border-zinc-800/60 bg-zinc-950/30">
      <button
        id="visibility-reset"
        class="w-full py-2 text-[10px] font-bold uppercase text-zinc-500 hover:text-zinc-200 transition-colors cursor-pointer"
      >
        Reset to defaults
      </button>
    </div>
  </div>
</div>

<script define:vars={{ initialFilters: currentFilters }}>
  const container = document.getElementById('visibility-filters-container');
  const btn = document.getElementById('visibility-toggle-btn');
  const popover = document.getElementById('visibility-popover');
  const closeBtn = document.getElementById('visibility-close');
  const resetBtn = document.getElementById('visibility-reset');
  
  const pageId = container.dataset.pageId;
  const isUnified = container.dataset.isUnified === "true";

  let activeFilters = { ...initialFilters };

  // Apply initial filters to body
  Object.entries(activeFilters).forEach(([key, value]) => {
    document.body.setAttribute(`data-v-${key}`, value);
  });

  function togglePopover(show) {
    popover.classList.toggle('hidden', !show);
    if (show) {
      requestAnimationFrame(() => {
        const rect = popover.getBoundingClientRect();
        const padding = 16;
        
        if (rect.left < padding) {
          const containerRect = container.getBoundingClientRect();
          const offset = padding - containerRect.left;
          popover.style.left = `${offset}px`;
          popover.style.right = 'auto';
        } else if (rect.right > window.innerWidth - padding) {
          popover.style.right = '0';
          popover.style.left = 'auto';
        }
      });
    } else {
      popover.style.left = '';
      popover.style.right = '';
    }
  }

  btn?.addEventListener('click', (e) => {
    e.stopPropagation();
    togglePopover(popover.classList.contains('hidden'));
  });

  closeBtn?.addEventListener('click', () => togglePopover(false));

  document.addEventListener('click', (e) => {
    if (!container.contains(e.target)) togglePopover(false);
  });

  // Handle filter changes
  container.querySelectorAll('[data-filter-group]').forEach(group => {
    const key = group.dataset.filterGroup;
    group.querySelectorAll('button[data-action]').forEach(actionBtn => {
      actionBtn.addEventListener('click', async () => {
        const action = actionBtn.dataset.action;
        
        group.querySelectorAll('button').forEach(b => {
          b.classList.remove('bg-blue-600', 'text-white', 'shadow-md', 'shadow-blue-500/20');
          b.classList.add('text-zinc-500', 'hover:text-zinc-300');
        });
        actionBtn.classList.remove('text-zinc-500', 'hover:text-zinc-300');
        actionBtn.classList.add('bg-blue-600', 'text-white', 'shadow-md', 'shadow-blue-500/20');

        document.body.setAttribute(`data-v-${key}`, action);
        activeFilters[key] = action;

        const prefKey = isUnified ? 'explore_filters' : `explore_filters_${pageId}`;

        try {
          await fetch('/api/proxy/auth/settings', {
            method: 'PATCH',
            headers: {
              'Content-Type': 'application/json',
              'Authorization': `Bearer ${window.__AUTH_TOKEN__}`
            },
            body: JSON.stringify({
              preferences: {
                [prefKey]: activeFilters
              }
            })
          });
        } catch (err) {
          console.error('Failed to save visibility settings:', err);
        }
      });
    });
  });

  resetBtn?.addEventListener('click', async () => {
    const defaults = {
      watched: 'show',
      unwatched: 'show',
      collected: 'show',
      uncollected: 'show',
      listed: 'show',
      unlisted: 'show'
    };
    
    activeFilters = { ...defaults };
    
    Object.entries(activeFilters).forEach(([key, value]) => {
      document.body.setAttribute(`data-v-${key}`, value);
    });

    container.querySelectorAll('[data-filter-group]').forEach(group => {
      const key = group.dataset.filterGroup;
      group.querySelectorAll('button').forEach(b => {
        const action = b.dataset.action;
        if (action === defaults[key]) {
          b.classList.add('bg-blue-600', 'text-white', 'shadow-md', 'shadow-blue-500/20');
          b.classList.remove('text-zinc-500', 'hover:text-zinc-300');
        } else {
          b.classList.remove('bg-blue-600', 'text-white', 'shadow-md', 'shadow-blue-500/20');
          b.classList.add('text-zinc-500', 'hover:text-zinc-300');
        }
      });
    });

    const prefKey = isUnified ? 'explore_filters' : `explore_filters_${pageId}`;

    try {
      await fetch('/api/proxy/auth/settings', {
        method: 'PATCH',
        headers: {
          'Content-Type': 'application/json',
          'Authorization': `Bearer ${window.__AUTH_TOKEN__}`
        },
        body: JSON.stringify({
          preferences: {
            [prefKey]: activeFilters
          }
        })
      });
    } catch (err) {
      console.error('Failed to reset visibility settings:', err);
    }
  });
</script>
