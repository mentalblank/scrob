---
import type { WatchEvent } from "../lib/api";
import { mediaUrl } from "../lib/urls";

interface Props {
  event: WatchEvent;
  use24h?: boolean;
}

const { event, use24h = false } = Astro.props;
const { media, watched_at } = event;

const date = new Date(watched_at + 'Z');
const timeString = date.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit', hour12: !use24h });

const isEpisode = media.type === 'episode';
const title = isEpisode ? media.title : media.title;
const showTitle = isEpisode ? (media.show_title || media.title) : null;
const year = media.release_date?.slice(0, 4);

// Episodes: use episode still (poster_path in this context). Movies: use backdrop.
const rawImage = isEpisode 
  ? (media.poster_path ?? media.show_backdrop_path ?? media.show_poster_path)
  : (media.backdrop_path ?? media.poster_path);

const imageUrl = rawImage
  ? (rawImage.startsWith('http') ? rawImage : `https://image.tmdb.org/t/p/w780${rawImage}`)
  : null;

const primaryMetadataSource = Astro.cookies.get("primary_metadata_source")?.value || "tmdb";
const href = mediaUrl(media, primaryMetadataSource === "tvdb") || "/";

const sxe = isEpisode && media.season_number != null && media.episode_number != null
  ? `S${String(media.season_number).padStart(2, "0")}E${String(media.episode_number).padStart(2, "0")}`
  : null;

const progressPct = event.progress_percent ? event.progress_percent * 100 : 0;
const showProgress = !event.completed && progressPct > 0;
---

<div 
  class="group relative flex flex-col rounded-2xl overflow-hidden glass-card active:scale-95 active:opacity-70"
  data-watched-at={watched_at}
  data-media-type={media.type}
  data-media-title={title}
  data-show-title={showTitle || ""}
  data-season-number={media.season_number || ""}
>
  <a href={href} class="block">
    <!-- Backdrop/Still container: 3:2 -->
    <div class="aspect-[3/2] bg-zinc-950 relative overflow-hidden ring-1 ring-white/5 group-hover:ring-blue-500/30 transition-all duration-300">
      {imageUrl ? (
        <img
          src={imageUrl}
          alt={title}
          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
          loading="lazy"
          decoding="async"
        />
      ) : (
        <div class="w-full h-full flex flex-col items-center justify-center p-4 text-center bg-zinc-900/40">
          <span class="text-3xl mb-2 opacity-30">{isEpisode ? '📺' : '🎬'}</span>
          <span class="text-xs font-bold uppercase tracking-widest text-zinc-500">{showTitle ?? title}</span>
        </div>
      )}

      <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>

      <!-- Time badge -->
      <div class="time-badge absolute top-2 left-2 z-30 bg-zinc-950/60 backdrop-blur-md text-zinc-100 text-[10px] font-bold px-2 py-1 rounded-lg border border-zinc-800/80 shadow-lg uppercase tracking-wider">
        {timeString}
      </div>

      <!-- Delete button -->
      <button 
        class="delete-history-btn absolute top-2 right-2 z-30 scale-0 group-hover:scale-100 origin-right transition-transform duration-200 p-1.5 rounded-lg bg-red-950/90 hover:bg-red-900 text-red-400 border border-red-900/30 cursor-pointer flex items-center justify-center shadow-lg active:scale-90"
        data-event-id={event.id}
        title="Delete this play from history"
      >
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-3.5 h-3.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
        </svg>
      </button>

      {showProgress && (
        <div class="absolute bottom-0 left-0 right-0 h-1.5 bg-zinc-800/80">
          <div class="h-full bg-blue-500 rounded-r-full" style={`width: ${progressPct}%`}></div>
        </div>
      )}
    </div>
  </a>

  <!-- Info -->
  <a href={href} class="block p-3 bg-transparent flex-1">
    {showTitle && (
      <p class="text-xs font-medium text-zinc-400 truncate mb-0.5">{showTitle}</p>
    )}
    <h3 class="text-sm font-bold text-zinc-100 truncate group-hover:text-blue-300 transition-colors leading-tight">
      {title}
    </h3>
    <div class="flex items-center justify-between">
      <div class="flex items-center gap-2">
        {!isEpisode && year && <span class="text-[11px] font-bold text-zinc-500 tracking-wide mt-0.5 block">{year}</span>}
        {isEpisode && sxe && <span class="text-[11px] font-bold text-blue-400 tracking-wide mt-0.5 block">{sxe}</span>}
      </div>
      <div class="flex items-center gap-2">
        {showProgress && (
          <span class="text-[10px] font-bold text-zinc-500 tabular-nums">{Math.round(progressPct)}%</span>
        )}
        {isEpisode ? (
          <span class="text-[9px] font-black text-zinc-400 uppercase tracking-widest px-1.5 py-0.5 bg-zinc-900/40 border border-zinc-800/80 rounded">EPISODE</span>
        ) : (
          <span class="text-[9px] font-black text-zinc-400 uppercase tracking-widest px-1.5 py-0.5 bg-zinc-900/40 border border-zinc-800/80 rounded">MOVIE</span>
        )}
      </div>
    </div>
  </a>
</div>

<script>
  if (!window["hasHistoryCardDeleteListener"]) {
    window["hasHistoryCardDeleteListener"] = true;
    document.addEventListener('click', async (e) => {
      const btn = (e.target as HTMLElement).closest('.delete-history-btn');
      if (!btn) return;
      
      e.preventDefault();
      e.stopPropagation();
      
      const eventId = btn.getAttribute('data-event-id');
      if (!eventId) return;
      
      if (!confirm('Are you sure you want to remove this play from your history?')) return;
      
      const originalHTML = btn.innerHTML;
      btn.setAttribute('disabled', 'true');
      btn.innerHTML = '<svg class="animate-spin h-3.5 w-3.5 text-red-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>';
      
      const token = window["__AUTH_TOKEN__"] || document.getElementById("app-data")?.dataset.token || 
                    document.querySelector("[data-token]")?.getAttribute("data-token") ||
                    document.cookie.split('; ').find(row => row.startsWith('auth_token='))?.split('=')[1];
                    
      try {
        const res = await fetch(`/api/proxy/history/event/${eventId}`, {
          method: 'DELETE',
          headers: { 'Authorization': `Bearer ${token}` }
        });
        
        if (!res.ok) {
          throw new Error('Failed to delete history event');
        }
        
        const card = btn.closest('[data-watched-at]');
        if (card) {
          card.classList.add('opacity-0', 'scale-95');
          (card as HTMLElement).style.transition = 'all 0.3s ease';
          setTimeout(() => {
            const grid = card.parentNode;
            card.remove();
            
            if (grid && grid.children.length === 0) {
              const groupSection = grid.closest('[data-history-group]');
              if (groupSection) {
                groupSection.remove();
              }
            }
          }, 300);
        }
      } catch (err: any) {
        alert('Error: ' + err.message);
        btn.removeAttribute('disabled');
        btn.innerHTML = originalHTML;
      }
    });
  }
</script>
