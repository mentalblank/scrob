---
interface Props {
  currentView: "grid" | "list";
}

const { currentView } = Astro.props;
---

<div class="flex items-center bg-zinc-900 border border-zinc-800 rounded-xl p-1 shrink-0">
  <button
    data-set-view="grid"
    class={`p-1.5 rounded-lg transition-all active:scale-95 cursor-pointer ${
      currentView === "grid" 
        ? "bg-zinc-700/50 text-white shadow-sm" 
        : "text-zinc-500 hover:text-zinc-300 hover:bg-zinc-800"
    }`}
    title="Grid View"
    aria-label="Switch to Grid View"
  >
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <rect width="7" height="7" x="3" y="3" rx="1" />
      <rect width="7" height="7" x="14" y="3" rx="1" />
      <rect width="7" height="7" x="14" y="14" rx="1" />
      <rect width="7" height="7" x="3" y="14" rx="1" />
    </svg>
  </button>
  <button
    data-set-view="list"
    class={`p-1.5 rounded-lg transition-all active:scale-95 cursor-pointer ${
      currentView === "list" 
        ? "bg-zinc-700/50 text-white shadow-sm" 
        : "text-zinc-500 hover:text-zinc-300 hover:bg-zinc-800"
    }`}
    title="List View"
    aria-label="Switch to List View"
  >
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <line x1="8" x2="21" y1="6" y2="6" />
      <line x1="8" x2="21" y1="12" y2="12" />
      <line x1="8" x2="21" y1="18" y2="18" />
      <line x1="3" x2="3.01" y1="6" y2="6" />
      <line x1="3" x2="3.01" y1="12" y2="12" />
      <line x1="3" x2="3.01" y1="18" y2="18" />
    </svg>
  </button>
</div>

<script>
  document.querySelectorAll('button[data-set-view]').forEach(btn => {
    btn.addEventListener('click', () => {
      const view = (btn as HTMLElement).dataset.setView;
      if (view) {
        document.cookie = `media_view_preference=${view}; path=/; max-age=31536000`;
        window.location.reload();
      }
    });
  });
</script>
