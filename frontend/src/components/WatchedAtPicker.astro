<!-- Watched-at picker popover (shared, repositioned on use) -->
<div id="watched-at-picker" class="hidden absolute z-50 w-72">
  <div class="bg-zinc-900/85 border border-zinc-800/85 rounded-2xl shadow-2xl backdrop-blur-xl overflow-hidden">
    <div class="px-4 pt-4 pb-3">
      <p class="text-xs font-bold uppercase tracking-wider text-zinc-400 mb-3">When did you watch this?</p>
      <div class="flex gap-2 mb-3">
        <button
          id="watched-at-now-btn"
          class="flex-1 px-3 py-2 rounded-xl text-sm font-bold transition-all cursor-pointer bg-blue-600 text-white hover:bg-blue-500 active:scale-95 shadow-md shadow-blue-500/20"
        >
          Just now
        </button>
        <button
          id="watched-at-custom-btn"
          class="flex-1 px-3 py-2 rounded-xl text-sm font-bold transition-all cursor-pointer bg-zinc-900/40 text-zinc-450 border border-zinc-800/80 hover:text-zinc-200"
        >
          Custom
        </button>
      </div>
      <input
        type="datetime-local"
        id="watched-at-input"
        class="hidden w-full px-3 py-2 bg-zinc-950/60 border border-zinc-850 rounded-xl text-sm text-zinc-200 focus:outline-none focus:ring-1 focus:ring-zinc-700 [color-scheme:dark]"
      />
    </div>
    <div class="px-4 pb-4 flex gap-2">
      <button id="watched-at-cancel" class="px-4 py-2.5 bg-zinc-900/40 hover:bg-zinc-900/60 border border-zinc-800/80 hover:border-zinc-700 text-zinc-400 font-bold text-sm rounded-xl transition-all cursor-pointer active:scale-95">
        Cancel
      </button>
      <button id="watched-at-confirm" class="flex-1 px-4 py-2.5 bg-green-600 hover:bg-green-500 text-white font-bold text-sm rounded-xl transition-all cursor-pointer active:scale-95 shadow-md shadow-green-500/20">
        Log
      </button>
    </div>
  </div>
</div>
