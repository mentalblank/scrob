---
import type { MediaItem } from "../lib/api";
import CardActionBar from "./CardActionBar.astro";
import ProgressStrip from "./ProgressStrip.astro";

interface Props {
  item: MediaItem;
}

const { item } = Astro.props;

const isPerson = item.type === "person";
const isCollection = item.type === "collection";
const year = item.release_date?.slice(0, 4) ?? null;
const rating = item.tmdb_rating ? item.tmdb_rating.toFixed(1) : null;
const isEpisode = item.type === "episode";
const isSeries = item.type === "series" || (item.type === "episode" && !item.season_number && !item.id);
const sxe = isEpisode && item.season_number != null && item.episode_number != null
  ? `S${String(item.season_number).padStart(2, '0')}E${String(item.episode_number).padStart(2, '0')}`
  : null;

const href = isPerson
  ? `/person/${item.tmdb_id}`
  : isCollection
    ? `/collection/${item.tmdb_id}`
    : isSeries && item.tmdb_id
    ? `/show/${item.tmdb_id}`
    : isEpisode && item.show_tmdb_id && item.season_number != null && item.episode_number != null
      ? `/show/${item.show_tmdb_id}/season/${item.season_number}/${item.episode_number}`
      : isEpisode && item.show_tmdb_id
        ? `/show/${item.show_tmdb_id}`
        : item.tmdb_id
          ? `/media/${item.type}/${item.tmdb_id}`
          : null;

const posterPath = isEpisode && item.show_poster_path
  ? (item.show_poster_path.startsWith('http') ? item.show_poster_path : `https://image.tmdb.org/t/p/w500${item.show_poster_path}`)
  : item.poster_path
    ? (item.poster_path.startsWith('http') ? item.poster_path : `https://image.tmdb.org/t/p/w500${item.poster_path}`)
    : null;

const showActionBar = !isPerson && !isCollection;
const watched = item.watched ?? false;
const inLists = item.in_lists ?? [];
const collectionPct = item.collection_pct ?? (item.in_library ? 100 : 0);
const inLibrary = item.in_library ?? false;
const isDvr = item.is_monitored === true;
const isPartialWatched = !watched && (
  (item.type === 'series' && (item.watched_episodes_count ?? 0) > 0) ||
  ((item.progress_percent ?? 0) > 0)
);
const isPartialCollected = item.type === 'series' && collectionPct > 0 && collectionPct < 100;

// Truncate overview if it's too long
const overview = item.overview || (isPerson && item.known_for_department ? `Known for: ${item.known_for_department}` : null);
---

<div
  class="group relative flex flex-row rounded-2xl bg-zinc-900 border border-zinc-800 hover:border-blue-500/50 hover:shadow-2xl hover:shadow-blue-900/20 transition-all duration-300 transform hover:-translate-y-0.5 active:scale-[0.99] active:opacity-90 overflow-hidden"
  data-card
  data-id={item.id ? String(item.id) : ""}
  data-tmdb-id={item.tmdb_id ? String(item.tmdb_id) : ""}
  data-media-type={item.type}
  data-show-tmdb-id={item.show_tmdb_id ? String(item.show_tmdb_id) : ""}
  data-season={item.season_number != null ? String(item.season_number) : ""}
  data-episode-number={item.episode_number != null ? String(item.episode_number) : ""}
  data-watched={String(watched)}
  data-collected={String(inLibrary)}
  data-listed={String(inLists.length > 0)}
  data-dvr={String(isDvr)}
  data-partial-watched={String(isPartialWatched)}
  data-partial-collected={String(isPartialCollected)}
>
  <!-- Left Side: Poster -->
  {href ? (
    <a href={href} class="block shrink-0 w-24 sm:w-32 md:w-40 relative">
      <div class="h-full bg-zinc-950 relative overflow-hidden" data-adult={item.adult ? "true" : undefined}>
        {posterPath ? (
          <img
            src={posterPath}
            alt={item.title}
            class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500 absolute inset-0"
            loading="lazy"
            decoding="async"
          />
        ) : (
          <div class="w-full h-full flex flex-col items-center justify-center text-zinc-700 bg-zinc-900 p-2 text-center absolute inset-0">
            <span class="text-2xl sm:text-3xl mb-1 opacity-30">🎬</span>
            <span class="text-[10px] font-bold uppercase tracking-widest line-clamp-2">{item.title}</span>
          </div>
        )}
        <div class="absolute inset-0 bg-gradient-to-r from-transparent via-transparent to-zinc-900 pointer-events-none opacity-80 md:opacity-0 md:group-hover:opacity-100 transition-opacity duration-300"></div>
        {item.library?.resolution && (
          <div class="absolute bottom-2 left-2 bg-zinc-900/90 backdrop-blur-md text-zinc-100 text-[9px] sm:text-[11px] font-bold px-1.5 sm:px-2 py-0.5 rounded-md border border-zinc-700/50 shadow-lg tracking-tighter">
            {item.library.resolution}
          </div>
        )}
      </div>
    </a>
  ) : (
    <div class="block shrink-0 w-24 sm:w-32 md:w-40 relative">
      <div class="h-full bg-zinc-950 relative overflow-hidden" data-adult={item.adult ? "true" : undefined}>
        {posterPath ? (
          <img
            src={posterPath}
            alt={item.title}
            class="w-full h-full object-cover absolute inset-0"
            loading="lazy"
            decoding="async"
          />
        ) : (
          <div class="w-full h-full flex flex-col items-center justify-center text-zinc-700 bg-zinc-900 p-2 text-center absolute inset-0">
            <span class="text-2xl sm:text-3xl mb-1 opacity-30">🎬</span>
            <span class="text-[10px] font-bold uppercase tracking-widest line-clamp-2">{item.title}</span>
          </div>
        )}
      </div>
    </div>
  )}

  <!-- Right Side: Info & Actions -->
  <div class="flex-1 flex flex-col min-w-0 p-3 sm:p-4 bg-gradient-to-r from-zinc-900 to-zinc-950">
    <div class="flex-1 min-w-0 flex flex-col justify-center">
      <!-- Title & Header -->
      <div class="flex items-start justify-between gap-4">
        <a href={href || "#"} class={`block min-w-0 ${!href ? 'pointer-events-none' : ''}`}>
          {isEpisode && item.show_title ? (
            <h3 class="text-xs font-medium text-zinc-400 truncate mb-0.5">{item.show_title}</h3>
          ) : null}
          <h3 class="text-base sm:text-lg font-bold text-zinc-100 truncate group-hover:text-blue-400 transition-colors leading-tight mb-1">
            {item.title}
          </h3>
          <div class="flex items-center gap-2 mb-2 flex-wrap">
            {sxe && <span class="text-xs font-bold text-blue-400 tracking-wide">{sxe}</span>}
            {year && !sxe && !isPerson && <span class="text-xs font-medium text-zinc-500 tracking-wide">{year}</span>}
            {rating && (
              <span class="flex items-center gap-1 text-xs font-bold text-yellow-400 bg-yellow-400/10 px-1.5 py-0.5 rounded border border-yellow-400/20">
                <span class="leading-none mt-[-1px]">★</span> {rating}
              </span>
            )}
            <span class="text-[10px] font-bold text-zinc-400 uppercase tracking-widest px-1.5 py-0.5 bg-zinc-800/50 rounded border border-zinc-800">
              {isPerson ? 'Person' : isCollection ? 'Collection' : isSeries ? 'Show' : (item.type === 'episode' ? 'Episode' : item.type)}
            </span>
          </div>
        </a>
        
        <!-- Block Button -->
        {showActionBar && (
          <button
            data-action="block"
            title="Don't show this again"
            class="text-zinc-500 hover:text-red-500 p-2 rounded-full hover:bg-red-500/10 transition-colors cursor-pointer shrink-0 hidden sm:block"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/><path d="m4.9 4.9 14.2 14.2"/>
            </svg>
          </button>
        )}
      </div>

      <!-- Overview -->
      {overview && (
        <p class="text-sm text-zinc-400 line-clamp-2 sm:line-clamp-3 mb-3 leading-relaxed hidden sm:block max-w-4xl">
          {overview}
        </p>
      )}
    </div>

    <!-- Action Bar & Progress Strip -->
    <div class="mt-auto">
      {showActionBar && (
        <div class="flex justify-between items-end gap-4 mt-2 border-t border-zinc-800/50 pt-3">
          <div class="max-w-[200px] w-full hidden md:block">
            {isSeries && item.total_episodes_count !== undefined && (
              <ProgressStrip
                watchedEpisodesCount={item.watched_episodes_count}
                totalEpisodesCount={item.total_episodes_count}
                totalPlays={item.total_plays}
                totalDurationWatched={item.total_duration_watched}
                remainingEpisodesCount={item.remaining_episodes_count}
                remainingDuration={item.remaining_duration}
                className="mt-0"
              />
            )}
          </div>
          <div class="flex-1 flex justify-end">
            <CardActionBar
              watched={watched}
              inLists={inLists}
              inLibrary={inLibrary}
              collectionPct={collectionPct}
              isSeries={isSeries}
            />
          </div>
        </div>
      )}
      
      {showActionBar && (
        <div class="block md:hidden mt-3 w-full">
          {isSeries && item.total_episodes_count !== undefined && (
            <ProgressStrip
              watchedEpisodesCount={item.watched_episodes_count}
              totalEpisodesCount={item.total_episodes_count}
              totalPlays={item.total_plays}
              totalDurationWatched={item.total_duration_watched}
              remainingEpisodesCount={item.remaining_episodes_count}
              remainingDuration={item.remaining_duration}
              className="mt-0"
            />
          )}
        </div>
      )}
    </div>
  </div>
</div>
