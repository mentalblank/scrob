---
interface Props {
  tmdbId: number;
  mediaType: string; // "movie" | "episode" | "series" | "season"
  seasonNumber?: number;
  inLibrary: boolean;
  title: string;
  token: string;
  secondary?: boolean;
}

const { tmdbId, mediaType, seasonNumber, inLibrary, title, token, secondary = false } = Astro.props;
---

{inLibrary && (
  <div class="w-full">
    <button
      id="play-btn"
      class={secondary
        ? "w-full h-11 flex items-center justify-center gap-2 px-4 text-sm font-bold leading-none text-zinc-300 bg-zinc-900/40 border border-zinc-800/80 hover:border-zinc-700 hover:bg-zinc-900/60 rounded-xl transition-all duration-300 active:scale-95 cursor-pointer"
        : "w-full h-11 flex items-center justify-center gap-2 px-5 text-sm font-bold leading-none text-white bg-blue-600 hover:bg-blue-500 rounded-xl transition-all duration-200 active:scale-95 cursor-pointer shadow-lg shadow-blue-900/20"}
    >
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 shrink-0">
        <path stroke-linecap="round" stroke-linejoin="round" d="M5.25 5.653c0-.856.917-1.398 1.667-.986l11.54 6.347a1.125 1.125 0 0 1 0 1.972l-11.54 6.347a1.125 1.125 0 0 1-1.667-.986V5.653Z" />
      </svg>
      Play
    </button>

    <dialog
      id="player-dialog"
      data-tmdb-id={tmdbId}
      data-media-type={mediaType}
      data-season-number={seasonNumber || ""}
      data-title={title}
      data-token={token}
      class="fixed inset-0 z-50 w-full max-w-5xl mx-auto my-auto bg-zinc-950/90 border border-zinc-800/80 rounded-2xl shadow-2xl p-0 backdrop:bg-black/60 backdrop:backdrop-blur-md"
    >
      <div class="flex items-center justify-between px-5 py-3 border-b border-zinc-800/60">
        <span id="player-title" class="text-sm font-bold text-zinc-100 truncate"></span>
        <button id="player-close" class="text-zinc-400 hover:text-zinc-200 transition p-1.5 rounded-xl hover:bg-zinc-900/60 cursor-pointer">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M18 6 6 18M6 6l12 12"/>
          </svg>
        </button>
      </div>
      <div class="bg-black relative">
        <video id="player-video" controls class="w-full max-h-[72vh] outline-none" preload="metadata"></video>
      </div>
      <div id="player-sources" class="px-5 py-3 flex flex-wrap gap-2 border-t border-zinc-800/60 min-h-[52px] items-center"></div>
    </dialog>
  </div>
)}

<script>
  function esc(str: string | null | undefined): string {
    if (str == null) return '';
    return String(str).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  }

  const dialog = document.getElementById('player-dialog') as HTMLDialogElement | null;
  if (dialog) {
    const tmdbId    = dialog.dataset.tmdbId!;
    const mediaType = dialog.dataset.mediaType!;
    const seasonNum = dialog.dataset.seasonNumber;
    const title     = dialog.dataset.title!;
    const token     = dialog.dataset.token!;

    const playBtn   = document.getElementById('play-btn') as HTMLButtonElement | null;
    const video     = document.getElementById('player-video') as HTMLVideoElement;
    const titleEl   = document.getElementById('player-title') as HTMLSpanElement;
    const sourcesEl = document.getElementById('player-sources') as HTMLDivElement;
    const closeBtn  = document.getElementById('player-close') as HTMLButtonElement | null;

    let currentConnectionId: string | null = null;
    let currentSubtitles: { index: number; language: string; label: string }[] = [];
    let sessionTimer: ReturnType<typeof setInterval> | null = null;

    function stopSession(): void {
      if (sessionTimer) { clearInterval(sessionTimer); sessionTimer = null; }
    }

    function attachSubtitles(connectionId: string, subtitles: typeof currentSubtitles): void {
      Array.from(video.querySelectorAll('track')).forEach(t => t.remove());
      subtitles.forEach(sub => {
        const track = document.createElement('track');
        track.kind = 'subtitles';
        track.src = `/api/proxy/media/subtitles/${mediaType}/${tmdbId}?connection_id=${connectionId}&stream_index=${sub.index}`;
        track.srclang = sub.language || '';
        track.label = sub.label || sub.language || 'Subtitle';
        video.appendChild(track);
      });
    }

    async function reportSession(state: string): Promise<void> {
      if (!currentConnectionId) return;
      try {
        await fetch(`/api/proxy/media/session/report/${mediaType}/${tmdbId}`, {
          method: 'POST',
          headers: {
            'Authorization': `Bearer ${token}`,
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({
            connection_id: parseInt(currentConnectionId),
            state,
            position_ms: Math.round(video.currentTime * 1000),
            duration_ms: Math.round((video.duration || 0) * 1000),
          }),
        });
      } catch {}
    }

    function loadSource(
      connectionId: string,
      subtitles: typeof currentSubtitles,
    ): void {
      stopSession();
      currentConnectionId = connectionId;
      currentSubtitles = subtitles;
      attachSubtitles(connectionId, subtitles);

      video.src = `/api/proxy/media/stream/${mediaType}/${tmdbId}?connection_id=${connectionId}`;
      video.load();
      video.play().catch(() => {});
      reportSession('playing');
      sessionTimer = setInterval(() => {
        if (!video.paused && !video.ended) reportSession('progress');
      }, 10_000);
    }

    video.addEventListener('pause', () => { reportSession('paused'); });
    video.addEventListener('play',  () => { reportSession('playing'); });

    function renderSources(sources: {
      connection_id: string;
      source: string;
      name: string;
      resolution?: string;
      subtitles: { index: number; language: string; label: string }[];
    }[]): void {
      if (sources.length === 0) {
        sourcesEl.innerHTML = '<span class="text-xs text-zinc-500">No playback source found.</span>';
        return;
      }
      const LOCAL_SOURCES = ['plex', 'jellyfin', 'emby'];
      sourcesEl.innerHTML = sources.map((s, i) =>
        `<button
          class="source-btn flex items-center gap-1.5 px-3 py-1.5 text-xs font-bold rounded-xl border transition-all cursor-pointer ${i === 0 ? 'bg-blue-600 border-blue-500 text-white hover:bg-blue-500' : 'bg-zinc-900/40 border-zinc-800 text-zinc-300 hover:border-zinc-700'}"
          data-connection-id="${s.connection_id}"
          data-subtitles="${esc(JSON.stringify(s.subtitles || []))}"
        >
          ${LOCAL_SOURCES.includes(s.source) ? `<img src="/icons/${esc(s.source)}.svg" alt="${esc(s.source)}" class="w-4 h-4 rounded shrink-0" />` : ''}
          ${esc(s.name)}${s.resolution ? ` <span class="opacity-60 font-mono">${esc(s.resolution)}</span>` : ''}
        </button>`
      ).join('');

      sourcesEl.querySelectorAll<HTMLButtonElement>('.source-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          sourcesEl.querySelectorAll('.source-btn').forEach(b => {
            b.classList.remove('bg-blue-600', 'border-blue-500', 'text-white', 'hover:bg-blue-500');
            b.classList.add('bg-zinc-900/40', 'border-zinc-800', 'text-zinc-300', 'hover:border-zinc-700');
          });
          btn.classList.add('bg-blue-600', 'border-blue-500', 'text-white', 'hover:bg-blue-500');
          btn.classList.remove('bg-zinc-900/40', 'border-zinc-800', 'text-zinc-300', 'hover:border-zinc-700');
          loadSource(btn.dataset.connectionId!, JSON.parse(btn.dataset.subtitles || '[]'));
        });
      });
    }

    function closePlayer(): void {
      reportSession('stopped');
      stopSession();
      video.pause();
      video.src = '';
      dialog.close();
    }

    async function startPlayback(preferredConnectionId?: number) {
      if (playBtn) {
        const origText = playBtn.innerHTML;
        playBtn.innerHTML = '<span class="animate-pulse flex items-center justify-center gap-2"><svg class="animate-spin -ml-1 mr-2 h-4 w-4 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>Loading</span>';
        playBtn.classList.add('opacity-80', 'cursor-not-allowed');
      }

      try {
        const url = new URL(`/api/proxy/media/playback/${mediaType}/${tmdbId}`, window.location.origin);
        if (seasonNum) url.searchParams.append('season_number', seasonNum);
        
        const res = await fetch(url.toString(), {
          headers: { 'Authorization': `Bearer ${token}` },
        });
        
        const sources = res.ok ? await res.json() : [];
        
        if (playBtn) {
          playBtn.innerHTML = playBtn.dataset.origText || playBtn.innerHTML;
          playBtn.classList.remove('opacity-80', 'cursor-not-allowed');
        }

        // Try to find the preferred source if provided, otherwise the first external one
        const targetSource = preferredConnectionId 
          ? sources.find((s: any) => s.connection_id == preferredConnectionId) 
          : sources.find((s: any) => s.external_url);

        if (targetSource && targetSource.external_url) {
          window.open(targetSource.external_url, '_blank', 'noopener,noreferrer');
          return;
        }

        // Otherwise open the internal player modal
        titleEl.textContent = title;
        dialog.showModal();
        renderSources(sources);
        if (sources.length > 0) {
          // If preferred connection exists, select it, otherwise first
          const sourceToLoad = targetSource || sources[0];
          const btn = sourcesEl.querySelector(`[data-connection-id="${sourceToLoad.connection_id}"]`) as HTMLButtonElement;
          if (btn) btn.click();
        } else {
          sourcesEl.innerHTML = '<span class="text-xs text-red-400">No local playback sources found.</span>';
        }
      } catch {
        if (playBtn) {
          playBtn.innerHTML = playBtn.dataset.origText || playBtn.innerHTML;
          playBtn.classList.remove('opacity-80', 'cursor-not-allowed');
        }
        titleEl.textContent = title;
        dialog.showModal();
        sourcesEl.innerHTML = '<span class="text-xs text-red-400">Failed to load sources.</span>';
      }
    }

    if (playBtn) playBtn.dataset.origText = playBtn.innerHTML;
    playBtn?.addEventListener('click', () => startPlayback());

    document.addEventListener(`start-playback-${tmdbId}`, (e: Event) => {
      const ce = e as CustomEvent<{ connectionId?: number }>;
      startPlayback(ce.detail?.connectionId);
    });

    closeBtn?.addEventListener('click', closePlayer);
    dialog.addEventListener('click', (e) => { if (e.target === dialog) closePlayer(); });
  }
</script>
