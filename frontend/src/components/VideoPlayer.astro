---
interface Props {
  uriId?: string | null;
  tmdbId?: number | null;
  mediaType: string; // "movie" | "episode" | "series" | "season"
  seasonNumber?: number;
  inLibrary: boolean;
  title: string;
  token: string;
  secondary?: boolean;
  mediaId?: number | null;
}

const { uriId, tmdbId, mediaType, seasonNumber, inLibrary, title, token, secondary = false, mediaId } = Astro.props;
const mediaRef = uriId ?? (tmdbId != null ? String(tmdbId) : "0");
const useHls = Astro.cookies.get("use_hls_player")?.value === "true";
const playbackTarget = Astro.cookies.get("playback_target")?.value || "web";
---

{inLibrary && (
  <div class="w-full">
    <button
      id="play-btn"
      class={secondary
        ? "w-full h-11 flex items-center justify-center gap-2 px-4 min-w-0 overflow-hidden text-sm font-bold leading-none text-zinc-300 bg-zinc-900/40 border border-zinc-800/80 hover:border-zinc-700 hover:bg-zinc-900/60 rounded-xl transition-all duration-300 active:scale-95 cursor-pointer"
        : "w-full h-11 flex items-center justify-center gap-2 px-4 min-w-0 overflow-hidden text-sm font-bold leading-none text-white bg-blue-600 hover:bg-blue-500 rounded-xl transition-all duration-200 active:scale-95 cursor-pointer shadow-lg shadow-blue-900/20"}
    >
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 shrink-0">
        <path stroke-linecap="round" stroke-linejoin="round" d="M5.25 5.653c0-.856.917-1.398 1.667-.986l11.54 6.347a1.125 1.125 0 0 1 0 1.972l-11.54 6.347a1.125 1.125 0 0 1-1.667-.986V5.653Z" />
      </svg>
      <span class="truncate">Play</span>
    </button>

    <dialog
      id="player-dialog"
      data-media-ref={mediaRef}
      data-media-id={mediaId ?? 0}
      data-media-type={mediaType}
      data-season-number={seasonNumber || ""}
      data-title={title}
      data-token={token}
      data-use-hls={useHls ? "true" : "false"}
      data-playback-target={playbackTarget}
      class="fixed inset-0 z-50 w-full max-w-5xl mx-auto my-auto bg-zinc-950/90 border border-zinc-800/80 rounded-2xl shadow-2xl p-0 backdrop:bg-zinc-950/85 backdrop:backdrop-blur-md"
    >
      <div class="flex items-center justify-between px-5 py-3 border-b border-zinc-800/60">
        <span id="player-title" class="text-sm font-bold text-zinc-100 truncate"></span>
        <button id="player-close" class="text-zinc-400 hover:text-zinc-200 transition p-1.5 rounded-xl hover:bg-zinc-900/60 cursor-pointer">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M18 6 6 18M6 6l12 12"/>
          </svg>
        </button>
      </div>
      <div class="bg-black relative">
        <video id="player-video" controls class="w-full max-h-[72vh] outline-none" preload="none"></video>
        <div id="player-error" class="hidden absolute inset-0 flex items-center justify-center bg-black/90 p-6 pointer-events-none">
          <div class="pointer-events-auto text-center max-w-xs">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-red-400 mx-auto mb-3" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z" />
            </svg>
            <p id="player-error-msg" class="text-zinc-200 text-sm font-semibold mb-1">Playback failed</p>
            <p id="player-error-detail" class="text-zinc-400 text-xs mb-4"></p>
            <a id="player-error-link" href="/settings" class="hidden inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-bold rounded-lg bg-blue-600 hover:bg-blue-500 text-white transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.325.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 0 1 1.37.49l1.296 2.247a1.125 1.125 0 0 1-.26 1.431l-1.003.827c-.293.241-.438.613-.43.992a7.723 7.723 0 0 1 0 .255c-.008.378.137.75.43.991l1.004.827c.424.35.534.955.26 1.43l-1.298 2.247a1.125 1.125 0 0 1-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.47 6.47 0 0 1-.22.128c-.331.183-.581.495-.644.869l-.213 1.281c-.09.543-.56.94-1.11.94h-2.594c-.55 0-1.019-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 0 1-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 0 1-1.369-.49l-1.297-2.247a1.125 1.125 0 0 1 .26-1.431l1.004-.827c.292-.24.437-.613.43-.991a6.932 6.932 0 0 1 0-.255c.007-.38-.138-.751-.43-.992l-1.004-.827a1.125 1.125 0 0 1-.26-1.43l1.297-2.247a1.125 1.125 0 0 1 1.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.086.22-.128.332-.183.582-.495.644-.869l.214-1.28Z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
              </svg>
              Enable HLS Player in Settings
            </a>
          </div>
        </div>
      </div>
      <div id="player-sources" class="px-5 py-3 flex flex-wrap gap-2 border-t border-zinc-800/60 min-h-[52px] items-center"></div>
    </dialog>
  </div>
)}

<script>
  import Hls from 'hls.js';

  function esc(str: string | null | undefined): string {
    if (str == null) return '';
    return String(str)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  };

  function generateUUID(): string {
    return 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, function(c) {
      const r = Math.random() * 16 | 0;
      const v = c === 'x' ? r : (r & 0x3 | 0x8);
      return v.toString(16);
    });
  }

  function getSupportedCodecs(): { video: string; audio: string } {
    const ms = (window as any).MediaSource;
    const check = (mime: string): boolean => {
      try { return ms?.isTypeSupported?.(mime) ?? false; } catch { return false; }
    };
    const video: string[] = ['h264']; // always baseline-safe
    if (check('video/mp4; codecs="hvc1.1.6.L153.B0"') || check('video/mp4; codecs="hev1.1.6.L153.B0"')) video.push('hevc');
    if (check('video/mp4; codecs="av01.0.08M.08"')) video.push('av1');
    if (check('video/webm; codecs="vp9"') || check('video/mp4; codecs="vp09.00.10.08"')) video.push('vp9');

    const audio: string[] = ['aac', 'mp3'];
    if (check('audio/mp4; codecs="ac-3"')) audio.push('ac3');
    if (check('audio/mp4; codecs="ec-3"')) audio.push('eac3');
    audio.push('opus', 'vorbis');

    return { video: video.join(','), audio: audio.join(',') };
  }

  const dialog = document.getElementById('player-dialog') as HTMLDialogElement | null;
  if (dialog) {
    const mediaRef  = dialog.dataset.mediaRef!;
    const mediaId   = parseInt(dialog.dataset.mediaId ?? '0', 10) || null;
    const mediaType = dialog.dataset.mediaType!;
    const seasonNum = dialog.dataset.seasonNumber;
    const title     = dialog.dataset.title!;
    const token     = dialog.dataset.token!;
    const useHls    = dialog.dataset.useHls === "true";
    const playbackTarget = dialog.dataset.playbackTarget || 'web';
    const mediaIdParam = mediaId ? `&media_id=${mediaId}` : '';

    const playBtn   = document.getElementById('play-btn') as HTMLButtonElement | null;
    const video     = document.getElementById('player-video') as HTMLVideoElement;

    // On-demand subtitle loading for Plex embedded subtitle tracks
    video.textTracks.addEventListener('change', () => {
      for (let i = 0; i < video.textTracks.length; i++) {
        const track = video.textTracks[i];
        if (track.mode === 'showing') {
          const trackEl = Array.from(video.querySelectorAll('track')).find(el => el.track === track);
          if (trackEl && trackEl.dataset.src && !trackEl.src) {
            trackEl.src = trackEl.dataset.src;
          }
        }
      }
    });

    const titleEl   = document.getElementById('player-title') as HTMLSpanElement;
    const sourcesEl = document.getElementById('player-sources') as HTMLDivElement;
    const closeBtn  = document.getElementById('player-close') as HTMLButtonElement | null;

    let currentConnectionId: string | null = null;
    let currentFileId: string | null = null;
    let currentSubtitles: { index: number; key?: string | null; language: string; label: string }[] = [];
    let currentPlexSessionId: string | null = null;
    let sessionTimer: ReturnType<typeof setInterval> | null = null;
    let hlsInstance: Hls | null = null;

    const errorOverlay  = document.getElementById('player-error') as HTMLDivElement;
    const errorDetail   = document.getElementById('player-error-detail') as HTMLParagraphElement;
    const errorLink     = document.getElementById('player-error-link') as HTMLAnchorElement;

    function showPlaybackError(detail: string, showHlsHint: boolean): void {
      errorDetail.textContent = detail;
      errorLink.classList.toggle('hidden', !showHlsHint);
      errorOverlay.classList.remove('hidden');
    }

    function hidePlaybackError(): void {
      errorOverlay.classList.add('hidden');
    }

    function canBrowserPlay(videoCodec: string | null, audioCodec: string | null): boolean {
      const check = (mime: string) => video.canPlayType(mime) !== '';
      if (videoCodec) {
        const vc = videoCodec.toLowerCase();
        if (vc === 'hevc' || vc === 'h265' || vc === 'hvc1' || vc === 'hev1') {
          if (!check('video/mp4; codecs="hvc1.1.6.L153.B0"') && !check('video/mp4; codecs="hev1.1.6.L153.B0"')) return false;
        } else if (vc === 'av1' || vc === 'av01') {
          if (!check('video/mp4; codecs="av01.0.08M.08"') && !check('video/webm; codecs="av01"')) return false;
        } else if (vc === 'vp9') {
          if (!check('video/webm; codecs="vp9"') && !check('video/mp4; codecs="vp09.00.10.08"')) return false;
        }
      }
      if (audioCodec) {
        const ac = audioCodec.toLowerCase();
        if (ac === 'ac3' || ac === 'ac-3') {
          if (!check('audio/mp4; codecs="ac-3"')) return false;
        } else if (ac === 'eac3' || ac === 'ec-3' || ac === 'truehd') {
          if (!check('audio/mp4; codecs="ec-3"')) return false;
        } else if (ac === 'dts' || ac === 'dts-hd' || ac === 'dca') {
          return false;
        }
      }
      return true;
    }

    function stopSession() {
      if (sessionTimer) { clearInterval(sessionTimer); sessionTimer = null; }
    }

    function destroyHls(): void {
      if (hlsInstance) { hlsInstance.destroy(); hlsInstance = null; }
    }

    function attachSubtitles(
      connectionId: string,
      fileId: string | null,
      subtitles: typeof currentSubtitles,
      session: string | null = null,
      source: string | null = null,
    ): void {
      Array.from(video.querySelectorAll('track')).forEach(t => t.remove());
      const fileParam = fileId ? `&file_id=${fileId}` : '';
      const sessionParam = session ? `&session=${encodeURIComponent(session)}` : '';
      subtitles.forEach(sub => {
        const track = document.createElement('track');
        track.kind = 'subtitles';
        const keyParam = sub.key ? `&key=${encodeURIComponent(sub.key)}` : '';
        const srcUrl = `/api/proxy/media/subtitles/${mediaType}/${mediaRef}?connection_id=${connectionId}&stream_index=${sub.index}${keyParam}${sessionParam}${mediaIdParam}${fileParam}`;

        // On-demand subtitle loading for Plex embedded subtitle tracks to prevent overwhelming the server with concurrent transcode sessions
        const isPlexEmbedded = source === 'plex' && (!sub.key || sub.key === 'None');
        if (isPlexEmbedded) {
          track.setAttribute('data-src', srcUrl);
        } else {
          track.src = srcUrl;
        }

        track.srclang = sub.language || '';
        track.label = sub.label || sub.language || 'Subtitle';
        video.appendChild(track);
        // Explicitly set mode to 'disabled' to register and load the track in the browser's TextTrackList
        track.track.mode = 'disabled';
      });
    }

    async function reportSession(state) {
      if (!currentConnectionId) return;
      try {
        await fetch(`/api/proxy/media/session/report/${mediaType}/${mediaRef}${mediaIdParam}`, {
          method: 'POST',
          headers: {
            'Authorization': `Bearer ${token}`,
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({
            connection_id: parseInt(currentConnectionId),
            file_id: currentFileId ? parseInt(currentFileId) : null,
            state,
            position_ms: Math.round(video.currentTime * 1000),
            duration_ms: Math.round((video.duration || 0) * 1000),
            plex_session_id: currentPlexSessionId,
          }),
        });
      } catch {}
    }

    function loadHlsUrl(url: string): void {
      destroyHls();
      if (Hls.isSupported()) {
        hlsInstance = new Hls({ xhrSetup: (xhr) => { xhr.setRequestHeader('Authorization', `Bearer ${token}`); } });
        hlsInstance.on(Hls.Events.ERROR, (_ev, data) => {
          if (data.fatal) {
            const detail = data.type === Hls.ErrorTypes.MEDIA_ERROR
              ? 'Your browser cannot decode this media format. Try a different source.'
              : 'Failed to load the HLS stream. The server may be unreachable.';
            showPlaybackError(detail, false);
          }
        });
        hlsInstance.attachMedia(video);
        hlsInstance.loadSource(url);
        video.play().catch(() => {});
      } else if (video.canPlayType('application/vnd.apple.mpegurl')) {
        // Safari — native HLS
        video.src = url;
        video.load();
        video.play().catch(() => {});
      }
    }

    video.addEventListener('canplay', () => hidePlaybackError());

    video.addEventListener('error', () => {
      const err = video.error;
      if (!err) return;
      const isCodecError = err.code === MediaError.MEDIA_ERR_DECODE || err.code === MediaError.MEDIA_ERR_SRC_NOT_SUPPORTED;
      if (!isCodecError) return;
      const detail = useHls
        ? 'Your browser cannot decode this media format. Try a different source or check your browser\'s codec support.'
        : 'Your browser may not support the codec used by this file.';
      showPlaybackError(detail, !useHls);
    });

    function loadSource(
      connectionId: string,
      fileId: string | null,
      source: string,
      subtitles: typeof currentSubtitles,
      videoCodec: string | null = null,
      audioCodec: string | null = null,
    ): void {
      hidePlaybackError();
      const willUseHls = useHls && (source === 'plex' || source === 'jellyfin' || source === 'emby');
      if (!willUseHls && !canBrowserPlay(videoCodec, audioCodec)) {
        const detail = 'Your browser cannot play this codec combination.';
        showPlaybackError(detail, true);
        return;
      }
      stopSession();
      currentConnectionId = connectionId;
      currentFileId = fileId;
      currentSubtitles = subtitles;

      const plexSessionId = source === 'plex' ? generateUUID() : null;
      currentPlexSessionId = plexSessionId;
      attachSubtitles(connectionId, fileId, subtitles, plexSessionId, source);

      const fileParam = fileId ? `&file_id=${fileId}` : '';

      if (useHls && (source === 'plex' || source === 'jellyfin' || source === 'emby')) {
        const codecs = getSupportedCodecs();
        const codecParams = `&video_codecs=${encodeURIComponent(codecs.video)}&audio_codecs=${encodeURIComponent(codecs.audio)}`;
        const sessionParam = plexSessionId ? `&session_id=${plexSessionId}` : '';
        const hlsPath = source === 'plex' ? 'plex-hls' : 'hls';
        loadHlsUrl(`/api/proxy/media/${hlsPath}/${mediaType}/${mediaRef}?connection_id=${connectionId}${mediaIdParam}${fileParam}${codecParams}${sessionParam}`);
      } else {
        destroyHls();
        video.src = `/api/proxy/media/stream/${mediaType}/${mediaRef}?connection_id=${connectionId}${mediaIdParam}${fileParam}&token=${encodeURIComponent(token)}`;
        video.play().catch(() => {});
      }

      reportSession('playing');
      sessionTimer = setInterval(() => {
        if (!video.paused && !video.ended) reportSession('progress');
      }, 10000);
    }

    video.addEventListener('pause',   () => { reportSession('paused'); });
    video.addEventListener('play',    () => { reportSession('playing'); });
    async function markWatched(): Promise<void> {
      try {
        const uId = mediaRef.includes(':') ? mediaRef : (mediaType === 'movie' ? `tmdb:m:${mediaRef}` : `tmdb:e:${mediaRef}`);
        await fetch('/api/proxy/history', {
          method: 'POST',
          keepalive: true,
          headers: { 'Authorization': `Bearer ${token}`, 'Content-Type': 'application/json' },
          body: JSON.stringify({ uri_id: uId, media_type: mediaType, completed: true }),
        });
      } catch {}
    }

    video.addEventListener('ended', () => {
      stopSession();
      reportSession('stopped');
      markWatched();
    });

    function renderSources(sources: {
      file_id?: string;
      connection_id: string;
      source: string;
      name: string;
      resolution?: string;
      video_codec?: string | null;
      audio_codec?: string | null;
      subtitles: { index: number; key?: string | null; language: string; label: string }[];
    }[]): void {
      if (sources.length === 0) {
        sourcesEl.innerHTML = '<span class="text-xs text-zinc-500">No playback source found.</span>';
        return;
      }
      const LOCAL_SOURCES = ['plex', 'jellyfin', 'emby'];
      sourcesEl.innerHTML = sources.map((s, i) =>
        `<button
          class="source-btn flex items-center gap-1.5 px-3 py-1.5 text-xs font-bold rounded-xl border transition-all cursor-pointer ${i === 0 ? 'bg-blue-600 border-blue-500 text-white hover:bg-blue-500' : 'bg-zinc-900/40 border-zinc-800 text-zinc-300 hover:border-zinc-700'}"
          data-connection-id="${s.connection_id}"
          data-file-id="${s.file_id ?? ''}"
          data-source="${esc(s.source)}"
          data-video-codec="${esc(s.video_codec)}"
          data-audio-codec="${esc(s.audio_codec)}"
          data-subtitles="${esc(JSON.stringify(s.subtitles || []))}"
        >
          ${LOCAL_SOURCES.includes(s.source) ? `<img src="/icons/${esc(s.source)}.svg" alt="${esc(s.source)}" class="w-4 h-4 rounded shrink-0" />` : ''}
          ${esc(s.name)}${s.resolution ? ` <span class="opacity-60 font-mono">${esc(s.resolution)}</span>` : ''}
        </button>`
      ).join('');

      sourcesEl.querySelectorAll('.source-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          sourcesEl.querySelectorAll('.source-btn').forEach(b => {
            b.classList.remove('bg-blue-600', 'border-blue-500', 'text-white', 'hover:bg-blue-500');
            b.classList.add('bg-zinc-900/40', 'border-zinc-800', 'text-zinc-300', 'hover:border-zinc-700');
          });
          btn.classList.add('bg-blue-600', 'border-blue-500', 'text-white', 'hover:bg-blue-500');
          btn.classList.remove('bg-zinc-900/40', 'border-zinc-800', 'text-zinc-300', 'hover:border-zinc-700');
          const sourceBtn = btn as HTMLButtonElement;
          loadSource(
            sourceBtn.dataset.connectionId!,
            sourceBtn.dataset.fileId || null,
            sourceBtn.dataset.source!,
            JSON.parse(sourceBtn.dataset.subtitles || '[]'),
            sourceBtn.dataset.videoCodec || null,
            sourceBtn.dataset.audioCodec || null,
          );
        });
      });
    }

    function closePlayer(): void {
      const dur = video.duration;
      if (dur > 0 && video.currentTime / dur >= 0.95) markWatched();
      reportSession('stopped');
      stopSession();
      hidePlaybackError();
      destroyHls();
      video.pause();
      video.src = '';
      dialog.close();
    }

    async function startPlayback(preferredConnectionId?: string) {
      if (playBtn) {
        const origText = playBtn.innerHTML;
        playBtn.innerHTML = '<span class="animate-pulse flex items-center justify-center gap-2"><svg class="animate-spin -ml-1 mr-2 h-4 w-4 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>Loading</span>';
        playBtn.classList.add('opacity-80', 'cursor-not-allowed');
      }

      try {
        const url = new URL(`/api/proxy/media/playback/${mediaType}/${mediaRef}`, window.location.origin);
        if (seasonNum) url.searchParams.append('season_number', seasonNum);
        if (mediaId) url.searchParams.append('media_id', String(mediaId));
        
        const res = await fetch(url.toString(), {
          headers: { 'Authorization': `Bearer ${token}` },
        });
        
        const sources = res.ok ? await res.json() : [];
        
        if (playBtn) {
          playBtn.innerHTML = playBtn.dataset.origText || playBtn.innerHTML;
          playBtn.classList.remove('opacity-80', 'cursor-not-allowed');
        }

        // "internal" — always use the built-in player. "web" — open the server web page.
        if (playbackTarget !== 'internal') {
          const targetSource = preferredConnectionId
            ? sources.find((s: any) => s.connection_id == preferredConnectionId)
            : sources.find((s: any) => s.external_url);

          if (targetSource && targetSource.external_url) {
            window.open(targetSource.external_url, '_blank', 'noopener,noreferrer');
            return;
          }
        }

        // Otherwise open the internal player modal
        titleEl.textContent = title;
        dialog.showModal();
        renderSources(sources);
        if (sources.length > 0) {
          // If preferred connection exists, select it, otherwise first
          const preferred = preferredConnectionId
            ? sources.find((s: any) => s.connection_id == preferredConnectionId)
            : null;
          const sourceToLoad = preferred || sources[0];
          const btn = sourcesEl.querySelector(`[data-connection-id="${sourceToLoad.connection_id}"]`) as HTMLButtonElement | null;
          if (btn) btn.click();
        } else {
          sourcesEl.innerHTML = '<span class="text-xs text-red-400">No local playback sources found.</span>';
        }
      } catch {
        if (playBtn) {
          playBtn.innerHTML = playBtn.dataset.origText || playBtn.innerHTML;
          playBtn.classList.remove('opacity-80', 'cursor-not-allowed');
        }
        titleEl.textContent = title;
        dialog.showModal();
        sourcesEl.innerHTML = '<span class="text-xs text-red-400">Failed to load sources.</span>';
      }
    }

    if (playBtn) playBtn.dataset.origText = playBtn.innerHTML;
    playBtn?.addEventListener('click', () => startPlayback());

    document.addEventListener(`start-playback-${mediaRef}`, (e) => {
      const ce = e as CustomEvent;
      startPlayback(ce.detail?.connectionId);
    });

    closeBtn?.addEventListener('click', closePlayer);
    dialog.addEventListener('click', (e) => { if (e.target === dialog) closePlayer(); });
  }
</script>
