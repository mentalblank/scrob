---
const { token } = Astro.locals;
---

<div id="sync-status-container" class="space-y-4 mb-8 hidden" data-token={token}>
  <div class="flex items-center justify-between border-b border-zinc-800 pb-2">
    <h2 class="text-xl font-semibold text-zinc-100">Active Sync</h2>
    <button 
      id="abort-sync-btn"
      class="text-xs font-bold uppercase tracking-widest text-red-500 hover:text-red-400 transition-colors border border-red-500/30 px-2 py-1 rounded-md bg-red-500/5 cursor-pointer"
    >
      Abort All
    </button>
  </div>
  <div id="active-jobs" class="grid gap-4">
    <!-- Jobs will be injected here -->
  </div>
</div>

<script>
  function setupSyncStatus() {
    const container = document.getElementById('sync-status-container') as HTMLElement | null;
    if (!container) return;

    const activeJobsList = document.getElementById('active-jobs');
    const abortBtn = document.getElementById('abort-sync-btn') as HTMLButtonElement | null;
    const token = container.dataset.token ?? '';
    const apiUrl = '/api/proxy';

    if (abortBtn) {
      abortBtn.addEventListener('click', async () => {
        if (!confirm('Are you sure you want to abort all active sync jobs?')) return;
        
        abortBtn.disabled = true;
        abortBtn.textContent = 'ABORTING...';
        
        try {
          const res = await fetch(`${apiUrl}/sync/abort`, {
            method: 'POST',
            headers: { 'Authorization': `Bearer ${token}` }
          });
          if (res.ok) {
            updateStatus();
          }
        } catch (e) {
          console.error('Failed to abort sync', e);
        } finally {
          abortBtn.disabled = false;
          abortBtn.textContent = 'ABORT ALL';
        }
      });
    }

    function esc(s: unknown): string {
      if (s == null) return '';
      return String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
    }

    async function updateStatus() {
      try {
        const res = await fetch(`${apiUrl}/sync/status`, {
          headers: { 'Authorization': `Bearer ${token}` }
        });
        if (!res.ok) return;
        
        const jobs = await res.json();
        const activeJobs = jobs.filter((j: any) => j.status === 'running' || j.status === 'pending' || (j.status === 'failed' && new Date(j.updated_at).getTime() > Date.now() - 15000));
        
        if (activeJobs.length > 0) {
          container.classList.remove('hidden');
          if (activeJobsList) {
            activeJobsList.innerHTML = activeJobs.map((job: any) => {
              const percent = job.total_items > 0
                ? Math.min(100, Math.round((job.processed_items / job.total_items) * 100))
                : 0;
              
              const isFailed = job.status === 'failed';
              const statusText = isFailed ? 'Failed' : job.status;
              const statusColor = isFailed ? 'text-red-500' : 'text-zinc-500';
              
              return `
                <div class="bg-zinc-900/50 border border-zinc-800 rounded-xl p-4 ${isFailed ? 'border-red-500/20' : ''}">
                  <div class="flex justify-between items-center mb-2">
                    <div class="flex items-center gap-2">
                      <span class="w-2 h-2 ${job.source === 'plex' ? 'bg-plex' : job.source === 'trakt' ? 'bg-red-500' : 'bg-jellyfin'} rounded-full"></span>
                      <span class="font-medium text-zinc-100 capitalize">${esc(job.source)} Sync</span>
                    </div>
                    <span class="text-xs ${statusColor} capitalize font-medium">${esc(statusText)}</span>
                  </div>
                  
                  ${isFailed ? `
                    <div class="text-xs text-red-400 bg-red-400/5 border border-red-400/10 rounded p-2 mb-1">
                      ${esc(job.error_message || 'Unknown error')}
                    </div>
                  ` : `
                    <div class="w-full bg-zinc-800 rounded-full h-1.5 mb-2 overflow-hidden">
                      <div class="bg-blue-600 h-1.5 rounded-full transition-all duration-500" style="width: ${percent}%"></div>
                    </div>
                    
                    <div class="flex justify-between text-xs text-zinc-500 uppercase tracking-wider font-bold">
                      <span>${percent >= 100 ? 'Enriching metadata...' : `${esc(String(job.processed_items))} / ${esc(String(job.total_items || '?'))} items`}</span>
                      <span>${esc(String(percent))}%</span>
                    </div>
                  `}
                </div>
              `;
            }).join('');
          }
          
          // Poll faster if there are active jobs
          setTimeout(updateStatus, 2000);
        } else {
          container.classList.add('hidden');
          // Poll slower if no active jobs
          setTimeout(updateStatus, 10000);
        }
      } catch (e) {
        console.error('Failed to poll sync status', e);
        setTimeout(updateStatus, 10000);
      }
    }

    updateStatus();
  }

  // Initial setup
  setupSyncStatus();
  // Setup again on navigation (Astro View Transitions)
  document.addEventListener('astro:after-swap', setupSyncStatus);
</script>
