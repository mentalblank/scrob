---
interface Props {
  code: string | number;
  title: string;
  message: string;
  glowColor?: 'blue' | 'red' | 'purple' | 'amber' | 'green';
  gradientClasses?: string;
  showReload?: boolean;
}

const {
  code,
  title,
  message,
  glowColor = 'blue',
  gradientClasses = 'from-blue-500 via-indigo-400 to-purple-500',
  showReload = false,
} = Astro.props;

const glowColorMap = {
  blue: 'bg-blue-600/10',
  red: 'bg-red-600/10',
  purple: 'bg-purple-600/10',
  amber: 'bg-amber-600/10',
  green: 'bg-green-600/10',
};

const glowClass = glowColorMap[glowColor] || 'bg-blue-600/10';
---

<div class="flex flex-col items-center justify-center min-h-[60vh] px-4 text-center">
  <div class="relative mb-8">
    <!-- Glow background effect -->
    <div class={`absolute inset-0 ${glowClass} blur-3xl rounded-full scale-150`}></div>
    
    <!-- Big styled code number -->
    <h1 class={`relative text-8xl md:text-9xl font-black tracking-widest text-transparent bg-clip-text bg-gradient-to-r ${gradientClasses} drop-shadow-lg select-none`}>
      {code}
    </h1>
  </div>

  <!-- Error title -->
  <h2 class="text-2xl md:text-3xl font-bold text-zinc-100 mb-3 tracking-tight">
    {title}
  </h2>

  <!-- Error description -->
  <p class="text-zinc-400 max-w-md mx-auto mb-8 text-sm md:text-base leading-relaxed">
    {message}
  </p>

  <!-- Navigation buttons -->
  <div class="flex flex-wrap items-center justify-center gap-4">
    {showReload && (
      <button 
        onclick="window.location.reload()" 
        class="inline-flex items-center gap-2 px-6 py-3.5 bg-zinc-800 hover:bg-zinc-700 border border-zinc-700 text-zinc-100 font-bold rounded-xl transition-all hover:scale-[1.02] active:scale-95 duration-200 cursor-pointer"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="shrink-0">
          <path d="M21 12a9 9 0 1 1-9-9c2.52 0 4.93 1 6.72 2.78L21.5 8"/>
          <polyline points="21.5 3 21.5 8 16.5 8"/>
        </svg>
        <span>Reload Page</span>
      </button>
    )}

    <a 
      href="/" 
      class="inline-flex items-center gap-2 px-6 py-3.5 bg-blue-600 hover:bg-blue-500 text-white font-bold rounded-xl transition-all shadow-lg shadow-blue-600/20 hover:shadow-blue-600/30 hover:scale-[1.02] active:scale-95 duration-200 cursor-pointer"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="shrink-0">
        <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
        <polyline points="9 22 9 12 15 12 15 22"/>
      </svg>
      <span>Back to Home</span>
    </a>
  </div>
</div>
