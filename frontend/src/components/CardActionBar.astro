---
interface Props {
  watched: boolean;
  inLists: number[];
  inLibrary: boolean;
  collectionPct: number;
  isSeries: boolean;
}

const { watched, inLists, inLibrary, collectionPct, isSeries } = Astro.props;

const collectStyle = isSeries && collectionPct > 0
  ? `background: linear-gradient(to right, rgba(168,85,247,0.2) ${collectionPct}%, transparent ${collectionPct}%)`
  : '';
---

<div class="card-action-bar">
  <!-- Watched (green) -->
  <button
    data-action="watched"
    data-watched={String(watched)}
    data-state={watched ? 'active' : 'inactive'}
    title={watched ? 'Mark as unwatched' : 'Mark as watched'}
    class="card-action-btn"
  >
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/>
      <circle cx="12" cy="12" r="3" fill={watched ? "currentColor" : "none"}/>
    </svg>
  </button>

  <!-- Lists (sky) -->
  <button
    data-action="list"
    data-in-lists={JSON.stringify(inLists)}
    data-state={inLists.length > 0 ? 'active' : 'inactive'}
    title="Add to list"
    class="card-action-btn"
  >
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <line x1="8" y1="6" x2="21" y2="6"/>
      <line x1="8" y1="12" x2="21" y2="12"/>
      <line x1="8" y1="18" x2="21" y2="18"/>
      <line x1="3" y1="6" x2="3.01" y2="6"/>
      <line x1="3" y1="12" x2="3.01" y2="12"/>
      <line x1="3" y1="18" x2="3.01" y2="18"/>
    </svg>
  </button>

  <!-- Collected (purple) -->
  <button
    data-action="collected"
    data-in-library={String(inLibrary)}
    data-collection-pct={String(collectionPct)}
    data-state={inLibrary ? 'active' : 'inactive'}
    title={isSeries ? `${collectionPct}% in library` : (inLibrary ? 'Remove from collection' : 'Add to collection')}
    style={collectStyle}
    class="card-action-btn"
  >
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="m2 7 4.41-4.41A2 2 0 0 1 7.83 2h8.34a2 2 0 0 1 1.42.59L22 7"/>
      <path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/>
      <path d="M15 22v-4a3 3 0 0 0-6 0v4"/>
      <path d="M2 7h20"/>
    </svg>
  </button>
</div>
