---
interface Props {
  currentPage: number;
  totalPages: number;
  baseUrl: string;
}

const { currentPage, totalPages, baseUrl } = Astro.props;

// Limit to 500 pages as per TMDB recommendation
const effectiveTotalPages = Math.min(totalPages, 500);

const hasPrevious = currentPage > 1;
const hasNext = currentPage < effectiveTotalPages;

const getUrl = (p: number) => `${baseUrl}${baseUrl.includes('?') ? '&' : '?'}page=${p}`;

// Desktop: ±2 around current (5 pages). Mobile: ±1 (3 pages).
const getPages = (delta: number) => {
  const start = Math.max(1, currentPage - delta);
  const end = Math.min(effectiveTotalPages, currentPage + delta);
  const adjustedStart = Math.max(1, Math.min(start, effectiveTotalPages - delta * 2));
  const adjustedEnd = Math.min(effectiveTotalPages, adjustedStart + delta * 2);
  const pages = [];
  for (let i = adjustedStart; i <= adjustedEnd; i++) pages.push(i);
  return pages;
};

const pagesDesktop = getPages(2); // 5 wide
const pagesMobile  = getPages(1); // 3 wide
---

{effectiveTotalPages > 1 && (
<nav aria-label="Pagination" class="mt-12 mb-8 flex flex-col items-center gap-3">
  <div class="flex items-center justify-center gap-2">
    {/* Previous */}
    {hasPrevious ? (
      <a href={getUrl(currentPage - 1)} aria-label="Previous page" class="px-3 py-2 bg-zinc-900 border border-zinc-800 rounded-xl text-zinc-400 hover:text-zinc-100 hover:bg-zinc-800 transition shadow-sm">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" />
        </svg>
      </a>
    ) : (
      <span aria-hidden="true" class="px-3 py-2 bg-zinc-900/50 border border-zinc-800/50 rounded-xl text-zinc-700 cursor-not-allowed">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" />
        </svg>
      </span>
    )}

    {/* Mobile page numbers (±1) */}
    <div class="flex items-center gap-2 md:hidden">
      {pagesMobile[0] > 1 && (
        <>
          <a href={getUrl(1)} aria-label="Page 1" class="w-10 h-10 flex items-center justify-center bg-zinc-900 border border-zinc-800 rounded-xl text-zinc-400 hover:text-zinc-100 hover:bg-zinc-800 transition shadow-sm text-sm font-bold">1</a>
          {pagesMobile[0] > 2 && <span class="text-zinc-700 px-0.5" aria-hidden="true">…</span>}
        </>
      )}
      {pagesMobile.map(p => (
        <a
          href={getUrl(p)}
          aria-label={`Page ${p}`}
          aria-current={p === currentPage ? 'page' : undefined}
          class={`w-10 h-10 flex items-center justify-center rounded-xl transition-all border shadow-sm font-bold text-sm ${p === currentPage
            ? 'bg-blue-600 border-blue-500 text-white shadow-blue-900/20 scale-110 z-10'
            : 'bg-zinc-900 border-zinc-800 text-zinc-400 hover:text-zinc-100 hover:bg-zinc-800'}`}
        >{p}</a>
      ))}
      {pagesMobile[pagesMobile.length - 1] < effectiveTotalPages && (
        <>
          {pagesMobile[pagesMobile.length - 1] < effectiveTotalPages - 1 && <span class="text-zinc-700 px-0.5" aria-hidden="true">…</span>}
          <a href={getUrl(effectiveTotalPages)} aria-label={`Page ${effectiveTotalPages}`} class="w-10 h-10 flex items-center justify-center bg-zinc-900 border border-zinc-800 rounded-xl text-zinc-400 hover:text-zinc-100 hover:bg-zinc-800 transition shadow-sm text-sm font-bold">{effectiveTotalPages}</a>
        </>
      )}
    </div>

    {/* Desktop page numbers (±2) */}
    <div class="hidden md:flex items-center gap-2">
      {pagesDesktop[0] > 1 && (
        <>
          <a href={getUrl(1)} aria-label="Page 1" class="w-10 h-10 flex items-center justify-center bg-zinc-900 border border-zinc-800 rounded-xl text-zinc-400 hover:text-zinc-100 hover:bg-zinc-800 transition shadow-sm text-sm font-bold">1</a>
          {pagesDesktop[0] > 2 && <span class="text-zinc-700 px-1" aria-hidden="true">…</span>}
        </>
      )}
      {pagesDesktop.map(p => (
        <a
          href={getUrl(p)}
          aria-label={`Page ${p}`}
          aria-current={p === currentPage ? 'page' : undefined}
          class={`w-10 h-10 flex items-center justify-center rounded-xl transition-all border shadow-sm font-bold text-sm ${p === currentPage
            ? 'bg-blue-600 border-blue-500 text-white shadow-blue-900/20 scale-110 z-10'
            : 'bg-zinc-900 border-zinc-800 text-zinc-400 hover:text-zinc-100 hover:bg-zinc-800'}`}
        >{p}</a>
      ))}
      {pagesDesktop[pagesDesktop.length - 1] < effectiveTotalPages && (
        <>
          {pagesDesktop[pagesDesktop.length - 1] < effectiveTotalPages - 1 && <span class="text-zinc-700 px-1" aria-hidden="true">…</span>}
          <a href={getUrl(effectiveTotalPages)} aria-label={`Page ${effectiveTotalPages}`} class="w-10 h-10 flex items-center justify-center bg-zinc-900 border border-zinc-800 rounded-xl text-zinc-400 hover:text-zinc-100 hover:bg-zinc-800 transition shadow-sm text-sm font-bold">{effectiveTotalPages}</a>
        </>
      )}
    </div>

    {/* Next */}
    {hasNext ? (
      <a href={getUrl(currentPage + 1)} aria-label="Next page" class="px-3 py-2 bg-zinc-900 border border-zinc-800 rounded-xl text-zinc-400 hover:text-zinc-100 hover:bg-zinc-800 transition shadow-sm">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
        </svg>
      </a>
    ) : (
      <span aria-hidden="true" class="px-3 py-2 bg-zinc-900/50 border border-zinc-800/50 rounded-xl text-zinc-700 cursor-not-allowed">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
        </svg>
      </span>
    )}
  </div>

  {/* Jump to page */}
  {effectiveTotalPages > 5 && (
    <form id="page-jump-form" class="flex items-center gap-2">
      <label for="page-jump-input" class="text-xs text-zinc-500 whitespace-nowrap">Go to page</label>
      <input
        id="page-jump-input"
        type="number"
        min="1"
        max={effectiveTotalPages}
        placeholder={String(currentPage)}
        class="w-20 bg-zinc-900 border border-zinc-800 rounded-lg px-3 py-1.5 text-sm text-zinc-100 text-center focus:outline-none focus:ring-1 focus:ring-blue-500 focus:border-blue-500 transition [appearance:textfield] [&::-webkit-outer-spin-button]:appearance-none [&::-webkit-inner-spin-button]:appearance-none"
      />
      <span class="text-xs text-zinc-400">of {effectiveTotalPages}</span>
      <button type="submit" class="px-3 py-1.5 bg-zinc-800 hover:bg-zinc-700 text-zinc-300 text-xs font-bold rounded-lg transition cursor-pointer">Go</button>
    </form>
  )}
</nav>
)}

<script define:vars={{ baseUrl, effectiveTotalPages }}>
  const form = document.getElementById('page-jump-form');
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const input = document.getElementById('page-jump-input');
    const page = Math.max(1, Math.min(effectiveTotalPages, parseInt(input.value, 10)));
    if (!isNaN(page)) {
      const sep = baseUrl.includes('?') ? '&' : '?';
      window.location.href = `${baseUrl}${sep}page=${page}`;
    }
  });
</script>
