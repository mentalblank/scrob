---
import type { MediaItem } from "../lib/api";
import CardActionBar from "./CardActionBar.astro";

interface Props {
  item: MediaItem;
  showDismiss?: boolean;
}

const { item, showDismiss = false } = Astro.props;

const sxe =
  item.season_number != null && item.episode_number != null
    ? `S${String(item.season_number).padStart(2, "0")}E${String(item.episode_number).padStart(2, "0")}`
    : null;

const isSeries = item.type === "series";

const primaryMetadataSource = Astro.cookies.get("primary_metadata_source")?.value || "tmdb";

const href =
  primaryMetadataSource === "tvdb" && item.show_tvdb_id && item.season_number != null && item.episode_number != null
    ? `/show/tvdb/${item.show_tvdb_id}/season/${item.season_number}/${item.episode_number}`
    : item.show_tmdb_id && item.season_number != null && item.episode_number != null
      ? `/show/${item.show_tmdb_id}/season/${item.season_number}/${item.episode_number}`
      : item.show_tvdb_id && item.season_number != null && item.episode_number != null
        ? `/show/tvdb/${item.show_tvdb_id}/season/${item.season_number}/${item.episode_number}`
        : item.type === "movie" && item.tmdb_id
          ? `/media/movie/${item.tmdb_id}`
          : primaryMetadataSource === "tvdb" && item.show_tvdb_id
            ? `/show/tvdb/${item.show_tvdb_id}`
            : item.show_tmdb_id
              ? `/show/${item.show_tmdb_id}`
              : item.show_tvdb_id
                ? `/show/tvdb/${item.show_tvdb_id}`
                : isSeries && item.tmdb_id
                  ? `/show/${item.tmdb_id}`
                  : item.tmdb_id && item.season_number != null
                    ? `/media/${item.type}/${item.tmdb_id}`
                    : null;

// Episodes: use episode still, fall back to show backdrop then show poster. Movies/Series: use backdrop.
const rawImage = isSeries
  ? (item.backdrop_path ?? item.poster_path)
  : item.type === "movie"
    ? (item.backdrop_path ?? item.poster_path)
    : (item.poster_path ?? item.show_backdrop_path ?? item.show_poster_path);
const imageUrl = rawImage
  ? rawImage.startsWith("http")
    ? rawImage
    : `https://image.tmdb.org/t/p/w780${rawImage}`
  : null;

const watched = item.watched ?? false;
const inLists = item.in_lists ?? [];
const inLibrary = item.in_library ?? false;
const collectionPct = item.collection_pct ?? (inLibrary ? 100 : 0);

const progressPct = item.progress_percent ?? 0;
const showProgress = progressPct > 0;
---

<div
  class="group relative flex flex-col rounded-2xl overflow-hidden glass-card active:scale-95 active:opacity-70"
  data-card
  data-tmdb-id={String(item.tmdb_id)}
  data-media-type={item.type}
  data-show-tmdb-id={item.show_tmdb_id ? String(item.show_tmdb_id) : ""}
  data-season={item.season_number != null ? String(item.season_number) : ""}
  data-watched={String(watched)}
  data-collected={String(inLibrary)}
  data-listed={String(inLists.length > 0)}
>
  {href ? (
    <a href={href} class="block">
      <!-- Backdrop container: 3:2 (no title info here — info is below action bar) -->
      <div class="aspect-[3/2] bg-zinc-950 relative overflow-hidden ring-1 ring-white/5 group-hover:ring-blue-500/30 transition-all duration-300">
        {imageUrl ? (
          <img
            src={imageUrl}
            alt={item.title}
            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
            loading="lazy"
            decoding="async"
          />
        ) : (
          <div class="w-full h-full flex flex-col items-center justify-center p-4 text-center bg-zinc-900/40">
            <span class="text-3xl mb-2 opacity-30">📺</span>
            <span class="text-xs font-bold uppercase tracking-widest text-zinc-500">{item.show_title ?? item.title}</span>
          </div>
        )}

        <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>

        {item.library?.resolution && (
          <div class={`absolute top-2 ${showDismiss ? 'right-10' : 'right-2'} bg-zinc-950/60 backdrop-blur-md text-zinc-100 text-[11px] font-bold px-2 py-0.5 rounded-lg border border-zinc-800/80 shadow-lg tracking-tighter`}>
            {item.library.resolution}
          </div>
        )}

        {showDismiss && (
          <button
            data-action="remove-progress"
            class="absolute top-2 right-2 z-10 bg-zinc-950/60 backdrop-blur-md text-zinc-400 hover:text-red-400 p-1.5 rounded-full opacity-0 group-hover:opacity-100 transition-all duration-200 border border-zinc-800/80 hover:border-red-500/40 cursor-pointer shadow-lg active:scale-90 animate-none"
            title="Remove from Continue Watching"
            aria-label="Remove from continue watching"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
            </svg>
          </button>
        )}

        {showProgress && (
          <div class="absolute bottom-0 left-0 right-0 h-1.5 bg-zinc-800/80">
            <div class="h-full bg-blue-500 rounded-r-full" style={`width: ${progressPct}%`}></div>
          </div>
        )}
      </div>
    </a>
  ) : (
    <div class="block">
      <!-- Backdrop container: no link when metadata is incomplete -->
      <div class="aspect-[3/2] bg-zinc-950 relative overflow-hidden ring-1 ring-white/5">
        {imageUrl ? (
          <img
            src={imageUrl}
            alt={item.title}
            class="w-full h-full object-cover"
            loading="lazy"
            decoding="async"
          />
        ) : (
          <div class="w-full h-full flex flex-col items-center justify-center p-4 text-center bg-zinc-900/40">
            <span class="text-3xl mb-2 opacity-30">📺</span>
            <span class="text-xs font-bold uppercase tracking-widest text-zinc-500">{item.show_title ?? item.title}</span>
          </div>
        )}

        <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>

        {item.library?.resolution && (
          <div class={`absolute top-2 ${showDismiss ? 'right-10' : 'right-2'} bg-zinc-950/60 backdrop-blur-md text-zinc-100 text-[11px] font-bold px-2 py-0.5 rounded-lg border border-zinc-800/80 shadow-lg tracking-tighter`}>
            {item.library.resolution}
          </div>
        )}

        {showDismiss && (
          <button
            data-action="remove-progress"
            class="absolute top-2 right-2 z-10 bg-zinc-950/60 backdrop-blur-md text-zinc-400 hover:text-red-400 p-1.5 rounded-full opacity-0 group-hover:opacity-100 transition-all duration-200 border border-zinc-800/80 hover:border-red-500/40 cursor-pointer shadow-lg active:scale-90 animate-none"
            title="Remove from Continue Watching"
            aria-label="Remove from continue watching"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
            </svg>
          </button>
        )}

        {showProgress && (
          <div class="absolute bottom-0 left-0 right-0 h-1.5 bg-zinc-800/80">
            <div class="h-full bg-blue-500 rounded-r-full" style={`width: ${progressPct}%`}></div>
          </div>
        )}

        <div class="absolute bottom-2 left-2 right-2 bg-amber-500/90 backdrop-blur-md text-zinc-950 text-xs font-bold px-2 py-1 rounded-md text-center tracking-tight">
          Could not identify — try pulling your library
        </div>
      </div>
    </div>
  )}

  <!-- Action bar (below image, above info) -->
  {!showDismiss && (
    <CardActionBar
      watched={watched}
      inLists={inLists}
      inLibrary={inLibrary}
      collectionPct={collectionPct}
      watchPct={watched ? 100 : 0}
      isSeries={isSeries}
    />
  )}

  <!-- Info -->
  {href ? (
    <a href={href} class="block p-3 bg-transparent flex-1">
      {item.show_title && (
        <p class="text-xs font-medium text-zinc-400 truncate mb-0.5">{item.show_title}</p>
      )}
      <div class="flex items-start justify-between gap-2">
        <h3 class="text-sm font-bold text-zinc-100 truncate group-hover:text-blue-300 transition-colors leading-tight">
          {item.title}
        </h3>
      </div>
      <div class="flex items-center justify-between">
        <div class="flex items-center gap-2">
          {sxe && <span class="text-[11px] font-bold text-blue-400 tracking-wide mt-0.5 block">{sxe}</span>}
        </div>
        <div class="flex items-center gap-2">
          {showProgress && (
            <span class="text-[10px] font-bold text-zinc-500 tabular-nums">{Math.round(progressPct)}%</span>
          )}
          <span class="text-[9px] font-black text-zinc-400 uppercase tracking-widest px-1.5 py-0.5 bg-zinc-900/40 border border-zinc-800/80 rounded">
            {item.type === "movie" ? "MOVIE" : "EPISODE"}
          </span>
        </div>
      </div>
    </a>
  ) : (
    <div class="block p-3 bg-transparent flex-1">
      {item.show_title && (
        <p class="text-xs font-medium text-zinc-400 truncate mb-0.5">{item.show_title}</p>
      )}
      <h3 class="text-sm font-bold text-zinc-500 truncate leading-tight">
        {item.title}
      </h3>
      <div class="flex items-center justify-between">
        <div class="flex items-center gap-2">
          {sxe && <span class="text-[11px] font-bold text-zinc-400 tracking-wide mt-0.5 block">{sxe}</span>}
        </div>
        <div class="flex items-center gap-2">
          {showProgress && (
            <span class="text-[10px] font-bold text-zinc-500 tabular-nums">{Math.round(progressPct)}%</span>
          )}
          <span class="text-[9px] font-black text-zinc-400 uppercase tracking-widest px-1.5 py-0.5 bg-zinc-900/40 border border-zinc-800/80 rounded">
            {item.type === "movie" ? "MOVIE" : "EPISODE"}
          </span>
        </div>
      </div>
    </div>
  )}
</div>

