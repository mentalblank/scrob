---
import type { PrivacyLevel } from "../lib/api";

interface Props {
  id: number;
  name: string;
  description: string | null;
  privacy_level: PrivacyLevel;
  item_count: number;
  preview_posters: string[];
  username?: string; // for public/community lists
}

const { id, name, description, privacy_level, item_count, preview_posters, username } = Astro.props;

function posterSrc(path: string): string {
  if (path.startsWith("http")) return path;
  return `https://image.tmdb.org/t/p/w185${path}`;
}

const p = preview_posters;
---

<a
  href={`/list/${id}`}
  class="group flex items-center gap-5 bg-zinc-900/60 border border-zinc-800 rounded-2xl px-4 py-4 hover:border-zinc-600 active:scale-[0.98] active:opacity-80 transition-all duration-150"
>
  <!-- Stacked posters -->
  <div class="relative shrink-0 w-14 h-[72px]">
    {p.length === 0 && (
      <div class="absolute inset-0 rounded-xl bg-zinc-800 border border-zinc-700 flex items-center justify-center text-zinc-400">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
      </div>
    )}
    {p.length >= 3 && (
      <div class="absolute inset-0 rounded-xl overflow-hidden bg-zinc-800 origin-bottom rotate-[8deg] opacity-50">
        <img src={posterSrc(p[2])} alt="" aria-hidden="true" class="w-full h-full object-cover" loading="lazy" />
      </div>
    )}
    {p.length >= 2 && (
      <div class="absolute inset-0 rounded-xl overflow-hidden bg-zinc-800 origin-bottom rotate-[4deg] opacity-75">
        <img src={posterSrc(p[1])} alt="" aria-hidden="true" class="w-full h-full object-cover" loading="lazy" />
      </div>
    )}
    {p.length >= 1 && (
      <div class="absolute inset-0 rounded-xl overflow-hidden bg-zinc-800 shadow-lg">
        <img src={posterSrc(p[0])} alt="" aria-hidden="true" class="w-full h-full object-cover" loading="lazy" />
      </div>
    )}
  </div>

  <!-- Info -->
  <div class="flex-1 min-w-0">
    <div class="flex items-center gap-1.5 mb-0.5">
      {privacy_level !== "public" && !username && (
        <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-zinc-400 shrink-0"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
      )}
      <p class="text-sm font-bold text-zinc-200 truncate">{name}</p>
    </div>
    {description ? (
      <>
        <p class="text-xs text-zinc-500 truncate">{description}</p>
        <p class="text-xs text-zinc-400 mt-0.5">
          {item_count} {item_count === 1 ? "item" : "items"}
          {username && <> · by {username}</>}
        </p>
      </>
    ) : (
      <p class="text-xs text-zinc-400">
        {item_count} {item_count === 1 ? "item" : "items"}
        {username && <> · by {username}</>}
      </p>
    )}
  </div>
</a>
