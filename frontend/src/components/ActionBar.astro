---
interface Props {
  tmdbId?: number | null;
  uriId?: string | null;
  showUriId?: string | null;
  mediaType: string;
  watched: boolean;
  inLists: number[];
  inLibrary: boolean;
  collectionPct: number;
  watchPct?: number;
  showTmdbId?: number;
  seasonNumber?: number;
  episodeNumber?: number;
  hideRequest?: boolean;
  hideLists?: boolean;
  isMonitored?: boolean;
  requestEnabled?: boolean;
  requestStatus?: string | null;
  mediaId?: number | null;
  userRating?: number | null;
  isBlocked?: boolean;
  isDropped?: boolean;
  listOnly?: boolean;
  hideBlock?: boolean;
  hideRate?: boolean;
  centered?: boolean;
}

const {
  tmdbId,
  uriId,
  showUriId,
  mediaType,
  watched,
  inLists,
  inLibrary,
  collectionPct,
  watchPct = 0,
  showTmdbId,
  seasonNumber,
  episodeNumber,
  hideRequest = false,
  hideLists = false,
  isMonitored = false,
  requestEnabled = false,
  requestStatus = null,
  mediaId = null,
  userRating = null,
  isBlocked = false,
  isDropped = false,
  listOnly = false,
  hideBlock = false,
  hideRate = false,
  centered = false,
} = Astro.props;

const showUserRatings = Astro.cookies.get("show_user_ratings")?.value !== "false";
const effectivelyHideRate = hideRate || !showUserRatings;

const effectivelyHideBlock = hideBlock;

const isSeries = mediaType === "series" || (mediaType === "episode" && (showTmdbId != null || showUriId != null));
const showRequest = !hideRequest && requestEnabled && (mediaType === "movie" || mediaType === "series" || (mediaType === "episode" && (showTmdbId != null || showUriId != null)));
const ratingLabel = userRating != null ? userRating.toFixed(1) : "Rate";

// Shared button classes
const btn = "flex items-center justify-center transition-all cursor-pointer";
const btnW = "w-10 h-10 flex-shrink-0 last:border-r-0";

// Consistent state classes per button colour — inactive / active
// inactive: bg-zinc-800 text-zinc-500 hover:bg-[c]-500/10 hover:text-[c]-400
// active:   bg-[c]-500/20 text-[c]-400 hover:bg-[c]-500/30
const isProgressBased = mediaType === "series" || mediaType === "season";

const watchActive = isProgressBased ? watchPct > 0 : watched;
const watchedCls  = watchActive
  ? "bg-green-500/20 text-green-400 hover:bg-green-500/30"
  : "bg-zinc-950/25 text-zinc-500 hover:bg-green-500/10 hover:text-green-400";

const listsCls    = inLists.length > 0
  ? "bg-sky-500/20 text-sky-400 hover:bg-sky-500/30"
  : "bg-zinc-950/25 text-zinc-500 hover:bg-sky-500/10 hover:text-sky-400";

const rateCls     = userRating != null
  ? "bg-amber-500/20 text-amber-400 hover:bg-amber-500/30"
  : "bg-zinc-950/25 text-zinc-500 hover:bg-amber-500/10 hover:text-amber-400";

const collectActive = isProgressBased ? collectionPct > 0 : inLibrary;
const collectedCls = collectActive
  ? "bg-purple-500/20 text-purple-400 hover:bg-purple-500/30"
  : "bg-zinc-950/25 text-zinc-500 hover:bg-purple-500/10 hover:text-purple-400";

const watchStyle = isProgressBased && watchPct > 0
  ? `background: linear-gradient(to right, rgba(34,197,94,0.2) ${watchPct}%, transparent ${watchPct}%)`
  : '';

const collectStyle = isProgressBased && collectionPct > 0
  ? `background: linear-gradient(to right, rgba(168,85,247,0.2) ${collectionPct}%, transparent ${collectionPct}%)`
  : '';

const needsCheck  = !requestStatus && !isMonitored;
const requestBlocked = isMonitored || !!requestStatus;
const requestCls  = requestBlocked
  ? "bg-orange-500/20 text-orange-400 hover:bg-orange-500/30"
  : "bg-zinc-950/25 text-zinc-500 hover:bg-orange-500/10 hover:text-orange-400";
const dropCls = isDropped
  ? "bg-amber-500/20 text-amber-400 hover:bg-amber-500/30"
  : "bg-zinc-950/25 text-zinc-500 hover:bg-amber-500/10 hover:text-amber-400";

const requestTitle = isMonitored
  ? (isSeries ? "Already in Sonarr" : "Already in Radarr")
  : requestStatus === "pending"
    ? "Awaiting admin approval"
    : requestStatus === "rejected"
      ? "Request rejected"
      : (isSeries ? "Request on Sonarr" : "Request on Radarr");

let effectiveUriId = uriId;
if (!effectiveUriId && tmdbId) {
  if (mediaType === "movie") effectiveUriId = `tmdb:m:${tmdbId}`;
  else if (mediaType === "series") effectiveUriId = `tmdb:s:${tmdbId}`;
  else if (mediaType === "episode") effectiveUriId = `tmdb:e:${tmdbId}`;
}
---

<div
  data-card
  data-tmdb-id={tmdbId != null ? String(tmdbId) : ""}
  data-uri-id={effectiveUriId ?? ""}
  data-media-type={mediaType}
  data-show-tmdb-id={showTmdbId ? String(showTmdbId) : ""}
  data-show-uri-id={showUriId ?? ""}
  data-season={seasonNumber != null ? String(seasonNumber) : ""}
  data-episode-number={episodeNumber != null ? String(episodeNumber) : ""}
  data-media-id={mediaId != null ? String(mediaId) : ""}
  class={`flex w-full max-w-full overflow-hidden ${centered ? 'justify-center' : ''}`}
>
  <div class="flex flex-row rounded-2xl bg-zinc-950/20 border border-zinc-800/80 shadow-lg backdrop-blur-md h-10 w-fit max-w-full overflow-hidden">

    <!-- Watched (green) -->
    {!listOnly && (
      <button
        data-action="watched"
        data-watched={String(watched)}
        data-watch-pct={String(watchPct)}
        data-state={watchActive ? "active" : "inactive"}
        title={isProgressBased ? `${watchPct}% watched` : (watched ? "Mark as unwatched" : "Mark as watched")}
        style={watchStyle}
        class={`${btn} ${btnW} border-r border-zinc-800/60 ${watchedCls}`}
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/>
          <circle cx="12" cy="12" r="3" fill={watchActive ? "currentColor" : "none"}/>
        </svg>
      </button>
    )}

    <!-- Lists (sky) -->
    {!hideLists && (
      <button
        data-action="list"
        data-in-lists={JSON.stringify(inLists)}
        data-state={inLists.length > 0 ? "active" : "inactive"}
        title="Add to list"
        class={`${btn} ${btnW} ${!listOnly ? "border-r border-zinc-800/60" : ""} ${listsCls}`}
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="8" y1="6" x2="21" y2="6"/>
          <line x1="8" y1="12" x2="21" y2="12"/>
          <line x1="8" y1="18" x2="21" y2="18"/>
          <line x1="3" y1="6" x2="3.01" y2="6"/>
          <line x1="3" y1="12" x2="3.01" y2="12"/>
          <line x1="3" y1="18" x2="3.01" y2="18"/>
        </svg>
      </button>
    )}

    <!-- Rate (amber) -->
    {!listOnly && !effectivelyHideRate && (
      <button
        data-action="rate"
        data-user-rating={userRating != null ? String(userRating) : ""}
        data-state={userRating != null ? "active" : "inactive"}
        title={userRating != null ? `Your rating: ${ratingLabel}/10` : "Rate this"}
        class={`${btn} ${btnW} border-r border-zinc-800/60 ${rateCls}`}
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill={userRating != null ? "currentColor" : "none"} stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
        </svg>
      </button>
    )}

    <!-- Collected (purple) -->
    {!listOnly && (
      <button
        data-action="collected"
        data-in-library={String(inLibrary)}
        data-collection-pct={String(collectionPct)}
        data-state={collectActive ? "active" : "inactive"}
        title={isProgressBased ? `${collectionPct}% in library` : (inLibrary ? "In collection" : "Add to collection")}
        style={collectStyle}
        class={`${btn} ${btnW} relative overflow-hidden border-r border-zinc-800/60 ${collectedCls}`}
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="m2 7 4.41-4.41A2 2 0 0 1 7.83 2h8.34a2 2 0 0 1 1.42.59L22 7"/>
          <path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/>
          <path d="M15 22v-4a3 3 0 0 0-6 0v4"/>
          <path d="M2 7h20"/>
        </svg>
      </button>
    )}

    <!-- Request (orange) -->
    {!listOnly && showRequest && (
      <button
        data-action="request"
        data-state={(requestBlocked || collectionPct === 100 || (inLibrary && !isSeries)) ? "active" : "inactive"}
        data-request-loading={needsCheck ? "true" : undefined}
        title={requestTitle}
        disabled={requestBlocked || needsCheck || collectionPct === 100 || (inLibrary && !isSeries)}
        class={`${btn} ${btnW} disabled:cursor-not-allowed border-r border-zinc-800/60 ${requestCls}`}
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
          <polyline points="7 10 12 15 17 10"/>
          <line x1="12" y1="15" x2="12" y2="3"/>
        </svg>
      </button>
    )}

    <!-- Block (red) -->
    {!listOnly && !effectivelyHideBlock && (
      <button
        data-action="block-item"
        data-blocked={String(isBlocked)}
        data-state={isBlocked ? "active" : "inactive"}
        title={isBlocked ? "Unblock this item" : "Block this item"}
        class={`${btn} ${btnW} ${effectivelyHideBlock ? "" : "border-r border-zinc-800/60"} ${isBlocked ? "bg-red-500/20 text-red-400 hover:bg-red-500/30" : "bg-zinc-950/25 text-zinc-500 hover:bg-red-500/10 hover:text-red-400"}`}
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"/>
          <line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/>
        </svg>
      </button>
    )}

    <!-- Drop (amber) -->
    {!listOnly && isSeries && (
      <button
        data-action="drop"
        data-dropped={String(isDropped)}
        data-state={isDropped ? "active" : "inactive"}
        title={isDropped ? "Resume tracking in Next Up" : "Drop from Next Up"}
        class={`${btn} ${btnW} ${isDropped ? "bg-amber-500/20 text-amber-400 hover:bg-amber-500/30" : "bg-zinc-950/25 text-zinc-500 hover:bg-amber-500/10 hover:text-amber-400"}`}
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M19 14l-7 7-7-7"/>
          <path d="M12 21V3"/>
        </svg>
      </button>
    )}
  </div>
</div>
