---
import type { MediaItem } from "../lib/api";
import MediaCard from "./MediaCard.astro";
import MediaListCard from "./MediaListCard.astro";

interface Props {
  title: string;
  items: MediaItem[];
  href?: string;
  view?: "grid" | "list";
}

const { title, items, href, view = "grid" } = Astro.props;
---

<section class="mb-16">
  <div class="flex items-center justify-between mb-8 group">
    <h2 class="text-2xl font-black text-zinc-100 tracking-tight flex items-center gap-3">
      <span class="w-1 h-6 bg-blue-600 rounded-full"></span>
      {title}
    </h2>
    {href && (
      <a href={href} class="text-sm font-bold uppercase tracking-widest text-zinc-500 hover:text-blue-400 transition-all flex items-center gap-2 group/all">
        See All 
        <span class="group-hover/all:translate-x-1 transition-transform">→</span>
      </a>
    )}
  </div>
  
  {items.length === 0 ? (
    <div class="p-12 rounded-3xl bg-zinc-900/20 border border-zinc-800/50 border-dashed text-center">
      <p class="text-zinc-500 font-medium italic">Nothing here yet.</p>
    </div>
  ) : (
    <>
      {view === "list" ? (
        <div class="flex flex-col gap-4">
          {items.map(item => <MediaListCard item={item} />)}
        </div>
      ) : (
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-6">
          {items.map(item => <MediaCard item={item} />)}
        </div>
      )}
    </>
  )}
</section>
